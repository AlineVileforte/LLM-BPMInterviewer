<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_ecbb3914-6dd1-4889-9183-fe7eab9010d0" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-PA1</outgoing>
    </startEvent>
    <task id="PA1" name="Patient Arrival">
      <incoming>Default_init-PA1</incoming>
      <outgoing>PA1-AR1</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>PA1-AR1</incoming>
      <outgoing>AR1-INT1</outgoing>
    </task>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>AR1-INT1</incoming>
      <outgoing>INT1-PAS1</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>INT1-PAS1</incoming>
      <outgoing>PAS1-G2</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>PAS1-G2</incoming>
      <outgoing>G2-MCA1</outgoing>
      <outgoing>G2-XORCLOSE11</outgoing>
    </exclusiveGateway>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>G2-MCA1</incoming>
      <outgoing>MCA1-G3</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>MCA1-G3</incoming>
      <outgoing>G3-HIA1</outgoing>
      <outgoing>G3-XORCLOSE10</outgoing>
    </exclusiveGateway>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>G3-HIA1</incoming>
      <outgoing>HIA1-XORCLOSE10</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE10" name="XORCLOSE10">
      <incoming>G3-XORCLOSE10</incoming>
      <incoming>HIA1-XORCLOSE10</incoming>
      <outgoing>XORCLOSE10-XORCLOSE11</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE11" name="XORCLOSE11">
      <incoming>G2-XORCLOSE11</incoming>
      <incoming>XORCLOSE10-XORCLOSE11</incoming>
      <outgoing>XORCLOSE11-PHP1</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>XORCLOSE11-PHP1</incoming>
      <outgoing>PHP1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PHP1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-PA1" sourceRef="Default_init" targetRef="PA1"/>
    <sequenceFlow id="PA1-AR1" sourceRef="PA1" targetRef="AR1"/>
    <sequenceFlow id="AR1-INT1" sourceRef="AR1" targetRef="INT1"/>
