<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_54d66ecb-c982-4bb4-9ac8-6ae879dcb3ed" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-AE1</outgoing>
    </startEvent>
    <task id="AE1" name="ACCESS ESSE3">
      <incoming>Default_init-AE1</incoming>
      <outgoing>AE1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>AE1-Par1</incoming>
      <outgoing>Par1-EL1</outgoing>
      <outgoing>Par1-EP1</outgoing>
    </parallelGateway>
    <task id="EL1" name="ENTER LOGIN">
      <incoming>Par1-EL1</incoming>
      <outgoing>EL1-EE1</outgoing>
    </task>
    <task id="EP1" name="ENTER PASSWORD">
      <incoming>Par1-EP1</incoming>
      <outgoing>EP1-PC1</outgoing>
    </task>
    <task id="PC1" name="PRESS CONFIRM">
      <incoming>EP1-PC1</incoming>
      <outgoing>PC1-CEI1</outgoing>
    </task>
    <task id="EE1" name="END ENROLLMENT">
      <incoming>EL1-EE1</incoming>
      <outgoing>EE1-HGO1</outgoing>
    </task>
    <task id="CEI1" name="CLICK THE “EXAMS” ITEM">
      <incoming>PC1-CEI1</incoming>
      <outgoing>CEI1-CESI1</outgoing>
    </task>
    <task id="HGO1" name="HOPE FOR A GOOD OUTCOME">
      <incoming>EE1-HGO1</incoming>
      <outgoing>HGO1-G0</outgoing>
    </task>
    <task id="CESI1" name="CLICK THE “EXAM SESSIONS” ITEM">
      <incoming>CEI1-CESI1</incoming>
      <outgoing>CESI1-XOR_JMPBB_EAE1_CC1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>HGO1-G0</incoming>
      <outgoing>G0-EAE1</outgoing>
      <outgoing>G0-XORCLOSE14</outgoing>
    </exclusiveGateway>
    <task id="EAE1" name="ENROLL IN ANOTHER EXAM">
      <incoming>G0-EAE1</incoming>
      <outgoing>EAE1-XOR_JMPAA_EAE1_CC1</outgoing>
    </task>
    <task id="CC1" name="CHOOSE THE COURSE">
      <incoming>XOR_JMPBB_EAE1_CC1-CC1</incoming>
      <outgoing>CC1-PC3T1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>G0-XORCLOSE14</incoming>
      <incoming>XOR_JMPAA_EAE1_CC1-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-PARCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="PC3T1" name="PRESS CONFIRM 3 TIMES WITHOUT READING WHAT IS WRITTEN">
      <incoming>CC1-PC3T1</incoming>
      <outgoing>PC3T1-PEC1</outgoing>
    </task>
    <task id="PEC1" name="PRINT THE ENROLLMENT CONFIRMATION">
      <incoming>PC3T1-PEC1</incoming>
      <outgoing>PEC1-PARCLOSE17</outgoing>
    </task>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>XORCLOSE14-PARCLOSE17</incoming>
      <incoming>PEC1-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE17-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_EAE1_CC1" name="XOR_JMPAA_ENROLL IN ANOTHER EXAM">
      <incoming>EAE1-XOR_JMPAA_EAE1_CC1</incoming>
      <outgoing>XOR_JMPAA_EAE1_CC1-XORCLOSE14</outgoing>
      <outgoing>XOR_JMPAA_EAE1_CC1-XOR_JMPBB_EAE1_CC1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_EAE1_CC1" name="XOR_JMPBB_CHOOSE THE COURSE">
      <incoming>CESI1-XOR_JMPBB_EAE1_CC1</incoming>
      <incoming>XOR_JMPAA_EAE1_CC1-XOR_JMPBB_EAE1_CC1</incoming>
      <outgoing>XOR_JMPBB_EAE1_CC1-CC1</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Default_init-AE1" sourceRef="Default_init" targetRef="AE1"/>
    <sequenceFlow id="AE1-Par1" sourceRef="AE1" targetRef="Par1"/>
    <sequenceFlow id="Par1-EL1" sourceRef="Par1" targetRef="EL1"/>
