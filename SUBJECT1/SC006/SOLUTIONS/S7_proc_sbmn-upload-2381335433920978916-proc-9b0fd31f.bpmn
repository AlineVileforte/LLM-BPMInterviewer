    <sequenceFlow id="G0-EAE1" sourceRef="G0" targetRef="EAE1"/>
    <sequenceFlow id="G0-XORCLOSE14" sourceRef="G0" targetRef="XORCLOSE14"/>
    <sequenceFlow id="EAE1-XOR_JMPAA_EAE1_CC1" sourceRef="EAE1" targetRef="XOR_JMPAA_EAE1_CC1"/>
    <sequenceFlow id="CC1-PC3T1" sourceRef="CC1" targetRef="PC3T1"/>
    <sequenceFlow id="XORCLOSE14-PARCLOSE17" sourceRef="XORCLOSE14" targetRef="PARCLOSE17"/>
    <sequenceFlow id="PC3T1-PEC1" sourceRef="PC3T1" targetRef="PEC1"/>
    <sequenceFlow id="PEC1-PARCLOSE17" sourceRef="PEC1" targetRef="PARCLOSE17"/>
    <sequenceFlow id="PARCLOSE17-END" sourceRef="PARCLOSE17" targetRef="END"/>
    <sequenceFlow id="XOR_JMPAA_EAE1_CC1-XORCLOSE14" sourceRef="XOR_JMPAA_EAE1_CC1" targetRef="XORCLOSE14"/>
    <sequenceFlow id="XOR_JMPAA_EAE1_CC1-XOR_JMPBB_EAE1_CC1" sourceRef="XOR_JMPAA_EAE1_CC1" targetRef="XOR_JMPBB_EAE1_CC1"/>
    <sequenceFlow id="XOR_JMPBB_EAE1_CC1-CC1" sourceRef="XOR_JMPBB_EAE1_CC1" targetRef="CC1"/>
  </process>
