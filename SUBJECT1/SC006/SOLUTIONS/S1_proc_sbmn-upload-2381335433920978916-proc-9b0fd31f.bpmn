<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_6f7914db-47ec-4c37-b300-aa4da3cf0ed8" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-EP1</outgoing>
    </startEvent>
    <task id="EP1" name="ENTER PASSWORD">
      <incoming>Default_init-EP1</incoming>
      <outgoing>EP1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>EP1-Par1</incoming>
      <outgoing>Par1-AE1</outgoing>
      <outgoing>Par1-PC1</outgoing>
    </parallelGateway>
    <task id="AE1" name="ACCESS ESSE3">
      <incoming>Par1-AE1</incoming>
      <outgoing>AE1-Par6</outgoing>
    </task>
    <task id="PC1" name="PRESS CONFIRM">
      <incoming>Par1-PC1</incoming>
      <outgoing>PC1-CEI1</outgoing>
    </task>
    <task id="CEI1" name="CLICK THE “EXAMS” ITEM">
      <incoming>PC1-CEI1</incoming>
      <outgoing>CEI1-CESI1</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>AE1-Par6</incoming>
      <outgoing>Par6-EL1</outgoing>
      <outgoing>Par6-EE1</outgoing>
    </parallelGateway>
    <task id="EL1" name="ENTER LOGIN">
      <incoming>Par6-EL1</incoming>
      <outgoing>EL1-PARCLOSE13</outgoing>
    </task>
    <task id="EE1" name="END ENROLLMENT">
      <incoming>Par6-EE1</incoming>
      <outgoing>EE1-HGO1</outgoing>
    </task>
    <task id="CESI1" name="CLICK THE “EXAM SESSIONS” ITEM">
      <incoming>CEI1-CESI1</incoming>
      <outgoing>CESI1-XOR_JMPBB_EAE1_CC1</outgoing>
    </task>
    <task id="HGO1" name="HOPE FOR A GOOD OUTCOME">
      <incoming>EE1-HGO1</incoming>
      <outgoing>HGO1-PARCLOSE13</outgoing>
    </task>
    <task id="CC1" name="CHOOSE THE COURSE">
      <incoming>XOR_JMPBB_EAE1_CC1-CC1</incoming>
      <outgoing>CC1-PC3T1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE13" name="PARCLOSE13">
      <incoming>EL1-PARCLOSE13</incoming>
      <incoming>HGO1-PARCLOSE13</incoming>
      <outgoing>PARCLOSE13-EAE1</outgoing>
    </parallelGateway>
    <task id="PC3T1" name="PRESS CONFIRM 3 TIMES WITHOUT READING WHAT IS WRITTEN">
      <incoming>CC1-PC3T1</incoming>
      <outgoing>PC3T1-PARCLOSE16</outgoing>
    </task>
    <task id="EAE1" name="ENROLL IN ANOTHER EXAM">
      <incoming>PARCLOSE13-EAE1</incoming>
      <outgoing>EAE1-XOR_JMPAA_EAE1_CC1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE16" name="PARCLOSE16">
      <incoming>PC3T1-PARCLOSE16</incoming>
      <incoming>XOR_JMPAA_EAE1_CC1-PARCLOSE16</incoming>
      <outgoing>PARCLOSE16-PEC1</outgoing>
    </parallelGateway>
    <task id="PEC1" name="PRINT THE ENROLLMENT CONFIRMATION">
      <incoming>PARCLOSE16-PEC1</incoming>
      <outgoing>PEC1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PEC1-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_EAE1_CC1" name="XOR_JMPAA_ENROLL IN ANOTHER EXAM">
      <incoming>EAE1-XOR_JMPAA_EAE1_CC1</incoming>
      <outgoing>XOR_JMPAA_EAE1_CC1-PARCLOSE16</outgoing>
      <outgoing>XOR_JMPAA_EAE1_CC1-XOR_JMPBB_EAE1_CC1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_EAE1_CC1" name="XOR_JMPBB_CHOOSE THE COURSE">
      <incoming>CESI1-XOR_JMPBB_EAE1_CC1</incoming>
      <incoming>XOR_JMPAA_EAE1_CC1-XOR_JMPBB_EAE1_CC1</incoming>
      <outgoing>XOR_JMPBB_EAE1_CC1-CC1</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Default_init-EP1" sourceRef="Default_init" targetRef="EP1"/>
    <sequenceFlow id="EP1-Par1" sourceRef="EP1" targetRef="Par1"/>
    <sequenceFlow id="Par1-AE1" sourceRef="Par1" targetRef="AE1"/>
    <sequenceFlow id="Par1-PC1" sourceRef="Par1" targetRef="PC1"/>
    <sequenceFlow id="AE1-Par6" sourceRef="AE1" targetRef="Par6"/>
    <sequenceFlow id="PC1-CEI1" sourceRef="PC1" targetRef="CEI1"/>
    <sequenceFlow id="CEI1-CESI1" sourceRef="CEI1" targetRef="CESI1"/>
    <sequenceFlow id="Par6-EL1" sourceRef="Par6" targetRef="EL1"/>
    <sequenceFlow id="Par6-EE1" sourceRef="Par6" targetRef="EE1"/>
    <sequenceFlow id="EL1-PARCLOSE13" sourceRef="EL1" targetRef="PARCLOSE13"/>
    <sequenceFlow id="EE1-HGO1" sourceRef="EE1" targetRef="HGO1"/>
    <sequenceFlow id="CESI1-XOR_JMPBB_EAE1_CC1" sourceRef="CESI1" targetRef="XOR_JMPBB_EAE1_CC1"/>
    <sequenceFlow id="HGO1-PARCLOSE13" sourceRef="HGO1" targetRef="PARCLOSE13"/>
    <sequenceFlow id="CC1-PC3T1" sourceRef="CC1" targetRef="PC3T1"/>
    <sequenceFlow id="PARCLOSE13-EAE1" sourceRef="PARCLOSE13" targetRef="EAE1"/>
    <sequenceFlow id="PC3T1-PARCLOSE16" sourceRef="PC3T1" targetRef="PARCLOSE16"/>
    <sequenceFlow id="EAE1-XOR_JMPAA_EAE1_CC1" sourceRef="EAE1" targetRef="XOR_JMPAA_EAE1_CC1"/>
    <sequenceFlow id="PARCLOSE16-PEC1" sourceRef="PARCLOSE16" targetRef="PEC1"/>
    <sequenceFlow id="PEC1-END" sourceRef="PEC1" targetRef="END"/>
    <sequenceFlow id="XOR_JMPAA_EAE1_CC1-PARCLOSE16" sourceRef="XOR_JMPAA_EAE1_CC1" targetRef="PARCLOSE16"/>
    <sequenceFlow id="XOR_JMPAA_EAE1_CC1-XOR_JMPBB_EAE1_CC1" sourceRef="XOR_JMPAA_EAE1_CC1" targetRef="XOR_JMPBB_EAE1_CC1"/>
    <sequenceFlow id="XOR_JMPBB_EAE1_CC1-CC1" sourceRef="XOR_JMPBB_EAE1_CC1" targetRef="CC1"/>
  </process>
