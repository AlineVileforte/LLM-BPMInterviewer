<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_cd2e3e2c-1375-47d2-a4d7-b25ca46b3e42" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-AE1</outgoing>
    </startEvent>
    <task id="AE1" name="ACCESS ESSE3">
      <incoming>Default_init-AE1</incoming>
      <outgoing>AE1-EL1</outgoing>
    </task>
    <task id="EL1" name="ENTER LOGIN">
      <incoming>AE1-EL1</incoming>
      <outgoing>EL1-EP1</outgoing>
    </task>
    <task id="EP1" name="ENTER PASSWORD">
      <incoming>EL1-EP1</incoming>
      <outgoing>EP1-PC1</outgoing>
    </task>
    <task id="PC1" name="PRESS CONFIRM">
      <incoming>EP1-PC1</incoming>
      <outgoing>PC1-CEI1</outgoing>
    </task>
    <task id="CEI1" name="CLICK THE “EXAMS” ITEM">
      <incoming>PC1-CEI1</incoming>
      <outgoing>CEI1-CESI1</outgoing>
    </task>
    <task id="CESI1" name="CLICK THE “EXAM SESSIONS” ITEM">
      <incoming>CEI1-CESI1</incoming>
      <outgoing>CESI1-XOR_JMPBB_EAE1_CC1</outgoing>
    </task>
    <task id="CC1" name="CHOOSE THE COURSE">
      <incoming>XOR_JMPBB_EAE1_CC1-CC1</incoming>
      <outgoing>CC1-PC3T1</outgoing>
    </task>
    <task id="PC3T1" name="PRESS CONFIRM 3 TIMES WITHOUT READING WHAT IS WRITTEN">
      <incoming>CC1-PC3T1</incoming>
      <outgoing>PC3T1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>PC3T1-G0</incoming>
      <outgoing>G0-EE1</outgoing>
      <outgoing>G0-PEC1</outgoing>
    </exclusiveGateway>
    <task id="PEC1" name="PRINT THE ENROLLMENT CONFIRMATION">
      <incoming>G0-PEC1</incoming>
      <outgoing>PEC1-XORCLOSE12</outgoing>
    </task>
    <task id="EE1" name="END ENROLLMENT">
      <incoming>G0-EE1</incoming>
      <outgoing>EE1-XORCLOSE12</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE12" name="XORCLOSE12">
      <incoming>PEC1-XORCLOSE12</incoming>
      <incoming>EE1-XORCLOSE12</incoming>
      <outgoing>XORCLOSE12-HGO1</outgoing>
    </exclusiveGateway>
    <task id="HGO1" name="HOPE FOR A GOOD OUTCOME">
      <incoming>XORCLOSE12-HGO1</incoming>
      <outgoing>HGO1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>HGO1-G1</incoming>
      <outgoing>G1-EAE1</outgoing>
      <outgoing>G1-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="EAE1" name="ENROLL IN ANOTHER EXAM">
      <incoming>G1-EAE1</incoming>
      <outgoing>EAE1-XOR_JMPAA_EAE1_CC1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE17" name="XORCLOSE17">
      <incoming>G1-XORCLOSE17</incoming>
      <incoming>XOR_JMPAA_EAE1_CC1-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE17-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_EAE1_CC1" name="XOR_JMPAA_ENROLL IN ANOTHER EXAM">
      <incoming>EAE1-XOR_JMPAA_EAE1_CC1</incoming>
      <outgoing>XOR_JMPAA_EAE1_CC1-XORCLOSE17</outgoing>
      <outgoing>XOR_JMPAA_EAE1_CC1-XOR_JMPBB_EAE1_CC1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_EAE1_CC1" name="XOR_JMPBB_CHOOSE THE COURSE">
      <incoming>CESI1-XOR_JMPBB_EAE1_CC1</incoming>
      <incoming>XOR_JMPAA_EAE1_CC1-XOR_JMPBB_EAE1_CC1</incoming>
      <outgoing>XOR_JMPBB_EAE1_CC1-CC1</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Default_init-AE1" sourceRef="Default_init" targetRef="AE1"/>
    <sequenceFlow id="AE1-EL1" sourceRef="AE1" targetRef="EL1"/>
    <sequenceFlow id="EL1-EP1" sourceRef="EL1" targetRef="EP1"/>
    <sequenceFlow id="EP1-PC1" sourceRef="EP1" targetRef="PC1"/>
