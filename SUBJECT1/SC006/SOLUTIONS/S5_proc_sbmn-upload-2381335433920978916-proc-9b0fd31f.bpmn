    <sequenceFlow id="PEC1-XORCLOSE12" sourceRef="PEC1" targetRef="XORCLOSE12"/>
    <sequenceFlow id="EE1-XORCLOSE12" sourceRef="EE1" targetRef="XORCLOSE12"/>
    <sequenceFlow id="XORCLOSE12-HGO1" sourceRef="XORCLOSE12" targetRef="HGO1"/>
    <sequenceFlow id="HGO1-G1" sourceRef="HGO1" targetRef="G1"/>
    <sequenceFlow id="G1-EAE1" sourceRef="G1" targetRef="EAE1"/>
    <sequenceFlow id="G1-XORCLOSE17" sourceRef="G1" targetRef="XORCLOSE17"/>
    <sequenceFlow id="EAE1-XOR_JMPAA_EAE1_CC1" sourceRef="EAE1" targetRef="XOR_JMPAA_EAE1_CC1"/>
    <sequenceFlow id="XORCLOSE17-END" sourceRef="XORCLOSE17" targetRef="END"/>
    <sequenceFlow id="XOR_JMPAA_EAE1_CC1-XORCLOSE17" sourceRef="XOR_JMPAA_EAE1_CC1" targetRef="XORCLOSE17"/>
    <sequenceFlow id="XOR_JMPAA_EAE1_CC1-XOR_JMPBB_EAE1_CC1" sourceRef="XOR_JMPAA_EAE1_CC1" targetRef="XOR_JMPBB_EAE1_CC1"/>
    <sequenceFlow id="XOR_JMPBB_EAE1_CC1-CC1" sourceRef="XOR_JMPBB_EAE1_CC1" targetRef="CC1"/>
  </process>
