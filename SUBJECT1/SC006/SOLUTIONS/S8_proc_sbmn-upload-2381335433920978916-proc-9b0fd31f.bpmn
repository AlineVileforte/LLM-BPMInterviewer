<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_9197327f-dc67-4d89-a254-8bc38f166068" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-EP1</outgoing>
    </startEvent>
    <task id="EP1" name="ENTER PASSWORD">
      <incoming>Default_init-EP1</incoming>
      <outgoing>EP1-AE1</outgoing>
    </task>
    <task id="AE1" name="ACCESS ESSE3">
      <incoming>EP1-AE1</incoming>
      <outgoing>AE1-PC1</outgoing>
    </task>
    <task id="PC1" name="PRESS CONFIRM">
      <incoming>AE1-PC1</incoming>
      <outgoing>PC1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>PC1-Par3</incoming>
      <outgoing>Par3-EL1</outgoing>
      <outgoing>Par3-CEI1</outgoing>
    </parallelGateway>
    <task id="EL1" name="ENTER LOGIN">
      <incoming>Par3-EL1</incoming>
      <outgoing>EL1-EE1</outgoing>
    </task>
    <task id="CEI1" name="CLICK THE “EXAMS” ITEM">
      <incoming>Par3-CEI1</incoming>
      <outgoing>CEI1-CESI1</outgoing>
    </task>
    <task id="EE1" name="END ENROLLMENT">
      <incoming>EL1-EE1</incoming>
      <outgoing>EE1-HGO1</outgoing>
    </task>
    <task id="CESI1" name="CLICK THE “EXAM SESSIONS” ITEM">
      <incoming>CEI1-CESI1</incoming>
      <outgoing>CESI1-XOR_JMPBB_EAE1_CC1</outgoing>
    </task>
    <task id="HGO1" name="HOPE FOR A GOOD OUTCOME">
      <incoming>EE1-HGO1</incoming>
      <outgoing>HGO1-PARCLOSE17</outgoing>
    </task>
    <task id="CC1" name="CHOOSE THE COURSE">
      <incoming>XOR_JMPBB_EAE1_CC1-CC1</incoming>
      <outgoing>CC1-EAE1</outgoing>
    </task>
    <task id="EAE1" name="ENROLL IN ANOTHER EXAM">
      <incoming>CC1-EAE1</incoming>
      <outgoing>EAE1-XOR_JMPAA_EAE1_CC1</outgoing>
    </task>
    <task id="PC3T1" name="PRESS CONFIRM 3 TIMES WITHOUT READING WHAT IS WRITTEN">
      <incoming>XOR_JMPAA_EAE1_CC1-PC3T1</incoming>
      <outgoing>PC3T1-PEC1</outgoing>
    </task>
    <task id="PEC1" name="PRINT THE ENROLLMENT CONFIRMATION">
      <incoming>PC3T1-PEC1</incoming>
      <outgoing>PEC1-PARCLOSE17</outgoing>
    </task>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>HGO1-PARCLOSE17</incoming>
      <incoming>PEC1-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE17-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_EAE1_CC1" name="XOR_JMPAA_ENROLL IN ANOTHER EXAM">
      <incoming>EAE1-XOR_JMPAA_EAE1_CC1</incoming>
      <outgoing>XOR_JMPAA_EAE1_CC1-PC3T1</outgoing>
      <outgoing>XOR_JMPAA_EAE1_CC1-XOR_JMPBB_EAE1_CC1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_EAE1_CC1" name="XOR_JMPBB_CHOOSE THE COURSE">
      <incoming>CESI1-XOR_JMPBB_EAE1_CC1</incoming>
      <incoming>XOR_JMPAA_EAE1_CC1-XOR_JMPBB_EAE1_CC1</incoming>
      <outgoing>XOR_JMPBB_EAE1_CC1-CC1</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Default_init-EP1" sourceRef="Default_init" targetRef="EP1"/>
    <sequenceFlow id="EP1-AE1" sourceRef="EP1" targetRef="AE1"/>
    <sequenceFlow id="AE1-PC1" sourceRef="AE1" targetRef="PC1"/>
    <sequenceFlow id="PC1-Par3" sourceRef="PC1" targetRef="Par3"/>
    <sequenceFlow id="Par3-EL1" sourceRef="Par3" targetRef="EL1"/>
    <sequenceFlow id="Par3-CEI1" sourceRef="Par3" targetRef="CEI1"/>
    <sequenceFlow id="EL1-EE1" sourceRef="EL1" targetRef="EE1"/>
    <sequenceFlow id="CEI1-CESI1" sourceRef="CEI1" targetRef="CESI1"/>
    <sequenceFlow id="EE1-HGO1" sourceRef="EE1" targetRef="HGO1"/>
    <sequenceFlow id="CESI1-XOR_JMPBB_EAE1_CC1" sourceRef="CESI1" targetRef="XOR_JMPBB_EAE1_CC1"/>
    <sequenceFlow id="HGO1-PARCLOSE17" sourceRef="HGO1" targetRef="PARCLOSE17"/>
    <sequenceFlow id="CC1-EAE1" sourceRef="CC1" targetRef="EAE1"/>
    <sequenceFlow id="EAE1-XOR_JMPAA_EAE1_CC1" sourceRef="EAE1" targetRef="XOR_JMPAA_EAE1_CC1"/>
    <sequenceFlow id="PC3T1-PEC1" sourceRef="PC3T1" targetRef="PEC1"/>
    <sequenceFlow id="PEC1-PARCLOSE17" sourceRef="PEC1" targetRef="PARCLOSE17"/>
    <sequenceFlow id="PARCLOSE17-END" sourceRef="PARCLOSE17" targetRef="END"/>
    <sequenceFlow id="XOR_JMPAA_EAE1_CC1-PC3T1" sourceRef="XOR_JMPAA_EAE1_CC1" targetRef="PC3T1"/>
    <sequenceFlow id="XOR_JMPAA_EAE1_CC1-XOR_JMPBB_EAE1_CC1" sourceRef="XOR_JMPAA_EAE1_CC1" targetRef="XOR_JMPBB_EAE1_CC1"/>
    <sequenceFlow id="XOR_JMPBB_EAE1_CC1-CC1" sourceRef="XOR_JMPBB_EAE1_CC1" targetRef="CC1"/>
  </process>
