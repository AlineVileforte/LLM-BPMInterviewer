    <sequenceFlow id="EL1-EE1" sourceRef="EL1" targetRef="EE1"/>
    <sequenceFlow id="CC1-PC3T1" sourceRef="CC1" targetRef="PC3T1"/>
    <sequenceFlow id="EE1-HGO1" sourceRef="EE1" targetRef="HGO1"/>
    <sequenceFlow id="PC3T1-PEC1" sourceRef="PC3T1" targetRef="PEC1"/>
    <sequenceFlow id="HGO1-G0" sourceRef="HGO1" targetRef="G0"/>
    <sequenceFlow id="PEC1-PARCLOSE19" sourceRef="PEC1" targetRef="PARCLOSE19"/>
    <sequenceFlow id="G0-EAE1" sourceRef="G0" targetRef="EAE1"/>
    <sequenceFlow id="G0-XORCLOSE17" sourceRef="G0" targetRef="XORCLOSE17"/>
    <sequenceFlow id="EAE1-XOR_JMPAA_EAE1_CC1" sourceRef="EAE1" targetRef="XOR_JMPAA_EAE1_CC1"/>
    <sequenceFlow id="XORCLOSE17-PARCLOSE19" sourceRef="XORCLOSE17" targetRef="PARCLOSE19"/>
    <sequenceFlow id="PARCLOSE19-END" sourceRef="PARCLOSE19" targetRef="END"/>
    <sequenceFlow id="XOR_JMPAA_EAE1_CC1-XORCLOSE17" sourceRef="XOR_JMPAA_EAE1_CC1" targetRef="XORCLOSE17"/>
    <sequenceFlow id="XOR_JMPAA_EAE1_CC1-XOR_JMPBB_EAE1_CC1" sourceRef="XOR_JMPAA_EAE1_CC1" targetRef="XOR_JMPBB_EAE1_CC1"/>
    <sequenceFlow id="XOR_JMPBB_EAE1_CC1-CC1" sourceRef="XOR_JMPBB_EAE1_CC1" targetRef="CC1"/>
  </process>
