<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_7919fa3b-7df9-4a14-b8ef-e5e7b3c9ff8b" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-EP1</outgoing>
    </startEvent>
    <task id="EP1" name="ENTER PASSWORD">
      <incoming>Default_init-EP1</incoming>
      <outgoing>EP1-PC1</outgoing>
    </task>
    <task id="PC1" name="PRESS CONFIRM">
      <incoming>EP1-PC1</incoming>
      <outgoing>PC1-CEI1</outgoing>
    </task>
    <task id="CEI1" name="CLICK THE “EXAMS” ITEM">
      <incoming>PC1-CEI1</incoming>
      <outgoing>CEI1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>CEI1-Par3</incoming>
      <outgoing>Par3-AE1</outgoing>
      <outgoing>Par3-CESI1</outgoing>
    </parallelGateway>
    <task id="AE1" name="ACCESS ESSE3">
      <incoming>Par3-AE1</incoming>
      <outgoing>AE1-EL1</outgoing>
    </task>
    <task id="CESI1" name="CLICK THE “EXAM SESSIONS” ITEM">
      <incoming>Par3-CESI1</incoming>
      <outgoing>CESI1-XOR_JMPBB_EAE1_CC1</outgoing>
    </task>
    <task id="EL1" name="ENTER LOGIN">
      <incoming>AE1-EL1</incoming>
      <outgoing>EL1-EE1</outgoing>
    </task>
    <task id="CC1" name="CHOOSE THE COURSE">
      <incoming>XOR_JMPBB_EAE1_CC1-CC1</incoming>
      <outgoing>CC1-PC3T1</outgoing>
    </task>
    <task id="EE1" name="END ENROLLMENT">
      <incoming>EL1-EE1</incoming>
      <outgoing>EE1-HGO1</outgoing>
    </task>
    <task id="PC3T1" name="PRESS CONFIRM 3 TIMES WITHOUT READING WHAT IS WRITTEN">
      <incoming>CC1-PC3T1</incoming>
      <outgoing>PC3T1-PEC1</outgoing>
    </task>
    <task id="HGO1" name="HOPE FOR A GOOD OUTCOME">
      <incoming>EE1-HGO1</incoming>
      <outgoing>HGO1-G0</outgoing>
    </task>
    <task id="PEC1" name="PRINT THE ENROLLMENT CONFIRMATION">
      <incoming>PC3T1-PEC1</incoming>
      <outgoing>PEC1-PARCLOSE19</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>HGO1-G0</incoming>
      <outgoing>G0-EAE1</outgoing>
      <outgoing>G0-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="EAE1" name="ENROLL IN ANOTHER EXAM">
      <incoming>G0-EAE1</incoming>
      <outgoing>EAE1-XOR_JMPAA_EAE1_CC1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE17" name="XORCLOSE17">
      <incoming>G0-XORCLOSE17</incoming>
      <incoming>XOR_JMPAA_EAE1_CC1-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-PARCLOSE19</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>PEC1-PARCLOSE19</incoming>
      <incoming>XORCLOSE17-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE19-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_EAE1_CC1" name="XOR_JMPAA_ENROLL IN ANOTHER EXAM">
      <incoming>EAE1-XOR_JMPAA_EAE1_CC1</incoming>
      <outgoing>XOR_JMPAA_EAE1_CC1-XORCLOSE17</outgoing>
      <outgoing>XOR_JMPAA_EAE1_CC1-XOR_JMPBB_EAE1_CC1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_EAE1_CC1" name="XOR_JMPBB_CHOOSE THE COURSE">
      <incoming>CESI1-XOR_JMPBB_EAE1_CC1</incoming>
      <incoming>XOR_JMPAA_EAE1_CC1-XOR_JMPBB_EAE1_CC1</incoming>
      <outgoing>XOR_JMPBB_EAE1_CC1-CC1</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Default_init-EP1" sourceRef="Default_init" targetRef="EP1"/>
    <sequenceFlow id="EP1-PC1" sourceRef="EP1" targetRef="PC1"/>
    <sequenceFlow id="PC1-CEI1" sourceRef="PC1" targetRef="CEI1"/>
    <sequenceFlow id="CEI1-Par3" sourceRef="CEI1" targetRef="Par3"/>
    <sequenceFlow id="Par3-AE1" sourceRef="Par3" targetRef="AE1"/>
    <sequenceFlow id="Par3-CESI1" sourceRef="Par3" targetRef="CESI1"/>
    <sequenceFlow id="AE1-EL1" sourceRef="AE1" targetRef="EL1"/>
