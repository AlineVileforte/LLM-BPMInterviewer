    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-KP1</outgoing>
      <outgoing>Par0-OE2</outgoing>
    </parallelGateway>
    <task id="KP1" name="Kontrola přihlášení">
      <incoming>Par0-KP1</incoming>
      <outgoing>KP1-ZR1</outgoing>
    </task>
