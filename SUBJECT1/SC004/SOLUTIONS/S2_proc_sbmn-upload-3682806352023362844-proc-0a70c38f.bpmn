    <sequenceFlow id="PARCLOSE9-G2" sourceRef="PARCLOSE9" targetRef="G2"/>
    <sequenceFlow id="G2-RCICR1" sourceRef="G2" targetRef="RCICR1"/>
    <sequenceFlow id="G2-CWVG1" sourceRef="G2" targetRef="CWVG1"/>
    <sequenceFlow id="RCICR1-XORCLOSE14" sourceRef="RCICR1" targetRef="XORCLOSE14"/>
    <sequenceFlow id="CWVG1-RISCP1" sourceRef="CWVG1" targetRef="RISCP1"/>
    <sequenceFlow id="RISCP1-XORCLOSE14" sourceRef="RISCP1" targetRef="XORCLOSE14"/>
    <sequenceFlow id="XORCLOSE14-END" sourceRef="XORCLOSE14" targetRef="END"/>
  </process>
