<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_d98c741e-94da-422e-8ec4-4b7adf51d9a6" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CCIR1</outgoing>
    </startEvent>
    <task id="CCIR1" name="Copy of Customer Invoice is Received">
      <incoming>Default_init-CCIR1</incoming>
      <outgoing>CCIR1-CPO1</outgoing>
    </task>
    <task id="CPO1" name="Customer Places Order">
      <incoming>CCIR1-CPO1</incoming>
      <outgoing>CPO1-PR1</outgoing>
    </task>
    <task id="PR1" name="Paymente is Received">
      <incoming>CPO1-PR1</incoming>
      <outgoing>PR1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>PR1-G1</incoming>
      <outgoing>G1-ONL1</outgoing>
      <outgoing>G1-OLU1</outgoing>
    </exclusiveGateway>
    <task id="ONL1" name="Order New License">
      <incoming>G1-ONL1</incoming>
      <outgoing>ONL1-XORCLOSE9</outgoing>
    </task>
    <task id="OLU1" name="Order License Upgrade">
      <incoming>G1-OLU1</incoming>
      <outgoing>OLU1-XORCLOSE9</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE9" name="XORCLOSE9">
      <incoming>ONL1-XORCLOSE9</incoming>
      <incoming>OLU1-XORCLOSE9</incoming>
      <outgoing>XORCLOSE9-G2</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G2" name="G2">
      <incoming>XORCLOSE9-G2</incoming>
      <outgoing>G2-RCICR1</outgoing>
      <outgoing>G2-CWVG1</outgoing>
    </exclusiveGateway>
    <task id="RCICR1" name="Register Customer — Information in Customer Register">
      <incoming>G2-RCICR1</incoming>
      <outgoing>RCICR1-XORCLOSE14</outgoing>
    </task>
    <task id="CWVG1" name="Check Which Version of the Game the Customer Has">
      <incoming>G2-CWVG1</incoming>
      <outgoing>CWVG1-RISCP1</outgoing>
    </task>
    <task id="RISCP1" name="Requested Item + Invoice is Sent to Customer by Post">
      <incoming>CWVG1-RISCP1</incoming>
      <outgoing>RISCP1-XORCLOSE14</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>RCICR1-XORCLOSE14</incoming>
      <incoming>RISCP1-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE14-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-CCIR1" sourceRef="Default_init" targetRef="CCIR1"/>
    <sequenceFlow id="CCIR1-CPO1" sourceRef="CCIR1" targetRef="CPO1"/>
    <sequenceFlow id="CPO1-PR1" sourceRef="CPO1" targetRef="PR1"/>
    <sequenceFlow id="PR1-G1" sourceRef="PR1" targetRef="G1"/>
    <sequenceFlow id="G1-ONL1" sourceRef="G1" targetRef="ONL1"/>
    <sequenceFlow id="G1-OLU1" sourceRef="G1" targetRef="OLU1"/>
    <sequenceFlow id="ONL1-XORCLOSE9" sourceRef="ONL1" targetRef="XORCLOSE9"/>
    <sequenceFlow id="OLU1-XORCLOSE9" sourceRef="OLU1" targetRef="XORCLOSE9"/>
    <sequenceFlow id="XORCLOSE9-G2" sourceRef="XORCLOSE9" targetRef="G2"/>
    <sequenceFlow id="G2-RCICR1" sourceRef="G2" targetRef="RCICR1"/>
    <sequenceFlow id="G2-CWVG1" sourceRef="G2" targetRef="CWVG1"/>
    <sequenceFlow id="RCICR1-XORCLOSE14" sourceRef="RCICR1" targetRef="XORCLOSE14"/>
    <sequenceFlow id="CWVG1-RISCP1" sourceRef="CWVG1" targetRef="RISCP1"/>
    <sequenceFlow id="RISCP1-XORCLOSE14" sourceRef="RISCP1" targetRef="XORCLOSE14"/>
    <sequenceFlow id="XORCLOSE14-END" sourceRef="XORCLOSE14" targetRef="END"/>
  </process>
