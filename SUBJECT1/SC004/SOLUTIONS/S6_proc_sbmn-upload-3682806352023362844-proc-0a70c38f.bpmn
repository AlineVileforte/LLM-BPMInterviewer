<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_390e47eb-da8b-4a67-901c-688c060256c2" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CCIR1</outgoing>
    </startEvent>
    <task id="CCIR1" name="Copy of Customer Invoice is Received">
      <incoming>Default_init-CCIR1</incoming>
      <outgoing>CCIR1-CPO1</outgoing>
    </task>
    <task id="CPO1" name="Customer Places Order">
      <incoming>CCIR1-CPO1</incoming>
      <outgoing>CPO1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>CPO1-Par2</incoming>
      <outgoing>Par2-PR1</outgoing>
      <outgoing>Par2-G0</outgoing>
    </parallelGateway>
    <task id="PR1" name="Paymente is Received">
      <incoming>Par2-PR1</incoming>
      <outgoing>PR1-PARCLOSE9</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par2-G0</incoming>
      <outgoing>G0-OLU1</outgoing>
      <outgoing>G0-ONL1</outgoing>
    </exclusiveGateway>
    <task id="ONL1" name="Order New License">
      <incoming>G0-ONL1</incoming>
      <outgoing>ONL1-XORCLOSE8</outgoing>
    </task>
    <task id="OLU1" name="Order License Upgrade">
      <incoming>G0-OLU1</incoming>
      <outgoing>OLU1-XORCLOSE8</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE8" name="XORCLOSE8">
      <incoming>ONL1-XORCLOSE8</incoming>
      <incoming>OLU1-XORCLOSE8</incoming>
      <outgoing>XORCLOSE8-PARCLOSE9</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE9" name="PARCLOSE9">
      <incoming>PR1-PARCLOSE9</incoming>
      <incoming>XORCLOSE8-PARCLOSE9</incoming>
      <outgoing>PARCLOSE9-G2</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G2" name="G2">
      <incoming>PARCLOSE9-G2</incoming>
      <outgoing>G2-RCICR1</outgoing>
      <outgoing>G2-CWVG1</outgoing>
    </exclusiveGateway>
    <task id="RCICR1" name="Register Customer — Information in Customer Register">
      <incoming>G2-RCICR1</incoming>
      <outgoing>RCICR1-XORCLOSE14</outgoing>
    </task>
    <task id="CWVG1" name="Check Which Version of the Game the Customer Has">
      <incoming>G2-CWVG1</incoming>
      <outgoing>CWVG1-RISCP1</outgoing>
    </task>
    <task id="RISCP1" name="Requested Item + Invoice is Sent to Customer by Post">
      <incoming>CWVG1-RISCP1</incoming>
      <outgoing>RISCP1-XORCLOSE14</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>RCICR1-XORCLOSE14</incoming>
      <incoming>RISCP1-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE14-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-CCIR1" sourceRef="Default_init" targetRef="CCIR1"/>
    <sequenceFlow id="CCIR1-CPO1" sourceRef="CCIR1" targetRef="CPO1"/>
    <sequenceFlow id="CPO1-Par2" sourceRef="CPO1" targetRef="Par2"/>
