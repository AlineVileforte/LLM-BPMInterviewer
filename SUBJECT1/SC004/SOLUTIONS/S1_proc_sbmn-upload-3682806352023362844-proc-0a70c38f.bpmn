<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_f82cdfe9-e46a-418d-a332-96ccdfdf331b" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-CPO1</outgoing>
      <outgoing>Par0-CCIR1</outgoing>
    </parallelGateway>
    <task id="CPO1" name="Customer Places Order">
      <incoming>Par0-CPO1</incoming>
      <outgoing>CPO1-G0</outgoing>
    </task>
    <task id="CCIR1" name="Copy of Customer Invoice is Received">
      <incoming>Par0-CCIR1</incoming>
      <outgoing>CCIR1-PR1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CPO1-G0</incoming>
      <outgoing>G0-OLU1</outgoing>
      <outgoing>G0-ONL1</outgoing>
    </exclusiveGateway>
    <task id="ONL1" name="Order New License">
      <incoming>G0-ONL1</incoming>
      <outgoing>ONL1-XORCLOSE8</outgoing>
    </task>
    <task id="OLU1" name="Order License Upgrade">
      <incoming>G0-OLU1</incoming>
      <outgoing>OLU1-XORCLOSE8</outgoing>
    </task>
    <task id="PR1" name="Paymente is Received">
      <incoming>CCIR1-PR1</incoming>
      <outgoing>PR1-PARCLOSE14</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE8" name="XORCLOSE8">
      <incoming>ONL1-XORCLOSE8</incoming>
      <incoming>OLU1-XORCLOSE8</incoming>
      <outgoing>XORCLOSE8-G1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G1" name="G1">
      <incoming>XORCLOSE8-G1</incoming>
      <outgoing>G1-RCICR1</outgoing>
      <outgoing>G1-CWVG1</outgoing>
    </exclusiveGateway>
    <task id="RCICR1" name="Register Customer — Information in Customer Register">
      <incoming>G1-RCICR1</incoming>
      <outgoing>RCICR1-XORCLOSE13</outgoing>
    </task>
    <task id="CWVG1" name="Check Which Version of the Game the Customer Has">
      <incoming>G1-CWVG1</incoming>
      <outgoing>CWVG1-RISCP1</outgoing>
    </task>
    <task id="RISCP1" name="Requested Item + Invoice is Sent to Customer by Post">
      <incoming>CWVG1-RISCP1</incoming>
      <outgoing>RISCP1-XORCLOSE13</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE13" name="XORCLOSE13">
      <incoming>RCICR1-XORCLOSE13</incoming>
      <incoming>RISCP1-XORCLOSE13</incoming>
      <outgoing>XORCLOSE13-PARCLOSE14</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE14" name="PARCLOSE14">
      <incoming>PR1-PARCLOSE14</incoming>
      <incoming>XORCLOSE13-PARCLOSE14</incoming>
      <outgoing>PARCLOSE14-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE14-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
    <sequenceFlow id="Par0-CPO1" sourceRef="Par0" targetRef="CPO1"/>
    <sequenceFlow id="Par0-CCIR1" sourceRef="Par0" targetRef="CCIR1"/>
