    <sequenceFlow id="OLU1-XORCLOSE8" sourceRef="OLU1" targetRef="XORCLOSE8"/>
    <sequenceFlow id="PR1-PARCLOSE14" sourceRef="PR1" targetRef="PARCLOSE14"/>
    <sequenceFlow id="XORCLOSE8-G1" sourceRef="XORCLOSE8" targetRef="G1"/>
    <sequenceFlow id="G1-RCICR1" sourceRef="G1" targetRef="RCICR1"/>
    <sequenceFlow id="G1-CWVG1" sourceRef="G1" targetRef="CWVG1"/>
    <sequenceFlow id="RCICR1-XORCLOSE13" sourceRef="RCICR1" targetRef="XORCLOSE13"/>
    <sequenceFlow id="CWVG1-RISCP1" sourceRef="CWVG1" targetRef="RISCP1"/>
    <sequenceFlow id="RISCP1-XORCLOSE13" sourceRef="RISCP1" targetRef="XORCLOSE13"/>
    <sequenceFlow id="XORCLOSE13-PARCLOSE14" sourceRef="XORCLOSE13" targetRef="PARCLOSE14"/>
    <sequenceFlow id="PARCLOSE14-END" sourceRef="PARCLOSE14" targetRef="END"/>
  </process>
