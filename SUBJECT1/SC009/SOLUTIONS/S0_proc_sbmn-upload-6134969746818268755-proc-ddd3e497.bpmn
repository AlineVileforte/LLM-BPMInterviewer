    <sequenceFlow id="IM1-XORCLOSE6" sourceRef="IM1" targetRef="XORCLOSE6"/>
    <sequenceFlow id="XORCLOSE6-END" sourceRef="XORCLOSE6" targetRef="END"/>
  </process>
