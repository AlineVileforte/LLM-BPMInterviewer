      <outgoing>MP1-XORCLOSE6</outgoing>
    </task>
    <task id="RP1" name="Reject Payment">
      <incoming>G0-RP1</incoming>
      <outgoing>RP1-IM1</outgoing>
    </task>
    <task id="IM1" name="Inform Merchant">
      <incoming>RP1-IM1</incoming>
      <outgoing>IM1-XORCLOSE6</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE6" name="XORCLOSE6">
      <incoming>MP1-XORCLOSE6</incoming>
      <incoming>IM1-XORCLOSE6</incoming>
      <outgoing>XORCLOSE6-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
