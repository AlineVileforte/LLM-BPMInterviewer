<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_45a5e367-e154-4027-a084-2a9cce43aca1" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-SISR1</outgoing>
    </startEvent>
    <task id="SISR1" name="Submit IT solution request">
      <incoming>Default_init-SISR1</incoming>
      <outgoing>SISR1-AC1</outgoing>
    </task>
    <task id="AC1" name="Assess compatibility">
      <incoming>SISR1-AC1</incoming>
      <outgoing>AC1-ECRN1</outgoing>
    </task>
    <task id="ECRN1" name="Evaluate cost and resource needs">
      <incoming>AC1-ECRN1</incoming>
      <outgoing>ECRN1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>ECRN1-G0</incoming>
      <outgoing>G0-PTL1</outgoing>
      <outgoing>G0-XORCLOSE14</outgoing>
    </exclusiveGateway>
    <task id="PTL1" name="Procure necessary tools or licenses">
      <incoming>G0-PTL1</incoming>
      <outgoing>PTL1-IS1</outgoing>
    </task>
    <task id="IS1" name="Install the solution">
      <incoming>PTL1-IS1</incoming>
      <outgoing>IS1-TS1</outgoing>
    </task>
    <task id="TS1" name="Test solution">
      <incoming>IS1-TS1</incoming>
      <outgoing>TS1-ROSRD1</outgoing>
    </task>
    <task id="ROSRD1" name="Roll out solution to requesting department">
      <incoming>TS1-ROSRD1</incoming>
      <outgoing>ROSRD1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>ROSRD1-G1</incoming>
      <outgoing>G1-PT1</outgoing>
      <outgoing>G1-XOR_JMPBB_PST1_PST1</outgoing>
    </exclusiveGateway>
    <task id="PT1" name="Provide training">
      <incoming>G1-PT1</incoming>
      <outgoing>PT1-XORCLOSE13</outgoing>
    </task>
    <task id="PST1" name="Provide support for troubleshooting">
      <incoming>XOR_JMPBB_PST1_PST1-PST1</incoming>
      <outgoing>PST1-XOR_JMPAA_PST1_PST1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE13" name="XORCLOSE13">
      <incoming>PT1-XORCLOSE13</incoming>
      <incoming>XOR_JMPAA_PST1_PST1-XORCLOSE13</incoming>
      <outgoing>XORCLOSE13-XORCLOSE14</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>G0-XORCLOSE14</incoming>
      <incoming>XORCLOSE13-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE14-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_PST1_PST1" name="XOR_JMPAA_Provide support for troubleshooting">
      <incoming>PST1-XOR_JMPAA_PST1_PST1</incoming>
      <outgoing>XOR_JMPAA_PST1_PST1-XORCLOSE13</outgoing>
      <outgoing>XOR_JMPAA_PST1_PST1-XOR_JMPBB_PST1_PST1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_PST1_PST1" name="XOR_JMPBB_Provide support for troubleshooting">
      <incoming>G1-XOR_JMPBB_PST1_PST1</incoming>
      <incoming>XOR_JMPAA_PST1_PST1-XOR_JMPBB_PST1_PST1</incoming>
      <outgoing>XOR_JMPBB_PST1_PST1-PST1</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Default_init-SISR1" sourceRef="Default_init" targetRef="SISR1"/>
    <sequenceFlow id="SISR1-AC1" sourceRef="SISR1" targetRef="AC1"/>
    <sequenceFlow id="AC1-ECRN1" sourceRef="AC1" targetRef="ECRN1"/>
    <sequenceFlow id="ECRN1-G0" sourceRef="ECRN1" targetRef="G0"/>
    <sequenceFlow id="G0-PTL1" sourceRef="G0" targetRef="PTL1"/>
    <sequenceFlow id="G0-XORCLOSE14" sourceRef="G0" targetRef="XORCLOSE14"/>
    <sequenceFlow id="PTL1-IS1" sourceRef="PTL1" targetRef="IS1"/>
    <sequenceFlow id="IS1-TS1" sourceRef="IS1" targetRef="TS1"/>
    <sequenceFlow id="TS1-ROSRD1" sourceRef="TS1" targetRef="ROSRD1"/>
    <sequenceFlow id="ROSRD1-G1" sourceRef="ROSRD1" targetRef="G1"/>
    <sequenceFlow id="G1-PT1" sourceRef="G1" targetRef="PT1"/>
    <sequenceFlow id="G1-XOR_JMPBB_PST1_PST1" sourceRef="G1" targetRef="XOR_JMPBB_PST1_PST1"/>
    <sequenceFlow id="PT1-XORCLOSE13" sourceRef="PT1" targetRef="XORCLOSE13"/>
    <sequenceFlow id="PST1-XOR_JMPAA_PST1_PST1" sourceRef="PST1" targetRef="XOR_JMPAA_PST1_PST1"/>
    <sequenceFlow id="XORCLOSE13-XORCLOSE14" sourceRef="XORCLOSE13" targetRef="XORCLOSE14"/>
    <sequenceFlow id="XORCLOSE14-END" sourceRef="XORCLOSE14" targetRef="END"/>
    <sequenceFlow id="XOR_JMPAA_PST1_PST1-XORCLOSE13" sourceRef="XOR_JMPAA_PST1_PST1" targetRef="XORCLOSE13"/>
    <sequenceFlow id="XOR_JMPAA_PST1_PST1-XOR_JMPBB_PST1_PST1" sourceRef="XOR_JMPAA_PST1_PST1" targetRef="XOR_JMPBB_PST1_PST1"/>
    <sequenceFlow id="XOR_JMPBB_PST1_PST1-PST1" sourceRef="XOR_JMPBB_PST1_PST1" targetRef="PST1"/>
  </process>
