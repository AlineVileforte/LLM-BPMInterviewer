    <sequenceFlow id="XORCLOSE8-G2" sourceRef="XORCLOSE8" targetRef="G2"/>
    <sequenceFlow id="G2-SP1" sourceRef="G2" targetRef="SP1"/>
    <sequenceFlow id="G2-SI1" sourceRef="G2" targetRef="SI1"/>
    <sequenceFlow id="SP1-XORCLOSE12" sourceRef="SP1" targetRef="XORCLOSE12"/>
    <sequenceFlow id="SI1-XORCLOSE12" sourceRef="SI1" targetRef="XORCLOSE12"/>
    <sequenceFlow id="XORCLOSE12-XORCLOSE13" sourceRef="XORCLOSE12" targetRef="XORCLOSE13"/>
    <sequenceFlow id="XORCLOSE13-END" sourceRef="XORCLOSE13" targetRef="END"/>
  </process>
