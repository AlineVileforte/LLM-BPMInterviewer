<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_98fa79ff-4e43-4de9-bb13-4c959e50bac8" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-AONPT1</outgoing>
    </startEvent>
    <task id="AONPT1" name="Ask old and new pick-up time">
      <incoming>Default_init-AONPT1</incoming>
      <outgoing>AONPT1-CSPE1</outgoing>
    </task>
    <task id="CSPE1" name="Check if script still pending data entry">
      <incoming>AONPT1-CSPE1</incoming>
      <outgoing>CSPE1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CSPE1-G0</incoming>
      <outgoing>G0-G1</outgoing>
      <outgoing>G0-DEPT1</outgoing>
    </exclusiveGateway>
    <task id="DEPT1" name="Decline earlier pick-up time">
      <incoming>G0-DEPT1</incoming>
      <outgoing>DEPT1-XORCLOSE9</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>G0-G1</incoming>
      <outgoing>G1-CPTS1</outgoing>
      <outgoing>G1-ANT1</outgoing>
    </exclusiveGateway>
    <task id="CPTS1" name="Change pick-up time on script">
      <incoming>G1-CPTS1</incoming>
      <outgoing>CPTS1-XORCLOSE8</outgoing>
    </task>
    <task id="ANT1" name="Approve new pickup time">
      <incoming>G1-ANT1</incoming>
      <outgoing>ANT1-XORCLOSE8</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE8" name="XORCLOSE8">
      <incoming>CPTS1-XORCLOSE8</incoming>
      <incoming>ANT1-XORCLOSE8</incoming>
      <outgoing>XORCLOSE8-XORCLOSE9</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE9" name="XORCLOSE9">
      <incoming>DEPT1-XORCLOSE9</incoming>
      <incoming>XORCLOSE8-XORCLOSE9</incoming>
      <outgoing>XORCLOSE9-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE9-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-AONPT1" sourceRef="Default_init" targetRef="AONPT1"/>
    <sequenceFlow id="AONPT1-CSPE1" sourceRef="AONPT1" targetRef="CSPE1"/>
    <sequenceFlow id="CSPE1-G0" sourceRef="CSPE1" targetRef="G0"/>
    <sequenceFlow id="G0-G1" sourceRef="G0" targetRef="G1"/>
    <sequenceFlow id="G0-DEPT1" sourceRef="G0" targetRef="DEPT1"/>
    <sequenceFlow id="DEPT1-XORCLOSE9" sourceRef="DEPT1" targetRef="XORCLOSE9"/>
    <sequenceFlow id="G1-CPTS1" sourceRef="G1" targetRef="CPTS1"/>
    <sequenceFlow id="G1-ANT1" sourceRef="G1" targetRef="ANT1"/>
    <sequenceFlow id="CPTS1-XORCLOSE8" sourceRef="CPTS1" targetRef="XORCLOSE8"/>
    <sequenceFlow id="ANT1-XORCLOSE8" sourceRef="ANT1" targetRef="XORCLOSE8"/>
    <sequenceFlow id="XORCLOSE8-XORCLOSE9" sourceRef="XORCLOSE8" targetRef="XORCLOSE9"/>
    <sequenceFlow id="XORCLOSE9-END" sourceRef="XORCLOSE9" targetRef="END"/>
  </process>
