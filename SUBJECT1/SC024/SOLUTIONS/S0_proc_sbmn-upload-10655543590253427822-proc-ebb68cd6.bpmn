<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_625ef092-d225-489f-a5ac-7a650266d812" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CCIL1</outgoing>
    </startEvent>
    <task id="CCIL1" name="Check current inventory level">
      <incoming>Default_init-CCIL1</incoming>
      <outgoing>CCIL1-POS1</outgoing>
    </task>
    <task id="POS1" name="Place order with suppliers">
      <incoming>CCIL1-POS1</incoming>
      <outgoing>POS1-UIS1</outgoing>
    </task>
    <task id="UIS1" name="Update inventory system with expected delivery dates">
      <incoming>POS1-UIS1</incoming>
      <outgoing>UIS1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>UIS1-Par3</incoming>
      <outgoing>Par3-RS1</outgoing>
      <outgoing>Par3-G2</outgoing>
    </parallelGateway>
    <task id="RS1" name="Receive stock">
      <incoming>Par3-RS1</incoming>
      <outgoing>RS1-RSS1</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par3-G2</incoming>
      <outgoing>G2-SAA1</outgoing>
      <outgoing>G2-SMA1</outgoing>
    </exclusiveGateway>
    <task id="SAA1" name="Send an automated alert">
      <incoming>G2-SAA1</incoming>
      <outgoing>SAA1-XORCLOSE9</outgoing>
    </task>
    <task id="SMA1" name="Send a manual alert">
      <incoming>G2-SMA1</incoming>
      <outgoing>SMA1-XORCLOSE9</outgoing>
    </task>
    <task id="RSS1" name="Record stock in system">
      <incoming>RS1-RSS1</incoming>
      <outgoing>RSS1-PARCLOSE10</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE9" name="XORCLOSE9">
      <incoming>SAA1-XORCLOSE9</incoming>
      <incoming>SMA1-XORCLOSE9</incoming>
      <outgoing>XORCLOSE9-PARCLOSE10</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE10" name="PARCLOSE10">
      <incoming>RSS1-PARCLOSE10</incoming>
      <incoming>XORCLOSE9-PARCLOSE10</incoming>
      <outgoing>PARCLOSE10-ISQ1</outgoing>
    </parallelGateway>
    <task id="ISQ1" name="Inspect stock for quality">
      <incoming>PARCLOSE10-ISQ1</incoming>
      <outgoing>ISQ1-Par12</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>ISQ1-Par12</incoming>
      <outgoing>Par12-UIL1</outgoing>
      <outgoing>Par12-G3</outgoing>
    </parallelGateway>
    <task id="UIL1" name="Update inventory levels">
      <incoming>Par12-UIL1</incoming>
      <outgoing>UIL1-PARCLOSE18</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>Par12-G3</incoming>
      <outgoing>G3-PSOS1</outgoing>
      <outgoing>G3-PSIS1</outgoing>
    </exclusiveGateway>
    <task id="PSOS1" name="Place stock on shelves">
      <incoming>G3-PSOS1</incoming>
      <outgoing>PSOS1-XORCLOSE17</outgoing>
    </task>
    <task id="PSIS1" name="Place stock in storage">
      <incoming>G3-PSIS1</incoming>
      <outgoing>PSIS1-XORCLOSE17</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE17" name="XORCLOSE17">
      <incoming>PSOS1-XORCLOSE17</incoming>
      <incoming>PSIS1-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-PARCLOSE18</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>UIL1-PARCLOSE18</incoming>
      <incoming>XORCLOSE17-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE18-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-CCIL1" sourceRef="Default_init" targetRef="CCIL1"/>
    <sequenceFlow id="CCIL1-POS1" sourceRef="CCIL1" targetRef="POS1"/>
    <sequenceFlow id="POS1-UIS1" sourceRef="POS1" targetRef="UIS1"/>
    <sequenceFlow id="UIS1-Par3" sourceRef="UIS1" targetRef="Par3"/>
    <sequenceFlow id="Par3-RS1" sourceRef="Par3" targetRef="RS1"/>
    <sequenceFlow id="Par3-G2" sourceRef="Par3" targetRef="G2"/>
    <sequenceFlow id="RS1-RSS1" sourceRef="RS1" targetRef="RSS1"/>
    <sequenceFlow id="G2-SAA1" sourceRef="G2" targetRef="SAA1"/>
    <sequenceFlow id="G2-SMA1" sourceRef="G2" targetRef="SMA1"/>
    <sequenceFlow id="SAA1-XORCLOSE9" sourceRef="SAA1" targetRef="XORCLOSE9"/>
    <sequenceFlow id="SMA1-XORCLOSE9" sourceRef="SMA1" targetRef="XORCLOSE9"/>
    <sequenceFlow id="RSS1-PARCLOSE10" sourceRef="RSS1" targetRef="PARCLOSE10"/>
    <sequenceFlow id="XORCLOSE9-PARCLOSE10" sourceRef="XORCLOSE9" targetRef="PARCLOSE10"/>
    <sequenceFlow id="PARCLOSE10-ISQ1" sourceRef="PARCLOSE10" targetRef="ISQ1"/>
    <sequenceFlow id="ISQ1-Par12" sourceRef="ISQ1" targetRef="Par12"/>
    <sequenceFlow id="Par12-UIL1" sourceRef="Par12" targetRef="UIL1"/>
    <sequenceFlow id="Par12-G3" sourceRef="Par12" targetRef="G3"/>
    <sequenceFlow id="UIL1-PARCLOSE18" sourceRef="UIL1" targetRef="PARCLOSE18"/>
    <sequenceFlow id="G3-PSOS1" sourceRef="G3" targetRef="PSOS1"/>
    <sequenceFlow id="G3-PSIS1" sourceRef="G3" targetRef="PSIS1"/>
    <sequenceFlow id="PSOS1-XORCLOSE17" sourceRef="PSOS1" targetRef="XORCLOSE17"/>
    <sequenceFlow id="PSIS1-XORCLOSE17" sourceRef="PSIS1" targetRef="XORCLOSE17"/>
    <sequenceFlow id="XORCLOSE17-PARCLOSE18" sourceRef="XORCLOSE17" targetRef="PARCLOSE18"/>
    <sequenceFlow id="PARCLOSE18-END" sourceRef="PARCLOSE18" targetRef="END"/>
  </process>
