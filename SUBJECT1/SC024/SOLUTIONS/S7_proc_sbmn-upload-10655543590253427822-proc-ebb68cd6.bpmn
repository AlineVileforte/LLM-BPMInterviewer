<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_f874064b-0dd9-4036-8cb3-c5554f318704" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CCIL1</outgoing>
    </startEvent>
    <task id="CCIL1" name="Check current inventory level">
      <incoming>Default_init-CCIL1</incoming>
      <outgoing>CCIL1-POS1</outgoing>
    </task>
    <task id="POS1" name="Place order with suppliers">
      <incoming>CCIL1-POS1</incoming>
      <outgoing>POS1-UIS1</outgoing>
    </task>
    <task id="UIS1" name="Update inventory system with expected delivery dates">
      <incoming>POS1-UIS1</incoming>
      <outgoing>UIS1-G2</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>UIS1-G2</incoming>
      <outgoing>G2-SAA1</outgoing>
      <outgoing>G2-SMA1</outgoing>
    </exclusiveGateway>
    <task id="SAA1" name="Send an automated alert">
      <incoming>G2-SAA1</incoming>
      <outgoing>SAA1-XORCLOSE6</outgoing>
    </task>
    <task id="SMA1" name="Send a manual alert">
      <incoming>G2-SMA1</incoming>
      <outgoing>SMA1-XORCLOSE6</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE6" name="XORCLOSE6">
      <incoming>SAA1-XORCLOSE6</incoming>
      <incoming>SMA1-XORCLOSE6</incoming>
      <outgoing>XORCLOSE6-RS1</outgoing>
    </exclusiveGateway>
    <task id="RS1" name="Receive stock">
      <incoming>XORCLOSE6-RS1</incoming>
      <outgoing>RS1-RSS1</outgoing>
    </task>
    <task id="RSS1" name="Record stock in system">
      <incoming>RS1-RSS1</incoming>
      <outgoing>RSS1-ISQ1</outgoing>
    </task>
    <task id="ISQ1" name="Inspect stock for quality">
      <incoming>RSS1-ISQ1</incoming>
      <outgoing>ISQ1-UIL1</outgoing>
    </task>
    <task id="UIL1" name="Update inventory levels">
      <incoming>ISQ1-UIL1</incoming>
      <outgoing>UIL1-G4</outgoing>
    </task>
    <exclusiveGateway id="G4" name="G4">
      <incoming>UIL1-G4</incoming>
      <outgoing>G4-PSOS1</outgoing>
      <outgoing>G4-PSIS1</outgoing>
    </exclusiveGateway>
    <task id="PSOS1" name="Place stock on shelves">
      <incoming>G4-PSOS1</incoming>
      <outgoing>PSOS1-XORCLOSE14</outgoing>
    </task>
    <task id="PSIS1" name="Place stock in storage">
      <incoming>G4-PSIS1</incoming>
      <outgoing>PSIS1-XORCLOSE14</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>PSOS1-XORCLOSE14</incoming>
      <incoming>PSIS1-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE14-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-CCIL1" sourceRef="Default_init" targetRef="CCIL1"/>
    <sequenceFlow id="CCIL1-POS1" sourceRef="CCIL1" targetRef="POS1"/>
    <sequenceFlow id="POS1-UIS1" sourceRef="POS1" targetRef="UIS1"/>
    <sequenceFlow id="UIS1-G2" sourceRef="UIS1" targetRef="G2"/>
    <sequenceFlow id="G2-SAA1" sourceRef="G2" targetRef="SAA1"/>
    <sequenceFlow id="G2-SMA1" sourceRef="G2" targetRef="SMA1"/>
    <sequenceFlow id="SAA1-XORCLOSE6" sourceRef="SAA1" targetRef="XORCLOSE6"/>
    <sequenceFlow id="SMA1-XORCLOSE6" sourceRef="SMA1" targetRef="XORCLOSE6"/>
    <sequenceFlow id="XORCLOSE6-RS1" sourceRef="XORCLOSE6" targetRef="RS1"/>
    <sequenceFlow id="RS1-RSS1" sourceRef="RS1" targetRef="RSS1"/>
    <sequenceFlow id="RSS1-ISQ1" sourceRef="RSS1" targetRef="ISQ1"/>
    <sequenceFlow id="ISQ1-UIL1" sourceRef="ISQ1" targetRef="UIL1"/>
    <sequenceFlow id="UIL1-G4" sourceRef="UIL1" targetRef="G4"/>
    <sequenceFlow id="G4-PSOS1" sourceRef="G4" targetRef="PSOS1"/>
    <sequenceFlow id="G4-PSIS1" sourceRef="G4" targetRef="PSIS1"/>
    <sequenceFlow id="PSOS1-XORCLOSE14" sourceRef="PSOS1" targetRef="XORCLOSE14"/>
    <sequenceFlow id="PSIS1-XORCLOSE14" sourceRef="PSIS1" targetRef="XORCLOSE14"/>
    <sequenceFlow id="XORCLOSE14-END" sourceRef="XORCLOSE14" targetRef="END"/>
  </process>
