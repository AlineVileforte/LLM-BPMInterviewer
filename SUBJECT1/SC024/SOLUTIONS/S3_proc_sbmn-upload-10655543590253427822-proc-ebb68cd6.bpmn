<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_c44c44f8-b43f-4043-b5b5-d835a205a6a5" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CCIL1</outgoing>
    </startEvent>
    <task id="CCIL1" name="Check current inventory level">
      <incoming>Default_init-CCIL1</incoming>
      <outgoing>CCIL1-POS1</outgoing>
    </task>
    <task id="POS1" name="Place order with suppliers">
      <incoming>CCIL1-POS1</incoming>
      <outgoing>POS1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>POS1-G1</incoming>
      <outgoing>G1-SAA1</outgoing>
      <outgoing>G1-SMA1</outgoing>
    </exclusiveGateway>
    <task id="SAA1" name="Send an automated alert">
      <incoming>G1-SAA1</incoming>
      <outgoing>SAA1-XORCLOSE5</outgoing>
    </task>
    <task id="SMA1" name="Send a manual alert">
      <incoming>G1-SMA1</incoming>
      <outgoing>SMA1-XORCLOSE5</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE5" name="XORCLOSE5">
      <incoming>SAA1-XORCLOSE5</incoming>
      <incoming>SMA1-XORCLOSE5</incoming>
      <outgoing>XORCLOSE5-UIS1</outgoing>
    </exclusiveGateway>
    <task id="UIS1" name="Update inventory system with expected delivery dates">
      <incoming>XORCLOSE5-UIS1</incoming>
      <outgoing>UIS1-RS1</outgoing>
    </task>
    <task id="RS1" name="Receive stock">
      <incoming>UIS1-RS1</incoming>
      <outgoing>RS1-ISQ1</outgoing>
    </task>
    <task id="ISQ1" name="Inspect stock for quality">
      <incoming>RS1-ISQ1</incoming>
      <outgoing>ISQ1-Par9</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>ISQ1-Par9</incoming>
      <outgoing>Par9-RSS1</outgoing>
      <outgoing>Par9-G2</outgoing>
    </parallelGateway>
    <task id="RSS1" name="Record stock in system">
      <incoming>Par9-RSS1</incoming>
      <outgoing>RSS1-UIL1</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par9-G2</incoming>
      <outgoing>G2-PSOS1</outgoing>
      <outgoing>G2-PSIS1</outgoing>
    </exclusiveGateway>
    <task id="PSOS1" name="Place stock on shelves">
      <incoming>G2-PSOS1</incoming>
      <outgoing>PSOS1-XORCLOSE15</outgoing>
    </task>
    <task id="PSIS1" name="Place stock in storage">
      <incoming>G2-PSIS1</incoming>
      <outgoing>PSIS1-XORCLOSE15</outgoing>
    </task>
    <task id="UIL1" name="Update inventory levels">
      <incoming>RSS1-UIL1</incoming>
      <outgoing>UIL1-PARCLOSE16</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE15" name="XORCLOSE15">
      <incoming>PSOS1-XORCLOSE15</incoming>
      <incoming>PSIS1-XORCLOSE15</incoming>
      <outgoing>XORCLOSE15-PARCLOSE16</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE16" name="PARCLOSE16">
      <incoming>UIL1-PARCLOSE16</incoming>
      <incoming>XORCLOSE15-PARCLOSE16</incoming>
      <outgoing>PARCLOSE16-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE16-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-CCIL1" sourceRef="Default_init" targetRef="CCIL1"/>
    <sequenceFlow id="CCIL1-POS1" sourceRef="CCIL1" targetRef="POS1"/>
    <sequenceFlow id="POS1-G1" sourceRef="POS1" targetRef="G1"/>
    <sequenceFlow id="G1-SAA1" sourceRef="G1" targetRef="SAA1"/>
    <sequenceFlow id="G1-SMA1" sourceRef="G1" targetRef="SMA1"/>
    <sequenceFlow id="SAA1-XORCLOSE5" sourceRef="SAA1" targetRef="XORCLOSE5"/>
    <sequenceFlow id="SMA1-XORCLOSE5" sourceRef="SMA1" targetRef="XORCLOSE5"/>
    <sequenceFlow id="XORCLOSE5-UIS1" sourceRef="XORCLOSE5" targetRef="UIS1"/>
    <sequenceFlow id="UIS1-RS1" sourceRef="UIS1" targetRef="RS1"/>
    <sequenceFlow id="RS1-ISQ1" sourceRef="RS1" targetRef="ISQ1"/>
    <sequenceFlow id="ISQ1-Par9" sourceRef="ISQ1" targetRef="Par9"/>
    <sequenceFlow id="Par9-RSS1" sourceRef="Par9" targetRef="RSS1"/>
    <sequenceFlow id="Par9-G2" sourceRef="Par9" targetRef="G2"/>
    <sequenceFlow id="RSS1-UIL1" sourceRef="RSS1" targetRef="UIL1"/>
    <sequenceFlow id="G2-PSOS1" sourceRef="G2" targetRef="PSOS1"/>
    <sequenceFlow id="G2-PSIS1" sourceRef="G2" targetRef="PSIS1"/>
    <sequenceFlow id="PSOS1-XORCLOSE15" sourceRef="PSOS1" targetRef="XORCLOSE15"/>
    <sequenceFlow id="PSIS1-XORCLOSE15" sourceRef="PSIS1" targetRef="XORCLOSE15"/>
    <sequenceFlow id="UIL1-PARCLOSE16" sourceRef="UIL1" targetRef="PARCLOSE16"/>
    <sequenceFlow id="XORCLOSE15-PARCLOSE16" sourceRef="XORCLOSE15" targetRef="PARCLOSE16"/>
    <sequenceFlow id="PARCLOSE16-END" sourceRef="PARCLOSE16" targetRef="END"/>
  </process>
