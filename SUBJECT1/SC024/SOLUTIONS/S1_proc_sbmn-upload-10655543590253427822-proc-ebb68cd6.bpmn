<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_2a809992-4614-45be-b9ac-0251e1cb78d6" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CCIL1</outgoing>
    </startEvent>
    <task id="CCIL1" name="Check current inventory level">
      <incoming>Default_init-CCIL1</incoming>
      <outgoing>CCIL1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>CCIL1-Par1</incoming>
      <outgoing>Par1-POS1</outgoing>
      <outgoing>Par1-G0</outgoing>
    </parallelGateway>
    <task id="POS1" name="Place order with suppliers">
      <incoming>Par1-POS1</incoming>
      <outgoing>POS1-UIS1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par1-G0</incoming>
      <outgoing>G0-SAA1</outgoing>
      <outgoing>G0-SMA1</outgoing>
    </exclusiveGateway>
    <task id="SAA1" name="Send an automated alert">
      <incoming>G0-SAA1</incoming>
      <outgoing>SAA1-XORCLOSE7</outgoing>
    </task>
    <task id="SMA1" name="Send a manual alert">
      <incoming>G0-SMA1</incoming>
      <outgoing>SMA1-XORCLOSE7</outgoing>
    </task>
    <task id="UIS1" name="Update inventory system with expected delivery dates">
      <incoming>POS1-UIS1</incoming>
      <outgoing>UIS1-PARCLOSE8</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE7" name="XORCLOSE7">
      <incoming>SAA1-XORCLOSE7</incoming>
      <incoming>SMA1-XORCLOSE7</incoming>
      <outgoing>XORCLOSE7-PARCLOSE8</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE8" name="PARCLOSE8">
      <incoming>UIS1-PARCLOSE8</incoming>
      <incoming>XORCLOSE7-PARCLOSE8</incoming>
      <outgoing>PARCLOSE8-RS1</outgoing>
    </parallelGateway>
    <task id="RS1" name="Receive stock">
      <incoming>PARCLOSE8-RS1</incoming>
      <outgoing>RS1-ISQ1</outgoing>
    </task>
    <task id="ISQ1" name="Inspect stock for quality">
      <incoming>RS1-ISQ1</incoming>
      <outgoing>ISQ1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>ISQ1-G1</incoming>
      <outgoing>G1-PSOS1</outgoing>
      <outgoing>G1-PSIS1</outgoing>
    </exclusiveGateway>
    <task id="PSOS1" name="Place stock on shelves">
      <incoming>G1-PSOS1</incoming>
      <outgoing>PSOS1-XORCLOSE14</outgoing>
    </task>
    <task id="PSIS1" name="Place stock in storage">
      <incoming>G1-PSIS1</incoming>
      <outgoing>PSIS1-XORCLOSE14</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>PSOS1-XORCLOSE14</incoming>
      <incoming>PSIS1-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-RSS1</outgoing>
    </exclusiveGateway>
    <task id="RSS1" name="Record stock in system">
      <incoming>XORCLOSE14-RSS1</incoming>
      <outgoing>RSS1-UIL1</outgoing>
    </task>
    <task id="UIL1" name="Update inventory levels">
      <incoming>RSS1-UIL1</incoming>
      <outgoing>UIL1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>UIL1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-CCIL1" sourceRef="Default_init" targetRef="CCIL1"/>
    <sequenceFlow id="CCIL1-Par1" sourceRef="CCIL1" targetRef="Par1"/>
    <sequenceFlow id="Par1-POS1" sourceRef="Par1" targetRef="POS1"/>
    <sequenceFlow id="Par1-G0" sourceRef="Par1" targetRef="G0"/>
    <sequenceFlow id="POS1-UIS1" sourceRef="POS1" targetRef="UIS1"/>
    <sequenceFlow id="G0-SAA1" sourceRef="G0" targetRef="SAA1"/>
    <sequenceFlow id="G0-SMA1" sourceRef="G0" targetRef="SMA1"/>
    <sequenceFlow id="SAA1-XORCLOSE7" sourceRef="SAA1" targetRef="XORCLOSE7"/>
    <sequenceFlow id="SMA1-XORCLOSE7" sourceRef="SMA1" targetRef="XORCLOSE7"/>
    <sequenceFlow id="UIS1-PARCLOSE8" sourceRef="UIS1" targetRef="PARCLOSE8"/>
    <sequenceFlow id="XORCLOSE7-PARCLOSE8" sourceRef="XORCLOSE7" targetRef="PARCLOSE8"/>
    <sequenceFlow id="PARCLOSE8-RS1" sourceRef="PARCLOSE8" targetRef="RS1"/>
    <sequenceFlow id="RS1-ISQ1" sourceRef="RS1" targetRef="ISQ1"/>
    <sequenceFlow id="ISQ1-G1" sourceRef="ISQ1" targetRef="G1"/>
    <sequenceFlow id="G1-PSOS1" sourceRef="G1" targetRef="PSOS1"/>
    <sequenceFlow id="G1-PSIS1" sourceRef="G1" targetRef="PSIS1"/>
    <sequenceFlow id="PSOS1-XORCLOSE14" sourceRef="PSOS1" targetRef="XORCLOSE14"/>
    <sequenceFlow id="PSIS1-XORCLOSE14" sourceRef="PSIS1" targetRef="XORCLOSE14"/>
    <sequenceFlow id="XORCLOSE14-RSS1" sourceRef="XORCLOSE14" targetRef="RSS1"/>
    <sequenceFlow id="RSS1-UIL1" sourceRef="RSS1" targetRef="UIL1"/>
    <sequenceFlow id="UIL1-END" sourceRef="UIL1" targetRef="END"/>
  </process>
