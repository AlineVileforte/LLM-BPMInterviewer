  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-PA1</outgoing>
    </startEvent>
    <task id="PA1" name="Patient Arrival">
      <incoming>Default_init-PA1</incoming>
      <outgoing>PA1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>PA1-Par1</incoming>
      <outgoing>Par1-AR1</outgoing>
      <outgoing>Par1-INT1</outgoing>
    </parallelGateway>
    <task id="AR1" name="Administrative Registration">
      <incoming>Par1-AR1</incoming>
      <outgoing>AR1-G0</outgoing>
    </task>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par1-INT1</incoming>
      <outgoing>INT1-PARCLOSE21</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>AR1-G0</incoming>
      <outgoing>G0-MCA1</outgoing>
      <outgoing>G0-XORCLOSE20</outgoing>
    </exclusiveGateway>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>G0-MCA1</incoming>
      <outgoing>MCA1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>MCA1-G1</incoming>
      <outgoing>G1-HIA1</outgoing>
      <outgoing>G1-XORCLOSE16</outgoing>
    </exclusiveGateway>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>G1-HIA1</incoming>
      <outgoing>HIA1-XORCLOSE16</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
      <incoming>G1-XORCLOSE16</incoming>
      <incoming>HIA1-XORCLOSE16</incoming>
      <outgoing>XORCLOSE16-XORCLOSE20</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>G0-XORCLOSE20</incoming>
      <incoming>XORCLOSE16-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-PARCLOSE21</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>INT1-PARCLOSE21</incoming>
      <incoming>XORCLOSE20-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-PAS1</outgoing>
    </parallelGateway>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>PARCLOSE21-PAS1</incoming>
      <outgoing>PAS1-PHP1</outgoing>
    </task>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>PAS1-PHP1</incoming>
      <outgoing>PHP1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PHP1-END</incoming>
    </endEvent>
