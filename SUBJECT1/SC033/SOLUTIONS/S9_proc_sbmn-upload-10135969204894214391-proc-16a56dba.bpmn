  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-PA1</outgoing>
    </startEvent>
    <task id="PA1" name="Patient Arrival">
      <incoming>Default_init-PA1</incoming>
      <outgoing>PA1-INT1</outgoing>
    </task>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>PA1-INT1</incoming>
      <outgoing>INT1-AR1</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>INT1-AR1</incoming>
      <outgoing>AR1-PAS1</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>AR1-PAS1</incoming>
      <outgoing>PAS1-Par4</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>PAS1-Par4</incoming>
      <outgoing>Par4-PHP1</outgoing>
      <outgoing>Par4-G1</outgoing>
    </parallelGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>Par4-PHP1</incoming>
      <outgoing>PHP1-PARCLOSE14</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par4-G1</incoming>
      <outgoing>G1-MCA1</outgoing>
      <outgoing>G1-XORCLOSE13</outgoing>
    </exclusiveGateway>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>G1-MCA1</incoming>
      <outgoing>MCA1-G2</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>MCA1-G2</incoming>
      <outgoing>G2-HIA1</outgoing>
      <outgoing>G2-XORCLOSE12</outgoing>
    </exclusiveGateway>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>G2-HIA1</incoming>
      <outgoing>HIA1-XORCLOSE12</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE12" name="XORCLOSE12">
      <incoming>G2-XORCLOSE12</incoming>
      <incoming>HIA1-XORCLOSE12</incoming>
      <outgoing>XORCLOSE12-XORCLOSE13</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE13" name="XORCLOSE13">
      <incoming>G1-XORCLOSE13</incoming>
      <incoming>XORCLOSE12-XORCLOSE13</incoming>
      <outgoing>XORCLOSE13-PARCLOSE14</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE14" name="PARCLOSE14">
      <incoming>PHP1-PARCLOSE14</incoming>
      <incoming>XORCLOSE13-PARCLOSE14</incoming>
      <outgoing>PARCLOSE14-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE14-END</incoming>
    </endEvent>
