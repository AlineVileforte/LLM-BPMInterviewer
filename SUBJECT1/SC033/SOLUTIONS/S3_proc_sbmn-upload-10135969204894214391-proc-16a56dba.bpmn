  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-PA1</outgoing>
    </startEvent>
    <task id="PA1" name="Patient Arrival">
      <incoming>Default_init-PA1</incoming>
      <outgoing>PA1-AR1</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>PA1-AR1</incoming>
      <outgoing>AR1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>AR1-G0</incoming>
      <outgoing>G0-MCA1</outgoing>
      <outgoing>G0-XORCLOSE9</outgoing>
    </exclusiveGateway>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>G0-MCA1</incoming>
      <outgoing>MCA1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>MCA1-G1</incoming>
      <outgoing>G1-HIA1</outgoing>
      <outgoing>G1-XORCLOSE8</outgoing>
    </exclusiveGateway>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>G1-HIA1</incoming>
      <outgoing>HIA1-XORCLOSE8</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE8" name="XORCLOSE8">
      <incoming>G1-XORCLOSE8</incoming>
      <incoming>HIA1-XORCLOSE8</incoming>
      <outgoing>XORCLOSE8-XORCLOSE9</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE9" name="XORCLOSE9">
      <incoming>G0-XORCLOSE9</incoming>
      <incoming>XORCLOSE8-XORCLOSE9</incoming>
      <outgoing>XORCLOSE9-INT1</outgoing>
    </exclusiveGateway>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>XORCLOSE9-INT1</incoming>
      <outgoing>INT1-PAS1</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>INT1-PAS1</incoming>
      <outgoing>PAS1-PHP1</outgoing>
    </task>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>PAS1-PHP1</incoming>
      <outgoing>PHP1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PHP1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-PA1" sourceRef="Default_init" targetRef="PA1"/>
