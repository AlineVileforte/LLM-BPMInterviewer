<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_6bfaabf3-9e0f-48d6-a46d-609bc24fe699" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-RCI1</outgoing>
    </startEvent>
    <task id="RCI1" name="Receive customer inquiry">
      <incoming>Default_init-RCI1</incoming>
      <outgoing>RCI1-ACCQ1</outgoing>
    </task>
    <task id="ACCQ1" name="Address customer concerns or questions">
      <incoming>RCI1-ACCQ1</incoming>
      <outgoing>ACCQ1-CCI1</outgoing>
    </task>
    <task id="CCI1" name="Collect customer information">
      <incoming>ACCQ1-CCI1</incoming>
      <outgoing>CCI1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CCI1-G0</incoming>
      <outgoing>G0-GCSP1</outgoing>
      <outgoing>G0-XORCLOSE16</outgoing>
    </exclusiveGateway>
    <task id="GCSP1" name="Guide customer in selecting product/service">
      <incoming>G0-GCSP1</incoming>
      <outgoing>GCSP1-PQ1</outgoing>
    </task>
    <task id="PQ1" name="Provide quote">
      <incoming>GCSP1-PQ1</incoming>
      <outgoing>PQ1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>PQ1-G1</incoming>
      <outgoing>G1-PO1</outgoing>
      <outgoing>G1-XORCLOSE15</outgoing>
    </exclusiveGateway>
    <task id="PO1" name="Place order">
      <incoming>G1-PO1</incoming>
      <outgoing>PO1-ROIS1</outgoing>
    </task>
    <task id="ROIS1" name="Record order in system">
      <incoming>PO1-ROIS1</incoming>
      <outgoing>ROIS1-SOCC1</outgoing>
    </task>
    <task id="SOCC1" name="Send order confirmation to customer">
      <incoming>ROIS1-SOCC1</incoming>
      <outgoing>SOCC1-XORCLOSE15</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE15" name="XORCLOSE15">
      <incoming>G1-XORCLOSE15</incoming>
      <incoming>SOCC1-XORCLOSE15</incoming>
      <outgoing>XORCLOSE15-XORCLOSE16</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
      <incoming>G0-XORCLOSE16</incoming>
      <incoming>XORCLOSE15-XORCLOSE16</incoming>
      <outgoing>XORCLOSE16-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE16-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-RCI1" sourceRef="Default_init" targetRef="RCI1"/>
    <sequenceFlow id="RCI1-ACCQ1" sourceRef="RCI1" targetRef="ACCQ1"/>
    <sequenceFlow id="ACCQ1-CCI1" sourceRef="ACCQ1" targetRef="CCI1"/>
    <sequenceFlow id="CCI1-G0" sourceRef="CCI1" targetRef="G0"/>
    <sequenceFlow id="G0-GCSP1" sourceRef="G0" targetRef="GCSP1"/>
    <sequenceFlow id="G0-XORCLOSE16" sourceRef="G0" targetRef="XORCLOSE16"/>
    <sequenceFlow id="GCSP1-PQ1" sourceRef="GCSP1" targetRef="PQ1"/>
    <sequenceFlow id="PQ1-G1" sourceRef="PQ1" targetRef="G1"/>
    <sequenceFlow id="G1-PO1" sourceRef="G1" targetRef="PO1"/>
    <sequenceFlow id="G1-XORCLOSE15" sourceRef="G1" targetRef="XORCLOSE15"/>
    <sequenceFlow id="PO1-ROIS1" sourceRef="PO1" targetRef="ROIS1"/>
    <sequenceFlow id="ROIS1-SOCC1" sourceRef="ROIS1" targetRef="SOCC1"/>
    <sequenceFlow id="SOCC1-XORCLOSE15" sourceRef="SOCC1" targetRef="XORCLOSE15"/>
    <sequenceFlow id="XORCLOSE15-XORCLOSE16" sourceRef="XORCLOSE15" targetRef="XORCLOSE16"/>
    <sequenceFlow id="XORCLOSE16-END" sourceRef="XORCLOSE16" targetRef="END"/>
  </process>
