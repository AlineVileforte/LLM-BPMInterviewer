    <sequenceFlow id="XORCLOSE14-RS1" sourceRef="XORCLOSE14" targetRef="RS1"/>
    <sequenceFlow id="RS1-G3" sourceRef="RS1" targetRef="G3"/>
    <sequenceFlow id="G3-CGR1" sourceRef="G3" targetRef="CGR1"/>
    <sequenceFlow id="G3-XORCLOSE20" sourceRef="G3" targetRef="XORCLOSE20"/>
    <sequenceFlow id="CGR1-XORCLOSE20" sourceRef="CGR1" targetRef="XORCLOSE20"/>
    <sequenceFlow id="XORCLOSE20-G4" sourceRef="XORCLOSE20" targetRef="G4"/>
    <sequenceFlow id="G4-EL1" sourceRef="G4" targetRef="EL1"/>
    <sequenceFlow id="G4-ER1" sourceRef="G4" targetRef="ER1"/>
    <sequenceFlow id="EL1-XORCLOSE24" sourceRef="EL1" targetRef="XORCLOSE24"/>
    <sequenceFlow id="ER1-XORCLOSE24" sourceRef="ER1" targetRef="XORCLOSE24"/>
    <sequenceFlow id="XORCLOSE24-PRN1" sourceRef="XORCLOSE24" targetRef="PRN1"/>
    <sequenceFlow id="PRN1-DP1" sourceRef="PRN1" targetRef="DP1"/>
    <sequenceFlow id="DP1-CPIM1" sourceRef="DP1" targetRef="CPIM1"/>
    <sequenceFlow id="CPIM1-GQG1" sourceRef="CPIM1" targetRef="GQG1"/>
    <sequenceFlow id="GQG1-END" sourceRef="GQG1" targetRef="END"/>
  </process>
