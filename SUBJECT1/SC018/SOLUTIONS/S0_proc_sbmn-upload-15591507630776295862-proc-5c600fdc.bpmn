<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_29bbc90c-aad7-4429-9443-f0258c26c359" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CSC1</outgoing>
    </startEvent>
    <task id="CSC1" name="Il cliente si connette al sistema informative">
      <incoming>Default_init-CSC1</incoming>
      <outgoing>CSC1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CSC1-G0</incoming>
      <outgoing>G0-SRCE1</outgoing>
      <outgoing>G0-XORCLOSE4</outgoing>
    </exclusiveGateway>
    <task id="SRCE1" name="Scelta del tipo di ricerca da effettuare">
      <incoming>G0-SRCE1</incoming>
      <outgoing>SRCE1-XORCLOSE4</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE4" name="XORCLOSE4">
      <incoming>G0-XORCLOSE4</incoming>
      <incoming>SRCE1-XORCLOSE4</incoming>
      <outgoing>XORCLOSE4-G1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G1" name="G1">
      <incoming>XORCLOSE4-G1</incoming>
      <outgoing>G1-SS1</outgoing>
      <outgoing>G1-G2</outgoing>
    </exclusiveGateway>
    <task id="SS1" name="selezione della sala">
      <incoming>G1-SS1</incoming>
      <outgoing>SS1-SFO1</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>G1-G2</incoming>
      <outgoing>G2-SF1</outgoing>
      <outgoing>G2-SO1</outgoing>
    </exclusiveGateway>
    <task id="SFO1" name="selezione del film edell'orario">
      <incoming>SS1-SFO1</incoming>
      <outgoing>SFO1-XORCLOSE14</outgoing>
    </task>
    <task id="SF1" name="selezione del film">
      <incoming>G2-SF1</incoming>
      <outgoing>SF1-SSO1</outgoing>
    </task>
    <task id="SO1" name="selezione dell'orario">
      <incoming>G2-SO1</incoming>
      <outgoing>SO1-SFS1</outgoing>
    </task>
    <task id="SSO1" name="selezione della sala e dell'orario">
      <incoming>SF1-SSO1</incoming>
      <outgoing>SSO1-XORCLOSE13</outgoing>
    </task>
    <task id="SFS1" name="selezione del film e della sala">
      <incoming>SO1-SFS1</incoming>
      <outgoing>SFS1-XORCLOSE13</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE13" name="XORCLOSE13">
      <incoming>SSO1-XORCLOSE13</incoming>
      <incoming>SFS1-XORCLOSE13</incoming>
      <outgoing>XORCLOSE13-XORCLOSE14</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>SFO1-XORCLOSE14</incoming>
      <incoming>XORCLOSE13-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-RS1</outgoing>
    </exclusiveGateway>
    <task id="RS1" name="riassunto della selezione">
      <incoming>XORCLOSE14-RS1</incoming>
      <outgoing>RS1-G3</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>RS1-G3</incoming>
      <outgoing>G3-CGR1</outgoing>
      <outgoing>G3-XORCLOSE20</outgoing>
    </exclusiveGateway>
    <task id="CGR1" name="Il cliente è già regitrato?">
      <incoming>G3-CGR1</incoming>
      <outgoing>CGR1-XORCLOSE20</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>G3-XORCLOSE20</incoming>
      <incoming>CGR1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-G4</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G4" name="G4">
      <incoming>XORCLOSE20-G4</incoming>
      <outgoing>G4-EL1</outgoing>
      <outgoing>G4-ER1</outgoing>
    </exclusiveGateway>
    <task id="EL1" name="effettua il Login">
      <incoming>G4-EL1</incoming>
      <outgoing>EL1-XORCLOSE24</outgoing>
    </task>
    <task id="ER1" name="Effettua Registrazione">
      <incoming>G4-ER1</incoming>
      <outgoing>ER1-XORCLOSE24</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE24" name="XORCLOSE24">
      <incoming>EL1-XORCLOSE24</incoming>
      <incoming>ER1-XORCLOSE24</incoming>
      <outgoing>XORCLOSE24-PRN1</outgoing>
    </exclusiveGateway>
    <task id="PRN1" name="prenotazione">
      <incoming>XORCLOSE24-PRN1</incoming>
      <outgoing>PRN1-DP1</outgoing>
    </task>
    <task id="DP1" name="decisione del pagamento">
      <incoming>PRN1-DP1</incoming>
      <outgoing>DP1-CPIM1</outgoing>
    </task>
    <task id="CPIM1" name="conferma prenotazione con invio di e-mail">
      <incoming>DP1-CPIM1</incoming>
      <outgoing>CPIM1-GQG1</outgoing>
    </task>
    <task id="GQG1" name="Gestione questionario di gradimento">
      <incoming>CPIM1-GQG1</incoming>
      <outgoing>GQG1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>GQG1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-CSC1" sourceRef="Default_init" targetRef="CSC1"/>
    <sequenceFlow id="CSC1-G0" sourceRef="CSC1" targetRef="G0"/>
