<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_2b50da9d-a911-4c95-ad00-59160b8ccb52" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-DALAP1</outgoing>
      <outgoing>Par0-SPRC1</outgoing>
    </parallelGateway>
    <task id="DALAP1" name="Determine any land action planned">
      <incoming>Par0-DALAP1</incoming>
      <outgoing>DALAP1-LVC1</outgoing>
    </task>
    <task id="SPRC1" name="Survey plan registration check">
      <incoming>Par0-SPRC1</incoming>
      <outgoing>SPRC1-PC1</outgoing>
    </task>
    <task id="LVC1" name="Land valuation check">
      <incoming>DALAP1-LVC1</incoming>
      <outgoing>LVC1-Par7</outgoing>
    </task>
    <task id="PC1" name="Parcel check">
      <incoming>SPRC1-PC1</incoming>
      <outgoing>PC1-PARCLOSE13</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>LVC1-Par7</incoming>
      <outgoing>Par7-TAC1</outgoing>
      <outgoing>Par7-NTC1</outgoing>
    </parallelGateway>
    <task id="TAC1" name="Title administrative check">
      <incoming>Par7-TAC1</incoming>
      <outgoing>TAC1-PARCLOSE11</outgoing>
    </task>
    <task id="NTC1" name="Native title check">
      <incoming>Par7-NTC1</incoming>
      <outgoing>NTC1-PARCLOSE11</outgoing>
    </task>
    <parallelGateway id="PARCLOSE11" name="PARCLOSE11">
      <incoming>TAC1-PARCLOSE11</incoming>
      <incoming>NTC1-PARCLOSE11</incoming>
      <outgoing>PARCLOSE11-PARCLOSE13</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE13" name="PARCLOSE13">
      <incoming>PC1-PARCLOSE13</incoming>
      <incoming>PARCLOSE11-PARCLOSE13</incoming>
      <outgoing>PARCLOSE13-FCR1</outgoing>
    </parallelGateway>
    <task id="FCR1" name="Finalize check result">
      <incoming>PARCLOSE13-FCR1</incoming>
      <outgoing>FCR1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>FCR1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
    <sequenceFlow id="Par0-DALAP1" sourceRef="Par0" targetRef="DALAP1"/>
    <sequenceFlow id="Par0-SPRC1" sourceRef="Par0" targetRef="SPRC1"/>
