    <sequenceFlow id="PC1-PARCLOSE13" sourceRef="PC1" targetRef="PARCLOSE13"/>
    <sequenceFlow id="Par7-TAC1" sourceRef="Par7" targetRef="TAC1"/>
    <sequenceFlow id="Par7-NTC1" sourceRef="Par7" targetRef="NTC1"/>
    <sequenceFlow id="TAC1-PARCLOSE11" sourceRef="TAC1" targetRef="PARCLOSE11"/>
    <sequenceFlow id="NTC1-PARCLOSE11" sourceRef="NTC1" targetRef="PARCLOSE11"/>
    <sequenceFlow id="PARCLOSE11-PARCLOSE13" sourceRef="PARCLOSE11" targetRef="PARCLOSE13"/>
    <sequenceFlow id="PARCLOSE13-FCR1" sourceRef="PARCLOSE13" targetRef="FCR1"/>
    <sequenceFlow id="FCR1-END" sourceRef="FCR1" targetRef="END"/>
  </process>
