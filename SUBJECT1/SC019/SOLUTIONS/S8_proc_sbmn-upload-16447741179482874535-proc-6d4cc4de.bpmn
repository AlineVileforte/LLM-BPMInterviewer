    <sequenceFlow id="LVC1-PARCLOSE8" sourceRef="LVC1" targetRef="PARCLOSE8"/>
    <sequenceFlow id="TAC1-PARCLOSE9" sourceRef="TAC1" targetRef="PARCLOSE9"/>
