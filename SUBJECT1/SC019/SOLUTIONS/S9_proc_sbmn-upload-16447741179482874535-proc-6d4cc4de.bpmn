<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_5b41406b-af8a-4ca8-bef7-34998c955b1f" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-TAC1</outgoing>
    </startEvent>
    <task id="TAC1" name="Title administrative check">
      <incoming>Default_init-TAC1</incoming>
      <outgoing>TAC1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>TAC1-Par1</incoming>
      <outgoing>Par1-PC1</outgoing>
      <outgoing>Par1-SPRC1</outgoing>
    </parallelGateway>
    <task id="PC1" name="Parcel check">
      <incoming>Par1-PC1</incoming>
      <outgoing>PC1-Par4</outgoing>
    </task>
    <task id="SPRC1" name="Survey plan registration check">
      <incoming>Par1-SPRC1</incoming>
      <outgoing>SPRC1-NTC1</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>PC1-Par4</incoming>
      <outgoing>Par4-DALAP1</outgoing>
      <outgoing>Par4-LVC1</outgoing>
    </parallelGateway>
    <task id="DALAP1" name="Determine any land action planned">
      <incoming>Par4-DALAP1</incoming>
      <outgoing>DALAP1-PARCLOSE8</outgoing>
    </task>
    <task id="LVC1" name="Land valuation check">
      <incoming>Par4-LVC1</incoming>
      <outgoing>LVC1-PARCLOSE8</outgoing>
    </task>
    <task id="NTC1" name="Native title check">
      <incoming>SPRC1-NTC1</incoming>
      <outgoing>NTC1-PARCLOSE9</outgoing>
    </task>
    <parallelGateway id="PARCLOSE8" name="PARCLOSE8">
      <incoming>DALAP1-PARCLOSE8</incoming>
      <incoming>LVC1-PARCLOSE8</incoming>
      <outgoing>PARCLOSE8-PARCLOSE9</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE9" name="PARCLOSE9">
      <incoming>NTC1-PARCLOSE9</incoming>
      <incoming>PARCLOSE8-PARCLOSE9</incoming>
      <outgoing>PARCLOSE9-FCR1</outgoing>
    </parallelGateway>
    <task id="FCR1" name="Finalize check result">
      <incoming>PARCLOSE9-FCR1</incoming>
      <outgoing>FCR1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>FCR1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-TAC1" sourceRef="Default_init" targetRef="TAC1"/>
    <sequenceFlow id="TAC1-Par1" sourceRef="TAC1" targetRef="Par1"/>
    <sequenceFlow id="Par1-PC1" sourceRef="Par1" targetRef="PC1"/>
