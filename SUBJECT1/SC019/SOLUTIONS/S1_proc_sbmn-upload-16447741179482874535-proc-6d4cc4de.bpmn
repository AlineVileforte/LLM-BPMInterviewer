  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-NTC1</outgoing>
      <outgoing>Par0-LVC1</outgoing>
    </parallelGateway>
    <task id="NTC1" name="Native title check">
      <incoming>Par0-NTC1</incoming>
      <outgoing>NTC1-Par3</outgoing>
    </task>
    <task id="LVC1" name="Land valuation check">
      <incoming>Par0-LVC1</incoming>
      <outgoing>LVC1-Par6</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>NTC1-Par3</incoming>
      <outgoing>Par3-DALAP1</outgoing>
      <outgoing>Par3-SPRC1</outgoing>
    </parallelGateway>
    <task id="DALAP1" name="Determine any land action planned">
      <incoming>Par3-DALAP1</incoming>
      <outgoing>DALAP1-PARCLOSE9</outgoing>
    </task>
    <task id="SPRC1" name="Survey plan registration check">
      <incoming>Par3-SPRC1</incoming>
      <outgoing>SPRC1-PARCLOSE9</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>LVC1-Par6</incoming>
      <outgoing>Par6-TAC1</outgoing>
      <outgoing>Par6-PC1</outgoing>
    </parallelGateway>
    <task id="TAC1" name="Title administrative check">
      <incoming>Par6-TAC1</incoming>
      <outgoing>TAC1-PARCLOSE10</outgoing>
    </task>
    <task id="PC1" name="Parcel check">
      <incoming>Par6-PC1</incoming>
      <outgoing>PC1-PARCLOSE10</outgoing>
    </task>
    <parallelGateway id="PARCLOSE9" name="PARCLOSE9">
      <incoming>DALAP1-PARCLOSE9</incoming>
      <incoming>SPRC1-PARCLOSE9</incoming>
      <outgoing>PARCLOSE9-PARCLOSE11</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE10" name="PARCLOSE10">
      <incoming>TAC1-PARCLOSE10</incoming>
      <incoming>PC1-PARCLOSE10</incoming>
      <outgoing>PARCLOSE10-PARCLOSE11</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE11" name="PARCLOSE11">
      <incoming>PARCLOSE9-PARCLOSE11</incoming>
      <incoming>PARCLOSE10-PARCLOSE11</incoming>
      <outgoing>PARCLOSE11-FCR1</outgoing>
    </parallelGateway>
    <task id="FCR1" name="Finalize check result">
      <incoming>PARCLOSE11-FCR1</incoming>
      <outgoing>FCR1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>FCR1-END</incoming>
    </endEvent>
