<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_add208b6-6106-4011-a8a3-7f9aace3cdf2" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-LVC1</outgoing>
    </startEvent>
    <task id="LVC1" name="Land valuation check">
      <incoming>Default_init-LVC1</incoming>
      <outgoing>LVC1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>LVC1-Par1</incoming>
      <outgoing>Par1-NTC1</outgoing>
      <outgoing>Par1-SPRC1</outgoing>
    </parallelGateway>
    <task id="NTC1" name="Native title check">
      <incoming>Par1-NTC1</incoming>
      <outgoing>NTC1-Par4</outgoing>
    </task>
    <task id="SPRC1" name="Survey plan registration check">
      <incoming>Par1-SPRC1</incoming>
      <outgoing>SPRC1-DALAP1</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>NTC1-Par4</incoming>
      <outgoing>Par4-TAC1</outgoing>
      <outgoing>Par4-PC1</outgoing>
    </parallelGateway>
    <task id="TAC1" name="Title administrative check">
      <incoming>Par4-TAC1</incoming>
      <outgoing>TAC1-PARCLOSE8</outgoing>
    </task>
    <task id="PC1" name="Parcel check">
      <incoming>Par4-PC1</incoming>
      <outgoing>PC1-PARCLOSE8</outgoing>
    </task>
    <task id="DALAP1" name="Determine any land action planned">
      <incoming>SPRC1-DALAP1</incoming>
      <outgoing>DALAP1-PARCLOSE9</outgoing>
    </task>
    <parallelGateway id="PARCLOSE8" name="PARCLOSE8">
      <incoming>TAC1-PARCLOSE8</incoming>
      <incoming>PC1-PARCLOSE8</incoming>
      <outgoing>PARCLOSE8-PARCLOSE9</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE9" name="PARCLOSE9">
      <incoming>DALAP1-PARCLOSE9</incoming>
      <incoming>PARCLOSE8-PARCLOSE9</incoming>
      <outgoing>PARCLOSE9-FCR1</outgoing>
    </parallelGateway>
    <task id="FCR1" name="Finalize check result">
      <incoming>PARCLOSE9-FCR1</incoming>
      <outgoing>FCR1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>FCR1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-LVC1" sourceRef="Default_init" targetRef="LVC1"/>
    <sequenceFlow id="LVC1-Par1" sourceRef="LVC1" targetRef="Par1"/>
    <sequenceFlow id="Par1-NTC1" sourceRef="Par1" targetRef="NTC1"/>
    <sequenceFlow id="Par1-SPRC1" sourceRef="Par1" targetRef="SPRC1"/>
    <sequenceFlow id="NTC1-Par4" sourceRef="NTC1" targetRef="Par4"/>
    <sequenceFlow id="SPRC1-DALAP1" sourceRef="SPRC1" targetRef="DALAP1"/>
    <sequenceFlow id="Par4-TAC1" sourceRef="Par4" targetRef="TAC1"/>
    <sequenceFlow id="Par4-PC1" sourceRef="Par4" targetRef="PC1"/>
    <sequenceFlow id="TAC1-PARCLOSE8" sourceRef="TAC1" targetRef="PARCLOSE8"/>
    <sequenceFlow id="PC1-PARCLOSE8" sourceRef="PC1" targetRef="PARCLOSE8"/>
    <sequenceFlow id="DALAP1-PARCLOSE9" sourceRef="DALAP1" targetRef="PARCLOSE9"/>
    <sequenceFlow id="PARCLOSE8-PARCLOSE9" sourceRef="PARCLOSE8" targetRef="PARCLOSE9"/>
    <sequenceFlow id="PARCLOSE9-FCR1" sourceRef="PARCLOSE9" targetRef="FCR1"/>
    <sequenceFlow id="FCR1-END" sourceRef="FCR1" targetRef="END"/>
  </process>
