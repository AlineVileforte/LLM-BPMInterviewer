      <outgoing>CBA1-G5</outgoing>
    </task>
    <exclusiveGateway id="G5" name="G5">
      <incoming>CBA1-G5</incoming>
      <outgoing>G5-CESA1</outgoing>
      <outgoing>G5-G7</outgoing>
    </exclusiveGateway>
    <task id="CESA1" name="Choose existing shipping address">
