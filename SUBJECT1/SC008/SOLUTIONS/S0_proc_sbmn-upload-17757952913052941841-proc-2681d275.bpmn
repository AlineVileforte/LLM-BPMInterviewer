      <incoming>G5-G7</incoming>
      <outgoing>G7-ENSA1</outgoing>
      <outgoing>G7-EESA1</outgoing>
    </exclusiveGateway>
    <task id="ENSA1" name="Enter new shipping address">
      <incoming>G7-ENSA1</incoming>
      <outgoing>ENSA1-XORCLOSE8</outgoing>
    </task>
    <task id="EESA1" name="Edit exist shipping address">
      <incoming>G7-EESA1</incoming>
      <outgoing>EESA1-XORCLOSE8</outgoing>
