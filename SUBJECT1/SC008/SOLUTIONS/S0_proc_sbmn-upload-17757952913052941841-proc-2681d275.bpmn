  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-SPM1</outgoing>
    </startEvent>
    <task id="SPM1" name="Select a payment method">
      <incoming>Default_init-SPM1</incoming>
      <outgoing>SPM1-XOR_JMPAA_SPM1_RYO1</outgoing>
