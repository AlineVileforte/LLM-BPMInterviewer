    <task id="PODC1" name="Place order in default currency">
      <incoming>PARCLOSE37-PODC1</incoming>
      <outgoing>PODC1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PODC1-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_SPM1_RYO1" name="XOR_JMPAA_Select a payment method">
