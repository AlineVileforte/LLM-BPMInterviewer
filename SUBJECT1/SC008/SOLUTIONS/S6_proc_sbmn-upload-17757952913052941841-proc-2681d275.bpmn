  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-SC1</outgoing>
    </startEvent>
    <task id="SC1" name="Switch currency">
      <incoming>Default_init-SC1</incoming>
      <outgoing>SC1-CBA1</outgoing>
    </task>
    <task id="CBA1" name="Change billing address">
      <incoming>SC1-CBA1</incoming>
      <outgoing>CBA1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>CBA1-Par2</incoming>
      <outgoing>Par2-PB1</outgoing>
      <outgoing>Par2-SPM1</outgoing>
    </parallelGateway>
    <task id="PB1" name="Pay the book/s fee">
      <incoming>Par2-PB1</incoming>
      <outgoing>PB1-Par5</outgoing>
    </task>
    <task id="SPM1" name="Select a payment method">
      <incoming>Par2-SPM1</incoming>
      <outgoing>SPM1-XOR_JMPAA_SPM1_RYO1</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>PB1-Par5</incoming>
      <outgoing>Par5-OEGI1</outgoing>
      <outgoing>Par5-G3</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G3" name="G3">
      <incoming>Par5-G3</incoming>
      <outgoing>G3-CESA1</outgoing>
      <outgoing>G3-G5</outgoing>
    </exclusiveGateway>
    <task id="CESA1" name="Choose existing shipping address">
      <incoming>G3-CESA1</incoming>
      <outgoing>CESA1-XORCLOSE18</outgoing>
    </task>
    <task id="CQDI1" name="Change quantities or delete items">
      <incoming>XOR_JMPAA_SPM1_RYO1-CQDI1</incoming>
      <outgoing>CQDI1-G6</outgoing>
    </task>
    <task id="OEGI1" name="Order the exist gift items">
      <incoming>Par5-OEGI1</incoming>
      <outgoing>OEGI1-PARCLOSE28</outgoing>
    </task>
    <exclusiveGateway id="G5" name="G5">
      <incoming>G3-G5</incoming>
      <outgoing>G5-ENSA1</outgoing>
      <outgoing>G5-EESA1</outgoing>
    </exclusiveGateway>
    <task id="ENSA1" name="Enter new shipping address">
      <incoming>G5-ENSA1</incoming>
      <outgoing>ENSA1-XORCLOSE15</outgoing>
    </task>
    <task id="EESA1" name="Edit exist shipping address">
      <incoming>G5-EESA1</incoming>
      <outgoing>EESA1-XORCLOSE15</outgoing>
    </task>
    <exclusiveGateway id="G6" name="G6">
