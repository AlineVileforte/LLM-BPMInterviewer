  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-AIA1</outgoing>
    </startEvent>
    <task id="AIA1" name="ANALYZE INSURANCE AGREEMENT">
      <incoming>Default_init-AIA1</incoming>
      <outgoing>AIA1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>AIA1-G0</incoming>
      <outgoing>G0-SOEH1</outgoing>
      <outgoing>G0-OIH1</outgoing>
    </exclusiveGateway>
    <task id="SOEH1" name="SEND OUT OFFER FOR EMERGENCY HELP">
      <incoming>G0-SOEH1</incoming>
      <outgoing>SOEH1-XORCLOSE8</outgoing>
    </task>
    <task id="OIH1" name="OFFER IMMEDIATE HELP">
      <incoming>G0-OIH1</incoming>
      <outgoing>OIH1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>OIH1-G1</incoming>
      <outgoing>G1-DIA1</outgoing>
      <outgoing>G1-ARN1</outgoing>
    </exclusiveGateway>
    <task id="DIA1" name="DO INTERNAL ACCOUNTING">
      <incoming>G1-DIA1</incoming>
      <outgoing>DIA1-XORCLOSE7</outgoing>
    </task>
    <task id="ARN1" name="ASK FOR REJECTION NOTIFICATIO">
      <incoming>G1-ARN1</incoming>
      <outgoing>ARN1-XORCLOSE7</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE7" name="XORCLOSE7">
      <incoming>DIA1-XORCLOSE7</incoming>
      <incoming>ARN1-XORCLOSE7</incoming>
      <outgoing>XORCLOSE7-XORCLOSE8</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE8" name="XORCLOSE8">
      <incoming>SOEH1-XORCLOSE8</incoming>
      <incoming>XORCLOSE7-XORCLOSE8</incoming>
      <outgoing>XORCLOSE8-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE8-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-AIA1" sourceRef="Default_init" targetRef="AIA1"/>
