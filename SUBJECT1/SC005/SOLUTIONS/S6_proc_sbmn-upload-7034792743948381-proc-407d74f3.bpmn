<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_86c15d93-9e53-40f4-8218-513540aca378" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CCIL1</outgoing>
    </startEvent>
    <task id="CCIL1" name="Check Current Inventory Level">
      <incoming>Default_init-CCIL1</incoming>
      <outgoing>CCIL1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CCIL1-G0</incoming>
      <outgoing>G0-CPO1</outgoing>
      <outgoing>G0-XORCLOSE4</outgoing>
    </exclusiveGateway>
    <task id="CPO1" name="Create Purchase Order">
      <incoming>G0-CPO1</incoming>
      <outgoing>CPO1-XORCLOSE4</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE4" name="XORCLOSE4">
      <incoming>G0-XORCLOSE4</incoming>
      <incoming>CPO1-XORCLOSE4</incoming>
      <outgoing>XORCLOSE4-XOR_JMPBB_RWPO1_RPO1</outgoing>
    </exclusiveGateway>
    <task id="RPO1" name="Review Purchase Order">
      <incoming>XOR_JMPBB_RWPO1_RPO1-RPO1</incoming>
      <outgoing>RPO1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>RPO1-G1</incoming>
      <outgoing>G1-APO1</outgoing>
      <outgoing>G1-RWPO1</outgoing>
    </exclusiveGateway>
    <task id="RWPO1" name="Rework Purchase Order">
      <incoming>G1-RWPO1</incoming>
      <outgoing>RWPO1-XOR_JMPAA_RWPO1_RPO1</outgoing>
    </task>
    <task id="APO1" name="Accept Purchase Order">
      <incoming>G1-APO1</incoming>
      <outgoing>APO1-RPF1</outgoing>
    </task>
    <task id="RPF1" name="Reserve Purchase Funds">
      <incoming>APO1-RPF1</incoming>
      <outgoing>RPF1-SPOS1</outgoing>
    </task>
    <task id="SPOS1" name="Send Purchase Order to Supplier">
      <incoming>RPF1-SPOS1</incoming>
      <outgoing>SPOS1-Par11</outgoing>
    </task>
    <parallelGateway id="Par11" name="PAR">
      <incoming>SPOS1-Par11</incoming>
      <outgoing>Par11-ROPS1</outgoing>
      <outgoing>Par11-ROI1</outgoing>
    </parallelGateway>
    <task id="ROPS1" name="Receive Order Packing Slip">
      <incoming>Par11-ROPS1</incoming>
      <outgoing>ROPS1-ROPS2</outgoing>
    </task>
    <task id="ROI1" name="Receive Order Invoice">
      <incoming>Par11-ROI1</incoming>
      <outgoing>ROI1-ROI2</outgoing>
    </task>
    <task id="ROPS2" name="Record Order Packing Slip">
      <incoming>ROPS1-ROPS2</incoming>
      <outgoing>ROPS2-PARCLOSE16</outgoing>
    </task>
    <task id="ROI2" name="Record Order Invoice">
      <incoming>ROI1-ROI2</incoming>
      <outgoing>ROI2-PARCLOSE16</outgoing>
    </task>
    <parallelGateway id="PARCLOSE16" name="PARCLOSE16">
      <incoming>ROPS2-PARCLOSE16</incoming>
      <incoming>ROI2-PARCLOSE16</incoming>
      <outgoing>PARCLOSE16-RF1</outgoing>
    </parallelGateway>
    <task id="RF1" name="Release Funds">
      <incoming>PARCLOSE16-RF1</incoming>
      <outgoing>RF1-IPS1</outgoing>
    </task>
    <task id="IPS1" name="Issue Payment to Supplier">
      <incoming>RF1-IPS1</incoming>
      <outgoing>IPS1-XORCLOSE19</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE19" name="XORCLOSE19">
      <incoming>IPS1-XORCLOSE19</incoming>
      <incoming>XOR_JMPAA_RWPO1_RPO1-XORCLOSE19</incoming>
      <outgoing>XORCLOSE19-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE19-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_RWPO1_RPO1" name="XOR_JMPAA_Rework Purchase Order">
      <incoming>RWPO1-XOR_JMPAA_RWPO1_RPO1</incoming>
      <outgoing>XOR_JMPAA_RWPO1_RPO1-XORCLOSE19</outgoing>
      <outgoing>XOR_JMPAA_RWPO1_RPO1-XOR_JMPBB_RWPO1_RPO1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_RWPO1_RPO1" name="XOR_JMPBB_Review Purchase Order">
      <incoming>XORCLOSE4-XOR_JMPBB_RWPO1_RPO1</incoming>
      <incoming>XOR_JMPAA_RWPO1_RPO1-XOR_JMPBB_RWPO1_RPO1</incoming>
      <outgoing>XOR_JMPBB_RWPO1_RPO1-RPO1</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Default_init-CCIL1" sourceRef="Default_init" targetRef="CCIL1"/>
    <sequenceFlow id="CCIL1-G0" sourceRef="CCIL1" targetRef="G0"/>
    <sequenceFlow id="G0-CPO1" sourceRef="G0" targetRef="CPO1"/>
    <sequenceFlow id="G0-XORCLOSE4" sourceRef="G0" targetRef="XORCLOSE4"/>
    <sequenceFlow id="CPO1-XORCLOSE4" sourceRef="CPO1" targetRef="XORCLOSE4"/>
    <sequenceFlow id="XORCLOSE4-XOR_JMPBB_RWPO1_RPO1" sourceRef="XORCLOSE4" targetRef="XOR_JMPBB_RWPO1_RPO1"/>
    <sequenceFlow id="RPO1-G1" sourceRef="RPO1" targetRef="G1"/>
    <sequenceFlow id="G1-APO1" sourceRef="G1" targetRef="APO1"/>
    <sequenceFlow id="G1-RWPO1" sourceRef="G1" targetRef="RWPO1"/>
    <sequenceFlow id="RWPO1-XOR_JMPAA_RWPO1_RPO1" sourceRef="RWPO1" targetRef="XOR_JMPAA_RWPO1_RPO1"/>
    <sequenceFlow id="APO1-RPF1" sourceRef="APO1" targetRef="RPF1"/>
    <sequenceFlow id="RPF1-SPOS1" sourceRef="RPF1" targetRef="SPOS1"/>
    <sequenceFlow id="SPOS1-Par11" sourceRef="SPOS1" targetRef="Par11"/>
    <sequenceFlow id="Par11-ROPS1" sourceRef="Par11" targetRef="ROPS1"/>
    <sequenceFlow id="Par11-ROI1" sourceRef="Par11" targetRef="ROI1"/>
    <sequenceFlow id="ROPS1-ROPS2" sourceRef="ROPS1" targetRef="ROPS2"/>
    <sequenceFlow id="ROI1-ROI2" sourceRef="ROI1" targetRef="ROI2"/>
    <sequenceFlow id="ROPS2-PARCLOSE16" sourceRef="ROPS2" targetRef="PARCLOSE16"/>
    <sequenceFlow id="ROI2-PARCLOSE16" sourceRef="ROI2" targetRef="PARCLOSE16"/>
    <sequenceFlow id="PARCLOSE16-RF1" sourceRef="PARCLOSE16" targetRef="RF1"/>
    <sequenceFlow id="RF1-IPS1" sourceRef="RF1" targetRef="IPS1"/>
    <sequenceFlow id="IPS1-XORCLOSE19" sourceRef="IPS1" targetRef="XORCLOSE19"/>
    <sequenceFlow id="XORCLOSE19-END" sourceRef="XORCLOSE19" targetRef="END"/>
    <sequenceFlow id="XOR_JMPAA_RWPO1_RPO1-XORCLOSE19" sourceRef="XOR_JMPAA_RWPO1_RPO1" targetRef="XORCLOSE19"/>
    <sequenceFlow id="XOR_JMPAA_RWPO1_RPO1-XOR_JMPBB_RWPO1_RPO1" sourceRef="XOR_JMPAA_RWPO1_RPO1" targetRef="XOR_JMPBB_RWPO1_RPO1"/>
    <sequenceFlow id="XOR_JMPBB_RWPO1_RPO1-RPO1" sourceRef="XOR_JMPBB_RWPO1_RPO1" targetRef="RPO1"/>
  </process>
