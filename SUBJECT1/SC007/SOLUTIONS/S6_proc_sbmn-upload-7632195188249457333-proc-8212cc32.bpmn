  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-PI1</outgoing>
    </startEvent>
    <task id="PI1" name="Preparing Invoice">
      <incoming>Default_init-PI1</incoming>
      <outgoing>PI1-SIC1</outgoing>
    </task>
    <task id="SIC1" name="Send the Invoice to Customer">
      <incoming>PI1-SIC1</incoming>
      <outgoing>SIC1-CC1</outgoing>
    </task>
    <task id="CC1" name="Check Customer">
      <incoming>SIC1-CC1</incoming>
      <outgoing>CC1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>CC1-Par3</incoming>
      <outgoing>Par3-G0</outgoing>
      <outgoing>Par3-XOR_JMPBB_CR1_CFP1</outgoing>
    </parallelGateway>
    <task id="CFP1" name="Check for Payment">
