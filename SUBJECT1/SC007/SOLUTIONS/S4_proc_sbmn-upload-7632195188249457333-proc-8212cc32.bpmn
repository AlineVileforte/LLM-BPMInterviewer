  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CC1</outgoing>
    </startEvent>
    <task id="CC1" name="Check Customer">
      <incoming>Default_init-CC1</incoming>
      <outgoing>CC1-PI1</outgoing>
    </task>
    <task id="PI1" name="Preparing Invoice">
      <incoming>CC1-PI1</incoming>
      <outgoing>PI1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>PI1-Par2</incoming>
      <outgoing>Par2-SIC1</outgoing>
      <outgoing>Par2-G1</outgoing>
    </parallelGateway>
    <task id="SIC1" name="Send the Invoice to Customer">
      <incoming>Par2-SIC1</incoming>
      <outgoing>SIC1-XOR_JMPBB_CR1_CFP1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par2-G1</incoming>
      <outgoing>G1-CPH1</outgoing>
      <outgoing>G1-CCT1</outgoing>
    </exclusiveGateway>
    <task id="CPH1" name="Check Payment History">
      <incoming>G1-CPH1</incoming>
      <outgoing>CPH1-XORCLOSE11</outgoing>
    </task>
    <task id="CFP1" name="Check for Payment">
      <incoming>XOR_JMPBB_CR1_CFP1-CFP1</incoming>
      <outgoing>CFP1-PARCLOSE12</outgoing>
    </task>
    <task id="CCT1" name="Check Customer Type">
      <incoming>G1-CCT1</incoming>
      <outgoing>CCT1-XORCLOSE11</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE11" name="XORCLOSE11">
      <incoming>CPH1-XORCLOSE11</incoming>
      <incoming>CCT1-XORCLOSE11</incoming>
      <outgoing>XORCLOSE11-PARCLOSE12</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE12" name="PARCLOSE12">
      <incoming>CFP1-PARCLOSE12</incoming>
      <incoming>XORCLOSE11-PARCLOSE12</incoming>
      <outgoing>PARCLOSE12-G2</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G2" name="G2">
      <incoming>PARCLOSE12-G2</incoming>
      <outgoing>G2-DM1</outgoing>
      <outgoing>G2-CNC1</outgoing>
    </exclusiveGateway>
    <task id="DM1" name="Declining Message">
      <incoming>G2-DM1</incoming>
      <outgoing>DM1-XORCLOSE34</outgoing>
    </task>
    <task id="CNC1" name="Create new Customer">
      <incoming>G2-CNC1</incoming>
      <outgoing>CNC1-G3</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>CNC1-G3</incoming>
      <outgoing>G3-CA1</outgoing>
      <outgoing>G3-XORCLOSE33</outgoing>
    </exclusiveGateway>
    <task id="CA1" name="Check Availability">
      <incoming>G3-CA1</incoming>
      <outgoing>CA1-G4</outgoing>
    </task>
    <exclusiveGateway id="G4" name="G4">
      <incoming>CA1-G4</incoming>
      <outgoing>G4-PMG1</outgoing>
      <outgoing>G4-XORCLOSE31</outgoing>
    </exclusiveGateway>
    <task id="PMG1" name="Producing missing goods">
      <incoming>G4-PMG1</incoming>
      <outgoing>PMG1-GRD1</outgoing>
    </task>
    <task id="GRD1" name="getting ready for delivery">
      <incoming>PMG1-GRD1</incoming>
      <outgoing>GRD1-PTG1</outgoing>
    </task>
    <task id="PTG1" name="Pack the Goods">
      <incoming>GRD1-PTG1</incoming>
      <outgoing>PTG1-DTG1</outgoing>
    </task>
    <task id="DTG1" name="Deliver the Goods">
      <incoming>PTG1-DTG1</incoming>
      <outgoing>DTG1-G6</outgoing>
    </task>
    <exclusiveGateway id="G6" name="G6">
      <incoming>DTG1-G6</incoming>
      <outgoing>G6-CO1</outgoing>
      <outgoing>G6-CR1</outgoing>
