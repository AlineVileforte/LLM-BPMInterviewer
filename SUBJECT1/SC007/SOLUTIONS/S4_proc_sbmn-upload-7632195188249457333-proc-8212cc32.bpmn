      <outgoing>XORCLOSE33-XORCLOSE34</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE34" name="XORCLOSE34">
      <incoming>DM1-XORCLOSE34</incoming>
      <incoming>XORCLOSE33-XORCLOSE34</incoming>
      <outgoing>XORCLOSE34-G7</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G7" name="G7">
      <incoming>XORCLOSE34-G7</incoming>
      <outgoing>G7-DP1</outgoing>
      <outgoing>G7-XORCLOSE38</outgoing>
    </exclusiveGateway>
    <task id="DP1" name="Dunning Process">
      <incoming>G7-DP1</incoming>
      <outgoing>DP1-XORCLOSE38</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE38" name="XORCLOSE38">
      <incoming>G7-XORCLOSE38</incoming>
      <incoming>DP1-XORCLOSE38</incoming>
      <outgoing>XORCLOSE38-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE38-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_CR1_CFP1" name="XOR_JMPAA_Checking the reminders">
