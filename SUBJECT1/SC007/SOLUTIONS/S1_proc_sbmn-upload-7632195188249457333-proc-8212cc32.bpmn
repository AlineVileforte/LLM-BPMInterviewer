  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-PI1</outgoing>
    </startEvent>
    <task id="PI1" name="Preparing Invoice">
      <incoming>Default_init-PI1</incoming>
      <outgoing>PI1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>PI1-Par1</incoming>
      <outgoing>Par1-CC1</outgoing>
      <outgoing>Par1-SIC1</outgoing>
    </parallelGateway>
    <task id="CC1" name="Check Customer">
      <incoming>Par1-CC1</incoming>
      <outgoing>CC1-Par4</outgoing>
    </task>
    <task id="SIC1" name="Send the Invoice to Customer">
      <incoming>Par1-SIC1</incoming>
      <outgoing>SIC1-CCT1__1</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>CC1-Par4</incoming>
      <outgoing>Par4-DM1</outgoing>
      <outgoing>Par4-CNC1</outgoing>
