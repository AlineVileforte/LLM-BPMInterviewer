  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CC1</outgoing>
    </startEvent>
    <task id="CC1" name="Check Customer">
      <incoming>Default_init-CC1</incoming>
      <outgoing>CC1-PI1</outgoing>
    </task>
    <task id="PI1" name="Preparing Invoice">
      <incoming>CC1-PI1</incoming>
      <outgoing>PI1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>PI1-G1</incoming>
      <outgoing>G1-CPH1</outgoing>
      <outgoing>G1-CCT1</outgoing>
    </exclusiveGateway>
    <task id="CPH1" name="Check Payment History">
      <incoming>G1-CPH1</incoming>
      <outgoing>CPH1-XORCLOSE6</outgoing>
    </task>
    <task id="CCT1" name="Check Customer Type">
      <incoming>G1-CCT1</incoming>
      <outgoing>CCT1-XORCLOSE6</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE6" name="XORCLOSE6">
      <incoming>CPH1-XORCLOSE6</incoming>
      <incoming>CCT1-XORCLOSE6</incoming>
      <outgoing>XORCLOSE6-SIC1</outgoing>
    </exclusiveGateway>
    <task id="SIC1" name="Send the Invoice to Customer">
      <incoming>XORCLOSE6-SIC1</incoming>
      <outgoing>SIC1-XOR_JMPBB_CR1_CFP1</outgoing>
    </task>
    <task id="CFP1" name="Check for Payment">
      <incoming>XOR_JMPBB_CR1_CFP1-CFP1</incoming>
      <outgoing>CFP1-G2</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>CFP1-G2</incoming>
      <outgoing>G2-DM1</outgoing>
      <outgoing>G2-CNC1</outgoing>
    </exclusiveGateway>
    <task id="DM1" name="Declining Message">
      <incoming>G2-DM1</incoming>
      <outgoing>DM1-XORCLOSE32</outgoing>
    </task>
    <task id="CNC1" name="Create new Customer">
      <incoming>G2-CNC1</incoming>
      <outgoing>CNC1-G3</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>CNC1-G3</incoming>
      <outgoing>G3-CA1</outgoing>
      <outgoing>G3-XORCLOSE31</outgoing>
