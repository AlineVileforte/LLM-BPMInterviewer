  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-CC1</outgoing>
      <outgoing>Par0-PI1</outgoing>
    </parallelGateway>
    <task id="CC1" name="Check Customer">
      <incoming>Par0-CC1</incoming>
      <outgoing>CC1-DM1</outgoing>
    </task>
    <task id="PI1" name="Preparing Invoice">
      <incoming>Par0-PI1</incoming>
      <outgoing>PI1-CCT1__1</outgoing>
    </task>
    <task id="DM1" name="Declining Message">
      <incoming>CC1-DM1</incoming>
      <outgoing>DM1-Par7</outgoing>
    </task>
    <task id="CCT1__1" name="Check Customer Type">
      <incoming>PI1-CCT1__1</incoming>
      <outgoing>CCT1__1-SIC1</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>DM1-Par7</incoming>
      <outgoing>Par7-CNC1</outgoing>
      <outgoing>Par7-G1</outgoing>
    </parallelGateway>
    <task id="CNC1" name="Create new Customer">
      <incoming>Par7-CNC1</incoming>
      <outgoing>CNC1-G2</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par7-G1</incoming>
      <outgoing>G1-CPH1</outgoing>
      <outgoing>G1-CCT1__2</outgoing>
    </exclusiveGateway>
    <task id="CPH1" name="Check Payment History">
      <incoming>G1-CPH1</incoming>
      <outgoing>CPH1-XORCLOSE22</outgoing>
    </task>
    <task id="SIC1" name="Send the Invoice to Customer">
      <incoming>CCT1__1-SIC1</incoming>
      <outgoing>SIC1-XOR_JMPBB_CR1_CFP1</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>CNC1-G2</incoming>
      <outgoing>G2-CA1</outgoing>
      <outgoing>G2-XORCLOSE36</outgoing>
    </exclusiveGateway>
    <task id="CA1" name="Check Availability">
      <incoming>G2-CA1</incoming>
      <outgoing>CA1-G3</outgoing>
    </task>
    <task id="CCT1__2" name="Check Customer Type">
      <incoming>G1-CCT1__2</incoming>
      <outgoing>CCT1__2-XORCLOSE22</outgoing>
    </task>
    <task id="CFP1" name="Check for Payment">
      <incoming>XOR_JMPBB_CR1_CFP1-CFP1</incoming>
      <outgoing>CFP1-SCC1</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>CA1-G3</incoming>
      <outgoing>G3-PMG1</outgoing>
      <outgoing>G3-XORCLOSE34</outgoing>
    </exclusiveGateway>
    <task id="PMG1" name="Producing missing goods">
      <incoming>G3-PMG1</incoming>
      <outgoing>PMG1-GRD1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE22" name="XORCLOSE22">
      <incoming>CPH1-XORCLOSE22</incoming>
      <incoming>CCT1__2-XORCLOSE22</incoming>
      <outgoing>XORCLOSE22-PARCLOSE37</outgoing>
    </exclusiveGateway>
    <task id="SCC1" name="Sending Confirmation to Customer">
      <incoming>CFP1-SCC1</incoming>
      <outgoing>SCC1-CR1</outgoing>
    </task>
    <task id="GRD1" name="getting ready for delivery">
      <incoming>PMG1-GRD1</incoming>
      <outgoing>GRD1-PTG1</outgoing>
    </task>
    <task id="CR1" name="Checking the reminders">
      <incoming>SCC1-CR1</incoming>
      <outgoing>CR1-XOR_JMPAA_CR1_CFP1</outgoing>
    </task>
    <task id="PTG1" name="Pack the Goods">
      <incoming>GRD1-PTG1</incoming>
      <outgoing>PTG1-DTG1</outgoing>
    </task>
    <task id="DP1" name="Dunning Process">
      <incoming>XOR_JMPAA_CR1_CFP1-DP1</incoming>
      <outgoing>DP1-CO1</outgoing>
    </task>
    <task id="DTG1" name="Deliver the Goods">
      <incoming>PTG1-DTG1</incoming>
      <outgoing>DTG1-XORCLOSE34</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE34" name="XORCLOSE34">
      <incoming>G3-XORCLOSE34</incoming>
      <incoming>DTG1-XORCLOSE34</incoming>
      <outgoing>XORCLOSE34-XORCLOSE36</outgoing>
    </exclusiveGateway>
    <task id="CO1" name="closing order">
      <incoming>DP1-CO1</incoming>
      <outgoing>CO1-PARCLOSE39</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE36" name="XORCLOSE36">
      <incoming>G2-XORCLOSE36</incoming>
      <incoming>XORCLOSE34-XORCLOSE36</incoming>
      <outgoing>XORCLOSE36-PARCLOSE37</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE37" name="PARCLOSE37">
      <incoming>XORCLOSE22-PARCLOSE37</incoming>
      <incoming>XORCLOSE36-PARCLOSE37</incoming>
      <outgoing>PARCLOSE37-PARCLOSE39</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE39" name="PARCLOSE39">
      <incoming>CO1-PARCLOSE39</incoming>
      <incoming>PARCLOSE37-PARCLOSE39</incoming>
      <outgoing>PARCLOSE39-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE39-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_CR1_CFP1" name="XOR_JMPAA_Checking the reminders">
