  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-PI1</outgoing>
    </startEvent>
    <task id="PI1" name="Preparing Invoice">
      <incoming>Default_init-PI1</incoming>
      <outgoing>PI1-CC1</outgoing>
    </task>
    <task id="CC1" name="Check Customer">
      <incoming>PI1-CC1</incoming>
      <outgoing>CC1-SIC1</outgoing>
    </task>
    <task id="SIC1" name="Send the Invoice to Customer">
