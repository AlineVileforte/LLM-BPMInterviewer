    <sequenceFlow id="NS1-XOR_JMPAA_NS1_NS1" sourceRef="NS1" targetRef="XOR_JMPAA_NS1_NS1"/>
    <sequenceFlow id="BOP1-Par23" sourceRef="BOP1" targetRef="Par23"/>
    <sequenceFlow id="Par23-CP1" sourceRef="Par23" targetRef="CP1"/>
    <sequenceFlow id="Par23-CO1" sourceRef="Par23" targetRef="CO1"/>
