<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_cf671d8e-e5a8-4948-9b5b-d3ba94cd4cc8" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-APC1</outgoing>
    </startEvent>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Default_init-APC1</incoming>
      <outgoing>APC1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>APC1-Par1</incoming>
      <outgoing>Par1-DSC1</outgoing>
      <outgoing>Par1-PP1</outgoing>
    </parallelGateway>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>Par1-DSC1</incoming>
      <outgoing>DSC1-NWS1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>Par1-PP1</incoming>
      <outgoing>PP1-PPL1</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>PP1-PPL1</incoming>
      <outgoing>PPL1-Par7</outgoing>
    </task>
    <task id="NWS1" name="Negotiate with Suppliers">
      <incoming>DSC1-NWS1</incoming>
      <outgoing>NWS1-PARCLOSE13</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>PPL1-Par7</incoming>
      <outgoing>Par7-MTD1</outgoing>
      <outgoing>Par7-PI1</outgoing>
    </parallelGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>Par7-MTD1</incoming>
      <outgoing>MTD1-CTD1</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>Par7-PI1</incoming>
      <outgoing>PI1-PMT1</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>MTD1-CTD1</incoming>
      <outgoing>CTD1-PARCLOSE12</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>PI1-PMT1</incoming>
      <outgoing>PMT1-PARCLOSE12</outgoing>
    </task>
    <parallelGateway id="PARCLOSE12" name="PARCLOSE12">
      <incoming>CTD1-PARCLOSE12</incoming>
      <incoming>PMT1-PARCLOSE12</incoming>
      <outgoing>PARCLOSE12-PARCLOSE13</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE13" name="PARCLOSE13">
      <incoming>NWS1-PARCLOSE13</incoming>
      <incoming>PARCLOSE12-PARCLOSE13</incoming>
      <outgoing>PARCLOSE13-FV1</outgoing>
    </parallelGateway>
    <task id="FV1" name="Final Validation">
      <incoming>PARCLOSE13-FV1</incoming>
      <outgoing>FV1-ALSP1</outgoing>
    </task>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>FV1-ALSP1</incoming>
      <outgoing>ALSP1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>ALSP1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-APC1" sourceRef="Default_init" targetRef="APC1"/>
    <sequenceFlow id="APC1-Par1" sourceRef="APC1" targetRef="Par1"/>
    <sequenceFlow id="Par1-DSC1" sourceRef="Par1" targetRef="DSC1"/>
    <sequenceFlow id="Par1-PP1" sourceRef="Par1" targetRef="PP1"/>
