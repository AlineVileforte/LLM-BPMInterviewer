    <sequenceFlow id="NWS1-PARCLOSE13" sourceRef="NWS1" targetRef="PARCLOSE13"/>
    <sequenceFlow id="Par7-MTD1" sourceRef="Par7" targetRef="MTD1"/>
    <sequenceFlow id="Par7-PI1" sourceRef="Par7" targetRef="PI1"/>
    <sequenceFlow id="MTD1-CTD1" sourceRef="MTD1" targetRef="CTD1"/>
    <sequenceFlow id="PI1-PMT1" sourceRef="PI1" targetRef="PMT1"/>
    <sequenceFlow id="CTD1-PARCLOSE12" sourceRef="CTD1" targetRef="PARCLOSE12"/>
    <sequenceFlow id="PMT1-PARCLOSE12" sourceRef="PMT1" targetRef="PARCLOSE12"/>
    <sequenceFlow id="PARCLOSE12-PARCLOSE13" sourceRef="PARCLOSE12" targetRef="PARCLOSE13"/>
    <sequenceFlow id="PARCLOSE13-FV1" sourceRef="PARCLOSE13" targetRef="FV1"/>
    <sequenceFlow id="FV1-ALSP1" sourceRef="FV1" targetRef="ALSP1"/>
    <sequenceFlow id="ALSP1-END" sourceRef="ALSP1" targetRef="END"/>
  </process>
