<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_4e8ed119-7b55-47e8-927f-1c282141cd81" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-APC1</outgoing>
    </startEvent>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Default_init-APC1</incoming>
      <outgoing>APC1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>APC1-Par1</incoming>
      <outgoing>Par1-DSC1</outgoing>
      <outgoing>Par1-PP1</outgoing>
    </parallelGateway>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>Par1-DSC1</incoming>
      <outgoing>DSC1-NWS1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>Par1-PP1</incoming>
      <outgoing>PP1-CTD1</outgoing>
    </task>
    <task id="NWS1" name="Negotiate with Suppliers">
      <incoming>DSC1-NWS1</incoming>
      <outgoing>NWS1-PARCLOSE16</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>PP1-CTD1</incoming>
      <outgoing>CTD1-Par9</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>CTD1-Par9</incoming>
      <outgoing>Par9-PPL1</outgoing>
      <outgoing>Par9-PMT1</outgoing>
    </parallelGateway>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>Par9-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>Par9-PMT1</incoming>
      <outgoing>PMT1-FV1</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-MTD1</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>PMT1-FV1</incoming>
      <outgoing>FV1-PARCLOSE15</outgoing>
    </task>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>PI1-MTD1</incoming>
      <outgoing>MTD1-PARCLOSE15</outgoing>
    </task>
    <parallelGateway id="PARCLOSE15" name="PARCLOSE15">
      <incoming>FV1-PARCLOSE15</incoming>
      <incoming>MTD1-PARCLOSE15</incoming>
      <outgoing>PARCLOSE15-PARCLOSE16</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE16" name="PARCLOSE16">
      <incoming>NWS1-PARCLOSE16</incoming>
      <incoming>PARCLOSE15-PARCLOSE16</incoming>
      <outgoing>PARCLOSE16-ALSP1</outgoing>
    </parallelGateway>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>PARCLOSE16-ALSP1</incoming>
      <outgoing>ALSP1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>ALSP1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-APC1" sourceRef="Default_init" targetRef="APC1"/>
    <sequenceFlow id="APC1-Par1" sourceRef="APC1" targetRef="Par1"/>
