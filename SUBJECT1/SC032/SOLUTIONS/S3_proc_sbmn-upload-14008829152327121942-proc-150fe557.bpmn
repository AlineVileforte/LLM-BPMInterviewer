<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_ae8eca24-8d15-4397-8ab1-449ba20a2cba" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-APC1</outgoing>
    </startEvent>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Default_init-APC1</incoming>
      <outgoing>APC1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>APC1-Par1</incoming>
      <outgoing>Par1-DSC1</outgoing>
      <outgoing>Par1-PP1</outgoing>
    </parallelGateway>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>Par1-DSC1</incoming>
      <outgoing>DSC1-NWS1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>Par1-PP1</incoming>
      <outgoing>PP1-Par5</outgoing>
    </task>
    <task id="NWS1" name="Negotiate with Suppliers">
      <incoming>DSC1-NWS1</incoming>
      <outgoing>NWS1-PARCLOSE17</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>PP1-Par5</incoming>
      <outgoing>Par5-PPL1</outgoing>
      <outgoing>Par5-PMT1</outgoing>
    </parallelGateway>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>Par5-PPL1</incoming>
      <outgoing>PPL1-Par8</outgoing>
    </task>
    <parallelGateway id="Par8" name="PAR">
      <incoming>PPL1-Par8</incoming>
      <outgoing>Par8-PI1</outgoing>
      <outgoing>Par8-CTD1</outgoing>
    </parallelGateway>
    <task id="PI1" name="Perform Inspections">
      <incoming>Par8-PI1</incoming>
      <outgoing>PI1-MTD1</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>Par8-CTD1</incoming>
      <outgoing>CTD1-PARCLOSE14</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>Par5-PMT1</incoming>
      <outgoing>PMT1-FV1</outgoing>
    </task>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>PI1-MTD1</incoming>
      <outgoing>MTD1-PARCLOSE14</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>PMT1-FV1</incoming>
      <outgoing>FV1-ALSP1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE14" name="PARCLOSE14">
      <incoming>CTD1-PARCLOSE14</incoming>
      <incoming>MTD1-PARCLOSE14</incoming>
      <outgoing>PARCLOSE14-PARCLOSE16</outgoing>
    </parallelGateway>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>FV1-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE16</outgoing>
    </task>
    <parallelGateway id="PARCLOSE16" name="PARCLOSE16">
      <incoming>PARCLOSE14-PARCLOSE16</incoming>
      <incoming>ALSP1-PARCLOSE16</incoming>
      <outgoing>PARCLOSE16-PARCLOSE17</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>NWS1-PARCLOSE17</incoming>
      <incoming>PARCLOSE16-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE17-END</incoming>
    </endEvent>
