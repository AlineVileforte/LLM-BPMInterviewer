<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_8adf0322-3b69-4bbb-a863-2bbe8a9a0c16" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-APC1</outgoing>
    </startEvent>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Default_init-APC1</incoming>
      <outgoing>APC1-PP1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>APC1-PP1</incoming>
      <outgoing>PP1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>PP1-Par2</incoming>
      <outgoing>Par2-PPL1</outgoing>
      <outgoing>Par2-G0</outgoing>
    </parallelGateway>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>Par2-PPL1</incoming>
      <outgoing>PPL1-DSC1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par2-G0</incoming>
      <outgoing>G0-MTD1</outgoing>
      <outgoing>G0-XORCLOSE12</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G0-MTD1</incoming>
      <outgoing>MTD1-ALSP1</outgoing>
    </task>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>PPL1-DSC1</incoming>
      <outgoing>DSC1-Par9</outgoing>
    </task>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>MTD1-ALSP1</incoming>
      <outgoing>ALSP1-XORCLOSE12</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>DSC1-Par9</incoming>
      <outgoing>Par9-NWS1</outgoing>
      <outgoing>Par9-PI1</outgoing>
    </parallelGateway>
    <task id="NWS1" name="Negotiate with Suppliers">
      <incoming>Par9-NWS1</incoming>
      <outgoing>NWS1-CTD1</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>Par9-PI1</incoming>
      <outgoing>PI1-PMT1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE12" name="XORCLOSE12">
      <incoming>G0-XORCLOSE12</incoming>
      <incoming>ALSP1-XORCLOSE12</incoming>
      <outgoing>XORCLOSE12-PARCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>NWS1-CTD1</incoming>
      <outgoing>CTD1-PARCLOSE16</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>PI1-PMT1</incoming>
      <outgoing>PMT1-FV1</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>PMT1-FV1</incoming>
      <outgoing>FV1-PARCLOSE16</outgoing>
    </task>
    <parallelGateway id="PARCLOSE16" name="PARCLOSE16">
      <incoming>CTD1-PARCLOSE16</incoming>
      <incoming>FV1-PARCLOSE16</incoming>
      <outgoing>PARCLOSE16-PARCLOSE17</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>XORCLOSE12-PARCLOSE17</incoming>
      <incoming>PARCLOSE16-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE17-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-APC1" sourceRef="Default_init" targetRef="APC1"/>
