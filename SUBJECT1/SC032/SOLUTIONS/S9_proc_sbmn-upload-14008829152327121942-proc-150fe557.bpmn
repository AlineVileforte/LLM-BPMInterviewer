<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_fdbeb1d0-ebcf-4ad6-b1dd-1f20367020b9" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-APC1</outgoing>
    </startEvent>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Default_init-APC1</incoming>
      <outgoing>APC1-DSC1</outgoing>
    </task>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>APC1-DSC1</incoming>
      <outgoing>DSC1-PP1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>DSC1-PP1</incoming>
      <outgoing>PP1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>PP1-Par3</incoming>
      <outgoing>Par3-CTD1</outgoing>
      <outgoing>Par3-G0</outgoing>
    </parallelGateway>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>Par3-CTD1</incoming>
      <outgoing>CTD1-Par8</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par3-G0</incoming>
      <outgoing>G0-MTD1</outgoing>
      <outgoing>G0-XORCLOSE14</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G0-MTD1</incoming>
      <outgoing>MTD1-ALSP1</outgoing>
    </task>
    <parallelGateway id="Par8" name="PAR">
      <incoming>CTD1-Par8</incoming>
      <outgoing>Par8-NWS1</outgoing>
      <outgoing>Par8-PMT1</outgoing>
    </parallelGateway>
    <task id="NWS1" name="Negotiate with Suppliers">
      <incoming>Par8-NWS1</incoming>
      <outgoing>NWS1-PPL1</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>Par8-PMT1</incoming>
      <outgoing>PMT1-FV1</outgoing>
    </task>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>MTD1-ALSP1</incoming>
      <outgoing>ALSP1-XORCLOSE14</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>NWS1-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>PMT1-FV1</incoming>
      <outgoing>FV1-PARCLOSE16</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>G0-XORCLOSE14</incoming>
      <incoming>ALSP1-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-PARCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-PARCLOSE16</outgoing>
    </task>
    <parallelGateway id="PARCLOSE16" name="PARCLOSE16">
      <incoming>FV1-PARCLOSE16</incoming>
      <incoming>PI1-PARCLOSE16</incoming>
      <outgoing>PARCLOSE16-PARCLOSE17</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>XORCLOSE14-PARCLOSE17</incoming>
      <incoming>PARCLOSE16-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE17-END</incoming>
    </endEvent>
