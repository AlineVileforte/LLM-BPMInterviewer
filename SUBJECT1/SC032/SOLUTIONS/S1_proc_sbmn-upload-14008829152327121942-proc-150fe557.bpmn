  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-APC1</outgoing>
    </startEvent>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Default_init-APC1</incoming>
      <outgoing>APC1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>APC1-Par1</incoming>
      <outgoing>Par1-DSC1</outgoing>
      <outgoing>Par1-PP1</outgoing>
    </parallelGateway>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>Par1-DSC1</incoming>
      <outgoing>DSC1-NWS1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>Par1-PP1</incoming>
      <outgoing>PP1-Par7</outgoing>
    </task>
    <task id="NWS1" name="Negotiate with Suppliers">
      <incoming>DSC1-NWS1</incoming>
      <outgoing>NWS1-PARCLOSE21</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>PP1-Par7</incoming>
      <outgoing>Par7-PPL1</outgoing>
      <outgoing>Par7-CTD1</outgoing>
    </parallelGateway>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>Par7-PPL1</incoming>
      <outgoing>PPL1-PMT1</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>Par7-CTD1</incoming>
      <outgoing>CTD1-MTD1</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>PPL1-PMT1</incoming>
      <outgoing>PMT1-Par14</outgoing>
    </task>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>CTD1-MTD1</incoming>
      <outgoing>MTD1-PARCLOSE20</outgoing>
    </task>
    <parallelGateway id="Par14" name="PAR">
      <incoming>PMT1-Par14</incoming>
      <outgoing>Par14-PI1</outgoing>
      <outgoing>Par14-FV1</outgoing>
    </parallelGateway>
    <task id="PI1" name="Perform Inspections">
      <incoming>Par14-PI1</incoming>
      <outgoing>PI1-PARCLOSE17</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>Par14-FV1</incoming>
      <outgoing>FV1-PARCLOSE17</outgoing>
    </task>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>PI1-PARCLOSE17</incoming>
      <incoming>FV1-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-ALSP1</outgoing>
    </parallelGateway>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>PARCLOSE17-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE20</outgoing>
    </task>
    <parallelGateway id="PARCLOSE20" name="PARCLOSE20">
      <incoming>MTD1-PARCLOSE20</incoming>
      <incoming>ALSP1-PARCLOSE20</incoming>
      <outgoing>PARCLOSE20-PARCLOSE21</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>NWS1-PARCLOSE21</incoming>
      <incoming>PARCLOSE20-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE21-END</incoming>
    </endEvent>
