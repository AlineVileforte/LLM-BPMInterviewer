    <sequenceFlow id="XORCLOSE7-Par8" sourceRef="XORCLOSE7" targetRef="Par8"/>
    <sequenceFlow id="Par8-PPL1" sourceRef="Par8" targetRef="PPL1"/>
    <sequenceFlow id="Par8-CTD1" sourceRef="Par8" targetRef="CTD1"/>
    <sequenceFlow id="PPL1-Par10" sourceRef="PPL1" targetRef="Par10"/>
    <sequenceFlow id="Par10-NWS1" sourceRef="Par10" targetRef="NWS1"/>
    <sequenceFlow id="Par10-PI1" sourceRef="Par10" targetRef="PI1"/>
    <sequenceFlow id="NWS1-PMT1" sourceRef="NWS1" targetRef="PMT1"/>
    <sequenceFlow id="PI1-PARCLOSE15" sourceRef="PI1" targetRef="PARCLOSE15"/>
    <sequenceFlow id="CTD1-PARCLOSE17" sourceRef="CTD1" targetRef="PARCLOSE17"/>
    <sequenceFlow id="PMT1-PARCLOSE15" sourceRef="PMT1" targetRef="PARCLOSE15"/>
    <sequenceFlow id="PARCLOSE15-FV1" sourceRef="PARCLOSE15" targetRef="FV1"/>
    <sequenceFlow id="FV1-PARCLOSE17" sourceRef="FV1" targetRef="PARCLOSE17"/>
    <sequenceFlow id="PARCLOSE17-END" sourceRef="PARCLOSE17" targetRef="END"/>
  </process>
