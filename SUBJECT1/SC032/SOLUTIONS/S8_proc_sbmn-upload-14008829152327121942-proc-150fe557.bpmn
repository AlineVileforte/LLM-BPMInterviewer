<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_51ac54cc-829e-4bf1-b475-1c84deab8922" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-APC1</outgoing>
    </startEvent>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Default_init-APC1</incoming>
      <outgoing>APC1-DSC1</outgoing>
    </task>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>APC1-DSC1</incoming>
      <outgoing>DSC1-PP1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>DSC1-PP1</incoming>
      <outgoing>PP1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>PP1-G0</incoming>
      <outgoing>G0-MTD1</outgoing>
      <outgoing>G0-XORCLOSE7</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G0-MTD1</incoming>
      <outgoing>MTD1-ALSP1</outgoing>
    </task>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>MTD1-ALSP1</incoming>
      <outgoing>ALSP1-XORCLOSE7</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE7" name="XORCLOSE7">
      <incoming>G0-XORCLOSE7</incoming>
      <incoming>ALSP1-XORCLOSE7</incoming>
      <outgoing>XORCLOSE7-Par8</outgoing>
    </exclusiveGateway>
    <parallelGateway id="Par8" name="PAR">
      <incoming>XORCLOSE7-Par8</incoming>
      <outgoing>Par8-PPL1</outgoing>
      <outgoing>Par8-CTD1</outgoing>
    </parallelGateway>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>Par8-PPL1</incoming>
      <outgoing>PPL1-Par10</outgoing>
    </task>
    <parallelGateway id="Par10" name="PAR">
      <incoming>PPL1-Par10</incoming>
      <outgoing>Par10-NWS1</outgoing>
      <outgoing>Par10-PI1</outgoing>
    </parallelGateway>
    <task id="NWS1" name="Negotiate with Suppliers">
      <incoming>Par10-NWS1</incoming>
      <outgoing>NWS1-PMT1</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>Par10-PI1</incoming>
      <outgoing>PI1-PARCLOSE15</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>Par8-CTD1</incoming>
      <outgoing>CTD1-PARCLOSE17</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>NWS1-PMT1</incoming>
      <outgoing>PMT1-PARCLOSE15</outgoing>
    </task>
    <parallelGateway id="PARCLOSE15" name="PARCLOSE15">
      <incoming>PI1-PARCLOSE15</incoming>
      <incoming>PMT1-PARCLOSE15</incoming>
      <outgoing>PARCLOSE15-FV1</outgoing>
    </parallelGateway>
    <task id="FV1" name="Final Validation">
      <incoming>PARCLOSE15-FV1</incoming>
      <outgoing>FV1-PARCLOSE17</outgoing>
    </task>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>CTD1-PARCLOSE17</incoming>
      <incoming>FV1-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE17-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-APC1" sourceRef="Default_init" targetRef="APC1"/>
