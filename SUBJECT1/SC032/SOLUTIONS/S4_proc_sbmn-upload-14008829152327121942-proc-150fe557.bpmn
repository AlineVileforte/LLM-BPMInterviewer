    <sequenceFlow id="MTD1-PI1" sourceRef="MTD1" targetRef="PI1"/>
    <sequenceFlow id="FV1-ALSP1" sourceRef="FV1" targetRef="ALSP1"/>
    <sequenceFlow id="PI1-PARCLOSE16" sourceRef="PI1" targetRef="PARCLOSE16"/>
    <sequenceFlow id="ALSP1-PARCLOSE16" sourceRef="ALSP1" targetRef="PARCLOSE16"/>
    <sequenceFlow id="PARCLOSE16-PARCLOSE17" sourceRef="PARCLOSE16" targetRef="PARCLOSE17"/>
    <sequenceFlow id="PARCLOSE17-END" sourceRef="PARCLOSE17" targetRef="END"/>
  </process>
