<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_745d0d10-a244-4b20-bcae-32094ac691b2" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-APC1</outgoing>
    </startEvent>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Default_init-APC1</incoming>
      <outgoing>APC1-DSC1</outgoing>
    </task>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>APC1-DSC1</incoming>
      <outgoing>DSC1-PP1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>DSC1-PP1</incoming>
      <outgoing>PP1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>PP1-Par3</incoming>
      <outgoing>Par3-PPL1</outgoing>
      <outgoing>Par3-CTD1</outgoing>
    </parallelGateway>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>Par3-PPL1</incoming>
      <outgoing>PPL1-G1</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>Par3-CTD1</incoming>
      <outgoing>CTD1-Par9</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>PPL1-G1</incoming>
      <outgoing>G1-MTD1</outgoing>
      <outgoing>G1-XORCLOSE14</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G1-MTD1</incoming>
      <outgoing>MTD1-ALSP1</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>CTD1-Par9</incoming>
      <outgoing>Par9-NWS1</outgoing>
      <outgoing>Par9-PMT1</outgoing>
    </parallelGateway>
    <task id="NWS1" name="Negotiate with Suppliers">
      <incoming>Par9-NWS1</incoming>
      <outgoing>NWS1-PARCLOSE13</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>Par9-PMT1</incoming>
      <outgoing>PMT1-PARCLOSE13</outgoing>
    </task>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>MTD1-ALSP1</incoming>
      <outgoing>ALSP1-XORCLOSE14</outgoing>
    </task>
    <parallelGateway id="PARCLOSE13" name="PARCLOSE13">
      <incoming>NWS1-PARCLOSE13</incoming>
      <incoming>PMT1-PARCLOSE13</incoming>
      <outgoing>PARCLOSE13-FV1</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>G1-XORCLOSE14</incoming>
      <incoming>ALSP1-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-PARCLOSE16</outgoing>
    </exclusiveGateway>
    <task id="FV1" name="Final Validation">
      <incoming>PARCLOSE13-FV1</incoming>
      <outgoing>FV1-PARCLOSE16</outgoing>
    </task>
    <parallelGateway id="PARCLOSE16" name="PARCLOSE16">
      <incoming>XORCLOSE14-PARCLOSE16</incoming>
      <incoming>FV1-PARCLOSE16</incoming>
      <outgoing>PARCLOSE16-PI1</outgoing>
    </parallelGateway>
    <task id="PI1" name="Perform Inspections">
      <incoming>PARCLOSE16-PI1</incoming>
      <outgoing>PI1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PI1-END</incoming>
    </endEvent>
