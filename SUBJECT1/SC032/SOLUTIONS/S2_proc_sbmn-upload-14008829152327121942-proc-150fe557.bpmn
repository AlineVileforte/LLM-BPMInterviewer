    <sequenceFlow id="FV1-PARCLOSE16" sourceRef="FV1" targetRef="PARCLOSE16"/>
    <sequenceFlow id="PARCLOSE16-PI1" sourceRef="PARCLOSE16" targetRef="PI1"/>
    <sequenceFlow id="PI1-END" sourceRef="PI1" targetRef="END"/>
  </process>
