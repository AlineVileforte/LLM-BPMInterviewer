<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_540598b8-a466-495f-95a7-bf1d107ac844" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-PPD1</outgoing>
      <outgoing>Par0-SDT1</outgoing>
    </parallelGateway>
    <task id="PPD1" name="Provide payment details">
      <incoming>Par0-PPD1</incoming>
      <outgoing>PPD1-CST1</outgoing>
    </task>
    <task id="CST1" name="Customer searches for ticket">
      <incoming>PPD1-CST1</incoming>
      <outgoing>CST1-SR1</outgoing>
    </task>
    <task id="SDT1" name="Select date and time">
      <incoming>Par0-SDT1</incoming>
      <outgoing>SDT1-PARCLOSE6</outgoing>
    </task>
    <task id="SR1" name="Select route">
      <incoming>CST1-SR1</incoming>
      <outgoing>SR1-PPI1</outgoing>
    </task>
    <task id="PPI1" name="Provide personal information">
      <incoming>SR1-PPI1</incoming>
      <outgoing>PPI1-PARCLOSE6</outgoing>
    </task>
    <parallelGateway id="PARCLOSE6" name="PARCLOSE6">
      <incoming>SDT1-PARCLOSE6</incoming>
      <incoming>PPI1-PARCLOSE6</incoming>
      <outgoing>PARCLOSE6-GT1</outgoing>
    </parallelGateway>
    <task id="GT1" name="Generate ticket">
      <incoming>PARCLOSE6-GT1</incoming>
      <outgoing>GT1-USI1</outgoing>
    </task>
    <task id="USI1" name="Update seat inventory">
      <incoming>GT1-USI1</incoming>
      <outgoing>USI1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>USI1-G0</incoming>
      <outgoing>G0-STEM1</outgoing>
      <outgoing>G0-Par11</outgoing>
    </exclusiveGateway>
    <task id="STEM1" name="Send ticket via email">
      <incoming>G0-STEM1</incoming>
      <outgoing>STEM1-XORCLOSE25</outgoing>
    </task>
    <parallelGateway id="Par11" name="PAR">
      <incoming>G0-Par11</incoming>
      <outgoing>Par11-STSMS1</outgoing>
      <outgoing>Par11-XOR_JMPBB_SINS1_SINS1</outgoing>
    </parallelGateway>
    <task id="STSMS1" name="Send ticket via SMS">
      <incoming>Par11-STSMS1</incoming>
      <outgoing>STSMS1-XOR_JMPBB_SRM1_SRM1</outgoing>
    </task>
    <task id="SRM1" name="Send reminder">
      <incoming>XOR_JMPBB_SRM1_SRM1-SRM1</incoming>
      <outgoing>SRM1-XOR_JMPAA_SRM1_SRM1</outgoing>
    </task>
    <task id="SINS1" name="Send instructions">
      <incoming>XOR_JMPBB_SINS1_SINS1-SINS1</incoming>
      <outgoing>SINS1-XOR_JMPAA_SINS1_SINS1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>XOR_JMPAA_SINS1_SINS1-G1</incoming>
      <outgoing>G1-CCJ1</outgoing>
      <outgoing>G1-XORCLOSE23</outgoing>
    </exclusiveGateway>
    <task id="CCJ1" name="Customer completes journey">
      <incoming>G1-CCJ1</incoming>
      <outgoing>CCJ1-G2</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>CCJ1-G2</incoming>
      <outgoing>G2-PTF1</outgoing>
      <outgoing>G2-XORCLOSE21</outgoing>
    </exclusiveGateway>
    <task id="PTF1" name="Post-travel feedback or services">
      <incoming>G2-PTF1</incoming>
      <outgoing>PTF1-XORCLOSE21</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE21" name="XORCLOSE21">
      <incoming>G2-XORCLOSE21</incoming>
      <incoming>PTF1-XORCLOSE21</incoming>
      <outgoing>XORCLOSE21-XORCLOSE23</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE23" name="XORCLOSE23">
      <incoming>G1-XORCLOSE23</incoming>
      <incoming>XORCLOSE21-XORCLOSE23</incoming>
      <outgoing>XORCLOSE23-PARCLOSE24</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>XORCLOSE23-PARCLOSE24</incoming>
      <incoming>XOR_JMPAA_SRM1_SRM1-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-XORCLOSE25</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE25" name="XORCLOSE25">
      <incoming>STEM1-XORCLOSE25</incoming>
      <incoming>PARCLOSE24-XORCLOSE25</incoming>
      <outgoing>XORCLOSE25-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE25-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_SINS1_SINS1" name="XOR_JMPAA_Send instructions">
      <incoming>SINS1-XOR_JMPAA_SINS1_SINS1</incoming>
      <outgoing>XOR_JMPAA_SINS1_SINS1-G1</outgoing>
      <outgoing>XOR_JMPAA_SINS1_SINS1-XOR_JMPBB_SINS1_SINS1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_SINS1_SINS1" name="XOR_JMPBB_Send instructions">
      <incoming>Par11-XOR_JMPBB_SINS1_SINS1</incoming>
      <incoming>XOR_JMPAA_SINS1_SINS1-XOR_JMPBB_SINS1_SINS1</incoming>
      <outgoing>XOR_JMPBB_SINS1_SINS1-SINS1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPAA_SRM1_SRM1" name="XOR_JMPAA_Send reminder">
      <incoming>SRM1-XOR_JMPAA_SRM1_SRM1</incoming>
      <outgoing>XOR_JMPAA_SRM1_SRM1-PARCLOSE24</outgoing>
      <outgoing>XOR_JMPAA_SRM1_SRM1-XOR_JMPBB_SRM1_SRM1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_SRM1_SRM1" name="XOR_JMPBB_Send reminder">
      <incoming>STSMS1-XOR_JMPBB_SRM1_SRM1</incoming>
      <incoming>XOR_JMPAA_SRM1_SRM1-XOR_JMPBB_SRM1_SRM1</incoming>
      <outgoing>XOR_JMPBB_SRM1_SRM1-SRM1</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
