    <sequenceFlow id="STEM1-XORCLOSE25" sourceRef="STEM1" targetRef="XORCLOSE25"/>
    <sequenceFlow id="Par11-STSMS1" sourceRef="Par11" targetRef="STSMS1"/>
    <sequenceFlow id="Par11-XOR_JMPBB_SINS1_SINS1" sourceRef="Par11" targetRef="XOR_JMPBB_SINS1_SINS1"/>
    <sequenceFlow id="STSMS1-XOR_JMPBB_SRM1_SRM1" sourceRef="STSMS1" targetRef="XOR_JMPBB_SRM1_SRM1"/>
    <sequenceFlow id="SRM1-XOR_JMPAA_SRM1_SRM1" sourceRef="SRM1" targetRef="XOR_JMPAA_SRM1_SRM1"/>
    <sequenceFlow id="SINS1-XOR_JMPAA_SINS1_SINS1" sourceRef="SINS1" targetRef="XOR_JMPAA_SINS1_SINS1"/>
    <sequenceFlow id="G1-CCJ1" sourceRef="G1" targetRef="CCJ1"/>
    <sequenceFlow id="G1-XORCLOSE23" sourceRef="G1" targetRef="XORCLOSE23"/>
    <sequenceFlow id="CCJ1-G2" sourceRef="CCJ1" targetRef="G2"/>
