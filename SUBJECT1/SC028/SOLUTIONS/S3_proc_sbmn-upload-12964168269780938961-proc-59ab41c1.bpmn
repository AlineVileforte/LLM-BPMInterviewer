<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_a5af9e5a-83a4-4983-830b-18c56f01b990" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-SDT1</outgoing>
      <outgoing>Par0-PPD1</outgoing>
    </parallelGateway>
    <task id="SDT1" name="Select date and time">
      <incoming>Par0-SDT1</incoming>
      <outgoing>SDT1-CST1</outgoing>
    </task>
    <task id="PPD1" name="Provide payment details">
      <incoming>Par0-PPD1</incoming>
      <outgoing>PPD1-PARCLOSE13</outgoing>
    </task>
    <task id="CST1" name="Customer searches for ticket">
      <incoming>SDT1-CST1</incoming>
      <outgoing>CST1-SR1</outgoing>
    </task>
    <task id="SR1" name="Select route">
      <incoming>CST1-SR1</incoming>
      <outgoing>SR1-PPI1</outgoing>
    </task>
    <task id="PPI1" name="Provide personal information">
      <incoming>SR1-PPI1</incoming>
      <outgoing>PPI1-PARCLOSE13</outgoing>
    </task>
    <parallelGateway id="PARCLOSE13" name="PARCLOSE13">
      <incoming>PPD1-PARCLOSE13</incoming>
      <incoming>PPI1-PARCLOSE13</incoming>
      <outgoing>PARCLOSE13-GT1</outgoing>
    </parallelGateway>
    <task id="GT1" name="Generate ticket">
      <incoming>PARCLOSE13-GT1</incoming>
      <outgoing>GT1-USI1</outgoing>
    </task>
    <task id="USI1" name="Update seat inventory">
      <incoming>GT1-USI1</incoming>
      <outgoing>USI1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>USI1-G0</incoming>
      <outgoing>G0-STEM1</outgoing>
      <outgoing>G0-STSMS1</outgoing>
    </exclusiveGateway>
    <task id="STEM1" name="Send ticket via email">
      <incoming>G0-STEM1</incoming>
      <outgoing>STEM1-XORCLOSE27</outgoing>
    </task>
    <task id="STSMS1" name="Send ticket via SMS">
      <incoming>G0-STSMS1</incoming>
      <outgoing>STSMS1-Par20</outgoing>
    </task>
    <parallelGateway id="Par20" name="PAR">
      <incoming>STSMS1-Par20</incoming>
      <outgoing>Par20-XOR_JMPBB_SINS1_SINS1</outgoing>
      <outgoing>Par20-XOR_JMPBB_SRM1_SRM1</outgoing>
    </parallelGateway>
    <task id="SRM1" name="Send reminder">
      <incoming>XOR_JMPBB_SRM1_SRM1-SRM1</incoming>
      <outgoing>SRM1-PARCLOSE23</outgoing>
    </task>
    <task id="SINS1" name="Send instructions">
      <incoming>XOR_JMPBB_SINS1_SINS1-SINS1</incoming>
      <outgoing>SINS1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>SRM1-PARCLOSE23</incoming>
      <incoming>SINS1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-XOR_JMPBB_SINS1_SINS1</outgoing>
      <outgoing>PARCLOSE23-XOR_JMPBB_SRM1_SRM1</outgoing>
      <outgoing>PARCLOSE23-CCJ1</outgoing>
    </parallelGateway>
    <task id="CCJ1" name="Customer completes journey">
      <incoming>PARCLOSE23-CCJ1</incoming>
      <outgoing>CCJ1-PTF1</outgoing>
    </task>
    <task id="PTF1" name="Post-travel feedback or services">
      <incoming>CCJ1-PTF1</incoming>
      <outgoing>PTF1-XORCLOSE27</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE27" name="XORCLOSE27">
      <incoming>STEM1-XORCLOSE27</incoming>
      <incoming>PTF1-XORCLOSE27</incoming>
      <outgoing>XORCLOSE27-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE27-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPBB_SINS1_SINS1" name="XOR_JMPBB_Send instructions">
      <incoming>Par20-XOR_JMPBB_SINS1_SINS1</incoming>
      <incoming>PARCLOSE23-XOR_JMPBB_SINS1_SINS1</incoming>
      <outgoing>XOR_JMPBB_SINS1_SINS1-SINS1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_SRM1_SRM1" name="XOR_JMPBB_Send reminder">
      <incoming>Par20-XOR_JMPBB_SRM1_SRM1</incoming>
      <incoming>PARCLOSE23-XOR_JMPBB_SRM1_SRM1</incoming>
      <outgoing>XOR_JMPBB_SRM1_SRM1-SRM1</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
    <sequenceFlow id="Par0-SDT1" sourceRef="Par0" targetRef="SDT1"/>
    <sequenceFlow id="Par0-PPD1" sourceRef="Par0" targetRef="PPD1"/>
    <sequenceFlow id="SDT1-CST1" sourceRef="SDT1" targetRef="CST1"/>
    <sequenceFlow id="PPD1-PARCLOSE13" sourceRef="PPD1" targetRef="PARCLOSE13"/>
    <sequenceFlow id="CST1-SR1" sourceRef="CST1" targetRef="SR1"/>
    <sequenceFlow id="SR1-PPI1" sourceRef="SR1" targetRef="PPI1"/>
    <sequenceFlow id="PPI1-PARCLOSE13" sourceRef="PPI1" targetRef="PARCLOSE13"/>
    <sequenceFlow id="PARCLOSE13-GT1" sourceRef="PARCLOSE13" targetRef="GT1"/>
    <sequenceFlow id="GT1-USI1" sourceRef="GT1" targetRef="USI1"/>
    <sequenceFlow id="USI1-G0" sourceRef="USI1" targetRef="G0"/>
    <sequenceFlow id="G0-STEM1" sourceRef="G0" targetRef="STEM1"/>
    <sequenceFlow id="G0-STSMS1" sourceRef="G0" targetRef="STSMS1"/>
    <sequenceFlow id="STEM1-XORCLOSE27" sourceRef="STEM1" targetRef="XORCLOSE27"/>
    <sequenceFlow id="STSMS1-Par20" sourceRef="STSMS1" targetRef="Par20"/>
    <sequenceFlow id="Par20-XOR_JMPBB_SINS1_SINS1" sourceRef="Par20" targetRef="XOR_JMPBB_SINS1_SINS1"/>
    <sequenceFlow id="Par20-XOR_JMPBB_SRM1_SRM1" sourceRef="Par20" targetRef="XOR_JMPBB_SRM1_SRM1"/>
    <sequenceFlow id="SRM1-PARCLOSE23" sourceRef="SRM1" targetRef="PARCLOSE23"/>
    <sequenceFlow id="SINS1-PARCLOSE23" sourceRef="SINS1" targetRef="PARCLOSE23"/>
    <sequenceFlow id="PARCLOSE23-XOR_JMPBB_SINS1_SINS1" sourceRef="PARCLOSE23" targetRef="XOR_JMPBB_SINS1_SINS1"/>
    <sequenceFlow id="PARCLOSE23-XOR_JMPBB_SRM1_SRM1" sourceRef="PARCLOSE23" targetRef="XOR_JMPBB_SRM1_SRM1"/>
    <sequenceFlow id="PARCLOSE23-CCJ1" sourceRef="PARCLOSE23" targetRef="CCJ1"/>
    <sequenceFlow id="CCJ1-PTF1" sourceRef="CCJ1" targetRef="PTF1"/>
    <sequenceFlow id="PTF1-XORCLOSE27" sourceRef="PTF1" targetRef="XORCLOSE27"/>
    <sequenceFlow id="XORCLOSE27-END" sourceRef="XORCLOSE27" targetRef="END"/>
    <sequenceFlow id="XOR_JMPBB_SINS1_SINS1-SINS1" sourceRef="XOR_JMPBB_SINS1_SINS1" targetRef="SINS1"/>
    <sequenceFlow id="XOR_JMPBB_SRM1_SRM1-SRM1" sourceRef="XOR_JMPBB_SRM1_SRM1" targetRef="SRM1"/>
  </process>
