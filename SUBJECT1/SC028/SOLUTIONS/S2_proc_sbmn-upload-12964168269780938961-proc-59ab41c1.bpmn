    <sequenceFlow id="PPI1-PARCLOSE13" sourceRef="PPI1" targetRef="PARCLOSE13"/>
    <sequenceFlow id="PARCLOSE13-GT1" sourceRef="PARCLOSE13" targetRef="GT1"/>
    <sequenceFlow id="GT1-USI1" sourceRef="GT1" targetRef="USI1"/>
    <sequenceFlow id="USI1-G0" sourceRef="USI1" targetRef="G0"/>
    <sequenceFlow id="G0-STEM1" sourceRef="G0" targetRef="STEM1"/>
    <sequenceFlow id="G0-XOR_JMPBB_SINS1_SINS1" sourceRef="G0" targetRef="XOR_JMPBB_SINS1_SINS1"/>
    <sequenceFlow id="STEM1-XORCLOSE25" sourceRef="STEM1" targetRef="XORCLOSE25"/>
    <sequenceFlow id="SINS1-XOR_JMPAA_SINS1_SINS1" sourceRef="SINS1" targetRef="XOR_JMPAA_SINS1_SINS1"/>
    <sequenceFlow id="Par19-STSMS1" sourceRef="Par19" targetRef="STSMS1"/>
    <sequenceFlow id="Par19-XOR_JMPBB_SRM1_SRM1" sourceRef="Par19" targetRef="XOR_JMPBB_SRM1_SRM1"/>
    <sequenceFlow id="STSMS1-PARCLOSE22" sourceRef="STSMS1" targetRef="PARCLOSE22"/>
    <sequenceFlow id="SRM1-XOR_JMPAA_SRM1_SRM1" sourceRef="SRM1" targetRef="XOR_JMPAA_SRM1_SRM1"/>
    <sequenceFlow id="PARCLOSE22-CCJ1" sourceRef="PARCLOSE22" targetRef="CCJ1"/>
    <sequenceFlow id="CCJ1-PTF1" sourceRef="CCJ1" targetRef="PTF1"/>
    <sequenceFlow id="PTF1-XORCLOSE25" sourceRef="PTF1" targetRef="XORCLOSE25"/>
    <sequenceFlow id="XORCLOSE25-END" sourceRef="XORCLOSE25" targetRef="END"/>
    <sequenceFlow id="XOR_JMPAA_SINS1_SINS1-Par19" sourceRef="XOR_JMPAA_SINS1_SINS1" targetRef="Par19"/>
    <sequenceFlow id="XOR_JMPAA_SINS1_SINS1-XOR_JMPBB_SINS1_SINS1" sourceRef="XOR_JMPAA_SINS1_SINS1" targetRef="XOR_JMPBB_SINS1_SINS1"/>
    <sequenceFlow id="XOR_JMPBB_SINS1_SINS1-SINS1" sourceRef="XOR_JMPBB_SINS1_SINS1" targetRef="SINS1"/>
    <sequenceFlow id="XOR_JMPAA_SRM1_SRM1-PARCLOSE22" sourceRef="XOR_JMPAA_SRM1_SRM1" targetRef="PARCLOSE22"/>
    <sequenceFlow id="XOR_JMPAA_SRM1_SRM1-XOR_JMPBB_SRM1_SRM1" sourceRef="XOR_JMPAA_SRM1_SRM1" targetRef="XOR_JMPBB_SRM1_SRM1"/>
    <sequenceFlow id="XOR_JMPBB_SRM1_SRM1-SRM1" sourceRef="XOR_JMPBB_SRM1_SRM1" targetRef="SRM1"/>
  </process>
