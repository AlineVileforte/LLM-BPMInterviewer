<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_e60d4a01-82e7-4dd5-8ce1-14599f0fd1f6" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CST1</outgoing>
    </startEvent>
    <task id="CST1" name="Customer searches for ticket">
      <incoming>Default_init-CST1</incoming>
      <outgoing>CST1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>CST1-Par1</incoming>
      <outgoing>Par1-SR1</outgoing>
      <outgoing>Par1-PPD1</outgoing>
    </parallelGateway>
    <task id="SR1" name="Select route">
      <incoming>Par1-SR1</incoming>
      <outgoing>SR1-SDT1</outgoing>
    </task>
    <task id="PPD1" name="Provide payment details">
      <incoming>Par1-PPD1</incoming>
      <outgoing>PPD1-PARCLOSE13</outgoing>
    </task>
    <task id="SDT1" name="Select date and time">
      <incoming>SR1-SDT1</incoming>
      <outgoing>SDT1-PPI1</outgoing>
    </task>
    <task id="PPI1" name="Provide personal information">
      <incoming>SDT1-PPI1</incoming>
      <outgoing>PPI1-PARCLOSE13</outgoing>
    </task>
    <parallelGateway id="PARCLOSE13" name="PARCLOSE13">
      <incoming>PPD1-PARCLOSE13</incoming>
      <incoming>PPI1-PARCLOSE13</incoming>
      <outgoing>PARCLOSE13-GT1</outgoing>
    </parallelGateway>
    <task id="GT1" name="Generate ticket">
      <incoming>PARCLOSE13-GT1</incoming>
      <outgoing>GT1-USI1</outgoing>
    </task>
    <task id="USI1" name="Update seat inventory">
      <incoming>GT1-USI1</incoming>
      <outgoing>USI1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>USI1-G0</incoming>
      <outgoing>G0-STEM1</outgoing>
      <outgoing>G0-XOR_JMPBB_SINS1_SINS1</outgoing>
    </exclusiveGateway>
    <task id="STEM1" name="Send ticket via email">
      <incoming>G0-STEM1</incoming>
      <outgoing>STEM1-XORCLOSE25</outgoing>
    </task>
    <task id="SINS1" name="Send instructions">
      <incoming>XOR_JMPBB_SINS1_SINS1-SINS1</incoming>
      <outgoing>SINS1-XOR_JMPAA_SINS1_SINS1</outgoing>
    </task>
    <parallelGateway id="Par19" name="PAR">
      <incoming>XOR_JMPAA_SINS1_SINS1-Par19</incoming>
      <outgoing>Par19-STSMS1</outgoing>
      <outgoing>Par19-XOR_JMPBB_SRM1_SRM1</outgoing>
    </parallelGateway>
    <task id="STSMS1" name="Send ticket via SMS">
      <incoming>Par19-STSMS1</incoming>
      <outgoing>STSMS1-PARCLOSE22</outgoing>
    </task>
    <task id="SRM1" name="Send reminder">
      <incoming>XOR_JMPBB_SRM1_SRM1-SRM1</incoming>
      <outgoing>SRM1-XOR_JMPAA_SRM1_SRM1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>STSMS1-PARCLOSE22</incoming>
      <incoming>XOR_JMPAA_SRM1_SRM1-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-CCJ1</outgoing>
    </parallelGateway>
    <task id="CCJ1" name="Customer completes journey">
      <incoming>PARCLOSE22-CCJ1</incoming>
      <outgoing>CCJ1-PTF1</outgoing>
    </task>
    <task id="PTF1" name="Post-travel feedback or services">
      <incoming>CCJ1-PTF1</incoming>
      <outgoing>PTF1-XORCLOSE25</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE25" name="XORCLOSE25">
      <incoming>STEM1-XORCLOSE25</incoming>
      <incoming>PTF1-XORCLOSE25</incoming>
      <outgoing>XORCLOSE25-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE25-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_SINS1_SINS1" name="XOR_JMPAA_Send instructions">
      <incoming>SINS1-XOR_JMPAA_SINS1_SINS1</incoming>
      <outgoing>XOR_JMPAA_SINS1_SINS1-Par19</outgoing>
      <outgoing>XOR_JMPAA_SINS1_SINS1-XOR_JMPBB_SINS1_SINS1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_SINS1_SINS1" name="XOR_JMPBB_Send instructions">
      <incoming>G0-XOR_JMPBB_SINS1_SINS1</incoming>
      <incoming>XOR_JMPAA_SINS1_SINS1-XOR_JMPBB_SINS1_SINS1</incoming>
      <outgoing>XOR_JMPBB_SINS1_SINS1-SINS1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPAA_SRM1_SRM1" name="XOR_JMPAA_Send reminder">
      <incoming>SRM1-XOR_JMPAA_SRM1_SRM1</incoming>
      <outgoing>XOR_JMPAA_SRM1_SRM1-PARCLOSE22</outgoing>
      <outgoing>XOR_JMPAA_SRM1_SRM1-XOR_JMPBB_SRM1_SRM1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_SRM1_SRM1" name="XOR_JMPBB_Send reminder">
      <incoming>Par19-XOR_JMPBB_SRM1_SRM1</incoming>
      <incoming>XOR_JMPAA_SRM1_SRM1-XOR_JMPBB_SRM1_SRM1</incoming>
      <outgoing>XOR_JMPBB_SRM1_SRM1-SRM1</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Default_init-CST1" sourceRef="Default_init" targetRef="CST1"/>
    <sequenceFlow id="CST1-Par1" sourceRef="CST1" targetRef="Par1"/>
    <sequenceFlow id="Par1-SR1" sourceRef="Par1" targetRef="SR1"/>
    <sequenceFlow id="Par1-PPD1" sourceRef="Par1" targetRef="PPD1"/>
    <sequenceFlow id="SR1-SDT1" sourceRef="SR1" targetRef="SDT1"/>
    <sequenceFlow id="PPD1-PARCLOSE13" sourceRef="PPD1" targetRef="PARCLOSE13"/>
