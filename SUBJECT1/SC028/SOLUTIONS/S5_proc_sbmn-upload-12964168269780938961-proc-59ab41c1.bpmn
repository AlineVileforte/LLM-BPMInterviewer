<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_ea7bbf17-9f8d-47db-a657-a31477ba717d" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-CST1</outgoing>
      <outgoing>Par0-PPD1</outgoing>
    </parallelGateway>
    <task id="CST1" name="Customer searches for ticket">
      <incoming>Par0-CST1</incoming>
      <outgoing>CST1-SR1</outgoing>
    </task>
    <task id="PPD1" name="Provide payment details">
      <incoming>Par0-PPD1</incoming>
      <outgoing>PPD1-PARCLOSE11</outgoing>
    </task>
    <task id="SR1" name="Select route">
      <incoming>CST1-SR1</incoming>
      <outgoing>SR1-SDT1</outgoing>
    </task>
    <task id="SDT1" name="Select date and time">
      <incoming>SR1-SDT1</incoming>
      <outgoing>SDT1-PPI1</outgoing>
    </task>
    <task id="PPI1" name="Provide personal information">
      <incoming>SDT1-PPI1</incoming>
      <outgoing>PPI1-PARCLOSE11</outgoing>
    </task>
    <parallelGateway id="PARCLOSE11" name="PARCLOSE11">
      <incoming>PPD1-PARCLOSE11</incoming>
      <incoming>PPI1-PARCLOSE11</incoming>
      <outgoing>PARCLOSE11-GT1</outgoing>
    </parallelGateway>
    <task id="GT1" name="Generate ticket">
      <incoming>PARCLOSE11-GT1</incoming>
      <outgoing>GT1-USI1</outgoing>
    </task>
    <task id="USI1" name="Update seat inventory">
      <incoming>GT1-USI1</incoming>
      <outgoing>USI1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>USI1-G0</incoming>
      <outgoing>G0-STEM1</outgoing>
      <outgoing>G0-Par16</outgoing>
    </exclusiveGateway>
    <task id="STEM1" name="Send ticket via email">
      <incoming>G0-STEM1</incoming>
      <outgoing>STEM1-XORCLOSE23</outgoing>
    </task>
    <parallelGateway id="Par16" name="PAR">
      <incoming>G0-Par16</incoming>
      <outgoing>Par16-STSMS1</outgoing>
      <outgoing>Par16-XOR_JMPBB_SINS1_SINS1</outgoing>
    </parallelGateway>
    <task id="STSMS1" name="Send ticket via SMS">
      <incoming>Par16-STSMS1</incoming>
      <outgoing>STSMS1-XOR_JMPBB_SRM1_SRM1</outgoing>
    </task>
    <task id="SINS1" name="Send instructions">
      <incoming>XOR_JMPBB_SINS1_SINS1-SINS1</incoming>
      <outgoing>SINS1-PARCLOSE20</outgoing>
    </task>
    <task id="SRM1" name="Send reminder">
      <incoming>XOR_JMPBB_SRM1_SRM1-SRM1</incoming>
      <outgoing>SRM1-PARCLOSE20</outgoing>
    </task>
    <parallelGateway id="PARCLOSE20" name="PARCLOSE20">
      <incoming>SINS1-PARCLOSE20</incoming>
      <incoming>SRM1-PARCLOSE20</incoming>
      <outgoing>PARCLOSE20-CCJ1</outgoing>
      <outgoing>PARCLOSE20-XOR_JMPBB_SRM1_SRM1</outgoing>
      <outgoing>PARCLOSE20-XOR_JMPBB_SINS1_SINS1</outgoing>
    </parallelGateway>
    <task id="CCJ1" name="Customer completes journey">
      <incoming>PARCLOSE20-CCJ1</incoming>
      <outgoing>CCJ1-PTF1</outgoing>
    </task>
    <task id="PTF1" name="Post-travel feedback or services">
      <incoming>CCJ1-PTF1</incoming>
      <outgoing>PTF1-XORCLOSE23</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE23" name="XORCLOSE23">
      <incoming>STEM1-XORCLOSE23</incoming>
      <incoming>PTF1-XORCLOSE23</incoming>
      <outgoing>XORCLOSE23-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE23-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPBB_SINS1_SINS1" name="XOR_JMPBB_Send instructions">
      <incoming>Par16-XOR_JMPBB_SINS1_SINS1</incoming>
      <incoming>PARCLOSE20-XOR_JMPBB_SINS1_SINS1</incoming>
      <outgoing>XOR_JMPBB_SINS1_SINS1-SINS1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_SRM1_SRM1" name="XOR_JMPBB_Send reminder">
      <incoming>STSMS1-XOR_JMPBB_SRM1_SRM1</incoming>
      <incoming>PARCLOSE20-XOR_JMPBB_SRM1_SRM1</incoming>
      <outgoing>XOR_JMPBB_SRM1_SRM1-SRM1</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
    <sequenceFlow id="Par0-CST1" sourceRef="Par0" targetRef="CST1"/>
    <sequenceFlow id="Par0-PPD1" sourceRef="Par0" targetRef="PPD1"/>
    <sequenceFlow id="CST1-SR1" sourceRef="CST1" targetRef="SR1"/>
