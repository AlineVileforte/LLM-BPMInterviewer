    <sequenceFlow id="SR1-SDT1" sourceRef="SR1" targetRef="SDT1"/>
    <sequenceFlow id="SDT1-PPI1" sourceRef="SDT1" targetRef="PPI1"/>
    <sequenceFlow id="PPI1-PARCLOSE11" sourceRef="PPI1" targetRef="PARCLOSE11"/>
    <sequenceFlow id="PARCLOSE11-GT1" sourceRef="PARCLOSE11" targetRef="GT1"/>
    <sequenceFlow id="GT1-USI1" sourceRef="GT1" targetRef="USI1"/>
    <sequenceFlow id="USI1-G0" sourceRef="USI1" targetRef="G0"/>
    <sequenceFlow id="G0-STEM1" sourceRef="G0" targetRef="STEM1"/>
    <sequenceFlow id="G0-Par16" sourceRef="G0" targetRef="Par16"/>
    <sequenceFlow id="STEM1-XORCLOSE23" sourceRef="STEM1" targetRef="XORCLOSE23"/>
    <sequenceFlow id="Par16-STSMS1" sourceRef="Par16" targetRef="STSMS1"/>
    <sequenceFlow id="Par16-XOR_JMPBB_SINS1_SINS1" sourceRef="Par16" targetRef="XOR_JMPBB_SINS1_SINS1"/>
    <sequenceFlow id="STSMS1-XOR_JMPBB_SRM1_SRM1" sourceRef="STSMS1" targetRef="XOR_JMPBB_SRM1_SRM1"/>
    <sequenceFlow id="SINS1-PARCLOSE20" sourceRef="SINS1" targetRef="PARCLOSE20"/>
    <sequenceFlow id="SRM1-PARCLOSE20" sourceRef="SRM1" targetRef="PARCLOSE20"/>
    <sequenceFlow id="PARCLOSE20-CCJ1" sourceRef="PARCLOSE20" targetRef="CCJ1"/>
    <sequenceFlow id="PARCLOSE20-XOR_JMPBB_SRM1_SRM1" sourceRef="PARCLOSE20" targetRef="XOR_JMPBB_SRM1_SRM1"/>
    <sequenceFlow id="PARCLOSE20-XOR_JMPBB_SINS1_SINS1" sourceRef="PARCLOSE20" targetRef="XOR_JMPBB_SINS1_SINS1"/>
    <sequenceFlow id="CCJ1-PTF1" sourceRef="CCJ1" targetRef="PTF1"/>
    <sequenceFlow id="PTF1-XORCLOSE23" sourceRef="PTF1" targetRef="XORCLOSE23"/>
    <sequenceFlow id="XORCLOSE23-END" sourceRef="XORCLOSE23" targetRef="END"/>
    <sequenceFlow id="XOR_JMPBB_SINS1_SINS1-SINS1" sourceRef="XOR_JMPBB_SINS1_SINS1" targetRef="SINS1"/>
    <sequenceFlow id="XOR_JMPBB_SRM1_SRM1-SRM1" sourceRef="XOR_JMPBB_SRM1_SRM1" targetRef="SRM1"/>
  </process>
