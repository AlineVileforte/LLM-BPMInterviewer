<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_5ff5a740-d813-4131-b8d0-5bef195fb471" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-CST1</outgoing>
      <outgoing>Par0-SDT1</outgoing>
    </parallelGateway>
    <task id="CST1" name="Customer searches for ticket">
      <incoming>Par0-CST1</incoming>
      <outgoing>CST1-Par3</outgoing>
    </task>
    <task id="SDT1" name="Select date and time">
      <incoming>Par0-SDT1</incoming>
      <outgoing>SDT1-PARCLOSE14</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>CST1-Par3</incoming>
      <outgoing>Par3-PPD1</outgoing>
      <outgoing>Par3-SR1</outgoing>
    </parallelGateway>
    <task id="PPD1" name="Provide payment details">
      <incoming>Par3-PPD1</incoming>
      <outgoing>PPD1-PARCLOSE13</outgoing>
    </task>
    <task id="SR1" name="Select route">
      <incoming>Par3-SR1</incoming>
      <outgoing>SR1-PARCLOSE13</outgoing>
    </task>
    <parallelGateway id="PARCLOSE13" name="PARCLOSE13">
      <incoming>PPD1-PARCLOSE13</incoming>
      <incoming>SR1-PARCLOSE13</incoming>
      <outgoing>PARCLOSE13-PARCLOSE14</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE14" name="PARCLOSE14">
      <incoming>SDT1-PARCLOSE14</incoming>
      <incoming>PARCLOSE13-PARCLOSE14</incoming>
      <outgoing>PARCLOSE14-PPI1</outgoing>
    </parallelGateway>
    <task id="PPI1" name="Provide personal information">
      <incoming>PARCLOSE14-PPI1</incoming>
      <outgoing>PPI1-GT1</outgoing>
    </task>
    <task id="GT1" name="Generate ticket">
      <incoming>PPI1-GT1</incoming>
      <outgoing>GT1-USI1</outgoing>
    </task>
    <task id="USI1" name="Update seat inventory">
      <incoming>GT1-USI1</incoming>
      <outgoing>USI1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>USI1-G0</incoming>
      <outgoing>G0-STEM1</outgoing>
      <outgoing>G0-XOR_JMPBB_SRM1_SRM1</outgoing>
    </exclusiveGateway>
    <task id="STEM1" name="Send ticket via email">
      <incoming>G0-STEM1</incoming>
      <outgoing>STEM1-XORCLOSE25</outgoing>
    </task>
    <task id="SRM1" name="Send reminder">
      <incoming>XOR_JMPBB_SRM1_SRM1-SRM1</incoming>
      <outgoing>SRM1-XOR_JMPAA_SRM1_SRM1</outgoing>
    </task>
    <task id="SINS1" name="Send instructions">
      <incoming>XOR_JMPBB_SINS1_SINS1-SINS1</incoming>
      <outgoing>SINS1-XOR_JMPAA_SINS1_SINS1</outgoing>
    </task>
    <task id="STSMS1" name="Send ticket via SMS">
      <incoming>XOR_JMPAA_SINS1_SINS1-STSMS1</incoming>
      <outgoing>STSMS1-CCJ1</outgoing>
    </task>
    <task id="CCJ1" name="Customer completes journey">
      <incoming>STSMS1-CCJ1</incoming>
      <outgoing>CCJ1-PTF1</outgoing>
    </task>
    <task id="PTF1" name="Post-travel feedback or services">
      <incoming>CCJ1-PTF1</incoming>
      <outgoing>PTF1-XORCLOSE25</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE25" name="XORCLOSE25">
      <incoming>STEM1-XORCLOSE25</incoming>
      <incoming>PTF1-XORCLOSE25</incoming>
      <outgoing>XORCLOSE25-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE25-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_SINS1_SINS1" name="XOR_JMPAA_Send instructions">
      <incoming>SINS1-XOR_JMPAA_SINS1_SINS1</incoming>
      <outgoing>XOR_JMPAA_SINS1_SINS1-STSMS1</outgoing>
      <outgoing>XOR_JMPAA_SINS1_SINS1-XOR_JMPBB_SINS1_SINS1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_SINS1_SINS1" name="XOR_JMPBB_Send instructions">
      <incoming>XOR_JMPAA_SINS1_SINS1-XOR_JMPBB_SINS1_SINS1</incoming>
      <incoming>XOR_JMPAA_SRM1_SRM1-XOR_JMPBB_SINS1_SINS1</incoming>
      <outgoing>XOR_JMPBB_SINS1_SINS1-SINS1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPAA_SRM1_SRM1" name="XOR_JMPAA_Send reminder">
      <incoming>SRM1-XOR_JMPAA_SRM1_SRM1</incoming>
      <outgoing>XOR_JMPAA_SRM1_SRM1-XOR_JMPBB_SINS1_SINS1</outgoing>
      <outgoing>XOR_JMPAA_SRM1_SRM1-XOR_JMPBB_SRM1_SRM1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_SRM1_SRM1" name="XOR_JMPBB_Send reminder">
      <incoming>G0-XOR_JMPBB_SRM1_SRM1</incoming>
      <incoming>XOR_JMPAA_SRM1_SRM1-XOR_JMPBB_SRM1_SRM1</incoming>
      <outgoing>XOR_JMPBB_SRM1_SRM1-SRM1</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
    <sequenceFlow id="Par0-CST1" sourceRef="Par0" targetRef="CST1"/>
    <sequenceFlow id="Par0-SDT1" sourceRef="Par0" targetRef="SDT1"/>
