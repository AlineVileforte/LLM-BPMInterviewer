    <sequenceFlow id="SR1-PARCLOSE12" sourceRef="SR1" targetRef="PARCLOSE12"/>
    <sequenceFlow id="PARCLOSE12-PPI1" sourceRef="PARCLOSE12" targetRef="PPI1"/>
    <sequenceFlow id="PPI1-GT1" sourceRef="PPI1" targetRef="GT1"/>
    <sequenceFlow id="GT1-USI1" sourceRef="GT1" targetRef="USI1"/>
    <sequenceFlow id="USI1-G0" sourceRef="USI1" targetRef="G0"/>
    <sequenceFlow id="G0-STEM1" sourceRef="G0" targetRef="STEM1"/>
    <sequenceFlow id="G0-Par18" sourceRef="G0" targetRef="Par18"/>
    <sequenceFlow id="STEM1-XORCLOSE25" sourceRef="STEM1" targetRef="XORCLOSE25"/>
    <sequenceFlow id="Par18-STSMS1" sourceRef="Par18" targetRef="STSMS1"/>
    <sequenceFlow id="Par18-XOR_JMPBB_SINS1_SINS1" sourceRef="Par18" targetRef="XOR_JMPBB_SINS1_SINS1"/>
    <sequenceFlow id="STSMS1-XOR_JMPBB_SRM1_SRM1" sourceRef="STSMS1" targetRef="XOR_JMPBB_SRM1_SRM1"/>
    <sequenceFlow id="SINS1-PARCLOSE22" sourceRef="SINS1" targetRef="PARCLOSE22"/>
    <sequenceFlow id="SRM1-PARCLOSE22" sourceRef="SRM1" targetRef="PARCLOSE22"/>
    <sequenceFlow id="PARCLOSE22-CCJ1" sourceRef="PARCLOSE22" targetRef="CCJ1"/>
    <sequenceFlow id="PARCLOSE22-XOR_JMPBB_SINS1_SINS1" sourceRef="PARCLOSE22" targetRef="XOR_JMPBB_SINS1_SINS1"/>
    <sequenceFlow id="PARCLOSE22-XOR_JMPBB_SRM1_SRM1" sourceRef="PARCLOSE22" targetRef="XOR_JMPBB_SRM1_SRM1"/>
    <sequenceFlow id="CCJ1-PTF1" sourceRef="CCJ1" targetRef="PTF1"/>
    <sequenceFlow id="PTF1-XORCLOSE25" sourceRef="PTF1" targetRef="XORCLOSE25"/>
    <sequenceFlow id="XORCLOSE25-END" sourceRef="XORCLOSE25" targetRef="END"/>
    <sequenceFlow id="XOR_JMPBB_SINS1_SINS1-SINS1" sourceRef="XOR_JMPBB_SINS1_SINS1" targetRef="SINS1"/>
    <sequenceFlow id="XOR_JMPBB_SRM1_SRM1-SRM1" sourceRef="XOR_JMPBB_SRM1_SRM1" targetRef="SRM1"/>
  </process>
