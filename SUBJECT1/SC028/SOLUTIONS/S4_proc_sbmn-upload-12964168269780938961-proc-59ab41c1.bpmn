<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_e26172be-edd0-4570-a8cf-e8b4a0071943" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-SDT1</outgoing>
    </startEvent>
    <task id="SDT1" name="Select date and time">
      <incoming>Default_init-SDT1</incoming>
      <outgoing>SDT1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>SDT1-Par1</incoming>
      <outgoing>Par1-CST1</outgoing>
      <outgoing>Par1-PPD1</outgoing>
    </parallelGateway>
    <task id="CST1" name="Customer searches for ticket">
      <incoming>Par1-CST1</incoming>
      <outgoing>CST1-SR1</outgoing>
    </task>
    <task id="PPD1" name="Provide payment details">
      <incoming>Par1-PPD1</incoming>
      <outgoing>PPD1-PARCLOSE11</outgoing>
    </task>
    <task id="SR1" name="Select route">
      <incoming>CST1-SR1</incoming>
      <outgoing>SR1-PPI1</outgoing>
    </task>
    <task id="PPI1" name="Provide personal information">
      <incoming>SR1-PPI1</incoming>
      <outgoing>PPI1-PARCLOSE11</outgoing>
    </task>
    <parallelGateway id="PARCLOSE11" name="PARCLOSE11">
      <incoming>PPD1-PARCLOSE11</incoming>
      <incoming>PPI1-PARCLOSE11</incoming>
      <outgoing>PARCLOSE11-GT1</outgoing>
    </parallelGateway>
    <task id="GT1" name="Generate ticket">
      <incoming>PARCLOSE11-GT1</incoming>
      <outgoing>GT1-USI1</outgoing>
    </task>
    <task id="USI1" name="Update seat inventory">
      <incoming>GT1-USI1</incoming>
      <outgoing>USI1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>USI1-G0</incoming>
      <outgoing>G0-STEM1</outgoing>
      <outgoing>G0-XOR_JMPBB_SRM1_SRM1</outgoing>
    </exclusiveGateway>
    <task id="STEM1" name="Send ticket via email">
      <incoming>G0-STEM1</incoming>
      <outgoing>STEM1-XORCLOSE21</outgoing>
    </task>
    <task id="SRM1" name="Send reminder">
      <incoming>XOR_JMPBB_SRM1_SRM1-SRM1</incoming>
      <outgoing>SRM1-XOR_JMPAA_SRM1_SRM1</outgoing>
    </task>
    <task id="SINS1" name="Send instructions">
      <incoming>XOR_JMPBB_SINS1_SINS1-SINS1</incoming>
      <outgoing>SINS1-XOR_JMPAA_SINS1_SINS1</outgoing>
    </task>
    <task id="STSMS1" name="Send ticket via SMS">
      <incoming>XOR_JMPAA_SINS1_SINS1-STSMS1</incoming>
      <outgoing>STSMS1-CCJ1</outgoing>
    </task>
    <task id="CCJ1" name="Customer completes journey">
      <incoming>STSMS1-CCJ1</incoming>
      <outgoing>CCJ1-PTF1</outgoing>
    </task>
    <task id="PTF1" name="Post-travel feedback or services">
      <incoming>CCJ1-PTF1</incoming>
      <outgoing>PTF1-XORCLOSE21</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE21" name="XORCLOSE21">
      <incoming>STEM1-XORCLOSE21</incoming>
      <incoming>PTF1-XORCLOSE21</incoming>
      <outgoing>XORCLOSE21-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE21-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_SINS1_SINS1" name="XOR_JMPAA_Send instructions">
      <incoming>SINS1-XOR_JMPAA_SINS1_SINS1</incoming>
      <outgoing>XOR_JMPAA_SINS1_SINS1-STSMS1</outgoing>
      <outgoing>XOR_JMPAA_SINS1_SINS1-XOR_JMPBB_SINS1_SINS1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_SINS1_SINS1" name="XOR_JMPBB_Send instructions">
      <incoming>XOR_JMPAA_SINS1_SINS1-XOR_JMPBB_SINS1_SINS1</incoming>
      <incoming>XOR_JMPAA_SRM1_SRM1-XOR_JMPBB_SINS1_SINS1</incoming>
      <outgoing>XOR_JMPBB_SINS1_SINS1-SINS1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPAA_SRM1_SRM1" name="XOR_JMPAA_Send reminder">
      <incoming>SRM1-XOR_JMPAA_SRM1_SRM1</incoming>
      <outgoing>XOR_JMPAA_SRM1_SRM1-XOR_JMPBB_SINS1_SINS1</outgoing>
      <outgoing>XOR_JMPAA_SRM1_SRM1-XOR_JMPBB_SRM1_SRM1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_SRM1_SRM1" name="XOR_JMPBB_Send reminder">
      <incoming>G0-XOR_JMPBB_SRM1_SRM1</incoming>
      <incoming>XOR_JMPAA_SRM1_SRM1-XOR_JMPBB_SRM1_SRM1</incoming>
      <outgoing>XOR_JMPBB_SRM1_SRM1-SRM1</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Default_init-SDT1" sourceRef="Default_init" targetRef="SDT1"/>
    <sequenceFlow id="SDT1-Par1" sourceRef="SDT1" targetRef="Par1"/>
    <sequenceFlow id="Par1-CST1" sourceRef="Par1" targetRef="CST1"/>
    <sequenceFlow id="Par1-PPD1" sourceRef="Par1" targetRef="PPD1"/>
    <sequenceFlow id="CST1-SR1" sourceRef="CST1" targetRef="SR1"/>
    <sequenceFlow id="PPD1-PARCLOSE11" sourceRef="PPD1" targetRef="PARCLOSE11"/>
    <sequenceFlow id="SR1-PPI1" sourceRef="SR1" targetRef="PPI1"/>
    <sequenceFlow id="PPI1-PARCLOSE11" sourceRef="PPI1" targetRef="PARCLOSE11"/>
    <sequenceFlow id="PARCLOSE11-GT1" sourceRef="PARCLOSE11" targetRef="GT1"/>
    <sequenceFlow id="GT1-USI1" sourceRef="GT1" targetRef="USI1"/>
    <sequenceFlow id="USI1-G0" sourceRef="USI1" targetRef="G0"/>
    <sequenceFlow id="G0-STEM1" sourceRef="G0" targetRef="STEM1"/>
    <sequenceFlow id="G0-XOR_JMPBB_SRM1_SRM1" sourceRef="G0" targetRef="XOR_JMPBB_SRM1_SRM1"/>
    <sequenceFlow id="STEM1-XORCLOSE21" sourceRef="STEM1" targetRef="XORCLOSE21"/>
    <sequenceFlow id="SRM1-XOR_JMPAA_SRM1_SRM1" sourceRef="SRM1" targetRef="XOR_JMPAA_SRM1_SRM1"/>
    <sequenceFlow id="SINS1-XOR_JMPAA_SINS1_SINS1" sourceRef="SINS1" targetRef="XOR_JMPAA_SINS1_SINS1"/>
    <sequenceFlow id="STSMS1-CCJ1" sourceRef="STSMS1" targetRef="CCJ1"/>
    <sequenceFlow id="CCJ1-PTF1" sourceRef="CCJ1" targetRef="PTF1"/>
    <sequenceFlow id="PTF1-XORCLOSE21" sourceRef="PTF1" targetRef="XORCLOSE21"/>
    <sequenceFlow id="XORCLOSE21-END" sourceRef="XORCLOSE21" targetRef="END"/>
    <sequenceFlow id="XOR_JMPAA_SINS1_SINS1-STSMS1" sourceRef="XOR_JMPAA_SINS1_SINS1" targetRef="STSMS1"/>
    <sequenceFlow id="XOR_JMPAA_SINS1_SINS1-XOR_JMPBB_SINS1_SINS1" sourceRef="XOR_JMPAA_SINS1_SINS1" targetRef="XOR_JMPBB_SINS1_SINS1"/>
    <sequenceFlow id="XOR_JMPBB_SINS1_SINS1-SINS1" sourceRef="XOR_JMPBB_SINS1_SINS1" targetRef="SINS1"/>
    <sequenceFlow id="XOR_JMPAA_SRM1_SRM1-XOR_JMPBB_SINS1_SINS1" sourceRef="XOR_JMPAA_SRM1_SRM1" targetRef="XOR_JMPBB_SINS1_SINS1"/>
    <sequenceFlow id="XOR_JMPAA_SRM1_SRM1-XOR_JMPBB_SRM1_SRM1" sourceRef="XOR_JMPAA_SRM1_SRM1" targetRef="XOR_JMPBB_SRM1_SRM1"/>
    <sequenceFlow id="XOR_JMPBB_SRM1_SRM1-SRM1" sourceRef="XOR_JMPBB_SRM1_SRM1" targetRef="SRM1"/>
  </process>
