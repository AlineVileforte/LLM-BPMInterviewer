    <sequenceFlow id="PARCLOSE5-LC1" sourceRef="PARCLOSE5" targetRef="LC1"/>
    <sequenceFlow id="LC1-TPRT1" sourceRef="LC1" targetRef="TPRT1"/>
    <sequenceFlow id="TPRT1-CLCRM1" sourceRef="TPRT1" targetRef="CLCRM1"/>
    <sequenceFlow id="CLCRM1-Par9" sourceRef="CLCRM1" targetRef="Par9"/>
    <sequenceFlow id="Par9-APFO1" sourceRef="Par9" targetRef="APFO1"/>
    <sequenceFlow id="Par9-G0" sourceRef="Par9" targetRef="G0"/>
    <sequenceFlow id="APFO1-CPE1" sourceRef="APFO1" targetRef="CPE1"/>
    <sequenceFlow id="G0-STFUL1" sourceRef="G0" targetRef="STFUL1"/>
    <sequenceFlow id="G0-XORCLOSE16" sourceRef="G0" targetRef="XORCLOSE16"/>
    <sequenceFlow id="STFUL1-XORCLOSE16" sourceRef="STFUL1" targetRef="XORCLOSE16"/>
    <sequenceFlow id="CPE1-PARCLOSE17" sourceRef="CPE1" targetRef="PARCLOSE17"/>
    <sequenceFlow id="XORCLOSE16-PARCLOSE17" sourceRef="XORCLOSE16" targetRef="PARCLOSE17"/>
    <sequenceFlow id="PARCLOSE17-END" sourceRef="PARCLOSE17" targetRef="END"/>
  </process>
