<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_a77f3bcd-4f60-489e-a6a6-77a31c843ef1" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DCO1</outgoing>
    </startEvent>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>Default_init-DCO1</incoming>
      <outgoing>DCO1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>DCO1-Par1</incoming>
      <outgoing>Par1-DV1</outgoing>
      <outgoing>Par1-SPC1</outgoing>
    </parallelGateway>
    <task id="DV1" name="Design visuals">
      <incoming>Par1-DV1</incoming>
      <outgoing>DV1-CC1</outgoing>
    </task>
    <task id="CC1" name="Create content">
      <incoming>DV1-CC1</incoming>
      <outgoing>CC1-PARCLOSE6</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>Par1-SPC1</incoming>
      <outgoing>SPC1-LC1</outgoing>
    </task>
    <task id="LC1" name="Launch campaign">
      <incoming>SPC1-LC1</incoming>
      <outgoing>LC1-PARCLOSE6</outgoing>
    </task>
    <parallelGateway id="PARCLOSE6" name="PARCLOSE6">
      <incoming>CC1-PARCLOSE6</incoming>
      <incoming>LC1-PARCLOSE6</incoming>
      <outgoing>PARCLOSE6-CLCRM1</outgoing>
    </parallelGateway>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>PARCLOSE6-CLCRM1</incoming>
      <outgoing>CLCRM1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CLCRM1-G0</incoming>
      <outgoing>G0-STFUL1</outgoing>
      <outgoing>G0-XORCLOSE12</outgoing>
    </exclusiveGateway>
    <task id="STFUL1" name="Sales teams follows up on leads">
      <incoming>G0-STFUL1</incoming>
      <outgoing>STFUL1-XORCLOSE12</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE12" name="XORCLOSE12">
      <incoming>G0-XORCLOSE12</incoming>
      <incoming>STFUL1-XORCLOSE12</incoming>
      <outgoing>XORCLOSE12-TPRT1</outgoing>
    </exclusiveGateway>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>XORCLOSE12-TPRT1</incoming>
      <outgoing>TPRT1-APFO1</outgoing>
    </task>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>TPRT1-APFO1</incoming>
      <outgoing>APFO1-CPE1</outgoing>
    </task>
    <task id="CPE1" name="Campaign period ends">
      <incoming>APFO1-CPE1</incoming>
      <outgoing>CPE1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>CPE1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DCO1" sourceRef="Default_init" targetRef="DCO1"/>
    <sequenceFlow id="DCO1-Par1" sourceRef="DCO1" targetRef="Par1"/>
    <sequenceFlow id="Par1-DV1" sourceRef="Par1" targetRef="DV1"/>
    <sequenceFlow id="Par1-SPC1" sourceRef="Par1" targetRef="SPC1"/>
    <sequenceFlow id="DV1-CC1" sourceRef="DV1" targetRef="CC1"/>
    <sequenceFlow id="CC1-PARCLOSE6" sourceRef="CC1" targetRef="PARCLOSE6"/>
    <sequenceFlow id="SPC1-LC1" sourceRef="SPC1" targetRef="LC1"/>
    <sequenceFlow id="LC1-PARCLOSE6" sourceRef="LC1" targetRef="PARCLOSE6"/>
    <sequenceFlow id="PARCLOSE6-CLCRM1" sourceRef="PARCLOSE6" targetRef="CLCRM1"/>
    <sequenceFlow id="CLCRM1-G0" sourceRef="CLCRM1" targetRef="G0"/>
    <sequenceFlow id="G0-STFUL1" sourceRef="G0" targetRef="STFUL1"/>
    <sequenceFlow id="G0-XORCLOSE12" sourceRef="G0" targetRef="XORCLOSE12"/>
    <sequenceFlow id="STFUL1-XORCLOSE12" sourceRef="STFUL1" targetRef="XORCLOSE12"/>
    <sequenceFlow id="XORCLOSE12-TPRT1" sourceRef="XORCLOSE12" targetRef="TPRT1"/>
    <sequenceFlow id="TPRT1-APFO1" sourceRef="TPRT1" targetRef="APFO1"/>
    <sequenceFlow id="APFO1-CPE1" sourceRef="APFO1" targetRef="CPE1"/>
    <sequenceFlow id="CPE1-END" sourceRef="CPE1" targetRef="END"/>
  </process>
