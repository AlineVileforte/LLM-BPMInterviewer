<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_8dbdbba6-91ce-4267-a9ba-08e9ac89c862" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DCO1</outgoing>
    </startEvent>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>Default_init-DCO1</incoming>
      <outgoing>DCO1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>DCO1-Par1</incoming>
      <outgoing>Par1-DV1</outgoing>
      <outgoing>Par1-SPC1</outgoing>
    </parallelGateway>
    <task id="DV1" name="Design visuals">
      <incoming>Par1-DV1</incoming>
      <outgoing>DV1-PARCLOSE11</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>Par1-SPC1</incoming>
      <outgoing>SPC1-CC1</outgoing>
    </task>
    <task id="CC1" name="Create content">
      <incoming>SPC1-CC1</incoming>
      <outgoing>CC1-PARCLOSE11</outgoing>
    </task>
    <parallelGateway id="PARCLOSE11" name="PARCLOSE11">
      <incoming>DV1-PARCLOSE11</incoming>
      <incoming>CC1-PARCLOSE11</incoming>
      <outgoing>PARCLOSE11-LC1</outgoing>
    </parallelGateway>
    <task id="LC1" name="Launch campaign">
      <incoming>PARCLOSE11-LC1</incoming>
      <outgoing>LC1-TPRT1</outgoing>
    </task>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>LC1-TPRT1</incoming>
      <outgoing>TPRT1-APFO1</outgoing>
    </task>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>TPRT1-APFO1</incoming>
      <outgoing>APFO1-CLCRM1</outgoing>
    </task>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>APFO1-CLCRM1</incoming>
      <outgoing>CLCRM1-Par16</outgoing>
    </task>
    <parallelGateway id="Par16" name="PAR">
      <incoming>CLCRM1-Par16</incoming>
      <outgoing>Par16-STFUL1</outgoing>
      <outgoing>Par16-CPE1</outgoing>
    </parallelGateway>
    <task id="STFUL1" name="Sales teams follows up on leads">
      <incoming>Par16-STFUL1</incoming>
      <outgoing>STFUL1-PARCLOSE19</outgoing>
    </task>
    <task id="CPE1" name="Campaign period ends">
      <incoming>Par16-CPE1</incoming>
      <outgoing>CPE1-PARCLOSE19</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>STFUL1-PARCLOSE19</incoming>
      <incoming>CPE1-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE19-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DCO1" sourceRef="Default_init" targetRef="DCO1"/>
    <sequenceFlow id="DCO1-Par1" sourceRef="DCO1" targetRef="Par1"/>
    <sequenceFlow id="Par1-DV1" sourceRef="Par1" targetRef="DV1"/>
    <sequenceFlow id="Par1-SPC1" sourceRef="Par1" targetRef="SPC1"/>
    <sequenceFlow id="DV1-PARCLOSE11" sourceRef="DV1" targetRef="PARCLOSE11"/>
    <sequenceFlow id="SPC1-CC1" sourceRef="SPC1" targetRef="CC1"/>
    <sequenceFlow id="CC1-PARCLOSE11" sourceRef="CC1" targetRef="PARCLOSE11"/>
    <sequenceFlow id="PARCLOSE11-LC1" sourceRef="PARCLOSE11" targetRef="LC1"/>
    <sequenceFlow id="LC1-TPRT1" sourceRef="LC1" targetRef="TPRT1"/>
    <sequenceFlow id="TPRT1-APFO1" sourceRef="TPRT1" targetRef="APFO1"/>
    <sequenceFlow id="APFO1-CLCRM1" sourceRef="APFO1" targetRef="CLCRM1"/>
    <sequenceFlow id="CLCRM1-Par16" sourceRef="CLCRM1" targetRef="Par16"/>
    <sequenceFlow id="Par16-STFUL1" sourceRef="Par16" targetRef="STFUL1"/>
    <sequenceFlow id="Par16-CPE1" sourceRef="Par16" targetRef="CPE1"/>
    <sequenceFlow id="STFUL1-PARCLOSE19" sourceRef="STFUL1" targetRef="PARCLOSE19"/>
    <sequenceFlow id="CPE1-PARCLOSE19" sourceRef="CPE1" targetRef="PARCLOSE19"/>
    <sequenceFlow id="PARCLOSE19-END" sourceRef="PARCLOSE19" targetRef="END"/>
  </process>
