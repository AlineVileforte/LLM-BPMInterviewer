<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_caa732ad-632d-487b-8706-a802249958ab" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DCO1</outgoing>
    </startEvent>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>Default_init-DCO1</incoming>
      <outgoing>DCO1-SPC1</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>DCO1-SPC1</incoming>
      <outgoing>SPC1-DV1</outgoing>
    </task>
    <task id="DV1" name="Design visuals">
      <incoming>SPC1-DV1</incoming>
      <outgoing>DV1-CC1</outgoing>
    </task>
    <task id="CC1" name="Create content">
      <incoming>DV1-CC1</incoming>
      <outgoing>CC1-LC1</outgoing>
    </task>
    <task id="LC1" name="Launch campaign">
      <incoming>CC1-LC1</incoming>
      <outgoing>LC1-Par5</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>LC1-Par5</incoming>
      <outgoing>Par5-TPRT1</outgoing>
      <outgoing>Par5-CLCRM1</outgoing>
    </parallelGateway>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>Par5-TPRT1</incoming>
      <outgoing>TPRT1-APFO1</outgoing>
    </task>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>Par5-CLCRM1</incoming>
      <outgoing>CLCRM1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CLCRM1-G0</incoming>
      <outgoing>G0-STFUL1</outgoing>
      <outgoing>G0-XORCLOSE16</outgoing>
    </exclusiveGateway>
    <task id="STFUL1" name="Sales teams follows up on leads">
      <incoming>G0-STFUL1</incoming>
      <outgoing>STFUL1-XORCLOSE16</outgoing>
    </task>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>TPRT1-APFO1</incoming>
      <outgoing>APFO1-PARCLOSE17</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
      <incoming>G0-XORCLOSE16</incoming>
      <incoming>STFUL1-XORCLOSE16</incoming>
      <outgoing>XORCLOSE16-PARCLOSE17</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>APFO1-PARCLOSE17</incoming>
      <incoming>XORCLOSE16-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-CPE1</outgoing>
    </parallelGateway>
    <task id="CPE1" name="Campaign period ends">
      <incoming>PARCLOSE17-CPE1</incoming>
      <outgoing>CPE1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>CPE1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DCO1" sourceRef="Default_init" targetRef="DCO1"/>
    <sequenceFlow id="DCO1-SPC1" sourceRef="DCO1" targetRef="SPC1"/>
    <sequenceFlow id="SPC1-DV1" sourceRef="SPC1" targetRef="DV1"/>
    <sequenceFlow id="DV1-CC1" sourceRef="DV1" targetRef="CC1"/>
    <sequenceFlow id="CC1-LC1" sourceRef="CC1" targetRef="LC1"/>
    <sequenceFlow id="LC1-Par5" sourceRef="LC1" targetRef="Par5"/>
    <sequenceFlow id="Par5-TPRT1" sourceRef="Par5" targetRef="TPRT1"/>
    <sequenceFlow id="Par5-CLCRM1" sourceRef="Par5" targetRef="CLCRM1"/>
    <sequenceFlow id="TPRT1-APFO1" sourceRef="TPRT1" targetRef="APFO1"/>
    <sequenceFlow id="CLCRM1-G0" sourceRef="CLCRM1" targetRef="G0"/>
    <sequenceFlow id="G0-STFUL1" sourceRef="G0" targetRef="STFUL1"/>
    <sequenceFlow id="G0-XORCLOSE16" sourceRef="G0" targetRef="XORCLOSE16"/>
    <sequenceFlow id="STFUL1-XORCLOSE16" sourceRef="STFUL1" targetRef="XORCLOSE16"/>
    <sequenceFlow id="APFO1-PARCLOSE17" sourceRef="APFO1" targetRef="PARCLOSE17"/>
    <sequenceFlow id="XORCLOSE16-PARCLOSE17" sourceRef="XORCLOSE16" targetRef="PARCLOSE17"/>
    <sequenceFlow id="PARCLOSE17-CPE1" sourceRef="PARCLOSE17" targetRef="CPE1"/>
    <sequenceFlow id="CPE1-END" sourceRef="CPE1" targetRef="END"/>
  </process>
