<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_9398d87f-eb35-4acd-851a-b5f5adb2fea9" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DCO1</outgoing>
    </startEvent>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>Default_init-DCO1</incoming>
      <outgoing>DCO1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>DCO1-Par1</incoming>
      <outgoing>Par1-DV1</outgoing>
      <outgoing>Par1-SPC1</outgoing>
    </parallelGateway>
    <task id="DV1" name="Design visuals">
      <incoming>Par1-DV1</incoming>
      <outgoing>DV1-PARCLOSE9</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>Par1-SPC1</incoming>
      <outgoing>SPC1-CC1</outgoing>
    </task>
    <task id="CC1" name="Create content">
      <incoming>SPC1-CC1</incoming>
      <outgoing>CC1-PARCLOSE9</outgoing>
    </task>
    <parallelGateway id="PARCLOSE9" name="PARCLOSE9">
      <incoming>DV1-PARCLOSE9</incoming>
      <incoming>CC1-PARCLOSE9</incoming>
      <outgoing>PARCLOSE9-LC1</outgoing>
    </parallelGateway>
    <task id="LC1" name="Launch campaign">
      <incoming>PARCLOSE9-LC1</incoming>
      <outgoing>LC1-TPRT1</outgoing>
    </task>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>LC1-TPRT1</incoming>
      <outgoing>TPRT1-Par12</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>TPRT1-Par12</incoming>
      <outgoing>Par12-CLCRM1</outgoing>
      <outgoing>Par12-APFO1</outgoing>
    </parallelGateway>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>Par12-CLCRM1</incoming>
      <outgoing>CLCRM1-PARCLOSE15</outgoing>
    </task>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>Par12-APFO1</incoming>
      <outgoing>APFO1-PARCLOSE15</outgoing>
    </task>
    <parallelGateway id="PARCLOSE15" name="PARCLOSE15">
      <incoming>CLCRM1-PARCLOSE15</incoming>
      <incoming>APFO1-PARCLOSE15</incoming>
      <outgoing>PARCLOSE15-CPE1</outgoing>
    </parallelGateway>
    <task id="CPE1" name="Campaign period ends">
      <incoming>PARCLOSE15-CPE1</incoming>
      <outgoing>CPE1-STFUL1</outgoing>
    </task>
    <task id="STFUL1" name="Sales teams follows up on leads">
      <incoming>CPE1-STFUL1</incoming>
      <outgoing>STFUL1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>STFUL1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DCO1" sourceRef="Default_init" targetRef="DCO1"/>
    <sequenceFlow id="DCO1-Par1" sourceRef="DCO1" targetRef="Par1"/>
    <sequenceFlow id="Par1-DV1" sourceRef="Par1" targetRef="DV1"/>
    <sequenceFlow id="Par1-SPC1" sourceRef="Par1" targetRef="SPC1"/>
    <sequenceFlow id="DV1-PARCLOSE9" sourceRef="DV1" targetRef="PARCLOSE9"/>
    <sequenceFlow id="SPC1-CC1" sourceRef="SPC1" targetRef="CC1"/>
    <sequenceFlow id="CC1-PARCLOSE9" sourceRef="CC1" targetRef="PARCLOSE9"/>
    <sequenceFlow id="PARCLOSE9-LC1" sourceRef="PARCLOSE9" targetRef="LC1"/>
    <sequenceFlow id="LC1-TPRT1" sourceRef="LC1" targetRef="TPRT1"/>
    <sequenceFlow id="TPRT1-Par12" sourceRef="TPRT1" targetRef="Par12"/>
    <sequenceFlow id="Par12-CLCRM1" sourceRef="Par12" targetRef="CLCRM1"/>
    <sequenceFlow id="Par12-APFO1" sourceRef="Par12" targetRef="APFO1"/>
    <sequenceFlow id="CLCRM1-PARCLOSE15" sourceRef="CLCRM1" targetRef="PARCLOSE15"/>
    <sequenceFlow id="APFO1-PARCLOSE15" sourceRef="APFO1" targetRef="PARCLOSE15"/>
    <sequenceFlow id="PARCLOSE15-CPE1" sourceRef="PARCLOSE15" targetRef="CPE1"/>
    <sequenceFlow id="CPE1-STFUL1" sourceRef="CPE1" targetRef="STFUL1"/>
    <sequenceFlow id="STFUL1-END" sourceRef="STFUL1" targetRef="END"/>
  </process>
