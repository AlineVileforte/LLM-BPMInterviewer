<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_11bc38ef-4596-4cdb-99e7-994f9f734b80" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DCO1</outgoing>
    </startEvent>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>Default_init-DCO1</incoming>
      <outgoing>DCO1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>DCO1-Par1</incoming>
      <outgoing>Par1-CC1</outgoing>
      <outgoing>Par1-SPC1</outgoing>
    </parallelGateway>
    <task id="CC1" name="Create content">
      <incoming>Par1-CC1</incoming>
      <outgoing>CC1-DV1</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>Par1-SPC1</incoming>
      <outgoing>SPC1-PARCLOSE9</outgoing>
    </task>
    <task id="DV1" name="Design visuals">
      <incoming>CC1-DV1</incoming>
      <outgoing>DV1-PARCLOSE9</outgoing>
    </task>
    <parallelGateway id="PARCLOSE9" name="PARCLOSE9">
      <incoming>SPC1-PARCLOSE9</incoming>
      <incoming>DV1-PARCLOSE9</incoming>
      <outgoing>PARCLOSE9-LC1</outgoing>
    </parallelGateway>
    <task id="LC1" name="Launch campaign">
      <incoming>PARCLOSE9-LC1</incoming>
      <outgoing>LC1-CLCRM1</outgoing>
    </task>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>LC1-CLCRM1</incoming>
      <outgoing>CLCRM1-Par12</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>CLCRM1-Par12</incoming>
      <outgoing>Par12-TPRT1</outgoing>
      <outgoing>Par12-STFUL1</outgoing>
    </parallelGateway>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>Par12-TPRT1</incoming>
      <outgoing>TPRT1-CPE1</outgoing>
    </task>
    <task id="STFUL1" name="Sales teams follows up on leads">
      <incoming>Par12-STFUL1</incoming>
      <outgoing>STFUL1-PARCLOSE16</outgoing>
    </task>
    <task id="CPE1" name="Campaign period ends">
      <incoming>TPRT1-CPE1</incoming>
      <outgoing>CPE1-PARCLOSE16</outgoing>
    </task>
    <parallelGateway id="PARCLOSE16" name="PARCLOSE16">
      <incoming>STFUL1-PARCLOSE16</incoming>
      <incoming>CPE1-PARCLOSE16</incoming>
      <outgoing>PARCLOSE16-APFO1</outgoing>
    </parallelGateway>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>PARCLOSE16-APFO1</incoming>
      <outgoing>APFO1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>APFO1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DCO1" sourceRef="Default_init" targetRef="DCO1"/>
    <sequenceFlow id="DCO1-Par1" sourceRef="DCO1" targetRef="Par1"/>
    <sequenceFlow id="Par1-CC1" sourceRef="Par1" targetRef="CC1"/>
    <sequenceFlow id="Par1-SPC1" sourceRef="Par1" targetRef="SPC1"/>
    <sequenceFlow id="CC1-DV1" sourceRef="CC1" targetRef="DV1"/>
    <sequenceFlow id="SPC1-PARCLOSE9" sourceRef="SPC1" targetRef="PARCLOSE9"/>
    <sequenceFlow id="DV1-PARCLOSE9" sourceRef="DV1" targetRef="PARCLOSE9"/>
    <sequenceFlow id="PARCLOSE9-LC1" sourceRef="PARCLOSE9" targetRef="LC1"/>
    <sequenceFlow id="LC1-CLCRM1" sourceRef="LC1" targetRef="CLCRM1"/>
    <sequenceFlow id="CLCRM1-Par12" sourceRef="CLCRM1" targetRef="Par12"/>
    <sequenceFlow id="Par12-TPRT1" sourceRef="Par12" targetRef="TPRT1"/>
    <sequenceFlow id="Par12-STFUL1" sourceRef="Par12" targetRef="STFUL1"/>
    <sequenceFlow id="TPRT1-CPE1" sourceRef="TPRT1" targetRef="CPE1"/>
    <sequenceFlow id="STFUL1-PARCLOSE16" sourceRef="STFUL1" targetRef="PARCLOSE16"/>
    <sequenceFlow id="CPE1-PARCLOSE16" sourceRef="CPE1" targetRef="PARCLOSE16"/>
    <sequenceFlow id="PARCLOSE16-APFO1" sourceRef="PARCLOSE16" targetRef="APFO1"/>
    <sequenceFlow id="APFO1-END" sourceRef="APFO1" targetRef="END"/>
  </process>
