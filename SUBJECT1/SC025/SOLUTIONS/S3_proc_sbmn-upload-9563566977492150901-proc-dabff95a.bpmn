    <sequenceFlow id="SPC1-PARCLOSE5" sourceRef="SPC1" targetRef="PARCLOSE5"/>
    <sequenceFlow id="PARCLOSE5-LC1" sourceRef="PARCLOSE5" targetRef="LC1"/>
    <sequenceFlow id="LC1-Par7" sourceRef="LC1" targetRef="Par7"/>
    <sequenceFlow id="Par7-TPRT1" sourceRef="Par7" targetRef="TPRT1"/>
    <sequenceFlow id="Par7-CLCRM1" sourceRef="Par7" targetRef="CLCRM1"/>
    <sequenceFlow id="TPRT1-APFO1" sourceRef="TPRT1" targetRef="APFO1"/>
    <sequenceFlow id="CLCRM1-G0" sourceRef="CLCRM1" targetRef="G0"/>
    <sequenceFlow id="APFO1-PARCLOSE19" sourceRef="APFO1" targetRef="PARCLOSE19"/>
    <sequenceFlow id="G0-STFUL1" sourceRef="G0" targetRef="STFUL1"/>
    <sequenceFlow id="G0-XORCLOSE18" sourceRef="G0" targetRef="XORCLOSE18"/>
    <sequenceFlow id="STFUL1-XORCLOSE18" sourceRef="STFUL1" targetRef="XORCLOSE18"/>
    <sequenceFlow id="XORCLOSE18-PARCLOSE19" sourceRef="XORCLOSE18" targetRef="PARCLOSE19"/>
    <sequenceFlow id="PARCLOSE19-CPE1" sourceRef="PARCLOSE19" targetRef="CPE1"/>
    <sequenceFlow id="CPE1-END" sourceRef="CPE1" targetRef="END"/>
  </process>
