<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_e1fa5ed6-5093-4820-a121-9466058afa1c" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DCO1</outgoing>
    </startEvent>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>Default_init-DCO1</incoming>
      <outgoing>DCO1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>DCO1-Par1</incoming>
      <outgoing>Par1-DV1</outgoing>
      <outgoing>Par1-SPC1</outgoing>
    </parallelGateway>
    <task id="DV1" name="Design visuals">
      <incoming>Par1-DV1</incoming>
      <outgoing>DV1-CC1</outgoing>
    </task>
    <task id="CC1" name="Create content">
      <incoming>DV1-CC1</incoming>
      <outgoing>CC1-PARCLOSE5</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>Par1-SPC1</incoming>
      <outgoing>SPC1-PARCLOSE5</outgoing>
    </task>
    <parallelGateway id="PARCLOSE5" name="PARCLOSE5">
      <incoming>CC1-PARCLOSE5</incoming>
      <incoming>SPC1-PARCLOSE5</incoming>
      <outgoing>PARCLOSE5-LC1</outgoing>
    </parallelGateway>
    <task id="LC1" name="Launch campaign">
      <incoming>PARCLOSE5-LC1</incoming>
      <outgoing>LC1-Par7</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>LC1-Par7</incoming>
      <outgoing>Par7-TPRT1</outgoing>
      <outgoing>Par7-CLCRM1</outgoing>
    </parallelGateway>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>Par7-TPRT1</incoming>
      <outgoing>TPRT1-APFO1</outgoing>
    </task>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>Par7-CLCRM1</incoming>
      <outgoing>CLCRM1-G0</outgoing>
    </task>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>TPRT1-APFO1</incoming>
      <outgoing>APFO1-PARCLOSE19</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CLCRM1-G0</incoming>
      <outgoing>G0-STFUL1</outgoing>
      <outgoing>G0-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="STFUL1" name="Sales teams follows up on leads">
      <incoming>G0-STFUL1</incoming>
      <outgoing>STFUL1-XORCLOSE18</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>G0-XORCLOSE18</incoming>
      <incoming>STFUL1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-PARCLOSE19</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>APFO1-PARCLOSE19</incoming>
      <incoming>XORCLOSE18-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-CPE1</outgoing>
    </parallelGateway>
    <task id="CPE1" name="Campaign period ends">
      <incoming>PARCLOSE19-CPE1</incoming>
      <outgoing>CPE1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>CPE1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DCO1" sourceRef="Default_init" targetRef="DCO1"/>
    <sequenceFlow id="DCO1-Par1" sourceRef="DCO1" targetRef="Par1"/>
    <sequenceFlow id="Par1-DV1" sourceRef="Par1" targetRef="DV1"/>
