    <sequenceFlow id="G1-RF1" sourceRef="G1" targetRef="RF1"/>
    <sequenceFlow id="G1-SPOS1" sourceRef="G1" targetRef="SPOS1"/>
    <sequenceFlow id="RF1-RC1" sourceRef="RF1" targetRef="RC1"/>
    <sequenceFlow id="SPOS1-MO1" sourceRef="SPOS1" targetRef="MO1"/>
    <sequenceFlow id="RC1-RLF1" sourceRef="RC1" targetRef="RLF1"/>
    <sequenceFlow id="MO1-Par12" sourceRef="MO1" targetRef="Par12"/>
    <sequenceFlow id="RLF1-XORCLOSE16" sourceRef="RLF1" targetRef="XORCLOSE16"/>
    <sequenceFlow id="Par12-SPS1" sourceRef="Par12" targetRef="SPS1"/>
    <sequenceFlow id="Par12-SI1" sourceRef="Par12" targetRef="SI1"/>
    <sequenceFlow id="SPS1-PARCLOSE15" sourceRef="SPS1" targetRef="PARCLOSE15"/>
    <sequenceFlow id="SI1-PARCLOSE15" sourceRef="SI1" targetRef="PARCLOSE15"/>
    <sequenceFlow id="PARCLOSE15-XORCLOSE16" sourceRef="PARCLOSE15" targetRef="XORCLOSE16"/>
    <sequenceFlow id="XORCLOSE16-END" sourceRef="XORCLOSE16" targetRef="END"/>
  </process>
