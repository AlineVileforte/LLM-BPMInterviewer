<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_9d7c987b-7df7-43a4-bb9f-811c63a322ab" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CI1</outgoing>
    </startEvent>
    <task id="CI1" name="Check Inventory">
      <incoming>Default_init-CI1</incoming>
      <outgoing>CI1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CI1-G0</incoming>
      <outgoing>G0-CPO1</outgoing>
      <outgoing>G0-XORCLOSE4</outgoing>
    </exclusiveGateway>
    <task id="CPO1" name="Construct Purchase Order">
      <incoming>G0-CPO1</incoming>
      <outgoing>CPO1-XORCLOSE4</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE4" name="XORCLOSE4">
      <incoming>G0-XORCLOSE4</incoming>
      <incoming>CPO1-XORCLOSE4</incoming>
      <outgoing>XORCLOSE4-RPO1</outgoing>
    </exclusiveGateway>
    <task id="RPO1" name="Review Purchase Order">
      <incoming>XORCLOSE4-RPO1</incoming>
      <outgoing>RPO1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>RPO1-G1</incoming>
      <outgoing>G1-RF1</outgoing>
      <outgoing>G1-SPOS1</outgoing>
    </exclusiveGateway>
    <task id="RF1" name="Reserve Fund">
      <incoming>G1-RF1</incoming>
      <outgoing>RF1-RC1</outgoing>
    </task>
    <task id="SPOS1" name="Send Purchase Order to Supplier">
      <incoming>G1-SPOS1</incoming>
      <outgoing>SPOS1-MO1</outgoing>
    </task>
    <task id="RC1" name="Receive Confirmation">
      <incoming>RF1-RC1</incoming>
      <outgoing>RC1-RLF1</outgoing>
    </task>
    <task id="MO1" name="Match Order">
      <incoming>SPOS1-MO1</incoming>
      <outgoing>MO1-Par12</outgoing>
    </task>
    <task id="RLF1" name="Release Funds">
      <incoming>RC1-RLF1</incoming>
      <outgoing>RLF1-XORCLOSE16</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>MO1-Par12</incoming>
      <outgoing>Par12-SPS1</outgoing>
      <outgoing>Par12-SI1</outgoing>
    </parallelGateway>
    <task id="SPS1" name="Send Packing Slip">
      <incoming>Par12-SPS1</incoming>
      <outgoing>SPS1-PARCLOSE15</outgoing>
    </task>
    <task id="SI1" name="Send Invoice">
      <incoming>Par12-SI1</incoming>
      <outgoing>SI1-PARCLOSE15</outgoing>
    </task>
    <parallelGateway id="PARCLOSE15" name="PARCLOSE15">
      <incoming>SPS1-PARCLOSE15</incoming>
      <incoming>SI1-PARCLOSE15</incoming>
      <outgoing>PARCLOSE15-XORCLOSE16</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
      <incoming>RLF1-XORCLOSE16</incoming>
      <incoming>PARCLOSE15-XORCLOSE16</incoming>
      <outgoing>XORCLOSE16-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE16-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-CI1" sourceRef="Default_init" targetRef="CI1"/>
    <sequenceFlow id="CI1-G0" sourceRef="CI1" targetRef="G0"/>
    <sequenceFlow id="G0-CPO1" sourceRef="G0" targetRef="CPO1"/>
