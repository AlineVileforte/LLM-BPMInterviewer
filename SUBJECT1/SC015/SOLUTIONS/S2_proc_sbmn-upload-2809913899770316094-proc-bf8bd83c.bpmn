<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_20719ffa-93b2-4871-ab89-d134c8762c29" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CI1</outgoing>
    </startEvent>
    <task id="CI1" name="Check Inventory">
      <incoming>Default_init-CI1</incoming>
      <outgoing>CI1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CI1-G0</incoming>
      <outgoing>G0-CPO1</outgoing>
      <outgoing>G0-XORCLOSE4</outgoing>
    </exclusiveGateway>
    <task id="CPO1" name="Construct Purchase Order">
      <incoming>G0-CPO1</incoming>
      <outgoing>CPO1-XORCLOSE4</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE4" name="XORCLOSE4">
      <incoming>G0-XORCLOSE4</incoming>
      <incoming>CPO1-XORCLOSE4</incoming>
      <outgoing>XORCLOSE4-RPO1</outgoing>
    </exclusiveGateway>
    <task id="RPO1" name="Review Purchase Order">
      <incoming>XORCLOSE4-RPO1</incoming>
      <outgoing>RPO1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>RPO1-G1</incoming>
      <outgoing>G1-RF1</outgoing>
      <outgoing>G1-SPOS1</outgoing>
    </exclusiveGateway>
    <task id="RF1" name="Reserve Fund">
      <incoming>G1-RF1</incoming>
      <outgoing>RF1-RC1</outgoing>
    </task>
    <task id="SPOS1" name="Send Purchase Order to Supplier">
      <incoming>G1-SPOS1</incoming>
      <outgoing>SPOS1-MO1</outgoing>
    </task>
    <task id="RC1" name="Receive Confirmation">
      <incoming>RF1-RC1</incoming>
      <outgoing>RC1-RLF1</outgoing>
    </task>
    <task id="MO1" name="Match Order">
      <incoming>SPOS1-MO1</incoming>
      <outgoing>MO1-SI1</outgoing>
    </task>
    <task id="RLF1" name="Release Funds">
      <incoming>RC1-RLF1</incoming>
      <outgoing>RLF1-XORCLOSE14</outgoing>
    </task>
    <task id="SI1" name="Send Invoice">
      <incoming>MO1-SI1</incoming>
      <outgoing>SI1-SPS1</outgoing>
    </task>
    <task id="SPS1" name="Send Packing Slip">
      <incoming>SI1-SPS1</incoming>
      <outgoing>SPS1-XORCLOSE14</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>RLF1-XORCLOSE14</incoming>
      <incoming>SPS1-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE14-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-CI1" sourceRef="Default_init" targetRef="CI1"/>
    <sequenceFlow id="CI1-G0" sourceRef="CI1" targetRef="G0"/>
    <sequenceFlow id="G0-CPO1" sourceRef="G0" targetRef="CPO1"/>
    <sequenceFlow id="G0-XORCLOSE4" sourceRef="G0" targetRef="XORCLOSE4"/>
    <sequenceFlow id="CPO1-XORCLOSE4" sourceRef="CPO1" targetRef="XORCLOSE4"/>
    <sequenceFlow id="XORCLOSE4-RPO1" sourceRef="XORCLOSE4" targetRef="RPO1"/>
    <sequenceFlow id="RPO1-G1" sourceRef="RPO1" targetRef="G1"/>
    <sequenceFlow id="G1-RF1" sourceRef="G1" targetRef="RF1"/>
    <sequenceFlow id="G1-SPOS1" sourceRef="G1" targetRef="SPOS1"/>
    <sequenceFlow id="RF1-RC1" sourceRef="RF1" targetRef="RC1"/>
    <sequenceFlow id="SPOS1-MO1" sourceRef="SPOS1" targetRef="MO1"/>
    <sequenceFlow id="RC1-RLF1" sourceRef="RC1" targetRef="RLF1"/>
    <sequenceFlow id="MO1-SI1" sourceRef="MO1" targetRef="SI1"/>
    <sequenceFlow id="RLF1-XORCLOSE14" sourceRef="RLF1" targetRef="XORCLOSE14"/>
    <sequenceFlow id="SI1-SPS1" sourceRef="SI1" targetRef="SPS1"/>
    <sequenceFlow id="SPS1-XORCLOSE14" sourceRef="SPS1" targetRef="XORCLOSE14"/>
    <sequenceFlow id="XORCLOSE14-END" sourceRef="XORCLOSE14" targetRef="END"/>
  </process>
