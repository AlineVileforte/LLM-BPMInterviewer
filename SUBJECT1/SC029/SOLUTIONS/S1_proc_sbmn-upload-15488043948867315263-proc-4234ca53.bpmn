    <sequenceFlow id="LR1-AR1" sourceRef="LR1" targetRef="AR1"/>
    <sequenceFlow id="AR1-PARCLOSE12" sourceRef="AR1" targetRef="PARCLOSE12"/>
    <sequenceFlow id="PARCLOSE12-G3" sourceRef="PARCLOSE12" targetRef="G3"/>
    <sequenceFlow id="G3-IF1" sourceRef="G3" targetRef="IF1"/>
    <sequenceFlow id="G3-G4" sourceRef="G3" targetRef="G4"/>
    <sequenceFlow id="IF1-CF1" sourceRef="IF1" targetRef="CF1"/>
    <sequenceFlow id="CF1-CI1" sourceRef="CF1" targetRef="CI1"/>
    <sequenceFlow id="G4-CT1" sourceRef="G4" targetRef="CT1"/>
    <sequenceFlow id="G4-CP1" sourceRef="G4" targetRef="CP1"/>
    <sequenceFlow id="CT1-XORCLOSE20" sourceRef="CT1" targetRef="XORCLOSE20"/>
    <sequenceFlow id="CP1-XORCLOSE20" sourceRef="CP1" targetRef="XORCLOSE20"/>
    <sequenceFlow id="CI1-NS1" sourceRef="CI1" targetRef="NS1"/>
    <sequenceFlow id="XORCLOSE20-XORCLOSE22" sourceRef="XORCLOSE20" targetRef="XORCLOSE22"/>
    <sequenceFlow id="NS1-XORCLOSE22" sourceRef="NS1" targetRef="XORCLOSE22"/>
    <sequenceFlow id="XORCLOSE22-END" sourceRef="XORCLOSE22" targetRef="END"/>
  </process>
