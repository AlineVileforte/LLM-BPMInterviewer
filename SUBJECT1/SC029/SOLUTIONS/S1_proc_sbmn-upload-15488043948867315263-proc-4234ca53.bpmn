<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_6f98e7f7-4bec-4e34-95c3-c6cb201fff89" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-GI1</outgoing>
      <outgoing>Par0-IC1</outgoing>
    </parallelGateway>
    <task id="GI1" name="Gather necessary information">
      <incoming>Par0-GI1</incoming>
      <outgoing>GI1-RI1</outgoing>
    </task>
    <task id="IC1" name="Identify cause of incident">
      <incoming>Par0-IC1</incoming>
      <outgoing>IC1-PC1</outgoing>
    </task>
    <task id="RI1" name="Report incident">
      <incoming>GI1-RI1</incoming>
      <outgoing>RI1-PARCLOSE12</outgoing>
    </task>
    <task id="PC1" name="Propose corrective actions">
      <incoming>IC1-PC1</incoming>
      <outgoing>PC1-LR1</outgoing>
    </task>
    <task id="LR1" name="Log report into tracking system">
      <incoming>PC1-LR1</incoming>
      <outgoing>LR1-AR1</outgoing>
    </task>
    <task id="AR1" name="Assign report to appropriate team">
      <incoming>LR1-AR1</incoming>
      <outgoing>AR1-PARCLOSE12</outgoing>
    </task>
    <parallelGateway id="PARCLOSE12" name="PARCLOSE12">
      <incoming>RI1-PARCLOSE12</incoming>
      <incoming>AR1-PARCLOSE12</incoming>
      <outgoing>PARCLOSE12-G3</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G3" name="G3">
      <incoming>PARCLOSE12-G3</incoming>
      <outgoing>G3-IF1</outgoing>
      <outgoing>G3-G4</outgoing>
    </exclusiveGateway>
    <task id="IF1" name="Implement fix">
      <incoming>G3-IF1</incoming>
      <outgoing>IF1-CF1</outgoing>
    </task>
    <task id="CF1" name="Conduct follow-up">
      <incoming>IF1-CF1</incoming>
      <outgoing>CF1-CI1</outgoing>
    </task>
    <exclusiveGateway id="G4" name="G4">
      <incoming>G3-G4</incoming>
      <outgoing>G4-CT1</outgoing>
      <outgoing>G4-CP1</outgoing>
    </exclusiveGateway>
    <task id="CT1" name="Conduct training">
      <incoming>G4-CT1</incoming>
      <outgoing>CT1-XORCLOSE20</outgoing>
    </task>
    <task id="CP1" name="Change policy">
      <incoming>G4-CP1</incoming>
      <outgoing>CP1-XORCLOSE20</outgoing>
    </task>
    <task id="CI1" name="Close incident report">
      <incoming>CF1-CI1</incoming>
      <outgoing>CI1-NS1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>CT1-XORCLOSE20</incoming>
      <incoming>CP1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-XORCLOSE22</outgoing>
    </exclusiveGateway>
    <task id="NS1" name="Notify all stakeholders">
      <incoming>CI1-NS1</incoming>
      <outgoing>NS1-XORCLOSE22</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE22" name="XORCLOSE22">
      <incoming>XORCLOSE20-XORCLOSE22</incoming>
      <incoming>NS1-XORCLOSE22</incoming>
      <outgoing>XORCLOSE22-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE22-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
    <sequenceFlow id="Par0-GI1" sourceRef="Par0" targetRef="GI1"/>
    <sequenceFlow id="Par0-IC1" sourceRef="Par0" targetRef="IC1"/>
