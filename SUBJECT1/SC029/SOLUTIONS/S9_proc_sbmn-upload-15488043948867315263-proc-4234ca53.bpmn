<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_44c65249-48d5-48ff-b220-a84a5cfe8b87" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-GI1</outgoing>
    </startEvent>
    <task id="GI1" name="Gather necessary information">
      <incoming>Default_init-GI1</incoming>
      <outgoing>GI1-IC1</outgoing>
    </task>
    <task id="IC1" name="Identify cause of incident">
      <incoming>GI1-IC1</incoming>
      <outgoing>IC1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>IC1-Par2</incoming>
      <outgoing>Par2-RI1</outgoing>
      <outgoing>Par2-PC1</outgoing>
    </parallelGateway>
    <task id="RI1" name="Report incident">
      <incoming>Par2-RI1</incoming>
      <outgoing>RI1-LR1</outgoing>
    </task>
    <task id="PC1" name="Propose corrective actions">
      <incoming>Par2-PC1</incoming>
      <outgoing>PC1-G0</outgoing>
    </task>
    <task id="LR1" name="Log report into tracking system">
      <incoming>RI1-LR1</incoming>
      <outgoing>LR1-AR1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>PC1-G0</incoming>
      <outgoing>G0-IF1</outgoing>
      <outgoing>G0-G2</outgoing>
    </exclusiveGateway>
    <task id="IF1" name="Implement fix">
      <incoming>G0-IF1</incoming>
      <outgoing>IF1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>IF1-G1</incoming>
      <outgoing>G1-CF1</outgoing>
      <outgoing>G1-XORCLOSE24</outgoing>
    </exclusiveGateway>
    <task id="CF1" name="Conduct follow-up">
      <incoming>G1-CF1</incoming>
      <outgoing>CF1-CI1</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>G0-G2</incoming>
      <outgoing>G2-CT1</outgoing>
      <outgoing>G2-CP1</outgoing>
    </exclusiveGateway>
    <task id="CT1" name="Conduct training">
      <incoming>G2-CT1</incoming>
      <outgoing>CT1-XORCLOSE20</outgoing>
    </task>
    <task id="CP1" name="Change policy">
      <incoming>G2-CP1</incoming>
      <outgoing>CP1-XORCLOSE20</outgoing>
    </task>
    <task id="AR1" name="Assign report to appropriate team">
      <incoming>LR1-AR1</incoming>
      <outgoing>AR1-PARCLOSE26</outgoing>
    </task>
    <task id="CI1" name="Close incident report">
      <incoming>CF1-CI1</incoming>
      <outgoing>CI1-NS1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>CT1-XORCLOSE20</incoming>
      <incoming>CP1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-XORCLOSE25</outgoing>
    </exclusiveGateway>
    <task id="NS1" name="Notify all stakeholders">
      <incoming>CI1-NS1</incoming>
      <outgoing>NS1-XORCLOSE24</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE24" name="XORCLOSE24">
      <incoming>G1-XORCLOSE24</incoming>
      <incoming>NS1-XORCLOSE24</incoming>
      <outgoing>XORCLOSE24-XORCLOSE25</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE25" name="XORCLOSE25">
      <incoming>XORCLOSE20-XORCLOSE25</incoming>
      <incoming>XORCLOSE24-XORCLOSE25</incoming>
      <outgoing>XORCLOSE25-PARCLOSE26</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>AR1-PARCLOSE26</incoming>
      <incoming>XORCLOSE25-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE26-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-GI1" sourceRef="Default_init" targetRef="GI1"/>
    <sequenceFlow id="GI1-IC1" sourceRef="GI1" targetRef="IC1"/>
    <sequenceFlow id="IC1-Par2" sourceRef="IC1" targetRef="Par2"/>
