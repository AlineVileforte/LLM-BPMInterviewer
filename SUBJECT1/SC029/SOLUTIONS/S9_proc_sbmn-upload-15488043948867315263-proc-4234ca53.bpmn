    <sequenceFlow id="G2-CT1" sourceRef="G2" targetRef="CT1"/>
    <sequenceFlow id="G2-CP1" sourceRef="G2" targetRef="CP1"/>
    <sequenceFlow id="CT1-XORCLOSE20" sourceRef="CT1" targetRef="XORCLOSE20"/>
    <sequenceFlow id="CP1-XORCLOSE20" sourceRef="CP1" targetRef="XORCLOSE20"/>
    <sequenceFlow id="AR1-PARCLOSE26" sourceRef="AR1" targetRef="PARCLOSE26"/>
    <sequenceFlow id="CI1-NS1" sourceRef="CI1" targetRef="NS1"/>
    <sequenceFlow id="XORCLOSE20-XORCLOSE25" sourceRef="XORCLOSE20" targetRef="XORCLOSE25"/>
    <sequenceFlow id="NS1-XORCLOSE24" sourceRef="NS1" targetRef="XORCLOSE24"/>
    <sequenceFlow id="XORCLOSE24-XORCLOSE25" sourceRef="XORCLOSE24" targetRef="XORCLOSE25"/>
    <sequenceFlow id="XORCLOSE25-PARCLOSE26" sourceRef="XORCLOSE25" targetRef="PARCLOSE26"/>
    <sequenceFlow id="PARCLOSE26-END" sourceRef="PARCLOSE26" targetRef="END"/>
  </process>
