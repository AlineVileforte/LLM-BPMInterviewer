<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_66242188-5a60-4d54-aeee-1c75a6ca5196" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-GI1</outgoing>
      <outgoing>Par0-IC1</outgoing>
    </parallelGateway>
    <task id="GI1" name="Gather necessary information">
      <incoming>Par0-GI1</incoming>
      <outgoing>GI1-RI1</outgoing>
    </task>
    <task id="IC1" name="Identify cause of incident">
      <incoming>Par0-IC1</incoming>
      <outgoing>IC1-PC1</outgoing>
    </task>
    <task id="PC1" name="Propose corrective actions">
      <incoming>IC1-PC1</incoming>
      <outgoing>PC1-G0</outgoing>
    </task>
    <task id="RI1" name="Report incident">
      <incoming>GI1-RI1</incoming>
      <outgoing>RI1-LR1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>PC1-G0</incoming>
      <outgoing>G0-IF1</outgoing>
      <outgoing>G0-G1</outgoing>
    </exclusiveGateway>
    <task id="IF1" name="Implement fix">
      <incoming>G0-IF1</incoming>
      <outgoing>IF1-CF1</outgoing>
    </task>
    <task id="LR1" name="Log report into tracking system">
      <incoming>RI1-LR1</incoming>
      <outgoing>LR1-AR1</outgoing>
    </task>
    <task id="CF1" name="Conduct follow-up">
      <incoming>IF1-CF1</incoming>
      <outgoing>CF1-CI1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>G0-G1</incoming>
      <outgoing>G1-CT1</outgoing>
      <outgoing>G1-CP1</outgoing>
    </exclusiveGateway>
    <task id="CT1" name="Conduct training">
      <incoming>G1-CT1</incoming>
      <outgoing>CT1-XORCLOSE19</outgoing>
    </task>
    <task id="CP1" name="Change policy">
      <incoming>G1-CP1</incoming>
      <outgoing>CP1-XORCLOSE19</outgoing>
    </task>
    <task id="AR1" name="Assign report to appropriate team">
      <incoming>LR1-AR1</incoming>
      <outgoing>AR1-PARCLOSE22</outgoing>
    </task>
    <task id="CI1" name="Close incident report">
      <incoming>CF1-CI1</incoming>
      <outgoing>CI1-NS1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE19" name="XORCLOSE19">
      <incoming>CT1-XORCLOSE19</incoming>
      <incoming>CP1-XORCLOSE19</incoming>
      <outgoing>XORCLOSE19-XORCLOSE21</outgoing>
    </exclusiveGateway>
    <task id="NS1" name="Notify all stakeholders">
      <incoming>CI1-NS1</incoming>
      <outgoing>NS1-XORCLOSE21</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE21" name="XORCLOSE21">
      <incoming>XORCLOSE19-XORCLOSE21</incoming>
      <incoming>NS1-XORCLOSE21</incoming>
      <outgoing>XORCLOSE21-PARCLOSE22</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>AR1-PARCLOSE22</incoming>
      <incoming>XORCLOSE21-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE22-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
