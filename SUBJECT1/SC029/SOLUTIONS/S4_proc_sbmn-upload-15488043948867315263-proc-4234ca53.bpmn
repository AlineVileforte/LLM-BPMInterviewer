    <sequenceFlow id="XORCLOSE19-XORCLOSE21" sourceRef="XORCLOSE19" targetRef="XORCLOSE21"/>
    <sequenceFlow id="NS1-XORCLOSE21" sourceRef="NS1" targetRef="XORCLOSE21"/>
    <sequenceFlow id="XORCLOSE21-PARCLOSE22" sourceRef="XORCLOSE21" targetRef="PARCLOSE22"/>
    <sequenceFlow id="PARCLOSE22-END" sourceRef="PARCLOSE22" targetRef="END"/>
  </process>
