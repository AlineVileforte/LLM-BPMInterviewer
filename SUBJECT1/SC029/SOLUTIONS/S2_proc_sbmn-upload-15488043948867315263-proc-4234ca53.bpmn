    <sequenceFlow id="G1-XORCLOSE22" sourceRef="G1" targetRef="XORCLOSE22"/>
    <sequenceFlow id="CF1-CI1" sourceRef="CF1" targetRef="CI1"/>
    <sequenceFlow id="G2-CT1" sourceRef="G2" targetRef="CT1"/>
    <sequenceFlow id="G2-CP1" sourceRef="G2" targetRef="CP1"/>
    <sequenceFlow id="CT1-XORCLOSE18" sourceRef="CT1" targetRef="XORCLOSE18"/>
    <sequenceFlow id="CP1-XORCLOSE18" sourceRef="CP1" targetRef="XORCLOSE18"/>
    <sequenceFlow id="CI1-NS1" sourceRef="CI1" targetRef="NS1"/>
    <sequenceFlow id="XORCLOSE18-XORCLOSE23" sourceRef="XORCLOSE18" targetRef="XORCLOSE23"/>
    <sequenceFlow id="NS1-XORCLOSE22" sourceRef="NS1" targetRef="XORCLOSE22"/>
    <sequenceFlow id="XORCLOSE22-XORCLOSE23" sourceRef="XORCLOSE22" targetRef="XORCLOSE23"/>
    <sequenceFlow id="XORCLOSE23-PARCLOSE24" sourceRef="XORCLOSE23" targetRef="PARCLOSE24"/>
    <sequenceFlow id="PARCLOSE24-END" sourceRef="PARCLOSE24" targetRef="END"/>
  </process>
