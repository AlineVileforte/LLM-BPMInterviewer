    <sequenceFlow id="G2-CT1" sourceRef="G2" targetRef="CT1"/>
    <sequenceFlow id="G2-CP1" sourceRef="G2" targetRef="CP1"/>
    <sequenceFlow id="CT1-XORCLOSE21" sourceRef="CT1" targetRef="XORCLOSE21"/>
    <sequenceFlow id="CP1-XORCLOSE21" sourceRef="CP1" targetRef="XORCLOSE21"/>
    <sequenceFlow id="CI1-NS1" sourceRef="CI1" targetRef="NS1"/>
    <sequenceFlow id="XORCLOSE21-XORCLOSE26" sourceRef="XORCLOSE21" targetRef="XORCLOSE26"/>
    <sequenceFlow id="NS1-XORCLOSE25" sourceRef="NS1" targetRef="XORCLOSE25"/>
    <sequenceFlow id="XORCLOSE25-XORCLOSE26" sourceRef="XORCLOSE25" targetRef="XORCLOSE26"/>
    <sequenceFlow id="XORCLOSE26-PARCLOSE28" sourceRef="XORCLOSE26" targetRef="PARCLOSE28"/>
    <sequenceFlow id="PARCLOSE28-END" sourceRef="PARCLOSE28" targetRef="END"/>
  </process>
