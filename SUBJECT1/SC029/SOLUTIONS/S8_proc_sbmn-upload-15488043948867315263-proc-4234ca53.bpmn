<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_7bdad1a3-2f3d-4148-8946-9e05adf7b847" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-RI1</outgoing>
      <outgoing>Par0-Par4</outgoing>
    </parallelGateway>
    <task id="RI1" name="Report incident">
      <incoming>Par0-RI1</incoming>
      <outgoing>RI1-IC1</outgoing>
    </task>
    <task id="IC1" name="Identify cause of incident">
      <incoming>RI1-IC1</incoming>
      <outgoing>IC1-PC1</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>Par0-Par4</incoming>
      <outgoing>Par4-LR1</outgoing>
      <outgoing>Par4-GI1</outgoing>
    </parallelGateway>
    <task id="LR1" name="Log report into tracking system">
      <incoming>Par4-LR1</incoming>
      <outgoing>LR1-PARCLOSE8</outgoing>
    </task>
    <task id="GI1" name="Gather necessary information">
      <incoming>Par4-GI1</incoming>
      <outgoing>GI1-PARCLOSE8</outgoing>
    </task>
    <task id="PC1" name="Propose corrective actions">
      <incoming>IC1-PC1</incoming>
      <outgoing>PC1-G0</outgoing>
    </task>
    <parallelGateway id="PARCLOSE8" name="PARCLOSE8">
      <incoming>LR1-PARCLOSE8</incoming>
      <incoming>GI1-PARCLOSE8</incoming>
      <outgoing>PARCLOSE8-AR1</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G0" name="G0">
      <incoming>PC1-G0</incoming>
      <outgoing>G0-IF1</outgoing>
      <outgoing>G0-G2</outgoing>
    </exclusiveGateway>
    <task id="IF1" name="Implement fix">
      <incoming>G0-IF1</incoming>
      <outgoing>IF1-G1</outgoing>
    </task>
    <task id="AR1" name="Assign report to appropriate team">
      <incoming>PARCLOSE8-AR1</incoming>
      <outgoing>AR1-PARCLOSE28</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>IF1-G1</incoming>
      <outgoing>G1-CF1</outgoing>
      <outgoing>G1-XORCLOSE25</outgoing>
    </exclusiveGateway>
    <task id="CF1" name="Conduct follow-up">
      <incoming>G1-CF1</incoming>
      <outgoing>CF1-CI1</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>G0-G2</incoming>
      <outgoing>G2-CT1</outgoing>
      <outgoing>G2-CP1</outgoing>
    </exclusiveGateway>
    <task id="CT1" name="Conduct training">
      <incoming>G2-CT1</incoming>
      <outgoing>CT1-XORCLOSE21</outgoing>
    </task>
    <task id="CP1" name="Change policy">
      <incoming>G2-CP1</incoming>
      <outgoing>CP1-XORCLOSE21</outgoing>
    </task>
    <task id="CI1" name="Close incident report">
      <incoming>CF1-CI1</incoming>
      <outgoing>CI1-NS1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE21" name="XORCLOSE21">
      <incoming>CT1-XORCLOSE21</incoming>
      <incoming>CP1-XORCLOSE21</incoming>
      <outgoing>XORCLOSE21-XORCLOSE26</outgoing>
    </exclusiveGateway>
    <task id="NS1" name="Notify all stakeholders">
      <incoming>CI1-NS1</incoming>
      <outgoing>NS1-XORCLOSE25</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE25" name="XORCLOSE25">
      <incoming>G1-XORCLOSE25</incoming>
      <incoming>NS1-XORCLOSE25</incoming>
      <outgoing>XORCLOSE25-XORCLOSE26</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE26" name="XORCLOSE26">
      <incoming>XORCLOSE21-XORCLOSE26</incoming>
      <incoming>XORCLOSE25-XORCLOSE26</incoming>
      <outgoing>XORCLOSE26-PARCLOSE28</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>AR1-PARCLOSE28</incoming>
      <incoming>XORCLOSE26-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE28-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
