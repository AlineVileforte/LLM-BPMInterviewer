    <sequenceFlow id="G0-IF1" sourceRef="G0" targetRef="IF1"/>
    <sequenceFlow id="G0-G1" sourceRef="G0" targetRef="G1"/>
    <sequenceFlow id="IF1-CF1" sourceRef="IF1" targetRef="CF1"/>
    <sequenceFlow id="AR1-PARCLOSE24" sourceRef="AR1" targetRef="PARCLOSE24"/>
    <sequenceFlow id="CF1-CI1" sourceRef="CF1" targetRef="CI1"/>
    <sequenceFlow id="G1-CT1" sourceRef="G1" targetRef="CT1"/>
    <sequenceFlow id="G1-CP1" sourceRef="G1" targetRef="CP1"/>
    <sequenceFlow id="CT1-XORCLOSE21" sourceRef="CT1" targetRef="XORCLOSE21"/>
    <sequenceFlow id="CP1-XORCLOSE21" sourceRef="CP1" targetRef="XORCLOSE21"/>
    <sequenceFlow id="CI1-NS1" sourceRef="CI1" targetRef="NS1"/>
    <sequenceFlow id="XORCLOSE21-XORCLOSE23" sourceRef="XORCLOSE21" targetRef="XORCLOSE23"/>
    <sequenceFlow id="NS1-XORCLOSE23" sourceRef="NS1" targetRef="XORCLOSE23"/>
    <sequenceFlow id="XORCLOSE23-PARCLOSE24" sourceRef="XORCLOSE23" targetRef="PARCLOSE24"/>
    <sequenceFlow id="PARCLOSE24-END" sourceRef="PARCLOSE24" targetRef="END"/>
  </process>
