<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_efcf5f9d-77ea-40a2-9510-b747cdd87a8c" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-RI1</outgoing>
      <outgoing>Par0-Par4</outgoing>
    </parallelGateway>
    <task id="RI1" name="Report incident">
      <incoming>Par0-RI1</incoming>
      <outgoing>RI1-LR1</outgoing>
    </task>
    <task id="LR1" name="Log report into tracking system">
      <incoming>RI1-LR1</incoming>
      <outgoing>LR1-AR1</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>Par0-Par4</incoming>
      <outgoing>Par4-GI1</outgoing>
      <outgoing>Par4-IC1</outgoing>
    </parallelGateway>
    <task id="GI1" name="Gather necessary information">
      <incoming>Par4-GI1</incoming>
      <outgoing>GI1-PARCLOSE25</outgoing>
    </task>
    <task id="IC1" name="Identify cause of incident">
      <incoming>Par4-IC1</incoming>
      <outgoing>IC1-PC1</outgoing>
    </task>
    <task id="AR1" name="Assign report to appropriate team">
      <incoming>LR1-AR1</incoming>
      <outgoing>AR1-PARCLOSE26</outgoing>
    </task>
    <task id="PC1" name="Propose corrective actions">
      <incoming>IC1-PC1</incoming>
      <outgoing>PC1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>PC1-G0</incoming>
      <outgoing>G0-IF1</outgoing>
      <outgoing>G0-G1</outgoing>
    </exclusiveGateway>
    <task id="IF1" name="Implement fix">
      <incoming>G0-IF1</incoming>
      <outgoing>IF1-CF1</outgoing>
    </task>
    <task id="CF1" name="Conduct follow-up">
      <incoming>IF1-CF1</incoming>
      <outgoing>CF1-CI1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>G0-G1</incoming>
      <outgoing>G1-CT1</outgoing>
      <outgoing>G1-CP1</outgoing>
    </exclusiveGateway>
    <task id="CT1" name="Conduct training">
      <incoming>G1-CT1</incoming>
      <outgoing>CT1-XORCLOSE21</outgoing>
    </task>
    <task id="CP1" name="Change policy">
      <incoming>G1-CP1</incoming>
      <outgoing>CP1-XORCLOSE21</outgoing>
    </task>
    <task id="CI1" name="Close incident report">
      <incoming>CF1-CI1</incoming>
      <outgoing>CI1-NS1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE21" name="XORCLOSE21">
      <incoming>CT1-XORCLOSE21</incoming>
      <incoming>CP1-XORCLOSE21</incoming>
      <outgoing>XORCLOSE21-XORCLOSE23</outgoing>
    </exclusiveGateway>
    <task id="NS1" name="Notify all stakeholders">
      <incoming>CI1-NS1</incoming>
      <outgoing>NS1-XORCLOSE23</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE23" name="XORCLOSE23">
      <incoming>XORCLOSE21-XORCLOSE23</incoming>
      <incoming>NS1-XORCLOSE23</incoming>
      <outgoing>XORCLOSE23-PARCLOSE25</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>GI1-PARCLOSE25</incoming>
      <incoming>XORCLOSE23-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-PARCLOSE26</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>AR1-PARCLOSE26</incoming>
      <incoming>PARCLOSE25-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE26-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
    <sequenceFlow id="Par0-RI1" sourceRef="Par0" targetRef="RI1"/>
    <sequenceFlow id="Par0-Par4" sourceRef="Par0" targetRef="Par4"/>
    <sequenceFlow id="RI1-LR1" sourceRef="RI1" targetRef="LR1"/>
