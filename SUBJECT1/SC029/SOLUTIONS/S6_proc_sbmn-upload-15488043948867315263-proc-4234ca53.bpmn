    <sequenceFlow id="G2-CT1" sourceRef="G2" targetRef="CT1"/>
    <sequenceFlow id="G2-CP1" sourceRef="G2" targetRef="CP1"/>
    <sequenceFlow id="CT1-XORCLOSE18" sourceRef="CT1" targetRef="XORCLOSE18"/>
    <sequenceFlow id="CP1-XORCLOSE18" sourceRef="CP1" targetRef="XORCLOSE18"/>
    <sequenceFlow id="CI1-NS1" sourceRef="CI1" targetRef="NS1"/>
    <sequenceFlow id="XORCLOSE18-XORCLOSE24" sourceRef="XORCLOSE18" targetRef="XORCLOSE24"/>
    <sequenceFlow id="NS1-XORCLOSE23" sourceRef="NS1" targetRef="XORCLOSE23"/>
    <sequenceFlow id="XORCLOSE23-XORCLOSE24" sourceRef="XORCLOSE23" targetRef="XORCLOSE24"/>
    <sequenceFlow id="XORCLOSE24-PARCLOSE26" sourceRef="XORCLOSE24" targetRef="PARCLOSE26"/>
    <sequenceFlow id="PARCLOSE26-END" sourceRef="PARCLOSE26" targetRef="END"/>
  </process>
