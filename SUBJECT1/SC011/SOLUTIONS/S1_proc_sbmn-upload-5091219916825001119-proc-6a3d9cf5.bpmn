  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CS2</outgoing>
    </startEvent>
    <task id="CS2" name="Compose Soundtrack">
      <incoming>Default_init-CS2</incoming>
      <outgoing>CS2-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>CS2-Par1</incoming>
      <outgoing>Par1-AS1</outgoing>
      <outgoing>Par1-AF1</outgoing>
    </parallelGateway>
    <task id="AS1" name="Approve Script">
      <incoming>Par1-AS1</incoming>
      <outgoing>AS1-Par4</outgoing>
    </task>
    <task id="AF1" name="Additional Filming">
      <incoming>Par1-AF1</incoming>
      <outgoing>AF1-G3</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>AS1-Par4</incoming>
      <outgoing>Par4-SL1</outgoing>
      <outgoing>Par4-BC1</outgoing>
    </parallelGateway>
    <task id="SL1" name="Search Locations">
      <incoming>Par4-SL1</incoming>
      <outgoing>SL1-Par9</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>AF1-G3</incoming>
      <outgoing>G3-NF1</outgoing>
      <outgoing>G3-XORCLOSE12</outgoing>
    </exclusiveGateway>
    <task id="NF1" name="Negotiate with Festivals">
      <incoming>G3-NF1</incoming>
      <outgoing>NF1-XORCLOSE12</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>SL1-Par9</incoming>
      <outgoing>Par9-DSS1</outgoing>
      <outgoing>Par9-HS1</outgoing>
    </parallelGateway>
    <task id="DSS1" name="Detail Script Scenes">
      <incoming>Par9-DSS1</incoming>
      <outgoing>DSS1-PPM1</outgoing>
    </task>
    <task id="BC1" name="Begin Casting">
      <incoming>Par4-BC1</incoming>
      <outgoing>BC1-Par15</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE12" name="XORCLOSE12">
      <incoming>G3-XORCLOSE12</incoming>
      <incoming>NF1-XORCLOSE12</incoming>
      <outgoing>XORCLOSE12-PARCLOSE34</outgoing>
    </exclusiveGateway>
    <task id="PPM1" name="Produce Promotional Material">
      <incoming>DSS1-PPM1</incoming>
      <outgoing>PPM1-DM1</outgoing>
    </task>
    <task id="HS1" name="Hire Suppliers">
      <incoming>Par9-HS1</incoming>
      <outgoing>HS1-PFE1</outgoing>
    </task>
    <parallelGateway id="Par15" name="PAR">
      <incoming>BC1-Par15</incoming>
      <outgoing>Par15-AJ1</outgoing>
      <outgoing>Par15-RS1</outgoing>
    </parallelGateway>
    <task id="AJ1" name="Adjust Script">
      <incoming>Par15-AJ1</incoming>
      <outgoing>AJ1-Par20</outgoing>
    </task>
    <task id="RS1" name="Rehearse Scenes">
      <incoming>Par15-RS1</incoming>
      <outgoing>RS1-FS1</outgoing>
    </task>
    <task id="DM1" name="Distribute Movie">
      <incoming>PPM1-DM1</incoming>
      <outgoing>DM1-PARCLOSE24</outgoing>
    </task>
    <task id="PFE1" name="Prepare Filming Equipment">
      <incoming>HS1-PFE1</incoming>
      <outgoing>PFE1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="Par20" name="PAR">
      <incoming>AJ1-Par20</incoming>
      <outgoing>Par20-PC1</outgoing>
      <outgoing>Par20-CS1</outgoing>
    </parallelGateway>
    <task id="PC1" name="Produce Costumes">
      <incoming>Par20-PC1</incoming>
      <outgoing>PC1-PARCLOSE25</outgoing>
    </task>
    <task id="CS1" name="Construct Stage">
      <incoming>Par20-CS1</incoming>
      <outgoing>CS1-PARCLOSE25</outgoing>
    </task>
    <task id="FS1" name="Film Scenes">
      <incoming>RS1-FS1</incoming>
      <outgoing>FS1-PARCLOSE26</outgoing>
    </task>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>DM1-PARCLOSE24</incoming>
      <incoming>PFE1-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-PVE1</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>PC1-PARCLOSE25</incoming>
      <incoming>CS1-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-PARCLOSE26</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>FS1-PARCLOSE26</incoming>
      <incoming>PARCLOSE25-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-PARCLOSE30</outgoing>
    </parallelGateway>
    <task id="PVE1" name="Produce Visual Effects">
      <incoming>PARCLOSE24-PVE1</incoming>
      <outgoing>PVE1-PE1</outgoing>
    </task>
    <task id="PE1" name="Preliminary Editing">
      <incoming>PVE1-PE1</incoming>
      <outgoing>PE1-AP1</outgoing>
    </task>
    <task id="AP1" name="Advance Post-Production">
      <incoming>PE1-AP1</incoming>
      <outgoing>AP1-PARCLOSE30</outgoing>
    </task>
    <parallelGateway id="PARCLOSE30" name="PARCLOSE30">
      <incoming>PARCLOSE26-PARCLOSE30</incoming>
      <incoming>AP1-PARCLOSE30</incoming>
      <outgoing>PARCLOSE30-FSE1</outgoing>
    </parallelGateway>
    <task id="FSE1" name="Final Sound Editing">
      <incoming>PARCLOSE30-FSE1</incoming>
      <outgoing>FSE1-AFV1</outgoing>
    </task>
    <task id="AFV1" name="Approve Final Version">
      <incoming>FSE1-AFV1</incoming>
      <outgoing>AFV1-RMC1</outgoing>
    </task>
    <task id="RMC1" name="Run Marketing Campaign">
      <incoming>AFV1-RMC1</incoming>
      <outgoing>RMC1-PARCLOSE34</outgoing>
    </task>
    <parallelGateway id="PARCLOSE34" name="PARCLOSE34">
      <incoming>XORCLOSE12-PARCLOSE34</incoming>
      <incoming>RMC1-PARCLOSE34</incoming>
      <outgoing>PARCLOSE34-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE34-END</incoming>
    </endEvent>
