    </task>
    <task id="SL1" name="Search Locations">
      <incoming>Par8-SL1</incoming>
      <outgoing>SL1-Par13</outgoing>
    </task>
    <task id="CS2" name="Compose Soundtrack">
      <incoming>Par5-CS2</incoming>
      <outgoing>CS2-PARCLOSE28</outgoing>
    </task>
    <task id="PPM1" name="Produce Promotional Material">
