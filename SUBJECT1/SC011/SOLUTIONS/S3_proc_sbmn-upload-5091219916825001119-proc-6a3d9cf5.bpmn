      <outgoing>PARCLOSE23-PARCLOSE25</outgoing>
    </parallelGateway>
    <task id="PC1" name="Produce Costumes">
      <incoming>PFE1-PC1</incoming>
      <outgoing>PC1-PARCLOSE25</outgoing>
