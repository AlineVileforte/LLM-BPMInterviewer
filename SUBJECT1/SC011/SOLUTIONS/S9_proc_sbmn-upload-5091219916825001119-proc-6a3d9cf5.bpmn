  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-AS1</outgoing>
      <outgoing>Par0-CS2</outgoing>
    </parallelGateway>
    <task id="AS1" name="Approve Script">
      <incoming>Par0-AS1</incoming>
      <outgoing>AS1-DSS1</outgoing>
    </task>
    <task id="CS2" name="Compose Soundtrack">
      <incoming>Par0-CS2</incoming>
      <outgoing>CS2-Par5</outgoing>
    </task>
    <task id="DSS1" name="Detail Script Scenes">
      <incoming>AS1-DSS1</incoming>
      <outgoing>DSS1-SL1</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>CS2-Par5</incoming>
      <outgoing>Par5-AF1</outgoing>
      <outgoing>Par5-G2</outgoing>
    </parallelGateway>
    <task id="AF1" name="Additional Filming">
      <incoming>Par5-AF1</incoming>
      <outgoing>AF1-PARCLOSE22</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par5-G2</incoming>
      <outgoing>G2-NF1</outgoing>
      <outgoing>G2-XORCLOSE11</outgoing>
    </exclusiveGateway>
    <task id="NF1" name="Negotiate with Festivals">
      <incoming>G2-NF1</incoming>
      <outgoing>NF1-XORCLOSE11</outgoing>
    </task>
    <task id="SL1" name="Search Locations">
      <incoming>DSS1-SL1</incoming>
      <outgoing>SL1-Par12</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE11" name="XORCLOSE11">
      <incoming>G2-XORCLOSE11</incoming>
      <incoming>NF1-XORCLOSE11</incoming>
      <outgoing>XORCLOSE11-PPM1</outgoing>
    </exclusiveGateway>
    <parallelGateway id="Par12" name="PAR">
      <incoming>SL1-Par12</incoming>
      <outgoing>Par12-BC1</outgoing>
      <outgoing>Par12-HS1</outgoing>
    </parallelGateway>
    <task id="BC1" name="Begin Casting">
      <incoming>Par12-BC1</incoming>
      <outgoing>BC1-Par16</outgoing>
    </task>
    <task id="HS1" name="Hire Suppliers">
      <incoming>Par12-HS1</incoming>
      <outgoing>HS1-Par19</outgoing>
    </task>
    <task id="PPM1" name="Produce Promotional Material">
      <incoming>XORCLOSE11-PPM1</incoming>
      <outgoing>PPM1-PARCLOSE22</outgoing>
    </task>
    <parallelGateway id="Par16" name="PAR">
      <incoming>BC1-Par16</incoming>
      <outgoing>Par16-AJ1</outgoing>
      <outgoing>Par16-RS1</outgoing>
    </parallelGateway>
    <task id="AJ1" name="Adjust Script">
      <incoming>Par16-AJ1</incoming>
      <outgoing>AJ1-DM1</outgoing>
    </task>
    <task id="RS1" name="Rehearse Scenes">
      <incoming>Par16-RS1</incoming>
      <outgoing>RS1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="Par19" name="PAR">
      <incoming>HS1-Par19</incoming>
      <outgoing>Par19-PC1</outgoing>
      <outgoing>Par19-PFE1</outgoing>
    </parallelGateway>
    <task id="PC1" name="Produce Costumes">
      <incoming>Par19-PC1</incoming>
      <outgoing>PC1-CS1</outgoing>
    </task>
    <task id="PFE1" name="Prepare Filming Equipment">
      <incoming>Par19-PFE1</incoming>
      <outgoing>PFE1-PARCLOSE26</outgoing>
    </task>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>AF1-PARCLOSE22</incoming>
      <incoming>PPM1-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-PARCLOSE33</outgoing>
    </parallelGateway>
    <task id="DM1" name="Distribute Movie">
      <incoming>AJ1-DM1</incoming>
      <outgoing>DM1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>RS1-PARCLOSE24</incoming>
      <incoming>DM1-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-PARCLOSE27</outgoing>
    </parallelGateway>
    <task id="CS1" name="Construct Stage">
      <incoming>PC1-CS1</incoming>
      <outgoing>CS1-PARCLOSE26</outgoing>
    </task>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>PFE1-PARCLOSE26</incoming>
      <incoming>CS1-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-PARCLOSE27</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>PARCLOSE24-PARCLOSE27</incoming>
      <incoming>PARCLOSE26-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-FS1</outgoing>
    </parallelGateway>
    <task id="FS1" name="Film Scenes">
      <incoming>PARCLOSE27-FS1</incoming>
      <outgoing>FS1-PVE1</outgoing>
    </task>
    <task id="PVE1" name="Produce Visual Effects">
      <incoming>FS1-PVE1</incoming>
      <outgoing>PVE1-PE1</outgoing>
    </task>
    <task id="PE1" name="Preliminary Editing">
      <incoming>PVE1-PE1</incoming>
      <outgoing>PE1-AP1</outgoing>
    </task>
    <task id="AP1" name="Advance Post-Production">
      <incoming>PE1-AP1</incoming>
      <outgoing>AP1-PARCLOSE33</outgoing>
    </task>
    <parallelGateway id="PARCLOSE33" name="PARCLOSE33">
      <incoming>PARCLOSE22-PARCLOSE33</incoming>
      <incoming>AP1-PARCLOSE33</incoming>
      <outgoing>PARCLOSE33-FSE1</outgoing>
    </parallelGateway>
    <task id="FSE1" name="Final Sound Editing">
      <incoming>PARCLOSE33-FSE1</incoming>
      <outgoing>FSE1-AFV1</outgoing>
    </task>
    <task id="AFV1" name="Approve Final Version">
      <incoming>FSE1-AFV1</incoming>
      <outgoing>AFV1-RMC1</outgoing>
    </task>
    <task id="RMC1" name="Run Marketing Campaign">
      <incoming>AFV1-RMC1</incoming>
      <outgoing>RMC1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>RMC1-END</incoming>
    </endEvent>
