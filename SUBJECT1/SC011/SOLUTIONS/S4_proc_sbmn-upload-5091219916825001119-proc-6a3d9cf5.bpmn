  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-G0</outgoing>
    </startEvent>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Default_init-G0</incoming>
      <outgoing>G0-NF1</outgoing>
      <outgoing>G0-XORCLOSE3</outgoing>
    </exclusiveGateway>
    <task id="NF1" name="Negotiate with Festivals">
      <incoming>G0-NF1</incoming>
      <outgoing>NF1-XORCLOSE3</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE3" name="XORCLOSE3">
      <incoming>G0-XORCLOSE3</incoming>
      <incoming>NF1-XORCLOSE3</incoming>
      <outgoing>XORCLOSE3-Par4</outgoing>
    </exclusiveGateway>
    <parallelGateway id="Par4" name="PAR">
      <incoming>XORCLOSE3-Par4</incoming>
      <outgoing>Par4-PPM1</outgoing>
      <outgoing>Par4-CS2</outgoing>
    </parallelGateway>
    <task id="PPM1" name="Produce Promotional Material">
      <incoming>Par4-PPM1</incoming>
      <outgoing>PPM1-Par7</outgoing>
    </task>
    <task id="CS2" name="Compose Soundtrack">
      <incoming>Par4-CS2</incoming>
      <outgoing>CS2-AS1</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>PPM1-Par7</incoming>
      <outgoing>Par7-DM1</outgoing>
      <outgoing>Par7-AF1</outgoing>
    </parallelGateway>
    <task id="DM1" name="Distribute Movie">
      <incoming>Par7-DM1</incoming>
      <outgoing>DM1-PARCLOSE11</outgoing>
    </task>
    <task id="AF1" name="Additional Filming">
      <incoming>Par7-AF1</incoming>
      <outgoing>AF1-PARCLOSE11</outgoing>
    </task>
    <task id="AS1" name="Approve Script">
      <incoming>CS2-AS1</incoming>
      <outgoing>AS1-DSS1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE11" name="PARCLOSE11">
      <incoming>DM1-PARCLOSE11</incoming>
      <incoming>AF1-PARCLOSE11</incoming>
      <outgoing>PARCLOSE11-SL1</outgoing>
    </parallelGateway>
    <task id="DSS1" name="Detail Script Scenes">
      <incoming>AS1-DSS1</incoming>
      <outgoing>DSS1-PARCLOSE32</outgoing>
    </task>
    <task id="SL1" name="Search Locations">
      <incoming>PARCLOSE11-SL1</incoming>
      <outgoing>SL1-BC1</outgoing>
    </task>
    <task id="BC1" name="Begin Casting">
      <incoming>SL1-BC1</incoming>
      <outgoing>BC1-Par15</outgoing>
    </task>
    <parallelGateway id="Par15" name="PAR">
      <incoming>BC1-Par15</incoming>
      <outgoing>Par15-RS1</outgoing>
      <outgoing>Par15-FS1</outgoing>
    </parallelGateway>
    <task id="RS1" name="Rehearse Scenes">
      <incoming>Par15-RS1</incoming>
      <outgoing>RS1-AJ1</outgoing>
    </task>
    <task id="AJ1" name="Adjust Script">
      <incoming>RS1-AJ1</incoming>
      <outgoing>AJ1-HS1</outgoing>
    </task>
    <task id="FS1" name="Film Scenes">
      <incoming>Par15-FS1</incoming>
      <outgoing>FS1-PVE1</outgoing>
    </task>
    <task id="HS1" name="Hire Suppliers">
      <incoming>AJ1-HS1</incoming>
      <outgoing>HS1-Par21</outgoing>
    </task>
    <task id="PVE1" name="Produce Visual Effects">
      <incoming>FS1-PVE1</incoming>
      <outgoing>PVE1-PE1</outgoing>
    </task>
    <parallelGateway id="Par21" name="PAR">
      <incoming>HS1-Par21</incoming>
      <outgoing>Par21-PC1</outgoing>
      <outgoing>Par21-PFE1</outgoing>
    </parallelGateway>
    <task id="PC1" name="Produce Costumes">
      <incoming>Par21-PC1</incoming>
      <outgoing>PC1-CS1</outgoing>
    </task>
    <task id="PFE1" name="Prepare Filming Equipment">
      <incoming>Par21-PFE1</incoming>
      <outgoing>PFE1-PARCLOSE27</outgoing>
    </task>
    <task id="PE1" name="Preliminary Editing">
      <incoming>PVE1-PE1</incoming>
      <outgoing>PE1-AP1</outgoing>
    </task>
    <task id="CS1" name="Construct Stage">
      <incoming>PC1-CS1</incoming>
      <outgoing>CS1-PARCLOSE27</outgoing>
    </task>
    <task id="AP1" name="Advance Post-Production">
      <incoming>PE1-AP1</incoming>
      <outgoing>AP1-FSE1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>PFE1-PARCLOSE27</incoming>
      <incoming>CS1-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-PARCLOSE31</outgoing>
    </parallelGateway>
    <task id="FSE1" name="Final Sound Editing">
      <incoming>AP1-FSE1</incoming>
      <outgoing>FSE1-AFV1</outgoing>
    </task>
    <task id="AFV1" name="Approve Final Version">
      <incoming>FSE1-AFV1</incoming>
      <outgoing>AFV1-RMC1</outgoing>
    </task>
    <task id="RMC1" name="Run Marketing Campaign">
      <incoming>AFV1-RMC1</incoming>
      <outgoing>RMC1-PARCLOSE31</outgoing>
    </task>
    <parallelGateway id="PARCLOSE31" name="PARCLOSE31">
      <incoming>PARCLOSE27-PARCLOSE31</incoming>
      <incoming>RMC1-PARCLOSE31</incoming>
      <outgoing>PARCLOSE31-PARCLOSE32</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE32" name="PARCLOSE32">
      <incoming>DSS1-PARCLOSE32</incoming>
      <incoming>PARCLOSE31-PARCLOSE32</incoming>
      <outgoing>PARCLOSE32-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE32-END</incoming>
    </endEvent>
