  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-CS2</outgoing>
      <outgoing>Par0-G0</outgoing>
    </parallelGateway>
    <task id="CS2" name="Compose Soundtrack">
      <incoming>Par0-CS2</incoming>
      <outgoing>CS2-Par5</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par0-G0</incoming>
      <outgoing>G0-NF1</outgoing>
      <outgoing>G0-XORCLOSE8</outgoing>
    </exclusiveGateway>
    <task id="NF1" name="Negotiate with Festivals">
      <incoming>G0-NF1</incoming>
      <outgoing>NF1-XORCLOSE8</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>CS2-Par5</incoming>
      <outgoing>Par5-AS1</outgoing>
      <outgoing>Par5-AF1</outgoing>
    </parallelGateway>
    <task id="AS1" name="Approve Script">
      <incoming>Par5-AS1</incoming>
      <outgoing>AS1-PARCLOSE9</outgoing>
    </task>
    <task id="AF1" name="Additional Filming">
      <incoming>Par5-AF1</incoming>
      <outgoing>AF1-PARCLOSE9</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE8" name="XORCLOSE8">
      <incoming>G0-XORCLOSE8</incoming>
      <incoming>NF1-XORCLOSE8</incoming>
      <outgoing>XORCLOSE8-Par10</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE9" name="PARCLOSE9">
      <incoming>AS1-PARCLOSE9</incoming>
      <incoming>AF1-PARCLOSE9</incoming>
      <outgoing>PARCLOSE9-SL1</outgoing>
    </parallelGateway>
    <parallelGateway id="Par10" name="PAR">
      <incoming>XORCLOSE8-Par10</incoming>
      <outgoing>Par10-DSS1</outgoing>
      <outgoing>Par10-PPM1</outgoing>
    </parallelGateway>
    <task id="DSS1" name="Detail Script Scenes">
      <incoming>Par10-DSS1</incoming>
      <outgoing>DSS1-PARCLOSE14</outgoing>
    </task>
    <task id="PPM1" name="Produce Promotional Material">
      <incoming>Par10-PPM1</incoming>
      <outgoing>PPM1-PARCLOSE14</outgoing>
    </task>
    <task id="SL1" name="Search Locations">
      <incoming>PARCLOSE9-SL1</incoming>
      <outgoing>SL1-BC1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE14" name="PARCLOSE14">
      <incoming>DSS1-PARCLOSE14</incoming>
      <incoming>PPM1-PARCLOSE14</incoming>
      <outgoing>PARCLOSE14-HS1</outgoing>
    </parallelGateway>
    <task id="BC1" name="Begin Casting">
      <incoming>SL1-BC1</incoming>
      <outgoing>BC1-AJ1</outgoing>
    </task>
    <task id="HS1" name="Hire Suppliers">
      <incoming>PARCLOSE14-HS1</incoming>
      <outgoing>HS1-Par18</outgoing>
    </task>
    <task id="AJ1" name="Adjust Script">
      <incoming>BC1-AJ1</incoming>
      <outgoing>AJ1-RS1</outgoing>
    </task>
    <parallelGateway id="Par18" name="PAR">
      <incoming>HS1-Par18</incoming>
      <outgoing>Par18-PC1</outgoing>
      <outgoing>Par18-PFE1</outgoing>
    </parallelGateway>
    <task id="PC1" name="Produce Costumes">
      <incoming>Par18-PC1</incoming>
      <outgoing>PC1-DM1</outgoing>
    </task>
    <task id="PFE1" name="Prepare Filming Equipment">
      <incoming>Par18-PFE1</incoming>
      <outgoing>PFE1-CS1</outgoing>
    </task>
    <task id="RS1" name="Rehearse Scenes">
      <incoming>AJ1-RS1</incoming>
      <outgoing>RS1-FS1</outgoing>
    </task>
    <task id="DM1" name="Distribute Movie">
      <incoming>PC1-DM1</incoming>
      <outgoing>DM1-PARCLOSE25</outgoing>
    </task>
    <task id="CS1" name="Construct Stage">
      <incoming>PFE1-CS1</incoming>
      <outgoing>CS1-PARCLOSE25</outgoing>
    </task>
    <task id="FS1" name="Film Scenes">
      <incoming>RS1-FS1</incoming>
      <outgoing>FS1-PVE1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>DM1-PARCLOSE25</incoming>
      <incoming>CS1-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-PARCLOSE27</outgoing>
    </parallelGateway>
    <task id="PVE1" name="Produce Visual Effects">
      <incoming>FS1-PVE1</incoming>
      <outgoing>PVE1-PARCLOSE27</outgoing>
    </task>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>PARCLOSE25-PARCLOSE27</incoming>
      <incoming>PVE1-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-PE1</outgoing>
    </parallelGateway>
    <task id="PE1" name="Preliminary Editing">
      <incoming>PARCLOSE27-PE1</incoming>
      <outgoing>PE1-AP1</outgoing>
    </task>
    <task id="AP1" name="Advance Post-Production">
      <incoming>PE1-AP1</incoming>
      <outgoing>AP1-FSE1</outgoing>
    </task>
    <task id="FSE1" name="Final Sound Editing">
      <incoming>AP1-FSE1</incoming>
      <outgoing>FSE1-AFV1</outgoing>
    </task>
    <task id="AFV1" name="Approve Final Version">
      <incoming>FSE1-AFV1</incoming>
      <outgoing>AFV1-RMC1</outgoing>
    </task>
    <task id="RMC1" name="Run Marketing Campaign">
      <incoming>AFV1-RMC1</incoming>
      <outgoing>RMC1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>RMC1-END</incoming>
    </endEvent>
