  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-AF1</outgoing>
      <outgoing>Par0-G2</outgoing>
    </parallelGateway>
    <task id="AF1" name="Additional Filming">
      <incoming>Par0-AF1</incoming>
      <outgoing>AF1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>AF1-Par2</incoming>
      <outgoing>Par2-AS1</outgoing>
      <outgoing>Par2-SL1</outgoing>
    </parallelGateway>
    <task id="AS1" name="Approve Script">
      <incoming>Par2-AS1</incoming>
      <outgoing>AS1-Par7</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par0-G2</incoming>
      <outgoing>G2-NF1</outgoing>
      <outgoing>G2-XORCLOSE10</outgoing>
    </exclusiveGateway>
    <task id="NF1" name="Negotiate with Festivals">
      <incoming>G2-NF1</incoming>
      <outgoing>NF1-XORCLOSE10</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>AS1-Par7</incoming>
      <outgoing>Par7-DSS1</outgoing>
      <outgoing>Par7-CS2</outgoing>
    </parallelGateway>
    <task id="DSS1" name="Detail Script Scenes">
      <incoming>Par7-DSS1</incoming>
      <outgoing>DSS1-PPM1</outgoing>
    </task>
    <task id="SL1" name="Search Locations">
      <incoming>Par2-SL1</incoming>
      <outgoing>SL1-HS1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE10" name="XORCLOSE10">
      <incoming>G2-XORCLOSE10</incoming>
      <incoming>NF1-XORCLOSE10</incoming>
      <outgoing>XORCLOSE10-BC1</outgoing>
    </exclusiveGateway>
    <task id="PPM1" name="Produce Promotional Material">
      <incoming>DSS1-PPM1</incoming>
      <outgoing>PPM1-DM1</outgoing>
    </task>
    <task id="CS2" name="Compose Soundtrack">
      <incoming>Par7-CS2</incoming>
      <outgoing>CS2-PARCLOSE26</outgoing>
    </task>
    <task id="HS1" name="Hire Suppliers">
      <incoming>SL1-HS1</incoming>
      <outgoing>HS1-Par16</outgoing>
    </task>
    <task id="BC1" name="Begin Casting">
      <incoming>XORCLOSE10-BC1</incoming>
      <outgoing>BC1-CS1</outgoing>
    </task>
    <task id="DM1" name="Distribute Movie">
      <incoming>PPM1-DM1</incoming>
      <outgoing>DM1-Par20</outgoing>
    </task>
    <parallelGateway id="Par16" name="PAR">
      <incoming>HS1-Par16</incoming>
      <outgoing>Par16-PC1</outgoing>
      <outgoing>Par16-PFE1</outgoing>
    </parallelGateway>
    <task id="PC1" name="Produce Costumes">
      <incoming>Par16-PC1</incoming>
      <outgoing>PC1-PARCLOSE23</outgoing>
    </task>
    <task id="PFE1" name="Prepare Filming Equipment">
      <incoming>Par16-PFE1</incoming>
      <outgoing>PFE1-PARCLOSE23</outgoing>
    </task>
    <task id="CS1" name="Construct Stage">
      <incoming>BC1-CS1</incoming>
      <outgoing>CS1-PARCLOSE29</outgoing>
    </task>
    <parallelGateway id="Par20" name="PAR">
      <incoming>DM1-Par20</incoming>
      <outgoing>Par20-AJ1</outgoing>
      <outgoing>Par20-RS1</outgoing>
    </parallelGateway>
    <task id="AJ1" name="Adjust Script">
      <incoming>Par20-AJ1</incoming>
      <outgoing>AJ1-PARCLOSE24</outgoing>
    </task>
    <task id="RS1" name="Rehearse Scenes">
      <incoming>Par20-RS1</incoming>
      <outgoing>RS1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>PC1-PARCLOSE23</incoming>
      <incoming>PFE1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-FS1</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>AJ1-PARCLOSE24</incoming>
      <incoming>RS1-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-PARCLOSE26</outgoing>
    </parallelGateway>
    <task id="FS1" name="Film Scenes">
      <incoming>PARCLOSE23-FS1</incoming>
      <outgoing>FS1-PVE1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>CS2-PARCLOSE26</incoming>
      <incoming>PARCLOSE24-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-PARCLOSE28</outgoing>
    </parallelGateway>
    <task id="PVE1" name="Produce Visual Effects">
      <incoming>FS1-PVE1</incoming>
      <outgoing>PVE1-PARCLOSE28</outgoing>
    </task>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>PARCLOSE26-PARCLOSE28</incoming>
      <incoming>PVE1-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-PARCLOSE29</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>CS1-PARCLOSE29</incoming>
      <incoming>PARCLOSE28-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-PE1</outgoing>
    </parallelGateway>
    <task id="PE1" name="Preliminary Editing">
      <incoming>PARCLOSE29-PE1</incoming>
      <outgoing>PE1-AP1</outgoing>
    </task>
    <task id="AP1" name="Advance Post-Production">
      <incoming>PE1-AP1</incoming>
      <outgoing>AP1-FSE1</outgoing>
    </task>
    <task id="FSE1" name="Final Sound Editing">
      <incoming>AP1-FSE1</incoming>
      <outgoing>FSE1-AFV1</outgoing>
    </task>
    <task id="AFV1" name="Approve Final Version">
      <incoming>FSE1-AFV1</incoming>
      <outgoing>AFV1-RMC1</outgoing>
    </task>
    <task id="RMC1" name="Run Marketing Campaign">
      <incoming>AFV1-RMC1</incoming>
      <outgoing>RMC1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>RMC1-END</incoming>
    </endEvent>
