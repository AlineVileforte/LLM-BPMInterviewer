  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-AS1</outgoing>
      <outgoing>Par0-CS2</outgoing>
    </parallelGateway>
    <task id="AS1" name="Approve Script">
      <incoming>Par0-AS1</incoming>
      <outgoing>AS1-Par3</outgoing>
    </task>
    <task id="CS2" name="Compose Soundtrack">
      <incoming>Par0-CS2</incoming>
      <outgoing>CS2-G2</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>AS1-Par3</incoming>
      <outgoing>Par3-SL1</outgoing>
      <outgoing>Par3-AF1</outgoing>
    </parallelGateway>
    <task id="SL1" name="Search Locations">
      <incoming>Par3-SL1</incoming>
      <outgoing>SL1-DSS1</outgoing>
    </task>
    <task id="AF1" name="Additional Filming">
      <incoming>Par3-AF1</incoming>
      <outgoing>AF1-PARCLOSE12</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>CS2-G2</incoming>
      <outgoing>G2-NF1</outgoing>
      <outgoing>G2-XORCLOSE10</outgoing>
    </exclusiveGateway>
    <task id="NF1" name="Negotiate with Festivals">
      <incoming>G2-NF1</incoming>
      <outgoing>NF1-XORCLOSE10</outgoing>
    </task>
    <task id="DSS1" name="Detail Script Scenes">
      <incoming>SL1-DSS1</incoming>
      <outgoing>DSS1-PPM1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE10" name="XORCLOSE10">
      <incoming>G2-XORCLOSE10</incoming>
      <incoming>NF1-XORCLOSE10</incoming>
      <outgoing>XORCLOSE10-PARCLOSE32</outgoing>
    </exclusiveGateway>
    <task id="PPM1" name="Produce Promotional Material">
      <incoming>DSS1-PPM1</incoming>
      <outgoing>PPM1-PARCLOSE12</outgoing>
    </task>
    <parallelGateway id="PARCLOSE12" name="PARCLOSE12">
      <incoming>AF1-PARCLOSE12</incoming>
      <incoming>PPM1-PARCLOSE12</incoming>
      <outgoing>PARCLOSE12-Par13</outgoing>
    </parallelGateway>
    <parallelGateway id="Par13" name="PAR">
      <incoming>PARCLOSE12-Par13</incoming>
      <outgoing>Par13-BC1</outgoing>
      <outgoing>Par13-DM1</outgoing>
    </parallelGateway>
    <task id="BC1" name="Begin Casting">
      <incoming>Par13-BC1</incoming>
      <outgoing>BC1-Par16</outgoing>
    </task>
    <task id="DM1" name="Distribute Movie">
      <incoming>Par13-DM1</incoming>
      <outgoing>DM1-HS1</outgoing>
    </task>
    <parallelGateway id="Par16" name="PAR">
      <incoming>BC1-Par16</incoming>
      <outgoing>Par16-RS1</outgoing>
      <outgoing>Par16-AJ1</outgoing>
    </parallelGateway>
    <task id="RS1" name="Rehearse Scenes">
      <incoming>Par16-RS1</incoming>
      <outgoing>RS1-FS1</outgoing>
    </task>
    <task id="HS1" name="Hire Suppliers">
      <incoming>DM1-HS1</incoming>
      <outgoing>HS1-PC1</outgoing>
    </task>
    <task id="FS1" name="Film Scenes">
      <incoming>RS1-FS1</incoming>
      <outgoing>FS1-PFE1</outgoing>
    </task>
    <task id="AJ1" name="Adjust Script">
      <incoming>Par16-AJ1</incoming>
      <outgoing>AJ1-PVE1</outgoing>
    </task>
    <task id="PC1" name="Produce Costumes">
      <incoming>HS1-PC1</incoming>
      <outgoing>PC1-CS1</outgoing>
    </task>
    <task id="PFE1" name="Prepare Filming Equipment">
      <incoming>FS1-PFE1</incoming>
      <outgoing>PFE1-PARCLOSE26</outgoing>
    </task>
    <task id="PVE1" name="Produce Visual Effects">
      <incoming>AJ1-PVE1</incoming>
      <outgoing>PVE1-PE1</outgoing>
    </task>
    <task id="CS1" name="Construct Stage">
      <incoming>PC1-CS1</incoming>
      <outgoing>CS1-PARCLOSE31</outgoing>
    </task>
    <task id="PE1" name="Preliminary Editing">
      <incoming>PVE1-PE1</incoming>
      <outgoing>PE1-PARCLOSE26</outgoing>
    </task>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>PFE1-PARCLOSE26</incoming>
      <incoming>PE1-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-AP1</outgoing>
    </parallelGateway>
    <task id="AP1" name="Advance Post-Production">
      <incoming>PARCLOSE26-AP1</incoming>
      <outgoing>AP1-FSE1</outgoing>
    </task>
    <task id="FSE1" name="Final Sound Editing">
      <incoming>AP1-FSE1</incoming>
      <outgoing>FSE1-AFV1</outgoing>
    </task>
    <task id="AFV1" name="Approve Final Version">
      <incoming>FSE1-AFV1</incoming>
      <outgoing>AFV1-RMC1</outgoing>
    </task>
    <task id="RMC1" name="Run Marketing Campaign">
      <incoming>AFV1-RMC1</incoming>
      <outgoing>RMC1-PARCLOSE31</outgoing>
    </task>
    <parallelGateway id="PARCLOSE31" name="PARCLOSE31">
      <incoming>CS1-PARCLOSE31</incoming>
      <incoming>RMC1-PARCLOSE31</incoming>
      <outgoing>PARCLOSE31-PARCLOSE32</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE32" name="PARCLOSE32">
      <incoming>XORCLOSE10-PARCLOSE32</incoming>
      <incoming>PARCLOSE31-PARCLOSE32</incoming>
      <outgoing>PARCLOSE32-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE32-END</incoming>
    </endEvent>
