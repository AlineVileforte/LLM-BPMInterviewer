  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-AF1</outgoing>
      <outgoing>Par0-G0</outgoing>
    </parallelGateway>
    <task id="AF1" name="Additional Filming">
      <incoming>Par0-AF1</incoming>
      <outgoing>AF1-AS1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par0-G0</incoming>
      <outgoing>G0-NF1</outgoing>
      <outgoing>G0-XORCLOSE6</outgoing>
    </exclusiveGateway>
    <task id="NF1" name="Negotiate with Festivals">
      <incoming>G0-NF1</incoming>
      <outgoing>NF1-XORCLOSE6</outgoing>
    </task>
    <task id="AS1" name="Approve Script">
      <incoming>AF1-AS1</incoming>
      <outgoing>AS1-DSS1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE6" name="XORCLOSE6">
      <incoming>G0-XORCLOSE6</incoming>
      <incoming>NF1-XORCLOSE6</incoming>
      <outgoing>XORCLOSE6-Par8</outgoing>
    </exclusiveGateway>
    <task id="DSS1" name="Detail Script Scenes">
      <incoming>AS1-DSS1</incoming>
      <outgoing>DSS1-SL1</outgoing>
    </task>
    <parallelGateway id="Par8" name="PAR">
      <incoming>XORCLOSE6-Par8</incoming>
      <outgoing>Par8-PPM1</outgoing>
      <outgoing>Par8-CS2</outgoing>
    </parallelGateway>
    <task id="PPM1" name="Produce Promotional Material">
      <incoming>Par8-PPM1</incoming>
      <outgoing>PPM1-PARCLOSE12</outgoing>
    </task>
    <task id="CS2" name="Compose Soundtrack">
      <incoming>Par8-CS2</incoming>
      <outgoing>CS2-PARCLOSE12</outgoing>
    </task>
    <task id="SL1" name="Search Locations">
      <incoming>DSS1-SL1</incoming>
      <outgoing>SL1-BC1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE12" name="PARCLOSE12">
      <incoming>PPM1-PARCLOSE12</incoming>
      <incoming>CS2-PARCLOSE12</incoming>
      <outgoing>PARCLOSE12-HS1</outgoing>
    </parallelGateway>
    <task id="BC1" name="Begin Casting">
      <incoming>SL1-BC1</incoming>
      <outgoing>BC1-Par15</outgoing>
    </task>
    <task id="HS1" name="Hire Suppliers">
      <incoming>PARCLOSE12-HS1</incoming>
      <outgoing>HS1-CS1</outgoing>
    </task>
    <parallelGateway id="Par15" name="PAR">
      <incoming>BC1-Par15</incoming>
      <outgoing>Par15-AJ1</outgoing>
      <outgoing>Par15-RS1</outgoing>
    </parallelGateway>
    <task id="AJ1" name="Adjust Script">
      <incoming>Par15-AJ1</incoming>
      <outgoing>AJ1-PFE1</outgoing>
    </task>
    <task id="RS1" name="Rehearse Scenes">
      <incoming>Par15-RS1</incoming>
      <outgoing>RS1-Par20</outgoing>
    </task>
    <task id="CS1" name="Construct Stage">
      <incoming>HS1-CS1</incoming>
      <outgoing>CS1-DM1</outgoing>
    </task>
    <task id="PFE1" name="Prepare Filming Equipment">
      <incoming>AJ1-PFE1</incoming>
      <outgoing>PFE1-PARCLOSE29</outgoing>
    </task>
    <parallelGateway id="Par20" name="PAR">
      <incoming>RS1-Par20</incoming>
      <outgoing>Par20-PC1</outgoing>
      <outgoing>Par20-FS1</outgoing>
    </parallelGateway>
    <task id="PC1" name="Produce Costumes">
      <incoming>Par20-PC1</incoming>
      <outgoing>PC1-PARCLOSE25</outgoing>
    </task>
    <task id="FS1" name="Film Scenes">
      <incoming>Par20-FS1</incoming>
      <outgoing>FS1-PVE1</outgoing>
    </task>
    <task id="DM1" name="Distribute Movie">
      <incoming>CS1-DM1</incoming>
      <outgoing>DM1-PARCLOSE31</outgoing>
    </task>
    <task id="PVE1" name="Produce Visual Effects">
      <incoming>FS1-PVE1</incoming>
      <outgoing>PVE1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>PC1-PARCLOSE25</incoming>
      <incoming>PVE1-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-PE1</outgoing>
    </parallelGateway>
    <task id="PE1" name="Preliminary Editing">
      <incoming>PARCLOSE25-PE1</incoming>
      <outgoing>PE1-AP1</outgoing>
    </task>
    <task id="AP1" name="Advance Post-Production">
      <incoming>PE1-AP1</incoming>
      <outgoing>AP1-FSE1</outgoing>
    </task>
    <task id="FSE1" name="Final Sound Editing">
      <incoming>AP1-FSE1</incoming>
      <outgoing>FSE1-PARCLOSE29</outgoing>
    </task>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>PFE1-PARCLOSE29</incoming>
      <incoming>FSE1-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-AFV1</outgoing>
    </parallelGateway>
    <task id="AFV1" name="Approve Final Version">
      <incoming>PARCLOSE29-AFV1</incoming>
      <outgoing>AFV1-PARCLOSE31</outgoing>
    </task>
    <parallelGateway id="PARCLOSE31" name="PARCLOSE31">
      <incoming>DM1-PARCLOSE31</incoming>
      <incoming>AFV1-PARCLOSE31</incoming>
      <outgoing>PARCLOSE31-RMC1</outgoing>
    </parallelGateway>
    <task id="RMC1" name="Run Marketing Campaign">
      <incoming>PARCLOSE31-RMC1</incoming>
      <outgoing>RMC1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>RMC1-END</incoming>
    </endEvent>
