  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-AS1</outgoing>
    </startEvent>
    <task id="AS1" name="Approve Script">
      <incoming>Default_init-AS1</incoming>
      <outgoing>AS1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>AS1-Par1</incoming>
      <outgoing>Par1-SL1</outgoing>
      <outgoing>Par1-AF1</outgoing>
    </parallelGateway>
    <task id="SL1" name="Search Locations">
      <incoming>Par1-SL1</incoming>
      <outgoing>SL1-Par4</outgoing>
    </task>
    <task id="AF1" name="Additional Filming">
      <incoming>Par1-AF1</incoming>
      <outgoing>AF1-Par9</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>SL1-Par4</incoming>
      <outgoing>Par4-BC1</outgoing>
      <outgoing>Par4-G2</outgoing>
    </parallelGateway>
    <task id="BC1" name="Begin Casting">
      <incoming>Par4-BC1</incoming>
      <outgoing>BC1-Par12</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par4-G2</incoming>
      <outgoing>G2-NF1</outgoing>
      <outgoing>G2-XORCLOSE14</outgoing>
    </exclusiveGateway>
    <task id="NF1" name="Negotiate with Festivals">
      <incoming>G2-NF1</incoming>
      <outgoing>NF1-XORCLOSE14</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>AF1-Par9</incoming>
      <outgoing>Par9-DSS1</outgoing>
      <outgoing>Par9-CS2</outgoing>
    </parallelGateway>
    <task id="DSS1" name="Detail Script Scenes">
      <incoming>Par9-DSS1</incoming>
      <outgoing>DSS1-PPM1</outgoing>
    </task>
    <task id="CS2" name="Compose Soundtrack">
      <incoming>Par9-CS2</incoming>
      <outgoing>CS2-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>BC1-Par12</incoming>
      <outgoing>Par12-HS1</outgoing>
      <outgoing>Par12-AJ1</outgoing>
    </parallelGateway>
    <task id="HS1" name="Hire Suppliers">
      <incoming>Par12-HS1</incoming>
      <outgoing>HS1-Par16</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>G2-XORCLOSE14</incoming>
      <incoming>NF1-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-PC1</outgoing>
    </exclusiveGateway>
    <task id="PPM1" name="Produce Promotional Material">
      <incoming>DSS1-PPM1</incoming>
      <outgoing>PPM1-DM1</outgoing>
    </task>
    <parallelGateway id="Par16" name="PAR">
      <incoming>HS1-Par16</incoming>
      <outgoing>Par16-CS1</outgoing>
      <outgoing>Par16-PFE1</outgoing>
    </parallelGateway>
    <task id="CS1" name="Construct Stage">
      <incoming>Par16-CS1</incoming>
      <outgoing>CS1-RS1</outgoing>
    </task>
    <task id="PFE1" name="Prepare Filming Equipment">
      <incoming>Par16-PFE1</incoming>
      <outgoing>PFE1-PARCLOSE29</outgoing>
    </task>
    <task id="AJ1" name="Adjust Script">
      <incoming>Par12-AJ1</incoming>
      <outgoing>AJ1-PARCLOSE30</outgoing>
    </task>
    <task id="PC1" name="Produce Costumes">
      <incoming>XORCLOSE14-PC1</incoming>
      <outgoing>PC1-PARCLOSE31</outgoing>
    </task>
    <task id="DM1" name="Distribute Movie">
      <incoming>PPM1-DM1</incoming>
      <outgoing>DM1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>CS2-PARCLOSE23</incoming>
      <incoming>DM1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-PARCLOSE32</outgoing>
    </parallelGateway>
    <task id="RS1" name="Rehearse Scenes">
      <incoming>CS1-RS1</incoming>
      <outgoing>RS1-FS1</outgoing>
    </task>
    <task id="FS1" name="Film Scenes">
      <incoming>RS1-FS1</incoming>
      <outgoing>FS1-PVE1</outgoing>
    </task>
    <task id="PVE1" name="Produce Visual Effects">
      <incoming>FS1-PVE1</incoming>
      <outgoing>PVE1-PE1</outgoing>
    </task>
    <task id="PE1" name="Preliminary Editing">
      <incoming>PVE1-PE1</incoming>
      <outgoing>PE1-PARCLOSE29</outgoing>
    </task>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>PFE1-PARCLOSE29</incoming>
      <incoming>PE1-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-PARCLOSE30</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE30" name="PARCLOSE30">
      <incoming>AJ1-PARCLOSE30</incoming>
      <incoming>PARCLOSE29-PARCLOSE30</incoming>
      <outgoing>PARCLOSE30-PARCLOSE31</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE31" name="PARCLOSE31">
      <incoming>PC1-PARCLOSE31</incoming>
      <incoming>PARCLOSE30-PARCLOSE31</incoming>
      <outgoing>PARCLOSE31-PARCLOSE32</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE32" name="PARCLOSE32">
      <incoming>PARCLOSE23-PARCLOSE32</incoming>
      <incoming>PARCLOSE31-PARCLOSE32</incoming>
      <outgoing>PARCLOSE32-AP1</outgoing>
    </parallelGateway>
    <task id="AP1" name="Advance Post-Production">
      <incoming>PARCLOSE32-AP1</incoming>
      <outgoing>AP1-FSE1</outgoing>
    </task>
    <task id="FSE1" name="Final Sound Editing">
      <incoming>AP1-FSE1</incoming>
      <outgoing>FSE1-AFV1</outgoing>
    </task>
    <task id="AFV1" name="Approve Final Version">
      <incoming>FSE1-AFV1</incoming>
      <outgoing>AFV1-RMC1</outgoing>
    </task>
    <task id="RMC1" name="Run Marketing Campaign">
      <incoming>AFV1-RMC1</incoming>
      <outgoing>RMC1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>RMC1-END</incoming>
    </endEvent>
