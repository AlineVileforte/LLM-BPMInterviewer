      <outgoing>FS1-PVE1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>DM1-PARCLOSE26</incoming>
      <incoming>PARCLOSE24-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-PARCLOSE33</outgoing>
    </parallelGateway>
    <task id="PVE1" name="Produce Visual Effects">
      <incoming>FS1-PVE1</incoming>
      <outgoing>PVE1-PARCLOSE28</outgoing>
    </task>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>AJ1-PARCLOSE28</incoming>
      <incoming>PVE1-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-PE1</outgoing>
    </parallelGateway>
    <task id="PE1" name="Preliminary Editing">
      <incoming>PARCLOSE28-PE1</incoming>
      <outgoing>PE1-PARCLOSE30</outgoing>
    </task>
    <parallelGateway id="PARCLOSE30" name="PARCLOSE30">
      <incoming>CS1-PARCLOSE30</incoming>
      <incoming>PE1-PARCLOSE30</incoming>
      <outgoing>PARCLOSE30-AP1</outgoing>
    </parallelGateway>
    <task id="AP1" name="Advance Post-Production">
      <incoming>PARCLOSE30-AP1</incoming>
      <outgoing>AP1-PARCLOSE32</outgoing>
    </task>
    <parallelGateway id="PARCLOSE32" name="PARCLOSE32">
      <incoming>XORCLOSE10-PARCLOSE32</incoming>
      <incoming>AP1-PARCLOSE32</incoming>
      <outgoing>PARCLOSE32-PARCLOSE33</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE33" name="PARCLOSE33">
      <incoming>PARCLOSE26-PARCLOSE33</incoming>
      <incoming>PARCLOSE32-PARCLOSE33</incoming>
      <outgoing>PARCLOSE33-FSE1</outgoing>
    </parallelGateway>
    <task id="FSE1" name="Final Sound Editing">
      <incoming>PARCLOSE33-FSE1</incoming>
      <outgoing>FSE1-AFV1</outgoing>
    </task>
    <task id="AFV1" name="Approve Final Version">
      <incoming>FSE1-AFV1</incoming>
      <outgoing>AFV1-RMC1</outgoing>
    </task>
    <task id="RMC1" name="Run Marketing Campaign">
      <incoming>AFV1-RMC1</incoming>
      <outgoing>RMC1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>RMC1-END</incoming>
    </endEvent>
