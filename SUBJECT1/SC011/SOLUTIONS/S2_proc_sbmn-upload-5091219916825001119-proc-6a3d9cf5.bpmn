  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-AS1</outgoing>
      <outgoing>Par0-Par7</outgoing>
    </parallelGateway>
    <task id="AS1" name="Approve Script">
      <incoming>Par0-AS1</incoming>
      <outgoing>AS1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>AS1-Par2</incoming>
      <outgoing>Par2-SL1</outgoing>
      <outgoing>Par2-G1</outgoing>
    </parallelGateway>
    <task id="SL1" name="Search Locations">
      <incoming>Par2-SL1</incoming>
      <outgoing>SL1-CS2</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par2-G1</incoming>
      <outgoing>G1-NF1</outgoing>
      <outgoing>G1-XORCLOSE10</outgoing>
    </exclusiveGateway>
    <task id="NF1" name="Negotiate with Festivals">
      <incoming>G1-NF1</incoming>
      <outgoing>NF1-XORCLOSE10</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>Par0-Par7</incoming>
      <outgoing>Par7-DSS1</outgoing>
      <outgoing>Par7-Par12</outgoing>
    </parallelGateway>
    <task id="DSS1" name="Detail Script Scenes">
      <incoming>Par7-DSS1</incoming>
      <outgoing>DSS1-PPM1</outgoing>
    </task>
    <task id="CS2" name="Compose Soundtrack">
      <incoming>SL1-CS2</incoming>
      <outgoing>CS2-Par14</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE10" name="XORCLOSE10">
      <incoming>G1-XORCLOSE10</incoming>
      <incoming>NF1-XORCLOSE10</incoming>
      <outgoing>XORCLOSE10-PARCLOSE32</outgoing>
    </exclusiveGateway>
    <task id="PPM1" name="Produce Promotional Material">
      <incoming>DSS1-PPM1</incoming>
      <outgoing>PPM1-DM1</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>Par7-Par12</incoming>
      <outgoing>Par12-HS1</outgoing>
      <outgoing>Par12-PFE1</outgoing>
    </parallelGateway>
    <task id="HS1" name="Hire Suppliers">
      <incoming>Par12-HS1</incoming>
      <outgoing>HS1-PC1</outgoing>
    </task>
    <parallelGateway id="Par14" name="PAR">
      <incoming>CS2-Par14</incoming>
      <outgoing>Par14-BC1</outgoing>
      <outgoing>Par14-AF1</outgoing>
    </parallelGateway>
    <task id="BC1" name="Begin Casting">
      <incoming>Par14-BC1</incoming>
      <outgoing>BC1-Par20</outgoing>
    </task>
    <task id="AF1" name="Additional Filming">
      <incoming>Par14-AF1</incoming>
      <outgoing>AF1-CS1</outgoing>
    </task>
    <task id="DM1" name="Distribute Movie">
      <incoming>PPM1-DM1</incoming>
      <outgoing>DM1-PARCLOSE26</outgoing>
    </task>
    <task id="PC1" name="Produce Costumes">
      <incoming>HS1-PC1</incoming>
      <outgoing>PC1-PARCLOSE24</outgoing>
    </task>
    <task id="PFE1" name="Prepare Filming Equipment">
      <incoming>Par12-PFE1</incoming>
      <outgoing>PFE1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="Par20" name="PAR">
      <incoming>BC1-Par20</incoming>
      <outgoing>Par20-AJ1</outgoing>
      <outgoing>Par20-RS1</outgoing>
    </parallelGateway>
    <task id="AJ1" name="Adjust Script">
      <incoming>Par20-AJ1</incoming>
      <outgoing>AJ1-PARCLOSE28</outgoing>
    </task>
    <task id="RS1" name="Rehearse Scenes">
      <incoming>Par20-RS1</incoming>
      <outgoing>RS1-FS1</outgoing>
    </task>
    <task id="CS1" name="Construct Stage">
      <incoming>AF1-CS1</incoming>
      <outgoing>CS1-PARCLOSE30</outgoing>
    </task>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
