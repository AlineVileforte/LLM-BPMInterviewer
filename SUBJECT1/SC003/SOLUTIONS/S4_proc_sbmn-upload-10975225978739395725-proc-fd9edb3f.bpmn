  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-IE1</outgoing>
    </startEvent>
    <task id="IE1" name="Incur Expense">
      <incoming>Default_init-IE1</incoming>
      <outgoing>IE1-VED1</outgoing>
    </task>
    <task id="VED1" name="Verify Expense Documentation">
      <incoming>IE1-VED1</incoming>
      <outgoing>VED1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>VED1-G0</incoming>
      <outgoing>G0-DNRP1</outgoing>
      <outgoing>G0-G1</outgoing>
    </exclusiveGateway>
    <task id="DNRP1" name="Do Not Record Payment">
      <incoming>G0-DNRP1</incoming>
      <outgoing>DNRP1-XORCLOSE12</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>G0-G1</incoming>
      <outgoing>G1-G2</outgoing>
      <outgoing>G1-RP1</outgoing>
    </exclusiveGateway>
    <task id="RP1" name="Record Payment">
      <incoming>G1-RP1</incoming>
      <outgoing>RP1-XORCLOSE11</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>G1-G2</incoming>
      <outgoing>G2-RPC1</outgoing>
      <outgoing>G2-XORCLOSE10</outgoing>
    </exclusiveGateway>
    <task id="RPC1" name="Receive Payment Confirmation">
      <incoming>G2-RPC1</incoming>
      <outgoing>RPC1-RNPN1</outgoing>
    </task>
    <task id="RNPN1" name="Receive Non-Payment Notification">
      <incoming>RPC1-RNPN1</incoming>
      <outgoing>RNPN1-XORCLOSE10</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE10" name="XORCLOSE10">
      <incoming>G2-XORCLOSE10</incoming>
      <incoming>RNPN1-XORCLOSE10</incoming>
      <outgoing>XORCLOSE10-XORCLOSE11</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE11" name="XORCLOSE11">
      <incoming>RP1-XORCLOSE11</incoming>
      <incoming>XORCLOSE10-XORCLOSE11</incoming>
      <outgoing>XORCLOSE11-XORCLOSE12</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE12" name="XORCLOSE12">
      <incoming>DNRP1-XORCLOSE12</incoming>
      <incoming>XORCLOSE11-XORCLOSE12</incoming>
      <outgoing>XORCLOSE12-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE12-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-IE1" sourceRef="Default_init" targetRef="IE1"/>
    <sequenceFlow id="IE1-VED1" sourceRef="IE1" targetRef="VED1"/>
    <sequenceFlow id="VED1-G0" sourceRef="VED1" targetRef="G0"/>
    <sequenceFlow id="G0-DNRP1" sourceRef="G0" targetRef="DNRP1"/>
    <sequenceFlow id="G0-G1" sourceRef="G0" targetRef="G1"/>
    <sequenceFlow id="DNRP1-XORCLOSE12" sourceRef="DNRP1" targetRef="XORCLOSE12"/>
    <sequenceFlow id="G1-G2" sourceRef="G1" targetRef="G2"/>
    <sequenceFlow id="G1-RP1" sourceRef="G1" targetRef="RP1"/>
    <sequenceFlow id="RP1-XORCLOSE11" sourceRef="RP1" targetRef="XORCLOSE11"/>
    <sequenceFlow id="G2-RPC1" sourceRef="G2" targetRef="RPC1"/>
    <sequenceFlow id="G2-XORCLOSE10" sourceRef="G2" targetRef="XORCLOSE10"/>
    <sequenceFlow id="RPC1-RNPN1" sourceRef="RPC1" targetRef="RNPN1"/>
    <sequenceFlow id="RNPN1-XORCLOSE10" sourceRef="RNPN1" targetRef="XORCLOSE10"/>
    <sequenceFlow id="XORCLOSE10-XORCLOSE11" sourceRef="XORCLOSE10" targetRef="XORCLOSE11"/>
    <sequenceFlow id="XORCLOSE11-XORCLOSE12" sourceRef="XORCLOSE11" targetRef="XORCLOSE12"/>
    <sequenceFlow id="XORCLOSE12-END" sourceRef="XORCLOSE12" targetRef="END"/>
  </process>
