      <outgoing>Par8-RPC1</outgoing>
      <outgoing>Par8-RNPN1</outgoing>
    </parallelGateway>
    <task id="RPC1" name="Receive Payment Confirmation">
      <incoming>Par8-RPC1</incoming>
      <outgoing>RPC1-PARCLOSE11</outgoing>
    </task>
    <task id="RNPN1" name="Receive Non-Payment Notification">
      <incoming>Par8-RNPN1</incoming>
      <outgoing>RNPN1-PARCLOSE11</outgoing>
    </task>
    <parallelGateway id="PARCLOSE11" name="PARCLOSE11">
      <incoming>RPC1-PARCLOSE11</incoming>
      <incoming>RNPN1-PARCLOSE11</incoming>
      <outgoing>PARCLOSE11-XORCLOSE12</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE12" name="XORCLOSE12">
      <incoming>G2-XORCLOSE12</incoming>
      <incoming>PARCLOSE11-XORCLOSE12</incoming>
      <outgoing>XORCLOSE12-XORCLOSE13</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE13" name="XORCLOSE13">
