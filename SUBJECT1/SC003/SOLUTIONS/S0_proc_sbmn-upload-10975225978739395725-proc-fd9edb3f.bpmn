  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-IE1</outgoing>
    </startEvent>
    <task id="IE1" name="Incur Expense">
      <incoming>Default_init-IE1</incoming>
      <outgoing>IE1-VED1</outgoing>
    </task>
    <task id="VED1" name="Verify Expense Documentation">
      <incoming>IE1-VED1</incoming>
      <outgoing>VED1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>VED1-G0</incoming>
      <outgoing>G0-DNRP1</outgoing>
      <outgoing>G0-G1</outgoing>
    </exclusiveGateway>
    <task id="DNRP1" name="Do Not Record Payment">
      <incoming>G0-DNRP1</incoming>
      <outgoing>DNRP1-XORCLOSE14</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>G0-G1</incoming>
      <outgoing>G1-G2</outgoing>
      <outgoing>G1-RP1</outgoing>
    </exclusiveGateway>
    <task id="RP1" name="Record Payment">
      <incoming>G1-RP1</incoming>
      <outgoing>RP1-XORCLOSE13</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>G1-G2</incoming>
