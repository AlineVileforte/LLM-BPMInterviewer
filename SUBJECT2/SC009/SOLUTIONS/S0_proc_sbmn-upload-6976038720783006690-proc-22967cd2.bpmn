      <outgoing>IM1-XORCLOSE9</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>G0-G1</incoming>
      <outgoing>G1-MP1</outgoing>
      <outgoing>G1-XORCLOSE8</outgoing>
    </exclusiveGateway>
    <task id="MP1" name="Make Payment">
      <incoming>G1-MP1</incoming>
      <outgoing>MP1-XORCLOSE8</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE8" name="XORCLOSE8">
      <incoming>G1-XORCLOSE8</incoming>
