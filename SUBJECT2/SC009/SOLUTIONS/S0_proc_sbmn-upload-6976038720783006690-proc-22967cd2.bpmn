      <outgoing>Default_init-RE1</outgoing>
    </startEvent>
    <task id="RE1" name="Register Expense">
      <incoming>Default_init-RE1</incoming>
      <outgoing>RE1-VE1</outgoing>
    </task>
    <task id="VE1" name="Validate Expense">
      <incoming>RE1-VE1</incoming>
      <outgoing>VE1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>VE1-G0</incoming>
      <outgoing>G0-RP1</outgoing>
      <outgoing>G0-G1</outgoing>
    </exclusiveGateway>
    <task id="RP1" name="Reject Payment">
      <incoming>G0-RP1</incoming>
      <outgoing>RP1-IM1</outgoing>
    </task>
    <task id="IM1" name="Inform Merchant">
