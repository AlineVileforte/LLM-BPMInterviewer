    <exclusiveGateway id="XORCLOSE9" name="XORCLOSE9">
      <incoming>IM1-XORCLOSE9</incoming>
      <incoming>XORCLOSE8-XORCLOSE9</incoming>
      <outgoing>XORCLOSE9-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE9-END</incoming>
    </endEvent>
