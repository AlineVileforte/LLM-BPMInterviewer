  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-NB1</outgoing>
    </startEvent>
    <task id="NB1" name="Nico is bored">
      <incoming>Default_init-NB1</incoming>
      <outgoing>NB1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>NB1-G0</incoming>
      <outgoing>G0-NIU1</outgoing>
      <outgoing>G0-NH1</outgoing>
    </exclusiveGateway>
    <task id="NIU1" name="Nico has an irresistible urge">
      <incoming>G0-NIU1</incoming>
      <outgoing>NIU1-NWF1</outgoing>
    </task>
    <task id="NH1" name="Nico is hungry">
      <incoming>G0-NH1</incoming>
      <outgoing>NH1-NEB1</outgoing>
    </task>
    <task id="NWF1" name="Nico wants to go fishing">
      <incoming>NIU1-NWF1</incoming>
      <outgoing>NWF1-G1</outgoing>
    </task>
    <task id="NEB1" name="Nico eats a banana">
      <incoming>NH1-NEB1</incoming>
      <outgoing>NEB1-XORCLOSE10</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>NWF1-G1</incoming>
      <outgoing>G1-NWV1</outgoing>
      <outgoing>G1-NGF1</outgoing>
    </exclusiveGateway>
    <task id="NWV1" name="Nico watches funny videos">
      <incoming>G1-NWV1</incoming>
      <outgoing>NWV1-XORCLOSE9</outgoing>
    </task>
    <task id="NGF1" name="Nico goes fishing">
      <incoming>G1-NGF1</incoming>
      <outgoing>NGF1-XORCLOSE9</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE9" name="XORCLOSE9">
      <incoming>NWV1-XORCLOSE9</incoming>
      <incoming>NGF1-XORCLOSE9</incoming>
      <outgoing>XORCLOSE9-XORCLOSE10</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE10" name="XORCLOSE10">
      <incoming>NEB1-XORCLOSE10</incoming>
      <incoming>XORCLOSE9-XORCLOSE10</incoming>
      <outgoing>XORCLOSE10-NHY1</outgoing>
    </exclusiveGateway>
    <task id="NHY1" name="Nico is happy">
      <incoming>XORCLOSE10-NHY1</incoming>
      <outgoing>NHY1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>NHY1-END</incoming>
    </endEvent>
