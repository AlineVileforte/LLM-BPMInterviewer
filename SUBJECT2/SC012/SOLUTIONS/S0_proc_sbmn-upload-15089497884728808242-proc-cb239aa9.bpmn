<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_5ad95376-7de2-41b6-b72c-f64f37320b56" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-NB1</outgoing>
    </startEvent>
    <task id="NB1" name="Nico is bored">
      <incoming>Default_init-NB1</incoming>
      <outgoing>NB1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>NB1-G0</incoming>
      <outgoing>G0-Par2</outgoing>
      <outgoing>G0-NH1</outgoing>
    </exclusiveGateway>
    <parallelGateway id="Par2" name="PAR">
      <incoming>G0-Par2</incoming>
      <outgoing>Par2-NIU1</outgoing>
      <outgoing>Par2-NWF1</outgoing>
    </parallelGateway>
    <task id="NIU1" name="Nico has an irresistible urge">
      <incoming>Par2-NIU1</incoming>
      <outgoing>NIU1-NWV1</outgoing>
    </task>
    <task id="NWF1" name="Nico wants to go fishing">
      <incoming>Par2-NWF1</incoming>
      <outgoing>NWF1-PARCLOSE7</outgoing>
    </task>
    <task id="NH1" name="Nico is hungry">
      <incoming>G0-NH1</incoming>
      <outgoing>NH1-NEB1</outgoing>
    </task>
    <task id="NWV1" name="Nico watches funny videos">
      <incoming>NIU1-NWV1</incoming>
      <outgoing>NWV1-PARCLOSE7</outgoing>
    </task>
    <parallelGateway id="PARCLOSE7" name="PARCLOSE7">
      <incoming>NWF1-PARCLOSE7</incoming>
      <incoming>NWV1-PARCLOSE7</incoming>
      <outgoing>PARCLOSE7-NGF1</outgoing>
    </parallelGateway>
    <task id="NEB1" name="Nico eats a banana">
      <incoming>NH1-NEB1</incoming>
      <outgoing>NEB1-XORCLOSE10</outgoing>
    </task>
    <task id="NGF1" name="Nico goes fishing">
      <incoming>PARCLOSE7-NGF1</incoming>
      <outgoing>NGF1-XORCLOSE10</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE10" name="XORCLOSE10">
      <incoming>NEB1-XORCLOSE10</incoming>
      <incoming>NGF1-XORCLOSE10</incoming>
      <outgoing>XORCLOSE10-NHY1</outgoing>
    </exclusiveGateway>
    <task id="NHY1" name="Nico is happy">
      <incoming>XORCLOSE10-NHY1</incoming>
      <outgoing>NHY1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>NHY1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-NB1" sourceRef="Default_init" targetRef="NB1"/>
