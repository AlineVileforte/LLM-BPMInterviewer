      <incoming>XORCLOSE9-XORCLOSE10</incoming>
      <outgoing>XORCLOSE10-NHY1</outgoing>
    </exclusiveGateway>
    <task id="NHY1" name="Nico is happy">
      <incoming>XORCLOSE10-NHY1</incoming>
      <outgoing>NHY1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
