<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_f43b1ae7-6a40-4bf7-a214-764fe8276722" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-CC1</outgoing>
      <outgoing>Par0-G0</outgoing>
    </parallelGateway>
    <task id="CC1" name="Check Customer">
      <incoming>Par0-CC1</incoming>
      <outgoing>CC1-CPH1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par0-G0</incoming>
      <outgoing>G0-PMG1</outgoing>
      <outgoing>G0-XORCLOSE6</outgoing>
    </exclusiveGateway>
    <task id="PMG1" name="Producing Missing Goods">
      <incoming>G0-PMG1</incoming>
      <outgoing>PMG1-XORCLOSE6</outgoing>
    </task>
    <task id="CPH1" name="Check Payment History">
      <incoming>CC1-CPH1</incoming>
      <outgoing>CPH1-G1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE6" name="XORCLOSE6">
      <incoming>G0-XORCLOSE6</incoming>
      <incoming>PMG1-XORCLOSE6</incoming>
      <outgoing>XORCLOSE6-PARCLOSE16</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G1" name="G1">
      <incoming>CPH1-G1</incoming>
      <outgoing>G1-DM1</outgoing>
      <outgoing>G1-XORCLOSE14</outgoing>
    </exclusiveGateway>
    <task id="DM1" name="Declining Message">
      <incoming>G1-DM1</incoming>
      <outgoing>DM1-CNC1</outgoing>
    </task>
    <task id="CNC1" name="Create New Customer">
      <incoming>DM1-CNC1</incoming>
      <outgoing>CNC1-CA1</outgoing>
    </task>
    <task id="CA1" name="Check Availability">
      <incoming>CNC1-CA1</incoming>
      <outgoing>CA1-SCC1</outgoing>
    </task>
    <task id="SCC1" name="Sending Confirmation to Customer">
      <incoming>CA1-SCC1</incoming>
      <outgoing>SCC1-XORCLOSE14</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>G1-XORCLOSE14</incoming>
      <incoming>SCC1-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-CCT1</outgoing>
    </exclusiveGateway>
    <task id="CCT1" name="Check Customer Type">
      <incoming>XORCLOSE14-CCT1</incoming>
      <outgoing>CCT1-PARCLOSE16</outgoing>
    </task>
    <parallelGateway id="PARCLOSE16" name="PARCLOSE16">
      <incoming>XORCLOSE6-PARCLOSE16</incoming>
      <incoming>CCT1-PARCLOSE16</incoming>
      <outgoing>PARCLOSE16-GRD1</outgoing>
    </parallelGateway>
    <task id="GRD1" name="Getting ready for delivery">
      <incoming>PARCLOSE16-GRD1</incoming>
      <outgoing>GRD1-PI1</outgoing>
    </task>
    <task id="PI1" name="Preparing Invoice">
      <incoming>GRD1-PI1</incoming>
      <outgoing>PI1-PTG1</outgoing>
    </task>
    <task id="PTG1" name="Pack the Goods">
      <incoming>PI1-PTG1</incoming>
      <outgoing>PTG1-DTG1</outgoing>
    </task>
    <task id="DTG1" name="Deliver the Goods">
      <incoming>PTG1-DTG1</incoming>
      <outgoing>DTG1-SIC1</outgoing>
    </task>
    <task id="SIC1" name="Send the Invoice invoice to customer">
      <incoming>DTG1-SIC1</incoming>
      <outgoing>SIC1-XOR_JMPBB_DP1_CFP1</outgoing>
    </task>
    <task id="CFP1" name="Check for Payment">
      <incoming>XOR_JMPBB_DP1_CFP1-CFP1</incoming>
      <outgoing>CFP1-G2</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>CFP1-G2</incoming>
      <outgoing>G2-CO1</outgoing>
      <outgoing>G2-CTR1</outgoing>
    </exclusiveGateway>
    <task id="CO1" name="Closing Order">
      <incoming>G2-CO1</incoming>
      <outgoing>CO1-XORCLOSE27</outgoing>
    </task>
    <task id="CTR1" name="Checking the reminders">
      <incoming>G2-CTR1</incoming>
      <outgoing>CTR1-DP1</outgoing>
    </task>
    <task id="DP1" name="Dunning Process">
      <incoming>CTR1-DP1</incoming>
      <outgoing>DP1-XOR_JMPAA_DP1_CFP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE27" name="XORCLOSE27">
      <incoming>CO1-XORCLOSE27</incoming>
      <incoming>XOR_JMPAA_DP1_CFP1-XORCLOSE27</incoming>
      <outgoing>XORCLOSE27-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE27-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_DP1_CFP1" name="XOR_JMPAA_Dunning Process">
      <incoming>DP1-XOR_JMPAA_DP1_CFP1</incoming>
      <outgoing>XOR_JMPAA_DP1_CFP1-XORCLOSE27</outgoing>
      <outgoing>XOR_JMPAA_DP1_CFP1-XOR_JMPBB_DP1_CFP1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_DP1_CFP1" name="XOR_JMPBB_Check for Payment">
      <incoming>SIC1-XOR_JMPBB_DP1_CFP1</incoming>
      <incoming>XOR_JMPAA_DP1_CFP1-XOR_JMPBB_DP1_CFP1</incoming>
      <outgoing>XOR_JMPBB_DP1_CFP1-CFP1</outgoing>
    </exclusiveGateway>
