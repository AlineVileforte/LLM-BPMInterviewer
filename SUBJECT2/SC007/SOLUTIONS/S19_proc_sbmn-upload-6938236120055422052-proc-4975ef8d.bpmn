<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_6253d687-ed46-4e79-bcb9-1f7b56feada2" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CC1</outgoing>
    </startEvent>
    <task id="CC1" name="Check Customer">
      <incoming>Default_init-CC1</incoming>
      <outgoing>CC1-CPH1</outgoing>
    </task>
    <task id="CPH1" name="Check Payment History">
      <incoming>CC1-CPH1</incoming>
      <outgoing>CPH1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>CPH1-Par2</incoming>
      <outgoing>Par2-G2</outgoing>
      <outgoing>Par2-G3</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par2-G2</incoming>
      <outgoing>G2-PMG1</outgoing>
      <outgoing>G2-XORCLOSE28</outgoing>
    </exclusiveGateway>
    <task id="PMG1" name="Producing Missing Goods">
      <incoming>G2-PMG1</incoming>
      <outgoing>PMG1-GRD1</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>Par2-G3</incoming>
      <outgoing>G3-DM1</outgoing>
      <outgoing>G3-XORCLOSE20</outgoing>
    </exclusiveGateway>
    <task id="DM1" name="Declining Message">
      <incoming>G3-DM1</incoming>
      <outgoing>DM1-CNC1</outgoing>
    </task>
    <task id="GRD1" name="Getting ready for delivery">
      <incoming>PMG1-GRD1</incoming>
      <outgoing>GRD1-Par11</outgoing>
    </task>
    <task id="CNC1" name="Create New Customer">
      <incoming>DM1-CNC1</incoming>
      <outgoing>CNC1-CA1</outgoing>
    </task>
    <parallelGateway id="Par11" name="PAR">
      <incoming>GRD1-Par11</incoming>
      <outgoing>Par11-PTG1</outgoing>
      <outgoing>Par11-PI1</outgoing>
    </parallelGateway>
    <task id="PTG1" name="Pack the Goods">
      <incoming>Par11-PTG1</incoming>
      <outgoing>PTG1-DTG1</outgoing>
    </task>
    <task id="PI1" name="Preparing Invoice">
      <incoming>Par11-PI1</incoming>
      <outgoing>PI1-PARCLOSE16</outgoing>
    </task>
    <task id="DTG1" name="Deliver the Goods">
      <incoming>PTG1-DTG1</incoming>
      <outgoing>DTG1-PARCLOSE16</outgoing>
    </task>
    <parallelGateway id="PARCLOSE16" name="PARCLOSE16">
      <incoming>PI1-PARCLOSE16</incoming>
      <incoming>DTG1-PARCLOSE16</incoming>
      <outgoing>PARCLOSE16-SIC1</outgoing>
    </parallelGateway>
    <task id="CA1" name="Check Availability">
      <incoming>CNC1-CA1</incoming>
      <outgoing>CA1-SCC1</outgoing>
    </task>
    <task id="SIC1" name="Send the Invoice invoice to customer">
      <incoming>PARCLOSE16-SIC1</incoming>
      <outgoing>SIC1-XOR_JMPBB_DP1_CFP1</outgoing>
    </task>
    <task id="SCC1" name="Sending Confirmation to Customer">
      <incoming>CA1-SCC1</incoming>
      <outgoing>SCC1-XORCLOSE20</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>G3-XORCLOSE20</incoming>
      <incoming>SCC1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-CCT1</outgoing>
    </exclusiveGateway>
    <task id="CFP1" name="Check for Payment">
      <incoming>XOR_JMPBB_DP1_CFP1-CFP1</incoming>
      <outgoing>CFP1-G4</outgoing>
    </task>
    <task id="CCT1" name="Check Customer Type">
      <incoming>XORCLOSE20-CCT1</incoming>
      <outgoing>CCT1-PARCLOSE29</outgoing>
    </task>
    <exclusiveGateway id="G4" name="G4">
      <incoming>CFP1-G4</incoming>
      <outgoing>G4-CO1</outgoing>
      <outgoing>G4-CTR1</outgoing>
    </exclusiveGateway>
    <task id="CO1" name="Closing Order">
      <incoming>G4-CO1</incoming>
      <outgoing>CO1-XORCLOSE27</outgoing>
    </task>
    <task id="CTR1" name="Checking the reminders">
      <incoming>G4-CTR1</incoming>
      <outgoing>CTR1-DP1</outgoing>
    </task>
    <task id="DP1" name="Dunning Process">
      <incoming>CTR1-DP1</incoming>
      <outgoing>DP1-XOR_JMPAA_DP1_CFP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE27" name="XORCLOSE27">
      <incoming>CO1-XORCLOSE27</incoming>
      <incoming>XOR_JMPAA_DP1_CFP1-XORCLOSE27</incoming>
      <outgoing>XORCLOSE27-XORCLOSE28</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE28" name="XORCLOSE28">
      <incoming>G2-XORCLOSE28</incoming>
      <incoming>XORCLOSE27-XORCLOSE28</incoming>
      <outgoing>XORCLOSE28-PARCLOSE29</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>CCT1-PARCLOSE29</incoming>
      <incoming>XORCLOSE28-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE29-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_DP1_CFP1" name="XOR_JMPAA_Dunning Process">
      <incoming>DP1-XOR_JMPAA_DP1_CFP1</incoming>
      <outgoing>XOR_JMPAA_DP1_CFP1-XORCLOSE27</outgoing>
      <outgoing>XOR_JMPAA_DP1_CFP1-XOR_JMPBB_DP1_CFP1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_DP1_CFP1" name="XOR_JMPBB_Check for Payment">
      <incoming>SIC1-XOR_JMPBB_DP1_CFP1</incoming>
      <incoming>XOR_JMPAA_DP1_CFP1-XOR_JMPBB_DP1_CFP1</incoming>
      <outgoing>XOR_JMPBB_DP1_CFP1-CFP1</outgoing>
    </exclusiveGateway>
