    <exclusiveGateway id="XORCLOSE33" name="XORCLOSE33">
      <incoming>XORCLOSE17-XORCLOSE33</incoming>
      <incoming>XORCLOSE32-XORCLOSE33</incoming>
      <outgoing>XORCLOSE33-END</outgoing>
    </exclusiveGateway>
