    <sequenceFlow id="SCC1-END" sourceRef="SCC1" targetRef="END"/>
    <sequenceFlow id="XOR_JMPAA_DP1_CFP1-XORCLOSE15" sourceRef="XOR_JMPAA_DP1_CFP1" targetRef="XORCLOSE15"/>
