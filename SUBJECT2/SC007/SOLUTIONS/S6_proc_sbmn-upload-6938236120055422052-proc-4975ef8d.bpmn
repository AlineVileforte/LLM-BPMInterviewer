<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_45f68881-d529-41b5-b86a-c4f27d4941a3" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-G0</outgoing>
    </startEvent>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Default_init-G0</incoming>
      <outgoing>G0-PMG1</outgoing>
      <outgoing>G0-XORCLOSE16</outgoing>
    </exclusiveGateway>
    <task id="PMG1" name="Producing Missing Goods">
      <incoming>G0-PMG1</incoming>
      <outgoing>PMG1-GRD1</outgoing>
    </task>
    <task id="GRD1" name="Getting ready for delivery">
      <incoming>PMG1-GRD1</incoming>
      <outgoing>GRD1-Par4</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>GRD1-Par4</incoming>
      <outgoing>Par4-PTG1</outgoing>
      <outgoing>Par4-PI1</outgoing>
    </parallelGateway>
    <task id="PTG1" name="Pack the Goods">
      <incoming>Par4-PTG1</incoming>
      <outgoing>PTG1-DTG1</outgoing>
    </task>
    <task id="PI1" name="Preparing Invoice">
      <incoming>Par4-PI1</incoming>
      <outgoing>PI1-PARCLOSE8</outgoing>
    </task>
    <task id="DTG1" name="Deliver the Goods">
      <incoming>PTG1-DTG1</incoming>
      <outgoing>DTG1-PARCLOSE8</outgoing>
    </task>
    <parallelGateway id="PARCLOSE8" name="PARCLOSE8">
      <incoming>PI1-PARCLOSE8</incoming>
      <incoming>DTG1-PARCLOSE8</incoming>
      <outgoing>PARCLOSE8-SIC1</outgoing>
    </parallelGateway>
    <task id="SIC1" name="Send the Invoice invoice to customer">
      <incoming>PARCLOSE8-SIC1</incoming>
      <outgoing>SIC1-XOR_JMPBB_DP1_CFP1</outgoing>
    </task>
    <task id="CFP1" name="Check for Payment">
      <incoming>XOR_JMPBB_DP1_CFP1-CFP1</incoming>
      <outgoing>CFP1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>CFP1-G1</incoming>
      <outgoing>G1-CO1</outgoing>
      <outgoing>G1-CTR1</outgoing>
    </exclusiveGateway>
    <task id="CO1" name="Closing Order">
      <incoming>G1-CO1</incoming>
      <outgoing>CO1-XORCLOSE15</outgoing>
    </task>
    <task id="CTR1" name="Checking the reminders">
      <incoming>G1-CTR1</incoming>
      <outgoing>CTR1-DP1</outgoing>
    </task>
    <task id="DP1" name="Dunning Process">
      <incoming>CTR1-DP1</incoming>
      <outgoing>DP1-XOR_JMPAA_DP1_CFP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE15" name="XORCLOSE15">
      <incoming>CO1-XORCLOSE15</incoming>
      <incoming>XOR_JMPAA_DP1_CFP1-XORCLOSE15</incoming>
      <outgoing>XORCLOSE15-XORCLOSE16</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
      <incoming>G0-XORCLOSE16</incoming>
      <incoming>XORCLOSE15-XORCLOSE16</incoming>
      <outgoing>XORCLOSE16-CC1</outgoing>
    </exclusiveGateway>
    <task id="CC1" name="Check Customer">
      <incoming>XORCLOSE16-CC1</incoming>
      <outgoing>CC1-Par18</outgoing>
    </task>
    <parallelGateway id="Par18" name="PAR">
      <incoming>CC1-Par18</incoming>
      <outgoing>Par18-CPH1</outgoing>
      <outgoing>Par18-CCT1</outgoing>
    </parallelGateway>
    <task id="CPH1" name="Check Payment History">
      <incoming>Par18-CPH1</incoming>
      <outgoing>CPH1-G2</outgoing>
    </task>
    <task id="CCT1" name="Check Customer Type">
      <incoming>Par18-CCT1</incoming>
      <outgoing>CCT1-PARCLOSE26</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>CPH1-G2</incoming>
      <outgoing>G2-DM1</outgoing>
      <outgoing>G2-XORCLOSE25</outgoing>
    </exclusiveGateway>
    <task id="DM1" name="Declining Message">
      <incoming>G2-DM1</incoming>
      <outgoing>DM1-XORCLOSE25</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE25" name="XORCLOSE25">
      <incoming>G2-XORCLOSE25</incoming>
      <incoming>DM1-XORCLOSE25</incoming>
      <outgoing>XORCLOSE25-PARCLOSE26</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>CCT1-PARCLOSE26</incoming>
      <incoming>XORCLOSE25-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-CNC1</outgoing>
    </parallelGateway>
    <task id="CNC1" name="Create New Customer">
      <incoming>PARCLOSE26-CNC1</incoming>
      <outgoing>CNC1-CA1</outgoing>
    </task>
    <task id="CA1" name="Check Availability">
      <incoming>CNC1-CA1</incoming>
      <outgoing>CA1-SCC1</outgoing>
    </task>
    <task id="SCC1" name="Sending Confirmation to Customer">
      <incoming>CA1-SCC1</incoming>
      <outgoing>SCC1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>SCC1-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_DP1_CFP1" name="XOR_JMPAA_Dunning Process">
      <incoming>DP1-XOR_JMPAA_DP1_CFP1</incoming>
      <outgoing>XOR_JMPAA_DP1_CFP1-XORCLOSE15</outgoing>
      <outgoing>XOR_JMPAA_DP1_CFP1-XOR_JMPBB_DP1_CFP1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_DP1_CFP1" name="XOR_JMPBB_Check for Payment">
      <incoming>SIC1-XOR_JMPBB_DP1_CFP1</incoming>
      <incoming>XOR_JMPAA_DP1_CFP1-XOR_JMPBB_DP1_CFP1</incoming>
      <outgoing>XOR_JMPBB_DP1_CFP1-CFP1</outgoing>
    </exclusiveGateway>
