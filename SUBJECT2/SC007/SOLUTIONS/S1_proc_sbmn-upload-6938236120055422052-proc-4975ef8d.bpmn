      <outgoing>XORCLOSE16-CC1</outgoing>
    </exclusiveGateway>
    <task id="CC1" name="Check Customer">
      <incoming>XORCLOSE16-CC1</incoming>
      <outgoing>CC1-CPH1</outgoing>
    </task>
    <task id="CPH1" name="Check Payment History">
      <incoming>CC1-CPH1</incoming>
      <outgoing>CPH1-Par19</outgoing>
    </task>
    <parallelGateway id="Par19" name="PAR">
