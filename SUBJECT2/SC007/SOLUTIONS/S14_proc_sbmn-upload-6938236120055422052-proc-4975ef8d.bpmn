    <sequenceFlow id="CCT1-PARCLOSE18" sourceRef="CCT1" targetRef="PARCLOSE18"/>
    <sequenceFlow id="CA1-SCC1" sourceRef="CA1" targetRef="SCC1"/>
    <sequenceFlow id="SCC1-XORCLOSE17" sourceRef="SCC1" targetRef="XORCLOSE17"/>
    <sequenceFlow id="XORCLOSE17-PARCLOSE18" sourceRef="XORCLOSE17" targetRef="PARCLOSE18"/>
    <sequenceFlow id="PARCLOSE18-GRD1" sourceRef="PARCLOSE18" targetRef="GRD1"/>
    <sequenceFlow id="GRD1-PTG1" sourceRef="GRD1" targetRef="PTG1"/>
    <sequenceFlow id="PTG1-PI1" sourceRef="PTG1" targetRef="PI1"/>
    <sequenceFlow id="PI1-DTG1" sourceRef="PI1" targetRef="DTG1"/>
    <sequenceFlow id="DTG1-SIC1" sourceRef="DTG1" targetRef="SIC1"/>
    <sequenceFlow id="SIC1-XOR_JMPBB_DP1_CFP1" sourceRef="SIC1" targetRef="XOR_JMPBB_DP1_CFP1"/>
    <sequenceFlow id="CFP1-G3" sourceRef="CFP1" targetRef="G3"/>
    <sequenceFlow id="G3-CO1" sourceRef="G3" targetRef="CO1"/>
    <sequenceFlow id="G3-CTR1" sourceRef="G3" targetRef="CTR1"/>
    <sequenceFlow id="CO1-XORCLOSE29" sourceRef="CO1" targetRef="XORCLOSE29"/>
    <sequenceFlow id="CTR1-DP1" sourceRef="CTR1" targetRef="DP1"/>
    <sequenceFlow id="DP1-XOR_JMPAA_DP1_CFP1" sourceRef="DP1" targetRef="XOR_JMPAA_DP1_CFP1"/>
    <sequenceFlow id="XORCLOSE29-END" sourceRef="XORCLOSE29" targetRef="END"/>
    <sequenceFlow id="XOR_JMPAA_DP1_CFP1-XORCLOSE29" sourceRef="XOR_JMPAA_DP1_CFP1" targetRef="XORCLOSE29"/>
    <sequenceFlow id="XOR_JMPAA_DP1_CFP1-XOR_JMPBB_DP1_CFP1" sourceRef="XOR_JMPAA_DP1_CFP1" targetRef="XOR_JMPBB_DP1_CFP1"/>
    <sequenceFlow id="XOR_JMPBB_DP1_CFP1-CFP1" sourceRef="XOR_JMPBB_DP1_CFP1" targetRef="CFP1"/>
  </process>
