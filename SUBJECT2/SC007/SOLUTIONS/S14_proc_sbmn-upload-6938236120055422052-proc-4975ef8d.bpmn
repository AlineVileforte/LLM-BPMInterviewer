<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_02e988c9-8252-4baa-b018-593e62eea715" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CC1</outgoing>
    </startEvent>
    <task id="CC1" name="Check Customer">
      <incoming>Default_init-CC1</incoming>
      <outgoing>CC1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>CC1-Par1</incoming>
      <outgoing>Par1-CPH1</outgoing>
      <outgoing>Par1-G1</outgoing>
    </parallelGateway>
    <task id="CPH1" name="Check Payment History">
      <incoming>Par1-CPH1</incoming>
      <outgoing>CPH1-G2</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par1-G1</incoming>
      <outgoing>G1-PMG1</outgoing>
      <outgoing>G1-XORCLOSE9</outgoing>
    </exclusiveGateway>
    <task id="PMG1" name="Producing Missing Goods">
      <incoming>G1-PMG1</incoming>
      <outgoing>PMG1-XORCLOSE9</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>CPH1-G2</incoming>
      <outgoing>G2-DM1</outgoing>
      <outgoing>G2-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="DM1" name="Declining Message">
      <incoming>G2-DM1</incoming>
      <outgoing>DM1-CNC1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE9" name="XORCLOSE9">
      <incoming>G1-XORCLOSE9</incoming>
      <incoming>PMG1-XORCLOSE9</incoming>
      <outgoing>XORCLOSE9-CCT1</outgoing>
    </exclusiveGateway>
    <task id="CNC1" name="Create New Customer">
      <incoming>DM1-CNC1</incoming>
      <outgoing>CNC1-CA1</outgoing>
    </task>
    <task id="CCT1" name="Check Customer Type">
      <incoming>XORCLOSE9-CCT1</incoming>
      <outgoing>CCT1-PARCLOSE18</outgoing>
    </task>
    <task id="CA1" name="Check Availability">
      <incoming>CNC1-CA1</incoming>
      <outgoing>CA1-SCC1</outgoing>
    </task>
    <task id="SCC1" name="Sending Confirmation to Customer">
      <incoming>CA1-SCC1</incoming>
      <outgoing>SCC1-XORCLOSE17</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE17" name="XORCLOSE17">
      <incoming>G2-XORCLOSE17</incoming>
      <incoming>SCC1-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-PARCLOSE18</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>CCT1-PARCLOSE18</incoming>
      <incoming>XORCLOSE17-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-GRD1</outgoing>
    </parallelGateway>
    <task id="GRD1" name="Getting ready for delivery">
      <incoming>PARCLOSE18-GRD1</incoming>
      <outgoing>GRD1-PTG1</outgoing>
    </task>
    <task id="PTG1" name="Pack the Goods">
      <incoming>GRD1-PTG1</incoming>
      <outgoing>PTG1-PI1</outgoing>
    </task>
    <task id="PI1" name="Preparing Invoice">
      <incoming>PTG1-PI1</incoming>
      <outgoing>PI1-DTG1</outgoing>
    </task>
    <task id="DTG1" name="Deliver the Goods">
      <incoming>PI1-DTG1</incoming>
      <outgoing>DTG1-SIC1</outgoing>
    </task>
    <task id="SIC1" name="Send the Invoice invoice to customer">
      <incoming>DTG1-SIC1</incoming>
      <outgoing>SIC1-XOR_JMPBB_DP1_CFP1</outgoing>
    </task>
    <task id="CFP1" name="Check for Payment">
      <incoming>XOR_JMPBB_DP1_CFP1-CFP1</incoming>
      <outgoing>CFP1-G3</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>CFP1-G3</incoming>
      <outgoing>G3-CO1</outgoing>
      <outgoing>G3-CTR1</outgoing>
    </exclusiveGateway>
    <task id="CO1" name="Closing Order">
      <incoming>G3-CO1</incoming>
      <outgoing>CO1-XORCLOSE29</outgoing>
    </task>
    <task id="CTR1" name="Checking the reminders">
      <incoming>G3-CTR1</incoming>
      <outgoing>CTR1-DP1</outgoing>
    </task>
    <task id="DP1" name="Dunning Process">
      <incoming>CTR1-DP1</incoming>
      <outgoing>DP1-XOR_JMPAA_DP1_CFP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE29" name="XORCLOSE29">
      <incoming>CO1-XORCLOSE29</incoming>
      <incoming>XOR_JMPAA_DP1_CFP1-XORCLOSE29</incoming>
      <outgoing>XORCLOSE29-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE29-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_DP1_CFP1" name="XOR_JMPAA_Dunning Process">
      <incoming>DP1-XOR_JMPAA_DP1_CFP1</incoming>
      <outgoing>XOR_JMPAA_DP1_CFP1-XORCLOSE29</outgoing>
      <outgoing>XOR_JMPAA_DP1_CFP1-XOR_JMPBB_DP1_CFP1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_DP1_CFP1" name="XOR_JMPBB_Check for Payment">
      <incoming>SIC1-XOR_JMPBB_DP1_CFP1</incoming>
      <incoming>XOR_JMPAA_DP1_CFP1-XOR_JMPBB_DP1_CFP1</incoming>
      <outgoing>XOR_JMPBB_DP1_CFP1-CFP1</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Default_init-CC1" sourceRef="Default_init" targetRef="CC1"/>
    <sequenceFlow id="CC1-Par1" sourceRef="CC1" targetRef="Par1"/>
    <sequenceFlow id="Par1-CPH1" sourceRef="Par1" targetRef="CPH1"/>
