<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_c0ec51c4-1fc4-48ee-812c-5d77fe842b2a" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CC1</outgoing>
    </startEvent>
    <task id="CC1" name="Check Customer">
      <incoming>Default_init-CC1</incoming>
      <outgoing>CC1-CCT1</outgoing>
    </task>
    <task id="CCT1" name="Check Customer Type">
      <incoming>CC1-CCT1</incoming>
      <outgoing>CCT1-G2</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>CCT1-G2</incoming>
      <outgoing>G2-PMG1</outgoing>
      <outgoing>G2-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="PMG1" name="Producing Missing Goods">
      <incoming>G2-PMG1</incoming>
      <outgoing>PMG1-GRD1</outgoing>
    </task>
    <task id="GRD1" name="Getting ready for delivery">
      <incoming>PMG1-GRD1</incoming>
      <outgoing>GRD1-PI1</outgoing>
    </task>
    <task id="PI1" name="Preparing Invoice">
      <incoming>GRD1-PI1</incoming>
      <outgoing>PI1-PTG1</outgoing>
    </task>
    <task id="PTG1" name="Pack the Goods">
      <incoming>PI1-PTG1</incoming>
      <outgoing>PTG1-Par8</outgoing>
    </task>
    <parallelGateway id="Par8" name="PAR">
      <incoming>PTG1-Par8</incoming>
      <outgoing>Par8-DTG1</outgoing>
      <outgoing>Par8-SIC1</outgoing>
    </parallelGateway>
    <task id="DTG1" name="Deliver the Goods">
      <incoming>Par8-DTG1</incoming>
      <outgoing>DTG1-PARCLOSE11</outgoing>
    </task>
    <task id="SIC1" name="Send the Invoice invoice to customer">
      <incoming>Par8-SIC1</incoming>
      <outgoing>SIC1-PARCLOSE11</outgoing>
    </task>
    <parallelGateway id="PARCLOSE11" name="PARCLOSE11">
      <incoming>DTG1-PARCLOSE11</incoming>
      <incoming>SIC1-PARCLOSE11</incoming>
      <outgoing>PARCLOSE11-XOR_JMPBB_DP1_CFP1</outgoing>
    </parallelGateway>
    <task id="CFP1" name="Check for Payment">
      <incoming>XOR_JMPBB_DP1_CFP1-CFP1</incoming>
      <outgoing>CFP1-G3</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>CFP1-G3</incoming>
      <outgoing>G3-CO1</outgoing>
      <outgoing>G3-CTR1</outgoing>
    </exclusiveGateway>
    <task id="CO1" name="Closing Order">
      <incoming>G3-CO1</incoming>
      <outgoing>CO1-XORCLOSE17</outgoing>
    </task>
    <task id="CTR1" name="Checking the reminders">
      <incoming>G3-CTR1</incoming>
      <outgoing>CTR1-DP1</outgoing>
    </task>
    <task id="DP1" name="Dunning Process">
      <incoming>CTR1-DP1</incoming>
      <outgoing>DP1-XOR_JMPAA_DP1_CFP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE17" name="XORCLOSE17">
      <incoming>CO1-XORCLOSE17</incoming>
      <incoming>XOR_JMPAA_DP1_CFP1-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>G2-XORCLOSE18</incoming>
      <incoming>XORCLOSE17-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-CPH1</outgoing>
    </exclusiveGateway>
    <task id="CPH1" name="Check Payment History">
      <incoming>XORCLOSE18-CPH1</incoming>
      <outgoing>CPH1-G4</outgoing>
    </task>
    <exclusiveGateway id="G4" name="G4">
      <incoming>CPH1-G4</incoming>
      <outgoing>G4-G5</outgoing>
      <outgoing>G4-CNC1</outgoing>
    </exclusiveGateway>
    <task id="CNC1" name="Create New Customer">
      <incoming>G4-CNC1</incoming>
      <outgoing>CNC1-CA1</outgoing>
    </task>
    <exclusiveGateway id="G5" name="G5">
      <incoming>G4-G5</incoming>
      <outgoing>G5-DM1</outgoing>
      <outgoing>G5-XORCLOSE26</outgoing>
    </exclusiveGateway>
    <task id="DM1" name="Declining Message">
      <incoming>G5-DM1</incoming>
      <outgoing>DM1-XORCLOSE26</outgoing>
    </task>
    <task id="CA1" name="Check Availability">
      <incoming>CNC1-CA1</incoming>
      <outgoing>CA1-SCC1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE26" name="XORCLOSE26">
      <incoming>G5-XORCLOSE26</incoming>
      <incoming>DM1-XORCLOSE26</incoming>
      <outgoing>XORCLOSE26-XORCLOSE29</outgoing>
    </exclusiveGateway>
    <task id="SCC1" name="Sending Confirmation to Customer">
      <incoming>CA1-SCC1</incoming>
      <outgoing>SCC1-XORCLOSE29</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE29" name="XORCLOSE29">
      <incoming>XORCLOSE26-XORCLOSE29</incoming>
      <incoming>SCC1-XORCLOSE29</incoming>
      <outgoing>XORCLOSE29-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE29-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_DP1_CFP1" name="XOR_JMPAA_Dunning Process">
      <incoming>DP1-XOR_JMPAA_DP1_CFP1</incoming>
      <outgoing>XOR_JMPAA_DP1_CFP1-XORCLOSE17</outgoing>
      <outgoing>XOR_JMPAA_DP1_CFP1-XOR_JMPBB_DP1_CFP1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_DP1_CFP1" name="XOR_JMPBB_Check for Payment">
      <incoming>PARCLOSE11-XOR_JMPBB_DP1_CFP1</incoming>
      <incoming>XOR_JMPAA_DP1_CFP1-XOR_JMPBB_DP1_CFP1</incoming>
      <outgoing>XOR_JMPBB_DP1_CFP1-CFP1</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Default_init-CC1" sourceRef="Default_init" targetRef="CC1"/>
    <sequenceFlow id="CC1-CCT1" sourceRef="CC1" targetRef="CCT1"/>
    <sequenceFlow id="CCT1-G2" sourceRef="CCT1" targetRef="G2"/>
