    <sequenceFlow id="G4-G5" sourceRef="G4" targetRef="G5"/>
    <sequenceFlow id="G4-CNC1" sourceRef="G4" targetRef="CNC1"/>
    <sequenceFlow id="CNC1-CA1" sourceRef="CNC1" targetRef="CA1"/>
    <sequenceFlow id="G5-DM1" sourceRef="G5" targetRef="DM1"/>
    <sequenceFlow id="G5-XORCLOSE26" sourceRef="G5" targetRef="XORCLOSE26"/>
    <sequenceFlow id="DM1-XORCLOSE26" sourceRef="DM1" targetRef="XORCLOSE26"/>
    <sequenceFlow id="CA1-SCC1" sourceRef="CA1" targetRef="SCC1"/>
    <sequenceFlow id="XORCLOSE26-XORCLOSE29" sourceRef="XORCLOSE26" targetRef="XORCLOSE29"/>
    <sequenceFlow id="SCC1-XORCLOSE29" sourceRef="SCC1" targetRef="XORCLOSE29"/>
    <sequenceFlow id="XORCLOSE29-END" sourceRef="XORCLOSE29" targetRef="END"/>
    <sequenceFlow id="XOR_JMPAA_DP1_CFP1-XORCLOSE17" sourceRef="XOR_JMPAA_DP1_CFP1" targetRef="XORCLOSE17"/>
