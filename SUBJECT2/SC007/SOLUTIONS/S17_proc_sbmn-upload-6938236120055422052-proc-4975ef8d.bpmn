    <sequenceFlow id="SIC1-PARCLOSE11" sourceRef="SIC1" targetRef="PARCLOSE11"/>
    <sequenceFlow id="PARCLOSE11-XOR_JMPBB_DP1_CFP1" sourceRef="PARCLOSE11" targetRef="XOR_JMPBB_DP1_CFP1"/>
    <sequenceFlow id="CFP1-G3" sourceRef="CFP1" targetRef="G3"/>
    <sequenceFlow id="G3-CO1" sourceRef="G3" targetRef="CO1"/>
    <sequenceFlow id="G3-CTR1" sourceRef="G3" targetRef="CTR1"/>
    <sequenceFlow id="CO1-XORCLOSE17" sourceRef="CO1" targetRef="XORCLOSE17"/>
    <sequenceFlow id="CTR1-DP1" sourceRef="CTR1" targetRef="DP1"/>
    <sequenceFlow id="DP1-XOR_JMPAA_DP1_CFP1" sourceRef="DP1" targetRef="XOR_JMPAA_DP1_CFP1"/>
    <sequenceFlow id="XORCLOSE17-XORCLOSE18" sourceRef="XORCLOSE17" targetRef="XORCLOSE18"/>
    <sequenceFlow id="XORCLOSE18-CPH1" sourceRef="XORCLOSE18" targetRef="CPH1"/>
