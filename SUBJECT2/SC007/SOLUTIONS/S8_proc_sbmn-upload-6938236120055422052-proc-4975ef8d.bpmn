  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CC1</outgoing>
    </startEvent>
    <task id="CC1" name="Check Customer">
      <incoming>Default_init-CC1</incoming>
      <outgoing>CC1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>CC1-Par1</incoming>
      <outgoing>Par1-CCT1</outgoing>
      <outgoing>Par1-G1</outgoing>
    </parallelGateway>
    <task id="CCT1" name="Check Customer Type">
      <incoming>Par1-CCT1</incoming>
      <outgoing>CCT1-CPH1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par1-G1</incoming>
      <outgoing>G1-PMG1</outgoing>
      <outgoing>G1-XORCLOSE7</outgoing>
    </exclusiveGateway>
    <task id="PMG1" name="Producing Missing Goods">
      <incoming>G1-PMG1</incoming>
      <outgoing>PMG1-XORCLOSE7</outgoing>
    </task>
    <task id="CPH1" name="Check Payment History">
      <incoming>CCT1-CPH1</incoming>
      <outgoing>CPH1-PARCLOSE8</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE7" name="XORCLOSE7">
      <incoming>G1-XORCLOSE7</incoming>
      <incoming>PMG1-XORCLOSE7</incoming>
      <outgoing>XORCLOSE7-PARCLOSE8</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE8" name="PARCLOSE8">
      <incoming>CPH1-PARCLOSE8</incoming>
      <incoming>XORCLOSE7-PARCLOSE8</incoming>
      <outgoing>PARCLOSE8-G3</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G3" name="G3">
      <incoming>PARCLOSE8-G3</incoming>
      <outgoing>G3-G4</outgoing>
      <outgoing>G3-CNC1</outgoing>
    </exclusiveGateway>
    <task id="CNC1" name="Create New Customer">
      <incoming>G3-CNC1</incoming>
      <outgoing>CNC1-CA1</outgoing>
    </task>
    <exclusiveGateway id="G4" name="G4">
      <incoming>G3-G4</incoming>
      <outgoing>G4-DM1</outgoing>
      <outgoing>G4-XORCLOSE15</outgoing>
    </exclusiveGateway>
    <task id="DM1" name="Declining Message">
      <incoming>G4-DM1</incoming>
      <outgoing>DM1-XORCLOSE15</outgoing>
    </task>
    <task id="CA1" name="Check Availability">
      <incoming>CNC1-CA1</incoming>
      <outgoing>CA1-SCC1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE15" name="XORCLOSE15">
      <incoming>G4-XORCLOSE15</incoming>
      <incoming>DM1-XORCLOSE15</incoming>
      <outgoing>XORCLOSE15-XORCLOSE31</outgoing>
    </exclusiveGateway>
    <task id="SCC1" name="Sending Confirmation to Customer">
      <incoming>CA1-SCC1</incoming>
      <outgoing>SCC1-GRD1</outgoing>
    </task>
    <task id="GRD1" name="Getting ready for delivery">
      <incoming>SCC1-GRD1</incoming>
      <outgoing>GRD1-PTG1</outgoing>
    </task>
    <task id="PTG1" name="Pack the Goods">
      <incoming>GRD1-PTG1</incoming>
      <outgoing>PTG1-Par20</outgoing>
    </task>
    <parallelGateway id="Par20" name="PAR">
      <incoming>PTG1-Par20</incoming>
      <outgoing>Par20-PI1</outgoing>
      <outgoing>Par20-DTG1</outgoing>
    </parallelGateway>
    <task id="PI1" name="Preparing Invoice">
      <incoming>Par20-PI1</incoming>
      <outgoing>PI1-PARCLOSE23</outgoing>
    </task>
    <task id="DTG1" name="Deliver the Goods">
      <incoming>Par20-DTG1</incoming>
      <outgoing>DTG1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>PI1-PARCLOSE23</incoming>
      <incoming>DTG1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-SIC1</outgoing>
    </parallelGateway>
    <task id="SIC1" name="Send the Invoice invoice to customer">
      <incoming>PARCLOSE23-SIC1</incoming>
      <outgoing>SIC1-XOR_JMPBB_DP1_CFP1</outgoing>
    </task>
    <task id="CFP1" name="Check for Payment">
      <incoming>XOR_JMPBB_DP1_CFP1-CFP1</incoming>
      <outgoing>CFP1-G5</outgoing>
    </task>
    <exclusiveGateway id="G5" name="G5">
      <incoming>CFP1-G5</incoming>
      <outgoing>G5-CO1</outgoing>
      <outgoing>G5-CTR1</outgoing>
    </exclusiveGateway>
    <task id="CO1" name="Closing Order">
      <incoming>G5-CO1</incoming>
      <outgoing>CO1-XORCLOSE30</outgoing>
    </task>
    <task id="CTR1" name="Checking the reminders">
      <incoming>G5-CTR1</incoming>
      <outgoing>CTR1-DP1</outgoing>
    </task>
    <task id="DP1" name="Dunning Process">
      <incoming>CTR1-DP1</incoming>
      <outgoing>DP1-XOR_JMPAA_DP1_CFP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE30" name="XORCLOSE30">
      <incoming>CO1-XORCLOSE30</incoming>
      <incoming>XOR_JMPAA_DP1_CFP1-XORCLOSE30</incoming>
      <outgoing>XORCLOSE30-XORCLOSE31</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE31" name="XORCLOSE31">
      <incoming>XORCLOSE15-XORCLOSE31</incoming>
      <incoming>XORCLOSE30-XORCLOSE31</incoming>
      <outgoing>XORCLOSE31-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE31-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_DP1_CFP1" name="XOR_JMPAA_Dunning Process">
