      <incoming>DM1-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-XORCLOSE32</outgoing>
    </exclusiveGateway>
    <task id="PTG1" name="Pack the Goods">
      <incoming>CA1-PTG1</incoming>
      <outgoing>PTG1-Par21</outgoing>
    </task>
    <task id="SIC1" name="Send the Invoice invoice to customer">
      <incoming>PI1-SIC1</incoming>
      <outgoing>SIC1-XORCLOSE24</outgoing>
    </task>
    <parallelGateway id="Par21" name="PAR">
      <incoming>PTG1-Par21</incoming>
      <outgoing>Par21-SCC1</outgoing>
      <outgoing>Par21-DTG1</outgoing>
    </parallelGateway>
    <task id="SCC1" name="Sending Confirmation to Customer">
      <incoming>Par21-SCC1</incoming>
      <outgoing>SCC1-PARCLOSE25</outgoing>
    </task>
    <task id="DTG1" name="Deliver the Goods">
      <incoming>Par21-DTG1</incoming>
      <outgoing>DTG1-PARCLOSE25</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE24" name="XORCLOSE24">
