    <sequenceFlow id="SCC1-GRD1" sourceRef="SCC1" targetRef="GRD1"/>
    <sequenceFlow id="XORCLOSE17-XORCLOSE29" sourceRef="XORCLOSE17" targetRef="XORCLOSE29"/>
