    <sequenceFlow id="G6-CO1" sourceRef="G6" targetRef="CO1"/>
    <sequenceFlow id="G6-CTR1" sourceRef="G6" targetRef="CTR1"/>
    <sequenceFlow id="CO1-XORCLOSE28" sourceRef="CO1" targetRef="XORCLOSE28"/>
    <sequenceFlow id="CTR1-DP1" sourceRef="CTR1" targetRef="DP1"/>
    <sequenceFlow id="DP1-XOR_JMPAA_DP1_CFP1" sourceRef="DP1" targetRef="XOR_JMPAA_DP1_CFP1"/>
    <sequenceFlow id="XORCLOSE28-XORCLOSE29" sourceRef="XORCLOSE28" targetRef="XORCLOSE29"/>
