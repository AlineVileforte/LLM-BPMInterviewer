  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-CC1</outgoing>
      <outgoing>Par0-G0</outgoing>
    </parallelGateway>
    <task id="CC1" name="Check Customer">
      <incoming>Par0-CC1</incoming>
      <outgoing>CC1-CCT1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par0-G0</incoming>
      <outgoing>G0-PMG1</outgoing>
      <outgoing>G0-XORCLOSE6</outgoing>
    </exclusiveGateway>
    <task id="PMG1" name="Producing Missing Goods">
      <incoming>G0-PMG1</incoming>
      <outgoing>PMG1-XORCLOSE6</outgoing>
    </task>
    <task id="CCT1" name="Check Customer Type">
      <incoming>CC1-CCT1</incoming>
      <outgoing>CCT1-CPH1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE6" name="XORCLOSE6">
      <incoming>G0-XORCLOSE6</incoming>
      <incoming>PMG1-XORCLOSE6</incoming>
      <outgoing>XORCLOSE6-PARCLOSE20</outgoing>
    </exclusiveGateway>
    <task id="CPH1" name="Check Payment History">
      <incoming>CCT1-CPH1</incoming>
      <outgoing>CPH1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>CPH1-G1</incoming>
      <outgoing>G1-CNC1</outgoing>
      <outgoing>G1-G2</outgoing>
    </exclusiveGateway>
    <task id="CNC1" name="Create New Customer">
      <incoming>G1-CNC1</incoming>
      <outgoing>CNC1-CA1</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>G1-G2</incoming>
      <outgoing>G2-DM1</outgoing>
      <outgoing>G2-XORCLOSE16</outgoing>
    </exclusiveGateway>
    <task id="DM1" name="Declining Message">
      <incoming>G2-DM1</incoming>
      <outgoing>DM1-XORCLOSE16</outgoing>
    </task>
    <task id="CA1" name="Check Availability">
      <incoming>CNC1-CA1</incoming>
      <outgoing>CA1-SCC1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
      <incoming>G2-XORCLOSE16</incoming>
      <incoming>DM1-XORCLOSE16</incoming>
      <outgoing>XORCLOSE16-XORCLOSE19</outgoing>
    </exclusiveGateway>
    <task id="SCC1" name="Sending Confirmation to Customer">
      <incoming>CA1-SCC1</incoming>
      <outgoing>SCC1-XORCLOSE19</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE19" name="XORCLOSE19">
      <incoming>XORCLOSE16-XORCLOSE19</incoming>
      <incoming>SCC1-XORCLOSE19</incoming>
      <outgoing>XORCLOSE19-PARCLOSE20</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE20" name="PARCLOSE20">
      <incoming>XORCLOSE6-PARCLOSE20</incoming>
      <incoming>XORCLOSE19-PARCLOSE20</incoming>
      <outgoing>PARCLOSE20-GRD1</outgoing>
    </parallelGateway>
    <task id="GRD1" name="Getting ready for delivery">
      <incoming>PARCLOSE20-GRD1</incoming>
      <outgoing>GRD1-PI1</outgoing>
    </task>
    <task id="PI1" name="Preparing Invoice">
      <incoming>GRD1-PI1</incoming>
      <outgoing>PI1-Par23</outgoing>
    </task>
    <parallelGateway id="Par23" name="PAR">
      <incoming>PI1-Par23</incoming>
      <outgoing>Par23-PTG1</outgoing>
      <outgoing>Par23-SIC1</outgoing>
    </parallelGateway>
    <task id="PTG1" name="Pack the Goods">
      <incoming>Par23-PTG1</incoming>
      <outgoing>PTG1-DTG1</outgoing>
    </task>
    <task id="SIC1" name="Send the Invoice invoice to customer">
      <incoming>Par23-SIC1</incoming>
      <outgoing>SIC1-PARCLOSE27</outgoing>
    </task>
    <task id="DTG1" name="Deliver the Goods">
      <incoming>PTG1-DTG1</incoming>
      <outgoing>DTG1-PARCLOSE27</outgoing>
    </task>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>SIC1-PARCLOSE27</incoming>
      <incoming>DTG1-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-XOR_JMPBB_DP1_CFP1</outgoing>
