<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_f8d69ad3-548a-4ab9-8c1f-facdea14dd11" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-DCO1</outgoing>
      <outgoing>Par0-DV1</outgoing>
    </parallelGateway>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>Par0-DCO1</incoming>
      <outgoing>DCO1-CC1</outgoing>
    </task>
    <task id="DV1" name="Design visuals">
      <incoming>Par0-DV1</incoming>
      <outgoing>DV1-PARCLOSE11</outgoing>
    </task>
    <task id="CC1" name="Create content">
      <incoming>DCO1-CC1</incoming>
      <outgoing>CC1-SPC1</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>CC1-SPC1</incoming>
      <outgoing>SPC1-PARCLOSE11</outgoing>
    </task>
    <parallelGateway id="PARCLOSE11" name="PARCLOSE11">
      <incoming>DV1-PARCLOSE11</incoming>
      <incoming>SPC1-PARCLOSE11</incoming>
      <outgoing>PARCLOSE11-LC1</outgoing>
    </parallelGateway>
    <task id="LC1" name="Launch campaign">
      <incoming>PARCLOSE11-LC1</incoming>
      <outgoing>LC1-CPE1</outgoing>
    </task>
    <task id="CPE1" name="Campaign period ends">
      <incoming>LC1-CPE1</incoming>
      <outgoing>CPE1-TPRT1</outgoing>
    </task>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>CPE1-TPRT1</incoming>
      <outgoing>TPRT1-CLCRM1</outgoing>
    </task>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>TPRT1-CLCRM1</incoming>
      <outgoing>CLCRM1-STFL1</outgoing>
    </task>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>CLCRM1-STFL1</incoming>
      <outgoing>STFL1-APFO1</outgoing>
    </task>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>STFL1-APFO1</incoming>
      <outgoing>APFO1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>APFO1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
    <sequenceFlow id="Par0-DCO1" sourceRef="Par0" targetRef="DCO1"/>
    <sequenceFlow id="Par0-DV1" sourceRef="Par0" targetRef="DV1"/>
    <sequenceFlow id="DCO1-CC1" sourceRef="DCO1" targetRef="CC1"/>
    <sequenceFlow id="DV1-PARCLOSE11" sourceRef="DV1" targetRef="PARCLOSE11"/>
    <sequenceFlow id="CC1-SPC1" sourceRef="CC1" targetRef="SPC1"/>
    <sequenceFlow id="SPC1-PARCLOSE11" sourceRef="SPC1" targetRef="PARCLOSE11"/>
    <sequenceFlow id="PARCLOSE11-LC1" sourceRef="PARCLOSE11" targetRef="LC1"/>
    <sequenceFlow id="LC1-CPE1" sourceRef="LC1" targetRef="CPE1"/>
    <sequenceFlow id="CPE1-TPRT1" sourceRef="CPE1" targetRef="TPRT1"/>
    <sequenceFlow id="TPRT1-CLCRM1" sourceRef="TPRT1" targetRef="CLCRM1"/>
    <sequenceFlow id="CLCRM1-STFL1" sourceRef="CLCRM1" targetRef="STFL1"/>
    <sequenceFlow id="STFL1-APFO1" sourceRef="STFL1" targetRef="APFO1"/>
    <sequenceFlow id="APFO1-END" sourceRef="APFO1" targetRef="END"/>
  </process>
