<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_5322aea3-e530-42a0-b4de-6fc02a87c4be" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DCO1</outgoing>
    </startEvent>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>Default_init-DCO1</incoming>
      <outgoing>DCO1-DV1</outgoing>
    </task>
    <task id="DV1" name="Design visuals">
      <incoming>DCO1-DV1</incoming>
      <outgoing>DV1-SPC1</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>DV1-SPC1</incoming>
      <outgoing>SPC1-CC1</outgoing>
    </task>
    <task id="CC1" name="Create content">
      <incoming>SPC1-CC1</incoming>
      <outgoing>CC1-LC1</outgoing>
    </task>
    <task id="LC1" name="Launch campaign">
      <incoming>CC1-LC1</incoming>
      <outgoing>LC1-Par5</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>LC1-Par5</incoming>
      <outgoing>Par5-TPRT1</outgoing>
      <outgoing>Par5-CLCRM1</outgoing>
    </parallelGateway>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>Par5-TPRT1</incoming>
      <outgoing>TPRT1-G2</outgoing>
    </task>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>Par5-CLCRM1</incoming>
      <outgoing>CLCRM1-Par9</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>CLCRM1-Par9</incoming>
      <outgoing>Par9-G1</outgoing>
      <outgoing>Par9-CPE1</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par9-G1</incoming>
      <outgoing>G1-STFL1</outgoing>
      <outgoing>G1-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>G1-STFL1</incoming>
      <outgoing>STFL1-XORCLOSE18</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>TPRT1-G2</incoming>
      <outgoing>G2-APFO1</outgoing>
      <outgoing>G2-XORCLOSE19</outgoing>
    </exclusiveGateway>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>G2-APFO1</incoming>
      <outgoing>APFO1-XORCLOSE19</outgoing>
    </task>
    <task id="CPE1" name="Campaign period ends">
      <incoming>Par9-CPE1</incoming>
      <outgoing>CPE1-PARCLOSE20</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>G1-XORCLOSE18</incoming>
      <incoming>STFL1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-PARCLOSE20</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE19" name="XORCLOSE19">
      <incoming>G2-XORCLOSE19</incoming>
      <incoming>APFO1-XORCLOSE19</incoming>
      <outgoing>XORCLOSE19-PARCLOSE21</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE20" name="PARCLOSE20">
      <incoming>CPE1-PARCLOSE20</incoming>
      <incoming>XORCLOSE18-PARCLOSE20</incoming>
      <outgoing>PARCLOSE20-PARCLOSE21</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>XORCLOSE19-PARCLOSE21</incoming>
      <incoming>PARCLOSE20-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE21-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DCO1" sourceRef="Default_init" targetRef="DCO1"/>
    <sequenceFlow id="DCO1-DV1" sourceRef="DCO1" targetRef="DV1"/>
    <sequenceFlow id="DV1-SPC1" sourceRef="DV1" targetRef="SPC1"/>
    <sequenceFlow id="SPC1-CC1" sourceRef="SPC1" targetRef="CC1"/>
    <sequenceFlow id="CC1-LC1" sourceRef="CC1" targetRef="LC1"/>
