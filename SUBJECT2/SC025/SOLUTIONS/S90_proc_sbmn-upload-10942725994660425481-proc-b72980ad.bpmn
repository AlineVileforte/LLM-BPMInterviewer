    <sequenceFlow id="CLCRM1-Par10" sourceRef="CLCRM1" targetRef="Par10"/>
    <sequenceFlow id="CPE1-PARCLOSE22" sourceRef="CPE1" targetRef="PARCLOSE22"/>
    <sequenceFlow id="Par10-TPRT1" sourceRef="Par10" targetRef="TPRT1"/>
    <sequenceFlow id="Par10-G0" sourceRef="Par10" targetRef="G0"/>
    <sequenceFlow id="TPRT1-G1" sourceRef="TPRT1" targetRef="G1"/>
    <sequenceFlow id="G0-STFL1" sourceRef="G0" targetRef="STFL1"/>
    <sequenceFlow id="G0-XORCLOSE19" sourceRef="G0" targetRef="XORCLOSE19"/>
    <sequenceFlow id="STFL1-XORCLOSE19" sourceRef="STFL1" targetRef="XORCLOSE19"/>
    <sequenceFlow id="G1-APFO1" sourceRef="G1" targetRef="APFO1"/>
    <sequenceFlow id="G1-XORCLOSE20" sourceRef="G1" targetRef="XORCLOSE20"/>
    <sequenceFlow id="APFO1-XORCLOSE20" sourceRef="APFO1" targetRef="XORCLOSE20"/>
    <sequenceFlow id="XORCLOSE19-PARCLOSE21" sourceRef="XORCLOSE19" targetRef="PARCLOSE21"/>
    <sequenceFlow id="XORCLOSE20-PARCLOSE21" sourceRef="XORCLOSE20" targetRef="PARCLOSE21"/>
    <sequenceFlow id="PARCLOSE21-PARCLOSE22" sourceRef="PARCLOSE21" targetRef="PARCLOSE22"/>
    <sequenceFlow id="PARCLOSE22-END" sourceRef="PARCLOSE22" targetRef="END"/>
  </process>
