<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_50e0d997-d591-45e8-9f7a-9ae12405e2d4" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DCO1</outgoing>
    </startEvent>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>Default_init-DCO1</incoming>
      <outgoing>DCO1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>DCO1-Par1</incoming>
      <outgoing>Par1-SPC1</outgoing>
      <outgoing>Par1-DV1</outgoing>
    </parallelGateway>
    <task id="SPC1" name="Select promotion channels">
      <incoming>Par1-SPC1</incoming>
      <outgoing>SPC1-CC1</outgoing>
    </task>
    <task id="CC1" name="Create content">
      <incoming>SPC1-CC1</incoming>
      <outgoing>CC1-PARCLOSE5</outgoing>
    </task>
    <task id="DV1" name="Design visuals">
      <incoming>Par1-DV1</incoming>
      <outgoing>DV1-PARCLOSE5</outgoing>
    </task>
    <parallelGateway id="PARCLOSE5" name="PARCLOSE5">
      <incoming>CC1-PARCLOSE5</incoming>
      <incoming>DV1-PARCLOSE5</incoming>
      <outgoing>PARCLOSE5-LC1</outgoing>
    </parallelGateway>
    <task id="LC1" name="Launch campaign">
      <incoming>PARCLOSE5-LC1</incoming>
      <outgoing>LC1-Par7</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>LC1-Par7</incoming>
      <outgoing>Par7-CLCRM1</outgoing>
      <outgoing>Par7-CPE1</outgoing>
    </parallelGateway>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>Par7-CLCRM1</incoming>
      <outgoing>CLCRM1-Par10</outgoing>
    </task>
    <task id="CPE1" name="Campaign period ends">
      <incoming>Par7-CPE1</incoming>
      <outgoing>CPE1-PARCLOSE22</outgoing>
    </task>
    <parallelGateway id="Par10" name="PAR">
      <incoming>CLCRM1-Par10</incoming>
      <outgoing>Par10-TPRT1</outgoing>
      <outgoing>Par10-G0</outgoing>
    </parallelGateway>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>Par10-TPRT1</incoming>
      <outgoing>TPRT1-G1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par10-G0</incoming>
      <outgoing>G0-STFL1</outgoing>
      <outgoing>G0-XORCLOSE19</outgoing>
    </exclusiveGateway>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>G0-STFL1</incoming>
      <outgoing>STFL1-XORCLOSE19</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>TPRT1-G1</incoming>
      <outgoing>G1-APFO1</outgoing>
      <outgoing>G1-XORCLOSE20</outgoing>
    </exclusiveGateway>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>G1-APFO1</incoming>
      <outgoing>APFO1-XORCLOSE20</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE19" name="XORCLOSE19">
      <incoming>G0-XORCLOSE19</incoming>
      <incoming>STFL1-XORCLOSE19</incoming>
      <outgoing>XORCLOSE19-PARCLOSE21</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>G1-XORCLOSE20</incoming>
      <incoming>APFO1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-PARCLOSE21</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>XORCLOSE19-PARCLOSE21</incoming>
      <incoming>XORCLOSE20-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-PARCLOSE22</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>CPE1-PARCLOSE22</incoming>
      <incoming>PARCLOSE21-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE22-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DCO1" sourceRef="Default_init" targetRef="DCO1"/>
    <sequenceFlow id="DCO1-Par1" sourceRef="DCO1" targetRef="Par1"/>
    <sequenceFlow id="Par1-SPC1" sourceRef="Par1" targetRef="SPC1"/>
    <sequenceFlow id="Par1-DV1" sourceRef="Par1" targetRef="DV1"/>
