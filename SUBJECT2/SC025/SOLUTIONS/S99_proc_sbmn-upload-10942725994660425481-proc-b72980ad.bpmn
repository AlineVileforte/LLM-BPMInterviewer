    <sequenceFlow id="TPRT1-Par7" sourceRef="TPRT1" targetRef="Par7"/>
    <sequenceFlow id="Par7-CLCRM1" sourceRef="Par7" targetRef="CLCRM1"/>
    <sequenceFlow id="Par7-CPE1" sourceRef="Par7" targetRef="CPE1"/>
    <sequenceFlow id="CLCRM1-G2" sourceRef="CLCRM1" targetRef="G2"/>
    <sequenceFlow id="CPE1-PARCLOSE19" sourceRef="CPE1" targetRef="PARCLOSE19"/>
    <sequenceFlow id="G1-APFO1" sourceRef="G1" targetRef="APFO1"/>
    <sequenceFlow id="G1-XORCLOSE17" sourceRef="G1" targetRef="XORCLOSE17"/>
    <sequenceFlow id="APFO1-XORCLOSE17" sourceRef="APFO1" targetRef="XORCLOSE17"/>
    <sequenceFlow id="G2-STFL1" sourceRef="G2" targetRef="STFL1"/>
    <sequenceFlow id="G2-XORCLOSE18" sourceRef="G2" targetRef="XORCLOSE18"/>
    <sequenceFlow id="STFL1-XORCLOSE18" sourceRef="STFL1" targetRef="XORCLOSE18"/>
    <sequenceFlow id="XORCLOSE17-PARCLOSE20" sourceRef="XORCLOSE17" targetRef="PARCLOSE20"/>
    <sequenceFlow id="XORCLOSE18-PARCLOSE19" sourceRef="XORCLOSE18" targetRef="PARCLOSE19"/>
    <sequenceFlow id="PARCLOSE19-PARCLOSE20" sourceRef="PARCLOSE19" targetRef="PARCLOSE20"/>
    <sequenceFlow id="PARCLOSE20-END" sourceRef="PARCLOSE20" targetRef="END"/>
  </process>
