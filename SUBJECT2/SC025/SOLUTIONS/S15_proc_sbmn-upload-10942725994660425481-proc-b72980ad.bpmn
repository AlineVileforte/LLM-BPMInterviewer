<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_a650e117-2772-4497-9cf4-e0521e37a222" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DCO1</outgoing>
    </startEvent>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>Default_init-DCO1</incoming>
      <outgoing>DCO1-SPC1</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>DCO1-SPC1</incoming>
      <outgoing>SPC1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>SPC1-Par2</incoming>
      <outgoing>Par2-CC1</outgoing>
      <outgoing>Par2-DV1</outgoing>
    </parallelGateway>
    <task id="CC1" name="Create content">
      <incoming>Par2-CC1</incoming>
      <outgoing>CC1-PARCLOSE7</outgoing>
    </task>
    <task id="DV1" name="Design visuals">
      <incoming>Par2-DV1</incoming>
      <outgoing>DV1-PARCLOSE7</outgoing>
    </task>
    <parallelGateway id="PARCLOSE7" name="PARCLOSE7">
      <incoming>CC1-PARCLOSE7</incoming>
      <incoming>DV1-PARCLOSE7</incoming>
      <outgoing>PARCLOSE7-LC1</outgoing>
    </parallelGateway>
    <task id="LC1" name="Launch campaign">
      <incoming>PARCLOSE7-LC1</incoming>
      <outgoing>LC1-Par9</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>LC1-Par9</incoming>
      <outgoing>Par9-TPRT1</outgoing>
      <outgoing>Par9-CPE1</outgoing>
    </parallelGateway>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>Par9-TPRT1</incoming>
      <outgoing>TPRT1-CLCRM1</outgoing>
    </task>
    <task id="CPE1" name="Campaign period ends">
      <incoming>Par9-CPE1</incoming>
      <outgoing>CPE1-PARCLOSE13</outgoing>
    </task>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>TPRT1-CLCRM1</incoming>
      <outgoing>CLCRM1-PARCLOSE13</outgoing>
    </task>
    <parallelGateway id="PARCLOSE13" name="PARCLOSE13">
      <incoming>CPE1-PARCLOSE13</incoming>
      <incoming>CLCRM1-PARCLOSE13</incoming>
      <outgoing>PARCLOSE13-APFO1</outgoing>
    </parallelGateway>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>PARCLOSE13-APFO1</incoming>
      <outgoing>APFO1-STFL1</outgoing>
    </task>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>APFO1-STFL1</incoming>
      <outgoing>STFL1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>STFL1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DCO1" sourceRef="Default_init" targetRef="DCO1"/>
    <sequenceFlow id="DCO1-SPC1" sourceRef="DCO1" targetRef="SPC1"/>
    <sequenceFlow id="SPC1-Par2" sourceRef="SPC1" targetRef="Par2"/>
    <sequenceFlow id="Par2-CC1" sourceRef="Par2" targetRef="CC1"/>
    <sequenceFlow id="Par2-DV1" sourceRef="Par2" targetRef="DV1"/>
    <sequenceFlow id="CC1-PARCLOSE7" sourceRef="CC1" targetRef="PARCLOSE7"/>
    <sequenceFlow id="DV1-PARCLOSE7" sourceRef="DV1" targetRef="PARCLOSE7"/>
    <sequenceFlow id="PARCLOSE7-LC1" sourceRef="PARCLOSE7" targetRef="LC1"/>
    <sequenceFlow id="LC1-Par9" sourceRef="LC1" targetRef="Par9"/>
    <sequenceFlow id="Par9-TPRT1" sourceRef="Par9" targetRef="TPRT1"/>
    <sequenceFlow id="Par9-CPE1" sourceRef="Par9" targetRef="CPE1"/>
    <sequenceFlow id="TPRT1-CLCRM1" sourceRef="TPRT1" targetRef="CLCRM1"/>
    <sequenceFlow id="CPE1-PARCLOSE13" sourceRef="CPE1" targetRef="PARCLOSE13"/>
    <sequenceFlow id="CLCRM1-PARCLOSE13" sourceRef="CLCRM1" targetRef="PARCLOSE13"/>
    <sequenceFlow id="PARCLOSE13-APFO1" sourceRef="PARCLOSE13" targetRef="APFO1"/>
    <sequenceFlow id="APFO1-STFL1" sourceRef="APFO1" targetRef="STFL1"/>
    <sequenceFlow id="STFL1-END" sourceRef="STFL1" targetRef="END"/>
  </process>
