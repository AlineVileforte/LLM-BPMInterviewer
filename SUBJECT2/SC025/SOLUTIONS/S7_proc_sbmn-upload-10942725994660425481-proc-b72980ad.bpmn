<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_3b50f78a-070b-4638-9db1-7336a86968e5" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DV1</outgoing>
    </startEvent>
    <task id="DV1" name="Design visuals">
      <incoming>Default_init-DV1</incoming>
      <outgoing>DV1-DCO1</outgoing>
    </task>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>DV1-DCO1</incoming>
      <outgoing>DCO1-SPC1</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>DCO1-SPC1</incoming>
      <outgoing>SPC1-CC1</outgoing>
    </task>
    <task id="CC1" name="Create content">
      <incoming>SPC1-CC1</incoming>
      <outgoing>CC1-LC1</outgoing>
    </task>
    <task id="LC1" name="Launch campaign">
      <incoming>CC1-LC1</incoming>
      <outgoing>LC1-CLCRM1</outgoing>
    </task>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>LC1-CLCRM1</incoming>
      <outgoing>CLCRM1-Par6</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>CLCRM1-Par6</incoming>
      <outgoing>Par6-TPRT1</outgoing>
      <outgoing>Par6-CPE1</outgoing>
    </parallelGateway>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>Par6-TPRT1</incoming>
      <outgoing>TPRT1-G2</outgoing>
    </task>
    <task id="CPE1" name="Campaign period ends">
      <incoming>Par6-CPE1</incoming>
      <outgoing>CPE1-PARCLOSE15</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>TPRT1-G2</incoming>
      <outgoing>G2-STFL1</outgoing>
      <outgoing>G2-XORCLOSE13</outgoing>
    </exclusiveGateway>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>G2-STFL1</incoming>
      <outgoing>STFL1-XORCLOSE13</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE13" name="XORCLOSE13">
      <incoming>G2-XORCLOSE13</incoming>
      <incoming>STFL1-XORCLOSE13</incoming>
      <outgoing>XORCLOSE13-APFO1</outgoing>
    </exclusiveGateway>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>XORCLOSE13-APFO1</incoming>
      <outgoing>APFO1-PARCLOSE15</outgoing>
    </task>
    <parallelGateway id="PARCLOSE15" name="PARCLOSE15">
      <incoming>CPE1-PARCLOSE15</incoming>
      <incoming>APFO1-PARCLOSE15</incoming>
      <outgoing>PARCLOSE15-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE15-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DV1" sourceRef="Default_init" targetRef="DV1"/>
    <sequenceFlow id="DV1-DCO1" sourceRef="DV1" targetRef="DCO1"/>
    <sequenceFlow id="DCO1-SPC1" sourceRef="DCO1" targetRef="SPC1"/>
    <sequenceFlow id="SPC1-CC1" sourceRef="SPC1" targetRef="CC1"/>
    <sequenceFlow id="CC1-LC1" sourceRef="CC1" targetRef="LC1"/>
    <sequenceFlow id="LC1-CLCRM1" sourceRef="LC1" targetRef="CLCRM1"/>
    <sequenceFlow id="CLCRM1-Par6" sourceRef="CLCRM1" targetRef="Par6"/>
    <sequenceFlow id="Par6-TPRT1" sourceRef="Par6" targetRef="TPRT1"/>
    <sequenceFlow id="Par6-CPE1" sourceRef="Par6" targetRef="CPE1"/>
    <sequenceFlow id="TPRT1-G2" sourceRef="TPRT1" targetRef="G2"/>
    <sequenceFlow id="CPE1-PARCLOSE15" sourceRef="CPE1" targetRef="PARCLOSE15"/>
    <sequenceFlow id="G2-STFL1" sourceRef="G2" targetRef="STFL1"/>
    <sequenceFlow id="G2-XORCLOSE13" sourceRef="G2" targetRef="XORCLOSE13"/>
    <sequenceFlow id="STFL1-XORCLOSE13" sourceRef="STFL1" targetRef="XORCLOSE13"/>
    <sequenceFlow id="XORCLOSE13-APFO1" sourceRef="XORCLOSE13" targetRef="APFO1"/>
    <sequenceFlow id="APFO1-PARCLOSE15" sourceRef="APFO1" targetRef="PARCLOSE15"/>
    <sequenceFlow id="PARCLOSE15-END" sourceRef="PARCLOSE15" targetRef="END"/>
  </process>
