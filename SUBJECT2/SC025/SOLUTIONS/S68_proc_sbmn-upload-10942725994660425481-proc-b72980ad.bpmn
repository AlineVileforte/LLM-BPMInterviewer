<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_4f2cbc03-619b-420f-a195-a7af2cea5af8" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DCO1</outgoing>
    </startEvent>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>Default_init-DCO1</incoming>
      <outgoing>DCO1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>DCO1-Par1</incoming>
      <outgoing>Par1-SPC1</outgoing>
      <outgoing>Par1-CC1</outgoing>
    </parallelGateway>
    <task id="SPC1" name="Select promotion channels">
      <incoming>Par1-SPC1</incoming>
      <outgoing>SPC1-DV1</outgoing>
    </task>
    <task id="DV1" name="Design visuals">
      <incoming>SPC1-DV1</incoming>
      <outgoing>DV1-PARCLOSE5</outgoing>
    </task>
    <task id="CC1" name="Create content">
      <incoming>Par1-CC1</incoming>
      <outgoing>CC1-PARCLOSE5</outgoing>
    </task>
    <parallelGateway id="PARCLOSE5" name="PARCLOSE5">
      <incoming>DV1-PARCLOSE5</incoming>
      <incoming>CC1-PARCLOSE5</incoming>
      <outgoing>PARCLOSE5-LC1</outgoing>
    </parallelGateway>
    <task id="LC1" name="Launch campaign">
      <incoming>PARCLOSE5-LC1</incoming>
      <outgoing>LC1-Par7</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>LC1-Par7</incoming>
      <outgoing>Par7-CPE1</outgoing>
      <outgoing>Par7-CLCRM1</outgoing>
    </parallelGateway>
    <task id="CPE1" name="Campaign period ends">
      <incoming>Par7-CPE1</incoming>
      <outgoing>CPE1-TPRT1</outgoing>
    </task>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>CPE1-TPRT1</incoming>
      <outgoing>TPRT1-G0</outgoing>
    </task>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>Par7-CLCRM1</incoming>
      <outgoing>CLCRM1-G1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>TPRT1-G0</incoming>
      <outgoing>G0-APFO1</outgoing>
      <outgoing>G0-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>G0-APFO1</incoming>
      <outgoing>APFO1-XORCLOSE17</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>CLCRM1-G1</incoming>
      <outgoing>G1-STFL1</outgoing>
      <outgoing>G1-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>G1-STFL1</incoming>
      <outgoing>STFL1-XORCLOSE18</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE17" name="XORCLOSE17">
      <incoming>G0-XORCLOSE17</incoming>
      <incoming>APFO1-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-PARCLOSE19</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>G1-XORCLOSE18</incoming>
      <incoming>STFL1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-PARCLOSE19</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>XORCLOSE17-PARCLOSE19</incoming>
      <incoming>XORCLOSE18-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE19-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DCO1" sourceRef="Default_init" targetRef="DCO1"/>
    <sequenceFlow id="DCO1-Par1" sourceRef="DCO1" targetRef="Par1"/>
    <sequenceFlow id="Par1-SPC1" sourceRef="Par1" targetRef="SPC1"/>
    <sequenceFlow id="Par1-CC1" sourceRef="Par1" targetRef="CC1"/>
    <sequenceFlow id="SPC1-DV1" sourceRef="SPC1" targetRef="DV1"/>
    <sequenceFlow id="DV1-PARCLOSE5" sourceRef="DV1" targetRef="PARCLOSE5"/>
    <sequenceFlow id="CC1-PARCLOSE5" sourceRef="CC1" targetRef="PARCLOSE5"/>
    <sequenceFlow id="PARCLOSE5-LC1" sourceRef="PARCLOSE5" targetRef="LC1"/>
    <sequenceFlow id="LC1-Par7" sourceRef="LC1" targetRef="Par7"/>
    <sequenceFlow id="Par7-CPE1" sourceRef="Par7" targetRef="CPE1"/>
    <sequenceFlow id="Par7-CLCRM1" sourceRef="Par7" targetRef="CLCRM1"/>
    <sequenceFlow id="CPE1-TPRT1" sourceRef="CPE1" targetRef="TPRT1"/>
    <sequenceFlow id="TPRT1-G0" sourceRef="TPRT1" targetRef="G0"/>
    <sequenceFlow id="CLCRM1-G1" sourceRef="CLCRM1" targetRef="G1"/>
    <sequenceFlow id="G0-APFO1" sourceRef="G0" targetRef="APFO1"/>
    <sequenceFlow id="G0-XORCLOSE17" sourceRef="G0" targetRef="XORCLOSE17"/>
    <sequenceFlow id="APFO1-XORCLOSE17" sourceRef="APFO1" targetRef="XORCLOSE17"/>
    <sequenceFlow id="G1-STFL1" sourceRef="G1" targetRef="STFL1"/>
    <sequenceFlow id="G1-XORCLOSE18" sourceRef="G1" targetRef="XORCLOSE18"/>
    <sequenceFlow id="STFL1-XORCLOSE18" sourceRef="STFL1" targetRef="XORCLOSE18"/>
    <sequenceFlow id="XORCLOSE17-PARCLOSE19" sourceRef="XORCLOSE17" targetRef="PARCLOSE19"/>
    <sequenceFlow id="XORCLOSE18-PARCLOSE19" sourceRef="XORCLOSE18" targetRef="PARCLOSE19"/>
    <sequenceFlow id="PARCLOSE19-END" sourceRef="PARCLOSE19" targetRef="END"/>
  </process>
