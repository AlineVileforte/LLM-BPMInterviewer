    <sequenceFlow id="CLCRM1-Par14" sourceRef="CLCRM1" targetRef="Par14"/>
    <sequenceFlow id="Par14-STFL1" sourceRef="Par14" targetRef="STFL1"/>
    <sequenceFlow id="Par14-APFO1" sourceRef="Par14" targetRef="APFO1"/>
    <sequenceFlow id="STFL1-PARCLOSE18" sourceRef="STFL1" targetRef="PARCLOSE18"/>
    <sequenceFlow id="APFO1-PARCLOSE18" sourceRef="APFO1" targetRef="PARCLOSE18"/>
    <sequenceFlow id="CPE1-PARCLOSE19" sourceRef="CPE1" targetRef="PARCLOSE19"/>
    <sequenceFlow id="PARCLOSE18-PARCLOSE19" sourceRef="PARCLOSE18" targetRef="PARCLOSE19"/>
    <sequenceFlow id="PARCLOSE19-END" sourceRef="PARCLOSE19" targetRef="END"/>
  </process>
