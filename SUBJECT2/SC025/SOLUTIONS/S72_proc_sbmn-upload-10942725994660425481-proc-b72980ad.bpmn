<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_211a1dfd-a523-4c3b-888a-8f8e3286ba5e" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-DCO1</outgoing>
      <outgoing>Par0-DV1</outgoing>
    </parallelGateway>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>Par0-DCO1</incoming>
      <outgoing>DCO1-Par3</outgoing>
    </task>
    <task id="DV1" name="Design visuals">
      <incoming>Par0-DV1</incoming>
      <outgoing>DV1-PARCLOSE9</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>DCO1-Par3</incoming>
      <outgoing>Par3-CC1</outgoing>
      <outgoing>Par3-SPC1</outgoing>
    </parallelGateway>
    <task id="CC1" name="Create content">
      <incoming>Par3-CC1</incoming>
      <outgoing>CC1-PARCLOSE8</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>Par3-SPC1</incoming>
      <outgoing>SPC1-PARCLOSE8</outgoing>
    </task>
    <parallelGateway id="PARCLOSE8" name="PARCLOSE8">
      <incoming>CC1-PARCLOSE8</incoming>
      <incoming>SPC1-PARCLOSE8</incoming>
      <outgoing>PARCLOSE8-PARCLOSE9</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE9" name="PARCLOSE9">
      <incoming>DV1-PARCLOSE9</incoming>
      <incoming>PARCLOSE8-PARCLOSE9</incoming>
      <outgoing>PARCLOSE9-LC1</outgoing>
    </parallelGateway>
    <task id="LC1" name="Launch campaign">
      <incoming>PARCLOSE9-LC1</incoming>
      <outgoing>LC1-TPRT1</outgoing>
    </task>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>LC1-TPRT1</incoming>
      <outgoing>TPRT1-Par12</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>TPRT1-Par12</incoming>
      <outgoing>Par12-CLCRM1</outgoing>
      <outgoing>Par12-CPE1</outgoing>
    </parallelGateway>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>Par12-CLCRM1</incoming>
      <outgoing>CLCRM1-Par14</outgoing>
    </task>
    <parallelGateway id="Par14" name="PAR">
      <incoming>CLCRM1-Par14</incoming>
      <outgoing>Par14-STFL1</outgoing>
      <outgoing>Par14-APFO1</outgoing>
    </parallelGateway>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>Par14-STFL1</incoming>
      <outgoing>STFL1-PARCLOSE18</outgoing>
    </task>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>Par14-APFO1</incoming>
      <outgoing>APFO1-PARCLOSE18</outgoing>
    </task>
    <task id="CPE1" name="Campaign period ends">
      <incoming>Par12-CPE1</incoming>
      <outgoing>CPE1-PARCLOSE19</outgoing>
    </task>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>STFL1-PARCLOSE18</incoming>
      <incoming>APFO1-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-PARCLOSE19</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>CPE1-PARCLOSE19</incoming>
      <incoming>PARCLOSE18-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE19-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
    <sequenceFlow id="Par0-DCO1" sourceRef="Par0" targetRef="DCO1"/>
