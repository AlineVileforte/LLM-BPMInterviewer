<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_a3957a94-c3e7-4083-9137-1eb2239c32df" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DCO1</outgoing>
    </startEvent>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>Default_init-DCO1</incoming>
      <outgoing>DCO1-CC1</outgoing>
    </task>
    <task id="CC1" name="Create content">
      <incoming>DCO1-CC1</incoming>
      <outgoing>CC1-SPC1</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>CC1-SPC1</incoming>
      <outgoing>SPC1-DV1</outgoing>
    </task>
    <task id="DV1" name="Design visuals">
      <incoming>SPC1-DV1</incoming>
      <outgoing>DV1-LC1</outgoing>
    </task>
    <task id="LC1" name="Launch campaign">
      <incoming>DV1-LC1</incoming>
      <outgoing>LC1-CPE1</outgoing>
    </task>
    <task id="CPE1" name="Campaign period ends">
      <incoming>LC1-CPE1</incoming>
      <outgoing>CPE1-Par6</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>CPE1-Par6</incoming>
      <outgoing>Par6-TPRT1</outgoing>
      <outgoing>Par6-CLCRM1</outgoing>
    </parallelGateway>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>Par6-TPRT1</incoming>
      <outgoing>TPRT1-G0</outgoing>
    </task>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>Par6-CLCRM1</incoming>
      <outgoing>CLCRM1-G1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>TPRT1-G0</incoming>
      <outgoing>G0-APFO1</outgoing>
      <outgoing>G0-XORCLOSE15</outgoing>
    </exclusiveGateway>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>G0-APFO1</incoming>
      <outgoing>APFO1-XORCLOSE15</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>CLCRM1-G1</incoming>
      <outgoing>G1-STFL1</outgoing>
      <outgoing>G1-XORCLOSE16</outgoing>
    </exclusiveGateway>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>G1-STFL1</incoming>
      <outgoing>STFL1-XORCLOSE16</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE15" name="XORCLOSE15">
      <incoming>G0-XORCLOSE15</incoming>
      <incoming>APFO1-XORCLOSE15</incoming>
      <outgoing>XORCLOSE15-PARCLOSE17</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
      <incoming>G1-XORCLOSE16</incoming>
      <incoming>STFL1-XORCLOSE16</incoming>
      <outgoing>XORCLOSE16-PARCLOSE17</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>XORCLOSE15-PARCLOSE17</incoming>
      <incoming>XORCLOSE16-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE17-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DCO1" sourceRef="Default_init" targetRef="DCO1"/>
    <sequenceFlow id="DCO1-CC1" sourceRef="DCO1" targetRef="CC1"/>
    <sequenceFlow id="CC1-SPC1" sourceRef="CC1" targetRef="SPC1"/>
    <sequenceFlow id="SPC1-DV1" sourceRef="SPC1" targetRef="DV1"/>
    <sequenceFlow id="DV1-LC1" sourceRef="DV1" targetRef="LC1"/>
    <sequenceFlow id="LC1-CPE1" sourceRef="LC1" targetRef="CPE1"/>
    <sequenceFlow id="CPE1-Par6" sourceRef="CPE1" targetRef="Par6"/>
    <sequenceFlow id="Par6-TPRT1" sourceRef="Par6" targetRef="TPRT1"/>
    <sequenceFlow id="Par6-CLCRM1" sourceRef="Par6" targetRef="CLCRM1"/>
    <sequenceFlow id="TPRT1-G0" sourceRef="TPRT1" targetRef="G0"/>
    <sequenceFlow id="CLCRM1-G1" sourceRef="CLCRM1" targetRef="G1"/>
    <sequenceFlow id="G0-APFO1" sourceRef="G0" targetRef="APFO1"/>
    <sequenceFlow id="G0-XORCLOSE15" sourceRef="G0" targetRef="XORCLOSE15"/>
    <sequenceFlow id="APFO1-XORCLOSE15" sourceRef="APFO1" targetRef="XORCLOSE15"/>
    <sequenceFlow id="G1-STFL1" sourceRef="G1" targetRef="STFL1"/>
    <sequenceFlow id="G1-XORCLOSE16" sourceRef="G1" targetRef="XORCLOSE16"/>
    <sequenceFlow id="STFL1-XORCLOSE16" sourceRef="STFL1" targetRef="XORCLOSE16"/>
    <sequenceFlow id="XORCLOSE15-PARCLOSE17" sourceRef="XORCLOSE15" targetRef="PARCLOSE17"/>
    <sequenceFlow id="XORCLOSE16-PARCLOSE17" sourceRef="XORCLOSE16" targetRef="PARCLOSE17"/>
    <sequenceFlow id="PARCLOSE17-END" sourceRef="PARCLOSE17" targetRef="END"/>
  </process>
