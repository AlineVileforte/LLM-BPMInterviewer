    <sequenceFlow id="Par11-CPE1" sourceRef="Par11" targetRef="CPE1"/>
    <sequenceFlow id="CLCRM1-Par14" sourceRef="CLCRM1" targetRef="Par14"/>
    <sequenceFlow id="CPE1-PARCLOSE18" sourceRef="CPE1" targetRef="PARCLOSE18"/>
    <sequenceFlow id="Par14-TPRT1" sourceRef="Par14" targetRef="TPRT1"/>
    <sequenceFlow id="Par14-STFL1" sourceRef="Par14" targetRef="STFL1"/>
    <sequenceFlow id="TPRT1-PARCLOSE17" sourceRef="TPRT1" targetRef="PARCLOSE17"/>
    <sequenceFlow id="STFL1-PARCLOSE17" sourceRef="STFL1" targetRef="PARCLOSE17"/>
    <sequenceFlow id="PARCLOSE17-PARCLOSE18" sourceRef="PARCLOSE17" targetRef="PARCLOSE18"/>
    <sequenceFlow id="PARCLOSE18-APFO1" sourceRef="PARCLOSE18" targetRef="APFO1"/>
    <sequenceFlow id="APFO1-END" sourceRef="APFO1" targetRef="END"/>
  </process>
