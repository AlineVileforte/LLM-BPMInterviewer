<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_f0d11069-9123-4a86-90e6-6f1fb559d382" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DCO1</outgoing>
    </startEvent>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>Default_init-DCO1</incoming>
      <outgoing>DCO1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>DCO1-Par1</incoming>
      <outgoing>Par1-SPC1</outgoing>
      <outgoing>Par1-DV1</outgoing>
    </parallelGateway>
    <task id="SPC1" name="Select promotion channels">
      <incoming>Par1-SPC1</incoming>
      <outgoing>SPC1-CC1</outgoing>
    </task>
    <task id="CC1" name="Create content">
      <incoming>SPC1-CC1</incoming>
      <outgoing>CC1-PARCLOSE5</outgoing>
    </task>
    <task id="DV1" name="Design visuals">
      <incoming>Par1-DV1</incoming>
      <outgoing>DV1-PARCLOSE5</outgoing>
    </task>
    <parallelGateway id="PARCLOSE5" name="PARCLOSE5">
      <incoming>CC1-PARCLOSE5</incoming>
      <incoming>DV1-PARCLOSE5</incoming>
      <outgoing>PARCLOSE5-LC1</outgoing>
    </parallelGateway>
    <task id="LC1" name="Launch campaign">
      <incoming>PARCLOSE5-LC1</incoming>
      <outgoing>LC1-CLCRM1</outgoing>
    </task>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>LC1-CLCRM1</incoming>
      <outgoing>CLCRM1-TPRT1</outgoing>
    </task>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>CLCRM1-TPRT1</incoming>
      <outgoing>TPRT1-CPE1</outgoing>
    </task>
    <task id="CPE1" name="Campaign period ends">
      <incoming>TPRT1-CPE1</incoming>
      <outgoing>CPE1-Par11</outgoing>
    </task>
    <parallelGateway id="Par11" name="PAR">
      <incoming>CPE1-Par11</incoming>
      <outgoing>Par11-G3</outgoing>
      <outgoing>Par11-G4</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G3" name="G3">
      <incoming>Par11-G3</incoming>
      <outgoing>G3-APFO1</outgoing>
      <outgoing>G3-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>G3-APFO1</incoming>
      <outgoing>APFO1-XORCLOSE18</outgoing>
    </task>
    <exclusiveGateway id="G4" name="G4">
      <incoming>Par11-G4</incoming>
      <outgoing>G4-STFL1</outgoing>
      <outgoing>G4-XORCLOSE19</outgoing>
    </exclusiveGateway>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>G4-STFL1</incoming>
      <outgoing>STFL1-XORCLOSE19</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>G3-XORCLOSE18</incoming>
      <incoming>APFO1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-PARCLOSE20</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE19" name="XORCLOSE19">
      <incoming>G4-XORCLOSE19</incoming>
      <incoming>STFL1-XORCLOSE19</incoming>
      <outgoing>XORCLOSE19-PARCLOSE20</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE20" name="PARCLOSE20">
      <incoming>XORCLOSE18-PARCLOSE20</incoming>
      <incoming>XORCLOSE19-PARCLOSE20</incoming>
      <outgoing>PARCLOSE20-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE20-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DCO1" sourceRef="Default_init" targetRef="DCO1"/>
    <sequenceFlow id="DCO1-Par1" sourceRef="DCO1" targetRef="Par1"/>
    <sequenceFlow id="Par1-SPC1" sourceRef="Par1" targetRef="SPC1"/>
    <sequenceFlow id="Par1-DV1" sourceRef="Par1" targetRef="DV1"/>
    <sequenceFlow id="SPC1-CC1" sourceRef="SPC1" targetRef="CC1"/>
    <sequenceFlow id="CC1-PARCLOSE5" sourceRef="CC1" targetRef="PARCLOSE5"/>
    <sequenceFlow id="DV1-PARCLOSE5" sourceRef="DV1" targetRef="PARCLOSE5"/>
    <sequenceFlow id="PARCLOSE5-LC1" sourceRef="PARCLOSE5" targetRef="LC1"/>
    <sequenceFlow id="LC1-CLCRM1" sourceRef="LC1" targetRef="CLCRM1"/>
    <sequenceFlow id="CLCRM1-TPRT1" sourceRef="CLCRM1" targetRef="TPRT1"/>
    <sequenceFlow id="TPRT1-CPE1" sourceRef="TPRT1" targetRef="CPE1"/>
    <sequenceFlow id="CPE1-Par11" sourceRef="CPE1" targetRef="Par11"/>
    <sequenceFlow id="Par11-G3" sourceRef="Par11" targetRef="G3"/>
    <sequenceFlow id="Par11-G4" sourceRef="Par11" targetRef="G4"/>
    <sequenceFlow id="G3-APFO1" sourceRef="G3" targetRef="APFO1"/>
    <sequenceFlow id="G3-XORCLOSE18" sourceRef="G3" targetRef="XORCLOSE18"/>
    <sequenceFlow id="APFO1-XORCLOSE18" sourceRef="APFO1" targetRef="XORCLOSE18"/>
    <sequenceFlow id="G4-STFL1" sourceRef="G4" targetRef="STFL1"/>
    <sequenceFlow id="G4-XORCLOSE19" sourceRef="G4" targetRef="XORCLOSE19"/>
    <sequenceFlow id="STFL1-XORCLOSE19" sourceRef="STFL1" targetRef="XORCLOSE19"/>
    <sequenceFlow id="XORCLOSE18-PARCLOSE20" sourceRef="XORCLOSE18" targetRef="PARCLOSE20"/>
    <sequenceFlow id="XORCLOSE19-PARCLOSE20" sourceRef="XORCLOSE19" targetRef="PARCLOSE20"/>
    <sequenceFlow id="PARCLOSE20-END" sourceRef="PARCLOSE20" targetRef="END"/>
  </process>
