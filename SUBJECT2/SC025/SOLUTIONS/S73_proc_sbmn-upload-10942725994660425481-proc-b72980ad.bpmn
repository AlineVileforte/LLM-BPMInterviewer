    <sequenceFlow id="LC1-Par9" sourceRef="LC1" targetRef="Par9"/>
    <sequenceFlow id="Par9-TPRT1" sourceRef="Par9" targetRef="TPRT1"/>
    <sequenceFlow id="Par9-CPE1" sourceRef="Par9" targetRef="CPE1"/>
    <sequenceFlow id="TPRT1-Par12" sourceRef="TPRT1" targetRef="Par12"/>
    <sequenceFlow id="CPE1-PARCLOSE16" sourceRef="CPE1" targetRef="PARCLOSE16"/>
    <sequenceFlow id="Par12-CLCRM1" sourceRef="Par12" targetRef="CLCRM1"/>
    <sequenceFlow id="Par12-APFO1" sourceRef="Par12" targetRef="APFO1"/>
    <sequenceFlow id="CLCRM1-PARCLOSE15" sourceRef="CLCRM1" targetRef="PARCLOSE15"/>
    <sequenceFlow id="APFO1-PARCLOSE15" sourceRef="APFO1" targetRef="PARCLOSE15"/>
    <sequenceFlow id="PARCLOSE15-PARCLOSE16" sourceRef="PARCLOSE15" targetRef="PARCLOSE16"/>
    <sequenceFlow id="PARCLOSE16-STFL1" sourceRef="PARCLOSE16" targetRef="STFL1"/>
    <sequenceFlow id="STFL1-END" sourceRef="STFL1" targetRef="END"/>
  </process>
