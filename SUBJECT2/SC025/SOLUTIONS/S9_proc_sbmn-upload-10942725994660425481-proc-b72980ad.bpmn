<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_8192e428-4828-4fa9-8957-a798b138e397" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-DCO1</outgoing>
      <outgoing>Par0-DV1</outgoing>
    </parallelGateway>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>Par0-DCO1</incoming>
      <outgoing>DCO1-Par6</outgoing>
    </task>
    <task id="DV1" name="Design visuals">
      <incoming>Par0-DV1</incoming>
      <outgoing>DV1-PARCLOSE11</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>DCO1-Par6</incoming>
      <outgoing>Par6-CC1</outgoing>
      <outgoing>Par6-SPC1</outgoing>
    </parallelGateway>
    <task id="CC1" name="Create content">
      <incoming>Par6-CC1</incoming>
      <outgoing>CC1-PARCLOSE9</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>Par6-SPC1</incoming>
      <outgoing>SPC1-PARCLOSE9</outgoing>
    </task>
    <parallelGateway id="PARCLOSE9" name="PARCLOSE9">
      <incoming>CC1-PARCLOSE9</incoming>
      <incoming>SPC1-PARCLOSE9</incoming>
      <outgoing>PARCLOSE9-PARCLOSE11</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE11" name="PARCLOSE11">
      <incoming>DV1-PARCLOSE11</incoming>
      <incoming>PARCLOSE9-PARCLOSE11</incoming>
      <outgoing>PARCLOSE11-LC1</outgoing>
    </parallelGateway>
    <task id="LC1" name="Launch campaign">
      <incoming>PARCLOSE11-LC1</incoming>
      <outgoing>LC1-CPE1</outgoing>
    </task>
    <task id="CPE1" name="Campaign period ends">
      <incoming>LC1-CPE1</incoming>
      <outgoing>CPE1-CLCRM1</outgoing>
    </task>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>CPE1-CLCRM1</incoming>
      <outgoing>CLCRM1-Par15</outgoing>
    </task>
    <parallelGateway id="Par15" name="PAR">
      <incoming>CLCRM1-Par15</incoming>
      <outgoing>Par15-TPRT1</outgoing>
      <outgoing>Par15-STFL1</outgoing>
    </parallelGateway>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>Par15-TPRT1</incoming>
      <outgoing>TPRT1-PARCLOSE18</outgoing>
    </task>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>Par15-STFL1</incoming>
      <outgoing>STFL1-PARCLOSE18</outgoing>
    </task>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>TPRT1-PARCLOSE18</incoming>
      <incoming>STFL1-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-APFO1</outgoing>
    </parallelGateway>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>PARCLOSE18-APFO1</incoming>
      <outgoing>APFO1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>APFO1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
