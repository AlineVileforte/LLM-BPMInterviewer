<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_18eef228-57eb-4dca-a261-b4617ee5059f" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DCO1</outgoing>
    </startEvent>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>Default_init-DCO1</incoming>
      <outgoing>DCO1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>DCO1-Par1</incoming>
      <outgoing>Par1-CC1</outgoing>
      <outgoing>Par1-SPC1</outgoing>
    </parallelGateway>
    <task id="CC1" name="Create content">
      <incoming>Par1-CC1</incoming>
      <outgoing>CC1-PARCLOSE9</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>Par1-SPC1</incoming>
      <outgoing>SPC1-DV1</outgoing>
    </task>
    <task id="DV1" name="Design visuals">
      <incoming>SPC1-DV1</incoming>
      <outgoing>DV1-PARCLOSE9</outgoing>
    </task>
    <parallelGateway id="PARCLOSE9" name="PARCLOSE9">
      <incoming>CC1-PARCLOSE9</incoming>
      <incoming>DV1-PARCLOSE9</incoming>
      <outgoing>PARCLOSE9-LC1</outgoing>
    </parallelGateway>
    <task id="LC1" name="Launch campaign">
      <incoming>PARCLOSE9-LC1</incoming>
      <outgoing>LC1-Par11</outgoing>
    </task>
    <parallelGateway id="Par11" name="PAR">
      <incoming>LC1-Par11</incoming>
      <outgoing>Par11-CLCRM1</outgoing>
      <outgoing>Par11-CPE1</outgoing>
    </parallelGateway>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>Par11-CLCRM1</incoming>
      <outgoing>CLCRM1-STFL1</outgoing>
    </task>
    <task id="CPE1" name="Campaign period ends">
      <incoming>Par11-CPE1</incoming>
      <outgoing>CPE1-TPRT1</outgoing>
    </task>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>CLCRM1-STFL1</incoming>
      <outgoing>STFL1-PARCLOSE17</outgoing>
    </task>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>CPE1-TPRT1</incoming>
      <outgoing>TPRT1-APFO1</outgoing>
    </task>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>TPRT1-APFO1</incoming>
      <outgoing>APFO1-PARCLOSE17</outgoing>
    </task>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>STFL1-PARCLOSE17</incoming>
      <incoming>APFO1-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE17-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DCO1" sourceRef="Default_init" targetRef="DCO1"/>
    <sequenceFlow id="DCO1-Par1" sourceRef="DCO1" targetRef="Par1"/>
    <sequenceFlow id="Par1-CC1" sourceRef="Par1" targetRef="CC1"/>
    <sequenceFlow id="Par1-SPC1" sourceRef="Par1" targetRef="SPC1"/>
    <sequenceFlow id="CC1-PARCLOSE9" sourceRef="CC1" targetRef="PARCLOSE9"/>
    <sequenceFlow id="SPC1-DV1" sourceRef="SPC1" targetRef="DV1"/>
    <sequenceFlow id="DV1-PARCLOSE9" sourceRef="DV1" targetRef="PARCLOSE9"/>
    <sequenceFlow id="PARCLOSE9-LC1" sourceRef="PARCLOSE9" targetRef="LC1"/>
    <sequenceFlow id="LC1-Par11" sourceRef="LC1" targetRef="Par11"/>
    <sequenceFlow id="Par11-CLCRM1" sourceRef="Par11" targetRef="CLCRM1"/>
    <sequenceFlow id="Par11-CPE1" sourceRef="Par11" targetRef="CPE1"/>
    <sequenceFlow id="CLCRM1-STFL1" sourceRef="CLCRM1" targetRef="STFL1"/>
    <sequenceFlow id="CPE1-TPRT1" sourceRef="CPE1" targetRef="TPRT1"/>
    <sequenceFlow id="STFL1-PARCLOSE17" sourceRef="STFL1" targetRef="PARCLOSE17"/>
    <sequenceFlow id="TPRT1-APFO1" sourceRef="TPRT1" targetRef="APFO1"/>
    <sequenceFlow id="APFO1-PARCLOSE17" sourceRef="APFO1" targetRef="PARCLOSE17"/>
    <sequenceFlow id="PARCLOSE17-END" sourceRef="PARCLOSE17" targetRef="END"/>
  </process>
