<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_a16756a9-4ad4-4db5-8465-c3c003cbbc52" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DV1</outgoing>
    </startEvent>
    <task id="DV1" name="Design visuals">
      <incoming>Default_init-DV1</incoming>
      <outgoing>DV1-DCO1</outgoing>
    </task>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>DV1-DCO1</incoming>
      <outgoing>DCO1-CC1</outgoing>
    </task>
    <task id="CC1" name="Create content">
      <incoming>DCO1-CC1</incoming>
      <outgoing>CC1-SPC1</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>CC1-SPC1</incoming>
      <outgoing>SPC1-LC1</outgoing>
    </task>
    <task id="LC1" name="Launch campaign">
      <incoming>SPC1-LC1</incoming>
      <outgoing>LC1-Par5</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>LC1-Par5</incoming>
      <outgoing>Par5-CLCRM1</outgoing>
      <outgoing>Par5-TPRT1</outgoing>
    </parallelGateway>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>Par5-CLCRM1</incoming>
      <outgoing>CLCRM1-Par7</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>CLCRM1-Par7</incoming>
      <outgoing>Par7-CPE1</outgoing>
      <outgoing>Par7-G0</outgoing>
    </parallelGateway>
    <task id="CPE1" name="Campaign period ends">
      <incoming>Par7-CPE1</incoming>
      <outgoing>CPE1-PARCLOSE17</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par7-G0</incoming>
      <outgoing>G0-STFL1</outgoing>
      <outgoing>G0-XORCLOSE13</outgoing>
    </exclusiveGateway>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>G0-STFL1</incoming>
      <outgoing>STFL1-XORCLOSE13</outgoing>
    </task>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>Par5-TPRT1</incoming>
      <outgoing>TPRT1-G1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE13" name="XORCLOSE13">
      <incoming>G0-XORCLOSE13</incoming>
      <incoming>STFL1-XORCLOSE13</incoming>
      <outgoing>XORCLOSE13-PARCLOSE17</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G1" name="G1">
      <incoming>TPRT1-G1</incoming>
      <outgoing>G1-APFO1</outgoing>
      <outgoing>G1-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>G1-APFO1</incoming>
      <outgoing>APFO1-XORCLOSE18</outgoing>
    </task>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>CPE1-PARCLOSE17</incoming>
      <incoming>XORCLOSE13-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-PARCLOSE19</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>G1-XORCLOSE18</incoming>
      <incoming>APFO1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-PARCLOSE19</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>PARCLOSE17-PARCLOSE19</incoming>
      <incoming>XORCLOSE18-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE19-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DV1" sourceRef="Default_init" targetRef="DV1"/>
    <sequenceFlow id="DV1-DCO1" sourceRef="DV1" targetRef="DCO1"/>
    <sequenceFlow id="DCO1-CC1" sourceRef="DCO1" targetRef="CC1"/>
    <sequenceFlow id="CC1-SPC1" sourceRef="CC1" targetRef="SPC1"/>
    <sequenceFlow id="SPC1-LC1" sourceRef="SPC1" targetRef="LC1"/>
    <sequenceFlow id="LC1-Par5" sourceRef="LC1" targetRef="Par5"/>
    <sequenceFlow id="Par5-CLCRM1" sourceRef="Par5" targetRef="CLCRM1"/>
    <sequenceFlow id="Par5-TPRT1" sourceRef="Par5" targetRef="TPRT1"/>
    <sequenceFlow id="CLCRM1-Par7" sourceRef="CLCRM1" targetRef="Par7"/>
    <sequenceFlow id="Par7-CPE1" sourceRef="Par7" targetRef="CPE1"/>
    <sequenceFlow id="Par7-G0" sourceRef="Par7" targetRef="G0"/>
    <sequenceFlow id="CPE1-PARCLOSE17" sourceRef="CPE1" targetRef="PARCLOSE17"/>
    <sequenceFlow id="G0-STFL1" sourceRef="G0" targetRef="STFL1"/>
    <sequenceFlow id="G0-XORCLOSE13" sourceRef="G0" targetRef="XORCLOSE13"/>
    <sequenceFlow id="STFL1-XORCLOSE13" sourceRef="STFL1" targetRef="XORCLOSE13"/>
    <sequenceFlow id="TPRT1-G1" sourceRef="TPRT1" targetRef="G1"/>
    <sequenceFlow id="XORCLOSE13-PARCLOSE17" sourceRef="XORCLOSE13" targetRef="PARCLOSE17"/>
    <sequenceFlow id="G1-APFO1" sourceRef="G1" targetRef="APFO1"/>
    <sequenceFlow id="G1-XORCLOSE18" sourceRef="G1" targetRef="XORCLOSE18"/>
    <sequenceFlow id="APFO1-XORCLOSE18" sourceRef="APFO1" targetRef="XORCLOSE18"/>
    <sequenceFlow id="PARCLOSE17-PARCLOSE19" sourceRef="PARCLOSE17" targetRef="PARCLOSE19"/>
    <sequenceFlow id="XORCLOSE18-PARCLOSE19" sourceRef="XORCLOSE18" targetRef="PARCLOSE19"/>
    <sequenceFlow id="PARCLOSE19-END" sourceRef="PARCLOSE19" targetRef="END"/>
  </process>
