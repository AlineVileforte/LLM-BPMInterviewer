    <sequenceFlow id="Par5-TPRT1" sourceRef="Par5" targetRef="TPRT1"/>
    <sequenceFlow id="CLCRM1-CPE1" sourceRef="CLCRM1" targetRef="CPE1"/>
    <sequenceFlow id="CPE1-G2" sourceRef="CPE1" targetRef="G2"/>
    <sequenceFlow id="TPRT1-G3" sourceRef="TPRT1" targetRef="G3"/>
    <sequenceFlow id="G2-STFL1" sourceRef="G2" targetRef="STFL1"/>
    <sequenceFlow id="G2-XORCLOSE15" sourceRef="G2" targetRef="XORCLOSE15"/>
    <sequenceFlow id="STFL1-XORCLOSE15" sourceRef="STFL1" targetRef="XORCLOSE15"/>
    <sequenceFlow id="G3-APFO1" sourceRef="G3" targetRef="APFO1"/>
    <sequenceFlow id="G3-XORCLOSE16" sourceRef="G3" targetRef="XORCLOSE16"/>
    <sequenceFlow id="APFO1-XORCLOSE16" sourceRef="APFO1" targetRef="XORCLOSE16"/>
    <sequenceFlow id="XORCLOSE15-PARCLOSE17" sourceRef="XORCLOSE15" targetRef="PARCLOSE17"/>
    <sequenceFlow id="XORCLOSE16-PARCLOSE17" sourceRef="XORCLOSE16" targetRef="PARCLOSE17"/>
    <sequenceFlow id="PARCLOSE17-END" sourceRef="PARCLOSE17" targetRef="END"/>
  </process>
