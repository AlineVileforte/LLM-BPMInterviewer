<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_aa6a199f-8e91-4bc9-97ca-098cad5a3220" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DCO1</outgoing>
    </startEvent>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>Default_init-DCO1</incoming>
      <outgoing>DCO1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>DCO1-Par1</incoming>
      <outgoing>Par1-SPC1</outgoing>
      <outgoing>Par1-DV1</outgoing>
    </parallelGateway>
    <task id="SPC1" name="Select promotion channels">
      <incoming>Par1-SPC1</incoming>
      <outgoing>SPC1-CC1</outgoing>
    </task>
    <task id="CC1" name="Create content">
      <incoming>SPC1-CC1</incoming>
      <outgoing>CC1-PARCLOSE23</outgoing>
    </task>
    <task id="DV1" name="Design visuals">
      <incoming>Par1-DV1</incoming>
      <outgoing>DV1-LC1</outgoing>
    </task>
    <task id="LC1" name="Launch campaign">
      <incoming>DV1-LC1</incoming>
      <outgoing>LC1-Par6</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>LC1-Par6</incoming>
      <outgoing>Par6-TPRT1</outgoing>
      <outgoing>Par6-CPE1</outgoing>
    </parallelGateway>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>Par6-TPRT1</incoming>
      <outgoing>TPRT1-G0</outgoing>
    </task>
    <task id="CPE1" name="Campaign period ends">
      <incoming>Par6-CPE1</incoming>
      <outgoing>CPE1-CLCRM1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>TPRT1-G0</incoming>
      <outgoing>G0-APFO1</outgoing>
      <outgoing>G0-XORCLOSE15</outgoing>
    </exclusiveGateway>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>G0-APFO1</incoming>
      <outgoing>APFO1-XORCLOSE15</outgoing>
    </task>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>CPE1-CLCRM1</incoming>
      <outgoing>CLCRM1-G1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE15" name="XORCLOSE15">
      <incoming>G0-XORCLOSE15</incoming>
      <incoming>APFO1-XORCLOSE15</incoming>
      <outgoing>XORCLOSE15-PARCLOSE22</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G1" name="G1">
      <incoming>CLCRM1-G1</incoming>
      <outgoing>G1-STFL1</outgoing>
      <outgoing>G1-XORCLOSE20</outgoing>
    </exclusiveGateway>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>G1-STFL1</incoming>
      <outgoing>STFL1-XORCLOSE20</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>G1-XORCLOSE20</incoming>
      <incoming>STFL1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-PARCLOSE22</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>XORCLOSE15-PARCLOSE22</incoming>
      <incoming>XORCLOSE20-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-PARCLOSE23</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>CC1-PARCLOSE23</incoming>
      <incoming>PARCLOSE22-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE23-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DCO1" sourceRef="Default_init" targetRef="DCO1"/>
    <sequenceFlow id="DCO1-Par1" sourceRef="DCO1" targetRef="Par1"/>
    <sequenceFlow id="Par1-SPC1" sourceRef="Par1" targetRef="SPC1"/>
    <sequenceFlow id="Par1-DV1" sourceRef="Par1" targetRef="DV1"/>
    <sequenceFlow id="SPC1-CC1" sourceRef="SPC1" targetRef="CC1"/>
    <sequenceFlow id="CC1-PARCLOSE23" sourceRef="CC1" targetRef="PARCLOSE23"/>
    <sequenceFlow id="DV1-LC1" sourceRef="DV1" targetRef="LC1"/>
    <sequenceFlow id="LC1-Par6" sourceRef="LC1" targetRef="Par6"/>
    <sequenceFlow id="Par6-TPRT1" sourceRef="Par6" targetRef="TPRT1"/>
    <sequenceFlow id="Par6-CPE1" sourceRef="Par6" targetRef="CPE1"/>
    <sequenceFlow id="TPRT1-G0" sourceRef="TPRT1" targetRef="G0"/>
    <sequenceFlow id="CPE1-CLCRM1" sourceRef="CPE1" targetRef="CLCRM1"/>
    <sequenceFlow id="G0-APFO1" sourceRef="G0" targetRef="APFO1"/>
    <sequenceFlow id="G0-XORCLOSE15" sourceRef="G0" targetRef="XORCLOSE15"/>
    <sequenceFlow id="APFO1-XORCLOSE15" sourceRef="APFO1" targetRef="XORCLOSE15"/>
    <sequenceFlow id="CLCRM1-G1" sourceRef="CLCRM1" targetRef="G1"/>
    <sequenceFlow id="XORCLOSE15-PARCLOSE22" sourceRef="XORCLOSE15" targetRef="PARCLOSE22"/>
    <sequenceFlow id="G1-STFL1" sourceRef="G1" targetRef="STFL1"/>
    <sequenceFlow id="G1-XORCLOSE20" sourceRef="G1" targetRef="XORCLOSE20"/>
    <sequenceFlow id="STFL1-XORCLOSE20" sourceRef="STFL1" targetRef="XORCLOSE20"/>
    <sequenceFlow id="XORCLOSE20-PARCLOSE22" sourceRef="XORCLOSE20" targetRef="PARCLOSE22"/>
    <sequenceFlow id="PARCLOSE22-PARCLOSE23" sourceRef="PARCLOSE22" targetRef="PARCLOSE23"/>
    <sequenceFlow id="PARCLOSE23-END" sourceRef="PARCLOSE23" targetRef="END"/>
  </process>
