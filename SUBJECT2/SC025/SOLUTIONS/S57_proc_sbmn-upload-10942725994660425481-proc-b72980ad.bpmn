<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_158d7c84-c897-4197-8bb7-573a371ef614" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-DCO1</outgoing>
      <outgoing>Par0-DV1</outgoing>
    </parallelGateway>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>Par0-DCO1</incoming>
      <outgoing>DCO1-CC1</outgoing>
    </task>
    <task id="DV1" name="Design visuals">
      <incoming>Par0-DV1</incoming>
      <outgoing>DV1-PARCLOSE7</outgoing>
    </task>
    <task id="CC1" name="Create content">
      <incoming>DCO1-CC1</incoming>
      <outgoing>CC1-SPC1</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>CC1-SPC1</incoming>
      <outgoing>SPC1-PARCLOSE7</outgoing>
    </task>
    <parallelGateway id="PARCLOSE7" name="PARCLOSE7">
      <incoming>DV1-PARCLOSE7</incoming>
      <incoming>SPC1-PARCLOSE7</incoming>
      <outgoing>PARCLOSE7-LC1</outgoing>
    </parallelGateway>
    <task id="LC1" name="Launch campaign">
      <incoming>PARCLOSE7-LC1</incoming>
      <outgoing>LC1-CPE1</outgoing>
    </task>
    <task id="CPE1" name="Campaign period ends">
      <incoming>LC1-CPE1</incoming>
      <outgoing>CPE1-CLCRM1</outgoing>
    </task>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>CPE1-CLCRM1</incoming>
      <outgoing>CLCRM1-Par11</outgoing>
    </task>
    <parallelGateway id="Par11" name="PAR">
      <incoming>CLCRM1-Par11</incoming>
      <outgoing>Par11-TPRT1</outgoing>
      <outgoing>Par11-STFL1</outgoing>
    </parallelGateway>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>Par11-TPRT1</incoming>
      <outgoing>TPRT1-PARCLOSE14</outgoing>
    </task>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>Par11-STFL1</incoming>
      <outgoing>STFL1-PARCLOSE14</outgoing>
    </task>
    <parallelGateway id="PARCLOSE14" name="PARCLOSE14">
      <incoming>TPRT1-PARCLOSE14</incoming>
      <incoming>STFL1-PARCLOSE14</incoming>
      <outgoing>PARCLOSE14-APFO1</outgoing>
    </parallelGateway>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>PARCLOSE14-APFO1</incoming>
      <outgoing>APFO1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>APFO1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
    <sequenceFlow id="Par0-DCO1" sourceRef="Par0" targetRef="DCO1"/>
    <sequenceFlow id="Par0-DV1" sourceRef="Par0" targetRef="DV1"/>
    <sequenceFlow id="DCO1-CC1" sourceRef="DCO1" targetRef="CC1"/>
    <sequenceFlow id="DV1-PARCLOSE7" sourceRef="DV1" targetRef="PARCLOSE7"/>
    <sequenceFlow id="CC1-SPC1" sourceRef="CC1" targetRef="SPC1"/>
    <sequenceFlow id="SPC1-PARCLOSE7" sourceRef="SPC1" targetRef="PARCLOSE7"/>
    <sequenceFlow id="PARCLOSE7-LC1" sourceRef="PARCLOSE7" targetRef="LC1"/>
    <sequenceFlow id="LC1-CPE1" sourceRef="LC1" targetRef="CPE1"/>
    <sequenceFlow id="CPE1-CLCRM1" sourceRef="CPE1" targetRef="CLCRM1"/>
    <sequenceFlow id="CLCRM1-Par11" sourceRef="CLCRM1" targetRef="Par11"/>
    <sequenceFlow id="Par11-TPRT1" sourceRef="Par11" targetRef="TPRT1"/>
    <sequenceFlow id="Par11-STFL1" sourceRef="Par11" targetRef="STFL1"/>
    <sequenceFlow id="TPRT1-PARCLOSE14" sourceRef="TPRT1" targetRef="PARCLOSE14"/>
    <sequenceFlow id="STFL1-PARCLOSE14" sourceRef="STFL1" targetRef="PARCLOSE14"/>
    <sequenceFlow id="PARCLOSE14-APFO1" sourceRef="PARCLOSE14" targetRef="APFO1"/>
    <sequenceFlow id="APFO1-END" sourceRef="APFO1" targetRef="END"/>
  </process>
