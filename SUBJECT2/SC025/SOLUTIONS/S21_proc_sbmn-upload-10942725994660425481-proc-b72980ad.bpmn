    <sequenceFlow id="Par9-TPRT1" sourceRef="Par9" targetRef="TPRT1"/>
    <sequenceFlow id="Par9-Par13" sourceRef="Par9" targetRef="Par13"/>
    <sequenceFlow id="TPRT1-CPE1" sourceRef="TPRT1" targetRef="CPE1"/>
    <sequenceFlow id="CPE1-STFL1" sourceRef="CPE1" targetRef="STFL1"/>
    <sequenceFlow id="Par13-CLCRM1" sourceRef="Par13" targetRef="CLCRM1"/>
    <sequenceFlow id="Par13-APFO1" sourceRef="Par13" targetRef="APFO1"/>
    <sequenceFlow id="CLCRM1-PARCLOSE17" sourceRef="CLCRM1" targetRef="PARCLOSE17"/>
