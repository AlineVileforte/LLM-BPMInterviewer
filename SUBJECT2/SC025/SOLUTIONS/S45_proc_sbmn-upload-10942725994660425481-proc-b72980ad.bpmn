<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_0b4c4dca-8bcd-41f1-95a8-c8e70ea618ad" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DCO1</outgoing>
    </startEvent>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>Default_init-DCO1</incoming>
      <outgoing>DCO1-SPC1</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>DCO1-SPC1</incoming>
      <outgoing>SPC1-DV1</outgoing>
    </task>
    <task id="DV1" name="Design visuals">
      <incoming>SPC1-DV1</incoming>
      <outgoing>DV1-CC1</outgoing>
    </task>
    <task id="CC1" name="Create content">
      <incoming>DV1-CC1</incoming>
      <outgoing>CC1-LC1</outgoing>
    </task>
    <task id="LC1" name="Launch campaign">
      <incoming>CC1-LC1</incoming>
      <outgoing>LC1-CLCRM1</outgoing>
    </task>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>LC1-CLCRM1</incoming>
      <outgoing>CLCRM1-Par6</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>CLCRM1-Par6</incoming>
      <outgoing>Par6-TPRT1</outgoing>
      <outgoing>Par6-Par10</outgoing>
    </parallelGateway>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>Par6-TPRT1</incoming>
      <outgoing>TPRT1-CPE1</outgoing>
    </task>
    <task id="CPE1" name="Campaign period ends">
      <incoming>TPRT1-CPE1</incoming>
      <outgoing>CPE1-PARCLOSE21</outgoing>
    </task>
    <parallelGateway id="Par10" name="PAR">
      <incoming>Par6-Par10</incoming>
      <outgoing>Par10-G3</outgoing>
      <outgoing>Par10-G4</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G3" name="G3">
      <incoming>Par10-G3</incoming>
      <outgoing>G3-APFO1</outgoing>
      <outgoing>G3-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>G3-APFO1</incoming>
      <outgoing>APFO1-XORCLOSE18</outgoing>
    </task>
    <exclusiveGateway id="G4" name="G4">
      <incoming>Par10-G4</incoming>
      <outgoing>G4-STFL1</outgoing>
      <outgoing>G4-XORCLOSE19</outgoing>
    </exclusiveGateway>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>G4-STFL1</incoming>
      <outgoing>STFL1-XORCLOSE19</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>G3-XORCLOSE18</incoming>
      <incoming>APFO1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-PARCLOSE20</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE19" name="XORCLOSE19">
      <incoming>G4-XORCLOSE19</incoming>
      <incoming>STFL1-XORCLOSE19</incoming>
      <outgoing>XORCLOSE19-PARCLOSE20</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE20" name="PARCLOSE20">
      <incoming>XORCLOSE18-PARCLOSE20</incoming>
      <incoming>XORCLOSE19-PARCLOSE20</incoming>
      <outgoing>PARCLOSE20-PARCLOSE21</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>CPE1-PARCLOSE21</incoming>
      <incoming>PARCLOSE20-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE21-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DCO1" sourceRef="Default_init" targetRef="DCO1"/>
    <sequenceFlow id="DCO1-SPC1" sourceRef="DCO1" targetRef="SPC1"/>
    <sequenceFlow id="SPC1-DV1" sourceRef="SPC1" targetRef="DV1"/>
    <sequenceFlow id="DV1-CC1" sourceRef="DV1" targetRef="CC1"/>
    <sequenceFlow id="CC1-LC1" sourceRef="CC1" targetRef="LC1"/>
    <sequenceFlow id="LC1-CLCRM1" sourceRef="LC1" targetRef="CLCRM1"/>
    <sequenceFlow id="CLCRM1-Par6" sourceRef="CLCRM1" targetRef="Par6"/>
    <sequenceFlow id="Par6-TPRT1" sourceRef="Par6" targetRef="TPRT1"/>
    <sequenceFlow id="Par6-Par10" sourceRef="Par6" targetRef="Par10"/>
    <sequenceFlow id="TPRT1-CPE1" sourceRef="TPRT1" targetRef="CPE1"/>
    <sequenceFlow id="CPE1-PARCLOSE21" sourceRef="CPE1" targetRef="PARCLOSE21"/>
    <sequenceFlow id="Par10-G3" sourceRef="Par10" targetRef="G3"/>
    <sequenceFlow id="Par10-G4" sourceRef="Par10" targetRef="G4"/>
    <sequenceFlow id="G3-APFO1" sourceRef="G3" targetRef="APFO1"/>
    <sequenceFlow id="G3-XORCLOSE18" sourceRef="G3" targetRef="XORCLOSE18"/>
    <sequenceFlow id="APFO1-XORCLOSE18" sourceRef="APFO1" targetRef="XORCLOSE18"/>
    <sequenceFlow id="G4-STFL1" sourceRef="G4" targetRef="STFL1"/>
    <sequenceFlow id="G4-XORCLOSE19" sourceRef="G4" targetRef="XORCLOSE19"/>
    <sequenceFlow id="STFL1-XORCLOSE19" sourceRef="STFL1" targetRef="XORCLOSE19"/>
    <sequenceFlow id="XORCLOSE18-PARCLOSE20" sourceRef="XORCLOSE18" targetRef="PARCLOSE20"/>
    <sequenceFlow id="XORCLOSE19-PARCLOSE20" sourceRef="XORCLOSE19" targetRef="PARCLOSE20"/>
    <sequenceFlow id="PARCLOSE20-PARCLOSE21" sourceRef="PARCLOSE20" targetRef="PARCLOSE21"/>
    <sequenceFlow id="PARCLOSE21-END" sourceRef="PARCLOSE21" targetRef="END"/>
  </process>
