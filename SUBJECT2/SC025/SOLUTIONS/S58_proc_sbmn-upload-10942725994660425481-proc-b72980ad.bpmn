<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_b70948f4-4136-43cb-839b-db3294509c90" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DV1</outgoing>
    </startEvent>
    <task id="DV1" name="Design visuals">
      <incoming>Default_init-DV1</incoming>
      <outgoing>DV1-DCO1</outgoing>
    </task>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>DV1-DCO1</incoming>
      <outgoing>DCO1-CC1</outgoing>
    </task>
    <task id="CC1" name="Create content">
      <incoming>DCO1-CC1</incoming>
      <outgoing>CC1-SPC1</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>CC1-SPC1</incoming>
      <outgoing>SPC1-LC1</outgoing>
    </task>
    <task id="LC1" name="Launch campaign">
      <incoming>SPC1-LC1</incoming>
      <outgoing>LC1-CPE1</outgoing>
    </task>
    <task id="CPE1" name="Campaign period ends">
      <incoming>LC1-CPE1</incoming>
      <outgoing>CPE1-Par6</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>CPE1-Par6</incoming>
      <outgoing>Par6-TPRT1</outgoing>
      <outgoing>Par6-CLCRM1</outgoing>
    </parallelGateway>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>Par6-TPRT1</incoming>
      <outgoing>TPRT1-G0</outgoing>
    </task>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>Par6-CLCRM1</incoming>
      <outgoing>CLCRM1-G2</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>TPRT1-G0</incoming>
      <outgoing>G0-APFO1</outgoing>
      <outgoing>G0-XORCLOSE13</outgoing>
    </exclusiveGateway>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>G0-APFO1</incoming>
      <outgoing>APFO1-XORCLOSE13</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE13" name="XORCLOSE13">
      <incoming>G0-XORCLOSE13</incoming>
      <incoming>APFO1-XORCLOSE13</incoming>
      <outgoing>XORCLOSE13-PARCLOSE19</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G2" name="G2">
      <incoming>CLCRM1-G2</incoming>
      <outgoing>G2-STFL1</outgoing>
      <outgoing>G2-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>G2-STFL1</incoming>
      <outgoing>STFL1-XORCLOSE18</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>G2-XORCLOSE18</incoming>
      <incoming>STFL1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-PARCLOSE19</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>XORCLOSE13-PARCLOSE19</incoming>
      <incoming>XORCLOSE18-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE19-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DV1" sourceRef="Default_init" targetRef="DV1"/>
