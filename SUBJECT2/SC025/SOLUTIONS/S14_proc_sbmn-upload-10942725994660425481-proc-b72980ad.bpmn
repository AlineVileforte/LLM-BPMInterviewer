    <sequenceFlow id="SPC1-PARCLOSE9" sourceRef="SPC1" targetRef="PARCLOSE9"/>
    <sequenceFlow id="PARCLOSE9-LC1" sourceRef="PARCLOSE9" targetRef="LC1"/>
    <sequenceFlow id="LC1-TPRT1" sourceRef="LC1" targetRef="TPRT1"/>
    <sequenceFlow id="TPRT1-Par12" sourceRef="TPRT1" targetRef="Par12"/>
    <sequenceFlow id="Par12-CLCRM1" sourceRef="Par12" targetRef="CLCRM1"/>
    <sequenceFlow id="Par12-STFL1" sourceRef="Par12" targetRef="STFL1"/>
    <sequenceFlow id="CLCRM1-CPE1" sourceRef="CLCRM1" targetRef="CPE1"/>
    <sequenceFlow id="CPE1-APFO1" sourceRef="CPE1" targetRef="APFO1"/>
    <sequenceFlow id="STFL1-PARCLOSE19" sourceRef="STFL1" targetRef="PARCLOSE19"/>
    <sequenceFlow id="APFO1-PARCLOSE19" sourceRef="APFO1" targetRef="PARCLOSE19"/>
    <sequenceFlow id="PARCLOSE19-END" sourceRef="PARCLOSE19" targetRef="END"/>
  </process>
