    <sequenceFlow id="Par9-TPRT1" sourceRef="Par9" targetRef="TPRT1"/>
    <sequenceFlow id="Par9-CLCRM1" sourceRef="Par9" targetRef="CLCRM1"/>
    <sequenceFlow id="TPRT1-APFO1" sourceRef="TPRT1" targetRef="APFO1"/>
    <sequenceFlow id="CLCRM1-Par13" sourceRef="CLCRM1" targetRef="Par13"/>
    <sequenceFlow id="APFO1-PARCLOSE17" sourceRef="APFO1" targetRef="PARCLOSE17"/>
    <sequenceFlow id="Par13-STFL1" sourceRef="Par13" targetRef="STFL1"/>
    <sequenceFlow id="Par13-CPE1" sourceRef="Par13" targetRef="CPE1"/>
    <sequenceFlow id="STFL1-PARCLOSE16" sourceRef="STFL1" targetRef="PARCLOSE16"/>
    <sequenceFlow id="CPE1-PARCLOSE16" sourceRef="CPE1" targetRef="PARCLOSE16"/>
    <sequenceFlow id="PARCLOSE16-PARCLOSE17" sourceRef="PARCLOSE16" targetRef="PARCLOSE17"/>
    <sequenceFlow id="PARCLOSE17-END" sourceRef="PARCLOSE17" targetRef="END"/>
  </process>
