<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_a0da9669-acd6-47c9-a0df-39ec259038cc" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DV1</outgoing>
    </startEvent>
    <task id="DV1" name="Design visuals">
      <incoming>Default_init-DV1</incoming>
      <outgoing>DV1-DCO1</outgoing>
    </task>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>DV1-DCO1</incoming>
      <outgoing>DCO1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>DCO1-Par2</incoming>
      <outgoing>Par2-CC1</outgoing>
      <outgoing>Par2-SPC1</outgoing>
    </parallelGateway>
    <task id="CC1" name="Create content">
      <incoming>Par2-CC1</incoming>
      <outgoing>CC1-PARCLOSE7</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>Par2-SPC1</incoming>
      <outgoing>SPC1-PARCLOSE7</outgoing>
    </task>
    <parallelGateway id="PARCLOSE7" name="PARCLOSE7">
      <incoming>CC1-PARCLOSE7</incoming>
      <incoming>SPC1-PARCLOSE7</incoming>
      <outgoing>PARCLOSE7-LC1</outgoing>
    </parallelGateway>
    <task id="LC1" name="Launch campaign">
      <incoming>PARCLOSE7-LC1</incoming>
      <outgoing>LC1-Par9</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>LC1-Par9</incoming>
      <outgoing>Par9-TPRT1</outgoing>
      <outgoing>Par9-CLCRM1</outgoing>
    </parallelGateway>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>Par9-TPRT1</incoming>
      <outgoing>TPRT1-APFO1</outgoing>
    </task>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>Par9-CLCRM1</incoming>
      <outgoing>CLCRM1-Par13</outgoing>
    </task>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>TPRT1-APFO1</incoming>
      <outgoing>APFO1-PARCLOSE17</outgoing>
    </task>
    <parallelGateway id="Par13" name="PAR">
      <incoming>CLCRM1-Par13</incoming>
      <outgoing>Par13-STFL1</outgoing>
      <outgoing>Par13-CPE1</outgoing>
    </parallelGateway>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>Par13-STFL1</incoming>
      <outgoing>STFL1-PARCLOSE16</outgoing>
    </task>
    <task id="CPE1" name="Campaign period ends">
      <incoming>Par13-CPE1</incoming>
      <outgoing>CPE1-PARCLOSE16</outgoing>
    </task>
    <parallelGateway id="PARCLOSE16" name="PARCLOSE16">
      <incoming>STFL1-PARCLOSE16</incoming>
      <incoming>CPE1-PARCLOSE16</incoming>
      <outgoing>PARCLOSE16-PARCLOSE17</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>APFO1-PARCLOSE17</incoming>
      <incoming>PARCLOSE16-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE17-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DV1" sourceRef="Default_init" targetRef="DV1"/>
