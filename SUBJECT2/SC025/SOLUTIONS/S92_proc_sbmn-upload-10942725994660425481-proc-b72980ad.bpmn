    <sequenceFlow id="TPRT1-PARCLOSE15" sourceRef="TPRT1" targetRef="PARCLOSE15"/>
    <sequenceFlow id="STFL1-PARCLOSE15" sourceRef="STFL1" targetRef="PARCLOSE15"/>
    <sequenceFlow id="PARCLOSE15-APFO1" sourceRef="PARCLOSE15" targetRef="APFO1"/>
    <sequenceFlow id="APFO1-PARCLOSE17" sourceRef="APFO1" targetRef="PARCLOSE17"/>
    <sequenceFlow id="PARCLOSE17-END" sourceRef="PARCLOSE17" targetRef="END"/>
  </process>
