    <sequenceFlow id="LC1-Par9" sourceRef="LC1" targetRef="Par9"/>
    <sequenceFlow id="Par9-CLCRM1" sourceRef="Par9" targetRef="CLCRM1"/>
    <sequenceFlow id="Par9-CPE1" sourceRef="Par9" targetRef="CPE1"/>
    <sequenceFlow id="CLCRM1-Par12" sourceRef="CLCRM1" targetRef="Par12"/>
    <sequenceFlow id="CPE1-PARCLOSE17" sourceRef="CPE1" targetRef="PARCLOSE17"/>
    <sequenceFlow id="Par12-TPRT1" sourceRef="Par12" targetRef="TPRT1"/>
