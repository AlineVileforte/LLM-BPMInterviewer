<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_a737716e-9861-4ed7-9d71-29aaa8a8d703" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DCO1</outgoing>
    </startEvent>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>Default_init-DCO1</incoming>
      <outgoing>DCO1-CC1</outgoing>
    </task>
    <task id="CC1" name="Create content">
      <incoming>DCO1-CC1</incoming>
      <outgoing>CC1-DV1</outgoing>
    </task>
    <task id="DV1" name="Design visuals">
      <incoming>CC1-DV1</incoming>
      <outgoing>DV1-SPC1</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>DV1-SPC1</incoming>
      <outgoing>SPC1-LC1</outgoing>
    </task>
    <task id="LC1" name="Launch campaign">
      <incoming>SPC1-LC1</incoming>
      <outgoing>LC1-Par5</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>LC1-Par5</incoming>
      <outgoing>Par5-CLCRM1</outgoing>
      <outgoing>Par5-Par9</outgoing>
    </parallelGateway>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>Par5-CLCRM1</incoming>
      <outgoing>CLCRM1-TPRT1</outgoing>
    </task>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>CLCRM1-TPRT1</incoming>
      <outgoing>TPRT1-G2</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>Par5-Par9</incoming>
      <outgoing>Par9-CPE1</outgoing>
      <outgoing>Par9-G1</outgoing>
    </parallelGateway>
    <task id="CPE1" name="Campaign period ends">
      <incoming>Par9-CPE1</incoming>
      <outgoing>CPE1-PARCLOSE20</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par9-G1</incoming>
      <outgoing>G1-STFL1</outgoing>
      <outgoing>G1-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>G1-STFL1</incoming>
      <outgoing>STFL1-XORCLOSE17</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>TPRT1-G2</incoming>
      <outgoing>G2-APFO1</outgoing>
      <outgoing>G2-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>G2-APFO1</incoming>
      <outgoing>APFO1-XORCLOSE18</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE17" name="XORCLOSE17">
      <incoming>G1-XORCLOSE17</incoming>
      <incoming>STFL1-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-PARCLOSE20</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>G2-XORCLOSE18</incoming>
      <incoming>APFO1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-PARCLOSE21</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE20" name="PARCLOSE20">
      <incoming>CPE1-PARCLOSE20</incoming>
      <incoming>XORCLOSE17-PARCLOSE20</incoming>
      <outgoing>PARCLOSE20-PARCLOSE21</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>XORCLOSE18-PARCLOSE21</incoming>
      <incoming>PARCLOSE20-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE21-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DCO1" sourceRef="Default_init" targetRef="DCO1"/>
    <sequenceFlow id="DCO1-CC1" sourceRef="DCO1" targetRef="CC1"/>
    <sequenceFlow id="CC1-DV1" sourceRef="CC1" targetRef="DV1"/>
    <sequenceFlow id="DV1-SPC1" sourceRef="DV1" targetRef="SPC1"/>
    <sequenceFlow id="SPC1-LC1" sourceRef="SPC1" targetRef="LC1"/>
    <sequenceFlow id="LC1-Par5" sourceRef="LC1" targetRef="Par5"/>
    <sequenceFlow id="Par5-CLCRM1" sourceRef="Par5" targetRef="CLCRM1"/>
    <sequenceFlow id="Par5-Par9" sourceRef="Par5" targetRef="Par9"/>
    <sequenceFlow id="CLCRM1-TPRT1" sourceRef="CLCRM1" targetRef="TPRT1"/>
    <sequenceFlow id="TPRT1-G2" sourceRef="TPRT1" targetRef="G2"/>
    <sequenceFlow id="Par9-CPE1" sourceRef="Par9" targetRef="CPE1"/>
    <sequenceFlow id="Par9-G1" sourceRef="Par9" targetRef="G1"/>
    <sequenceFlow id="CPE1-PARCLOSE20" sourceRef="CPE1" targetRef="PARCLOSE20"/>
    <sequenceFlow id="G1-STFL1" sourceRef="G1" targetRef="STFL1"/>
    <sequenceFlow id="G1-XORCLOSE17" sourceRef="G1" targetRef="XORCLOSE17"/>
    <sequenceFlow id="STFL1-XORCLOSE17" sourceRef="STFL1" targetRef="XORCLOSE17"/>
    <sequenceFlow id="G2-APFO1" sourceRef="G2" targetRef="APFO1"/>
    <sequenceFlow id="G2-XORCLOSE18" sourceRef="G2" targetRef="XORCLOSE18"/>
    <sequenceFlow id="APFO1-XORCLOSE18" sourceRef="APFO1" targetRef="XORCLOSE18"/>
    <sequenceFlow id="XORCLOSE17-PARCLOSE20" sourceRef="XORCLOSE17" targetRef="PARCLOSE20"/>
    <sequenceFlow id="XORCLOSE18-PARCLOSE21" sourceRef="XORCLOSE18" targetRef="PARCLOSE21"/>
    <sequenceFlow id="PARCLOSE20-PARCLOSE21" sourceRef="PARCLOSE20" targetRef="PARCLOSE21"/>
    <sequenceFlow id="PARCLOSE21-END" sourceRef="PARCLOSE21" targetRef="END"/>
  </process>
