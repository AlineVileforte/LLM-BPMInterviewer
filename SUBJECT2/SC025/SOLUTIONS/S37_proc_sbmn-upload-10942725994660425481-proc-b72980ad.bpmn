    <sequenceFlow id="STFL1-PARCLOSE19" sourceRef="STFL1" targetRef="PARCLOSE19"/>
    <sequenceFlow id="PARCLOSE19-END" sourceRef="PARCLOSE19" targetRef="END"/>
  </process>
