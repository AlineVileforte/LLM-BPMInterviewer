<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_6e55cf29-8b83-4128-acbb-fc45481e61f2" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DCO1</outgoing>
    </startEvent>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>Default_init-DCO1</incoming>
      <outgoing>DCO1-CC1</outgoing>
    </task>
    <task id="CC1" name="Create content">
      <incoming>DCO1-CC1</incoming>
      <outgoing>CC1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>CC1-Par3</incoming>
      <outgoing>Par3-DV1</outgoing>
      <outgoing>Par3-SPC1</outgoing>
    </parallelGateway>
    <task id="DV1" name="Design visuals">
      <incoming>Par3-DV1</incoming>
      <outgoing>DV1-PARCLOSE8</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>Par3-SPC1</incoming>
      <outgoing>SPC1-PARCLOSE8</outgoing>
    </task>
    <parallelGateway id="PARCLOSE8" name="PARCLOSE8">
      <incoming>DV1-PARCLOSE8</incoming>
      <incoming>SPC1-PARCLOSE8</incoming>
      <outgoing>PARCLOSE8-LC1</outgoing>
    </parallelGateway>
    <task id="LC1" name="Launch campaign">
      <incoming>PARCLOSE8-LC1</incoming>
      <outgoing>LC1-TPRT1</outgoing>
    </task>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>LC1-TPRT1</incoming>
      <outgoing>TPRT1-Par11</outgoing>
    </task>
    <parallelGateway id="Par11" name="PAR">
      <incoming>TPRT1-Par11</incoming>
      <outgoing>Par11-CLCRM1</outgoing>
      <outgoing>Par11-APFO1</outgoing>
    </parallelGateway>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>Par11-CLCRM1</incoming>
      <outgoing>CLCRM1-CPE1</outgoing>
    </task>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>Par11-APFO1</incoming>
      <outgoing>APFO1-PARCLOSE16</outgoing>
    </task>
    <task id="CPE1" name="Campaign period ends">
      <incoming>CLCRM1-CPE1</incoming>
      <outgoing>CPE1-STFL1</outgoing>
    </task>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>CPE1-STFL1</incoming>
      <outgoing>STFL1-PARCLOSE16</outgoing>
    </task>
    <parallelGateway id="PARCLOSE16" name="PARCLOSE16">
      <incoming>APFO1-PARCLOSE16</incoming>
      <incoming>STFL1-PARCLOSE16</incoming>
      <outgoing>PARCLOSE16-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE16-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DCO1" sourceRef="Default_init" targetRef="DCO1"/>
    <sequenceFlow id="DCO1-CC1" sourceRef="DCO1" targetRef="CC1"/>
    <sequenceFlow id="CC1-Par3" sourceRef="CC1" targetRef="Par3"/>
    <sequenceFlow id="Par3-DV1" sourceRef="Par3" targetRef="DV1"/>
    <sequenceFlow id="Par3-SPC1" sourceRef="Par3" targetRef="SPC1"/>
    <sequenceFlow id="DV1-PARCLOSE8" sourceRef="DV1" targetRef="PARCLOSE8"/>
    <sequenceFlow id="SPC1-PARCLOSE8" sourceRef="SPC1" targetRef="PARCLOSE8"/>
    <sequenceFlow id="PARCLOSE8-LC1" sourceRef="PARCLOSE8" targetRef="LC1"/>
    <sequenceFlow id="LC1-TPRT1" sourceRef="LC1" targetRef="TPRT1"/>
    <sequenceFlow id="TPRT1-Par11" sourceRef="TPRT1" targetRef="Par11"/>
    <sequenceFlow id="Par11-CLCRM1" sourceRef="Par11" targetRef="CLCRM1"/>
    <sequenceFlow id="Par11-APFO1" sourceRef="Par11" targetRef="APFO1"/>
    <sequenceFlow id="CLCRM1-CPE1" sourceRef="CLCRM1" targetRef="CPE1"/>
    <sequenceFlow id="APFO1-PARCLOSE16" sourceRef="APFO1" targetRef="PARCLOSE16"/>
    <sequenceFlow id="CPE1-STFL1" sourceRef="CPE1" targetRef="STFL1"/>
    <sequenceFlow id="STFL1-PARCLOSE16" sourceRef="STFL1" targetRef="PARCLOSE16"/>
    <sequenceFlow id="PARCLOSE16-END" sourceRef="PARCLOSE16" targetRef="END"/>
  </process>
