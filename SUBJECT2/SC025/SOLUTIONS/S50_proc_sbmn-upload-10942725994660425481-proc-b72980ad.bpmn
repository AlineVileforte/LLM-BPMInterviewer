<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_d27764e3-b572-402d-b067-0a8ace1842ea" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DV1</outgoing>
    </startEvent>
    <task id="DV1" name="Design visuals">
      <incoming>Default_init-DV1</incoming>
      <outgoing>DV1-DCO1</outgoing>
    </task>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>DV1-DCO1</incoming>
      <outgoing>DCO1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>DCO1-Par2</incoming>
      <outgoing>Par2-CC1</outgoing>
      <outgoing>Par2-SPC1</outgoing>
    </parallelGateway>
    <task id="CC1" name="Create content">
      <incoming>Par2-CC1</incoming>
      <outgoing>CC1-PARCLOSE9</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>Par2-SPC1</incoming>
      <outgoing>SPC1-PARCLOSE9</outgoing>
    </task>
    <parallelGateway id="PARCLOSE9" name="PARCLOSE9">
      <incoming>CC1-PARCLOSE9</incoming>
      <incoming>SPC1-PARCLOSE9</incoming>
      <outgoing>PARCLOSE9-LC1</outgoing>
    </parallelGateway>
    <task id="LC1" name="Launch campaign">
      <incoming>PARCLOSE9-LC1</incoming>
      <outgoing>LC1-Par11</outgoing>
    </task>
    <parallelGateway id="Par11" name="PAR">
      <incoming>LC1-Par11</incoming>
      <outgoing>Par11-TPRT1</outgoing>
      <outgoing>Par11-CPE1</outgoing>
    </parallelGateway>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>Par11-TPRT1</incoming>
      <outgoing>TPRT1-Par14</outgoing>
    </task>
    <task id="CPE1" name="Campaign period ends">
      <incoming>Par11-CPE1</incoming>
      <outgoing>CPE1-PARCLOSE19</outgoing>
    </task>
    <parallelGateway id="Par14" name="PAR">
      <incoming>TPRT1-Par14</incoming>
      <outgoing>Par14-CLCRM1</outgoing>
      <outgoing>Par14-APFO1</outgoing>
    </parallelGateway>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>Par14-CLCRM1</incoming>
      <outgoing>CLCRM1-PARCLOSE17</outgoing>
    </task>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>Par14-APFO1</incoming>
      <outgoing>APFO1-PARCLOSE17</outgoing>
    </task>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>CLCRM1-PARCLOSE17</incoming>
      <incoming>APFO1-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-STFL1</outgoing>
    </parallelGateway>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>PARCLOSE17-STFL1</incoming>
      <outgoing>STFL1-PARCLOSE19</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>CPE1-PARCLOSE19</incoming>
      <incoming>STFL1-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE19-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DV1" sourceRef="Default_init" targetRef="DV1"/>
