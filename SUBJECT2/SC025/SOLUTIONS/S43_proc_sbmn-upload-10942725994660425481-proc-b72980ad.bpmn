<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_8e20f418-3acd-44f0-8818-776e63cca392" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DCO1</outgoing>
    </startEvent>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>Default_init-DCO1</incoming>
      <outgoing>DCO1-DV1</outgoing>
    </task>
    <task id="DV1" name="Design visuals">
      <incoming>DCO1-DV1</incoming>
      <outgoing>DV1-SPC1</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>DV1-SPC1</incoming>
      <outgoing>SPC1-CC1</outgoing>
    </task>
    <task id="CC1" name="Create content">
      <incoming>SPC1-CC1</incoming>
      <outgoing>CC1-LC1</outgoing>
    </task>
    <task id="LC1" name="Launch campaign">
      <incoming>CC1-LC1</incoming>
      <outgoing>LC1-Par5</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>LC1-Par5</incoming>
      <outgoing>Par5-TPRT1</outgoing>
      <outgoing>Par5-CPE1</outgoing>
    </parallelGateway>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>Par5-TPRT1</incoming>
      <outgoing>TPRT1-CLCRM1</outgoing>
    </task>
    <task id="CPE1" name="Campaign period ends">
      <incoming>Par5-CPE1</incoming>
      <outgoing>CPE1-PARCLOSE14</outgoing>
    </task>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>TPRT1-CLCRM1</incoming>
      <outgoing>CLCRM1-G2</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>CLCRM1-G2</incoming>
      <outgoing>G2-STFL1</outgoing>
      <outgoing>G2-XORCLOSE13</outgoing>
    </exclusiveGateway>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>G2-STFL1</incoming>
      <outgoing>STFL1-XORCLOSE13</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE13" name="XORCLOSE13">
      <incoming>G2-XORCLOSE13</incoming>
      <incoming>STFL1-XORCLOSE13</incoming>
      <outgoing>XORCLOSE13-PARCLOSE14</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE14" name="PARCLOSE14">
      <incoming>CPE1-PARCLOSE14</incoming>
      <incoming>XORCLOSE13-PARCLOSE14</incoming>
      <outgoing>PARCLOSE14-APFO1</outgoing>
    </parallelGateway>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>PARCLOSE14-APFO1</incoming>
      <outgoing>APFO1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>APFO1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DCO1" sourceRef="Default_init" targetRef="DCO1"/>
    <sequenceFlow id="DCO1-DV1" sourceRef="DCO1" targetRef="DV1"/>
    <sequenceFlow id="DV1-SPC1" sourceRef="DV1" targetRef="SPC1"/>
    <sequenceFlow id="SPC1-CC1" sourceRef="SPC1" targetRef="CC1"/>
    <sequenceFlow id="CC1-LC1" sourceRef="CC1" targetRef="LC1"/>
    <sequenceFlow id="LC1-Par5" sourceRef="LC1" targetRef="Par5"/>
    <sequenceFlow id="Par5-TPRT1" sourceRef="Par5" targetRef="TPRT1"/>
    <sequenceFlow id="Par5-CPE1" sourceRef="Par5" targetRef="CPE1"/>
    <sequenceFlow id="TPRT1-CLCRM1" sourceRef="TPRT1" targetRef="CLCRM1"/>
    <sequenceFlow id="CPE1-PARCLOSE14" sourceRef="CPE1" targetRef="PARCLOSE14"/>
    <sequenceFlow id="CLCRM1-G2" sourceRef="CLCRM1" targetRef="G2"/>
    <sequenceFlow id="G2-STFL1" sourceRef="G2" targetRef="STFL1"/>
    <sequenceFlow id="G2-XORCLOSE13" sourceRef="G2" targetRef="XORCLOSE13"/>
    <sequenceFlow id="STFL1-XORCLOSE13" sourceRef="STFL1" targetRef="XORCLOSE13"/>
    <sequenceFlow id="XORCLOSE13-PARCLOSE14" sourceRef="XORCLOSE13" targetRef="PARCLOSE14"/>
    <sequenceFlow id="PARCLOSE14-APFO1" sourceRef="PARCLOSE14" targetRef="APFO1"/>
    <sequenceFlow id="APFO1-END" sourceRef="APFO1" targetRef="END"/>
  </process>
