<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_5920535b-6cef-4231-a497-e67d484d626d" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-DCO1</outgoing>
      <outgoing>Par0-DV1</outgoing>
    </parallelGateway>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>Par0-DCO1</incoming>
      <outgoing>DCO1-SPC1</outgoing>
    </task>
    <task id="DV1" name="Design visuals">
      <incoming>Par0-DV1</incoming>
      <outgoing>DV1-PARCLOSE9</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>DCO1-SPC1</incoming>
      <outgoing>SPC1-CC1</outgoing>
    </task>
    <task id="CC1" name="Create content">
      <incoming>SPC1-CC1</incoming>
      <outgoing>CC1-PARCLOSE9</outgoing>
    </task>
    <parallelGateway id="PARCLOSE9" name="PARCLOSE9">
      <incoming>DV1-PARCLOSE9</incoming>
      <incoming>CC1-PARCLOSE9</incoming>
      <outgoing>PARCLOSE9-LC1</outgoing>
    </parallelGateway>
    <task id="LC1" name="Launch campaign">
      <incoming>PARCLOSE9-LC1</incoming>
      <outgoing>LC1-CLCRM1</outgoing>
    </task>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>LC1-CLCRM1</incoming>
      <outgoing>CLCRM1-Par12</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>CLCRM1-Par12</incoming>
      <outgoing>Par12-TPRT1</outgoing>
      <outgoing>Par12-CPE1</outgoing>
    </parallelGateway>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>Par12-TPRT1</incoming>
      <outgoing>TPRT1-STFL1</outgoing>
    </task>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>TPRT1-STFL1</incoming>
      <outgoing>STFL1-APFO1</outgoing>
    </task>
    <task id="CPE1" name="Campaign period ends">
      <incoming>Par12-CPE1</incoming>
      <outgoing>CPE1-PARCLOSE19</outgoing>
    </task>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>STFL1-APFO1</incoming>
      <outgoing>APFO1-PARCLOSE19</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>CPE1-PARCLOSE19</incoming>
      <incoming>APFO1-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE19-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
    <sequenceFlow id="Par0-DCO1" sourceRef="Par0" targetRef="DCO1"/>
    <sequenceFlow id="Par0-DV1" sourceRef="Par0" targetRef="DV1"/>
    <sequenceFlow id="DCO1-SPC1" sourceRef="DCO1" targetRef="SPC1"/>
    <sequenceFlow id="DV1-PARCLOSE9" sourceRef="DV1" targetRef="PARCLOSE9"/>
    <sequenceFlow id="SPC1-CC1" sourceRef="SPC1" targetRef="CC1"/>
    <sequenceFlow id="CC1-PARCLOSE9" sourceRef="CC1" targetRef="PARCLOSE9"/>
    <sequenceFlow id="PARCLOSE9-LC1" sourceRef="PARCLOSE9" targetRef="LC1"/>
    <sequenceFlow id="LC1-CLCRM1" sourceRef="LC1" targetRef="CLCRM1"/>
    <sequenceFlow id="CLCRM1-Par12" sourceRef="CLCRM1" targetRef="Par12"/>
    <sequenceFlow id="Par12-TPRT1" sourceRef="Par12" targetRef="TPRT1"/>
    <sequenceFlow id="Par12-CPE1" sourceRef="Par12" targetRef="CPE1"/>
    <sequenceFlow id="TPRT1-STFL1" sourceRef="TPRT1" targetRef="STFL1"/>
    <sequenceFlow id="STFL1-APFO1" sourceRef="STFL1" targetRef="APFO1"/>
    <sequenceFlow id="CPE1-PARCLOSE19" sourceRef="CPE1" targetRef="PARCLOSE19"/>
    <sequenceFlow id="APFO1-PARCLOSE19" sourceRef="APFO1" targetRef="PARCLOSE19"/>
    <sequenceFlow id="PARCLOSE19-END" sourceRef="PARCLOSE19" targetRef="END"/>
  </process>
