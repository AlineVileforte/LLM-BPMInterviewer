    <sequenceFlow id="PARCLOSE11-LC1" sourceRef="PARCLOSE11" targetRef="LC1"/>
    <sequenceFlow id="LC1-Par13" sourceRef="LC1" targetRef="Par13"/>
    <sequenceFlow id="Par13-CLCRM1" sourceRef="Par13" targetRef="CLCRM1"/>
    <sequenceFlow id="Par13-Par16" sourceRef="Par13" targetRef="Par16"/>
    <sequenceFlow id="CLCRM1-TPRT1" sourceRef="CLCRM1" targetRef="TPRT1"/>
    <sequenceFlow id="TPRT1-APFO1" sourceRef="TPRT1" targetRef="APFO1"/>
    <sequenceFlow id="Par16-STFL1" sourceRef="Par16" targetRef="STFL1"/>
    <sequenceFlow id="Par16-CPE1" sourceRef="Par16" targetRef="CPE1"/>
    <sequenceFlow id="STFL1-PARCLOSE20" sourceRef="STFL1" targetRef="PARCLOSE20"/>
    <sequenceFlow id="CPE1-PARCLOSE20" sourceRef="CPE1" targetRef="PARCLOSE20"/>
    <sequenceFlow id="APFO1-PARCLOSE21" sourceRef="APFO1" targetRef="PARCLOSE21"/>
    <sequenceFlow id="PARCLOSE20-PARCLOSE21" sourceRef="PARCLOSE20" targetRef="PARCLOSE21"/>
    <sequenceFlow id="PARCLOSE21-END" sourceRef="PARCLOSE21" targetRef="END"/>
  </process>
