    <sequenceFlow id="Par6-CPE1" sourceRef="Par6" targetRef="CPE1"/>
    <sequenceFlow id="Par6-G0" sourceRef="Par6" targetRef="G0"/>
    <sequenceFlow id="CPE1-CLCRM1" sourceRef="CPE1" targetRef="CLCRM1"/>
    <sequenceFlow id="G0-APFO1" sourceRef="G0" targetRef="APFO1"/>
    <sequenceFlow id="G0-XORCLOSE12" sourceRef="G0" targetRef="XORCLOSE12"/>
    <sequenceFlow id="APFO1-XORCLOSE12" sourceRef="APFO1" targetRef="XORCLOSE12"/>
    <sequenceFlow id="CLCRM1-G1" sourceRef="CLCRM1" targetRef="G1"/>
    <sequenceFlow id="XORCLOSE12-PARCLOSE17" sourceRef="XORCLOSE12" targetRef="PARCLOSE17"/>
    <sequenceFlow id="G1-STFL1" sourceRef="G1" targetRef="STFL1"/>
    <sequenceFlow id="G1-XORCLOSE16" sourceRef="G1" targetRef="XORCLOSE16"/>
    <sequenceFlow id="STFL1-XORCLOSE16" sourceRef="STFL1" targetRef="XORCLOSE16"/>
    <sequenceFlow id="XORCLOSE16-PARCLOSE17" sourceRef="XORCLOSE16" targetRef="PARCLOSE17"/>
    <sequenceFlow id="PARCLOSE17-END" sourceRef="PARCLOSE17" targetRef="END"/>
  </process>
