<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_7c7e2e80-140b-4202-a20f-b9ac201e2985" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DV1</outgoing>
    </startEvent>
    <task id="DV1" name="Design visuals">
      <incoming>Default_init-DV1</incoming>
      <outgoing>DV1-DCO1</outgoing>
    </task>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>DV1-DCO1</incoming>
      <outgoing>DCO1-SPC1</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>DCO1-SPC1</incoming>
      <outgoing>SPC1-CC1</outgoing>
    </task>
    <task id="CC1" name="Create content">
      <incoming>SPC1-CC1</incoming>
      <outgoing>CC1-LC1</outgoing>
    </task>
    <task id="LC1" name="Launch campaign">
      <incoming>CC1-LC1</incoming>
      <outgoing>LC1-Par5</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>LC1-Par5</incoming>
      <outgoing>Par5-TPRT1</outgoing>
      <outgoing>Par5-CPE1</outgoing>
    </parallelGateway>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>Par5-TPRT1</incoming>
      <outgoing>TPRT1-CLCRM1</outgoing>
    </task>
    <task id="CPE1" name="Campaign period ends">
      <incoming>Par5-CPE1</incoming>
      <outgoing>CPE1-PARCLOSE20</outgoing>
    </task>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>TPRT1-CLCRM1</incoming>
      <outgoing>CLCRM1-Par10</outgoing>
    </task>
    <parallelGateway id="Par10" name="PAR">
      <incoming>CLCRM1-Par10</incoming>
      <outgoing>Par10-G1</outgoing>
      <outgoing>Par10-G2</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par10-G1</incoming>
      <outgoing>G1-APFO1</outgoing>
      <outgoing>G1-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>G1-APFO1</incoming>
      <outgoing>APFO1-XORCLOSE17</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par10-G2</incoming>
      <outgoing>G2-STFL1</outgoing>
      <outgoing>G2-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>G2-STFL1</incoming>
      <outgoing>STFL1-XORCLOSE18</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE17" name="XORCLOSE17">
      <incoming>G1-XORCLOSE17</incoming>
      <incoming>APFO1-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-PARCLOSE19</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>G2-XORCLOSE18</incoming>
      <incoming>STFL1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-PARCLOSE19</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>XORCLOSE17-PARCLOSE19</incoming>
      <incoming>XORCLOSE18-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-PARCLOSE20</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE20" name="PARCLOSE20">
      <incoming>CPE1-PARCLOSE20</incoming>
      <incoming>PARCLOSE19-PARCLOSE20</incoming>
      <outgoing>PARCLOSE20-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE20-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DV1" sourceRef="Default_init" targetRef="DV1"/>
    <sequenceFlow id="DV1-DCO1" sourceRef="DV1" targetRef="DCO1"/>
    <sequenceFlow id="DCO1-SPC1" sourceRef="DCO1" targetRef="SPC1"/>
    <sequenceFlow id="SPC1-CC1" sourceRef="SPC1" targetRef="CC1"/>
    <sequenceFlow id="CC1-LC1" sourceRef="CC1" targetRef="LC1"/>
    <sequenceFlow id="LC1-Par5" sourceRef="LC1" targetRef="Par5"/>
    <sequenceFlow id="Par5-TPRT1" sourceRef="Par5" targetRef="TPRT1"/>
    <sequenceFlow id="Par5-CPE1" sourceRef="Par5" targetRef="CPE1"/>
    <sequenceFlow id="TPRT1-CLCRM1" sourceRef="TPRT1" targetRef="CLCRM1"/>
    <sequenceFlow id="CPE1-PARCLOSE20" sourceRef="CPE1" targetRef="PARCLOSE20"/>
    <sequenceFlow id="CLCRM1-Par10" sourceRef="CLCRM1" targetRef="Par10"/>
    <sequenceFlow id="Par10-G1" sourceRef="Par10" targetRef="G1"/>
    <sequenceFlow id="Par10-G2" sourceRef="Par10" targetRef="G2"/>
    <sequenceFlow id="G1-APFO1" sourceRef="G1" targetRef="APFO1"/>
    <sequenceFlow id="G1-XORCLOSE17" sourceRef="G1" targetRef="XORCLOSE17"/>
    <sequenceFlow id="APFO1-XORCLOSE17" sourceRef="APFO1" targetRef="XORCLOSE17"/>
    <sequenceFlow id="G2-STFL1" sourceRef="G2" targetRef="STFL1"/>
    <sequenceFlow id="G2-XORCLOSE18" sourceRef="G2" targetRef="XORCLOSE18"/>
    <sequenceFlow id="STFL1-XORCLOSE18" sourceRef="STFL1" targetRef="XORCLOSE18"/>
    <sequenceFlow id="XORCLOSE17-PARCLOSE19" sourceRef="XORCLOSE17" targetRef="PARCLOSE19"/>
    <sequenceFlow id="XORCLOSE18-PARCLOSE19" sourceRef="XORCLOSE18" targetRef="PARCLOSE19"/>
    <sequenceFlow id="PARCLOSE19-PARCLOSE20" sourceRef="PARCLOSE19" targetRef="PARCLOSE20"/>
    <sequenceFlow id="PARCLOSE20-END" sourceRef="PARCLOSE20" targetRef="END"/>
  </process>
