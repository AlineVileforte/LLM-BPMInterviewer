    <sequenceFlow id="Par9-CPE1" sourceRef="Par9" targetRef="CPE1"/>
    <sequenceFlow id="Par9-G0" sourceRef="Par9" targetRef="G0"/>
    <sequenceFlow id="CPE1-PARCLOSE19" sourceRef="CPE1" targetRef="PARCLOSE19"/>
    <sequenceFlow id="G0-APFO1" sourceRef="G0" targetRef="APFO1"/>
    <sequenceFlow id="G0-XORCLOSE15" sourceRef="G0" targetRef="XORCLOSE15"/>
    <sequenceFlow id="APFO1-XORCLOSE15" sourceRef="APFO1" targetRef="XORCLOSE15"/>
    <sequenceFlow id="CLCRM1-G1" sourceRef="CLCRM1" targetRef="G1"/>
    <sequenceFlow id="XORCLOSE15-PARCLOSE19" sourceRef="XORCLOSE15" targetRef="PARCLOSE19"/>
    <sequenceFlow id="G1-STFL1" sourceRef="G1" targetRef="STFL1"/>
    <sequenceFlow id="G1-XORCLOSE20" sourceRef="G1" targetRef="XORCLOSE20"/>
    <sequenceFlow id="STFL1-XORCLOSE20" sourceRef="STFL1" targetRef="XORCLOSE20"/>
    <sequenceFlow id="PARCLOSE19-PARCLOSE21" sourceRef="PARCLOSE19" targetRef="PARCLOSE21"/>
    <sequenceFlow id="XORCLOSE20-PARCLOSE21" sourceRef="XORCLOSE20" targetRef="PARCLOSE21"/>
    <sequenceFlow id="PARCLOSE21-END" sourceRef="PARCLOSE21" targetRef="END"/>
  </process>
