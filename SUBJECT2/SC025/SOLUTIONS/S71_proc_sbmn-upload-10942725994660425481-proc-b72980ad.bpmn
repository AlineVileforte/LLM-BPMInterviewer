<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_cc234c0b-b145-4d11-b0df-7ff7dad95da3" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DCO1</outgoing>
    </startEvent>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>Default_init-DCO1</incoming>
      <outgoing>DCO1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>DCO1-Par1</incoming>
      <outgoing>Par1-DV1</outgoing>
      <outgoing>Par1-CC1</outgoing>
    </parallelGateway>
    <task id="DV1" name="Design visuals">
      <incoming>Par1-DV1</incoming>
      <outgoing>DV1-SPC1</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>DV1-SPC1</incoming>
      <outgoing>SPC1-PARCLOSE5</outgoing>
    </task>
    <task id="CC1" name="Create content">
      <incoming>Par1-CC1</incoming>
      <outgoing>CC1-PARCLOSE5</outgoing>
    </task>
    <parallelGateway id="PARCLOSE5" name="PARCLOSE5">
      <incoming>SPC1-PARCLOSE5</incoming>
      <incoming>CC1-PARCLOSE5</incoming>
      <outgoing>PARCLOSE5-LC1</outgoing>
    </parallelGateway>
    <task id="LC1" name="Launch campaign">
      <incoming>PARCLOSE5-LC1</incoming>
      <outgoing>LC1-Par7</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>LC1-Par7</incoming>
      <outgoing>Par7-TPRT1</outgoing>
      <outgoing>Par7-CLCRM1</outgoing>
    </parallelGateway>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>Par7-TPRT1</incoming>
      <outgoing>TPRT1-Par9</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>TPRT1-Par9</incoming>
      <outgoing>Par9-CPE1</outgoing>
      <outgoing>Par9-G0</outgoing>
    </parallelGateway>
    <task id="CPE1" name="Campaign period ends">
      <incoming>Par9-CPE1</incoming>
      <outgoing>CPE1-PARCLOSE19</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par9-G0</incoming>
      <outgoing>G0-APFO1</outgoing>
      <outgoing>G0-XORCLOSE15</outgoing>
    </exclusiveGateway>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>G0-APFO1</incoming>
      <outgoing>APFO1-XORCLOSE15</outgoing>
    </task>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>Par7-CLCRM1</incoming>
      <outgoing>CLCRM1-G1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE15" name="XORCLOSE15">
      <incoming>G0-XORCLOSE15</incoming>
      <incoming>APFO1-XORCLOSE15</incoming>
      <outgoing>XORCLOSE15-PARCLOSE19</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G1" name="G1">
      <incoming>CLCRM1-G1</incoming>
      <outgoing>G1-STFL1</outgoing>
      <outgoing>G1-XORCLOSE20</outgoing>
    </exclusiveGateway>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>G1-STFL1</incoming>
      <outgoing>STFL1-XORCLOSE20</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>CPE1-PARCLOSE19</incoming>
      <incoming>XORCLOSE15-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-PARCLOSE21</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>G1-XORCLOSE20</incoming>
      <incoming>STFL1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-PARCLOSE21</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>PARCLOSE19-PARCLOSE21</incoming>
      <incoming>XORCLOSE20-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE21-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DCO1" sourceRef="Default_init" targetRef="DCO1"/>
    <sequenceFlow id="DCO1-Par1" sourceRef="DCO1" targetRef="Par1"/>
    <sequenceFlow id="Par1-DV1" sourceRef="Par1" targetRef="DV1"/>
