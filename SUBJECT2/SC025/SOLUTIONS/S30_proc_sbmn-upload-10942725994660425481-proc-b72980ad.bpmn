<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_189a98a7-493f-4510-b5e5-99e6847a6119" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DV1</outgoing>
    </startEvent>
    <task id="DV1" name="Design visuals">
      <incoming>Default_init-DV1</incoming>
      <outgoing>DV1-DCO1</outgoing>
    </task>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>DV1-DCO1</incoming>
      <outgoing>DCO1-SPC1</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>DCO1-SPC1</incoming>
      <outgoing>SPC1-CC1</outgoing>
    </task>
    <task id="CC1" name="Create content">
      <incoming>SPC1-CC1</incoming>
      <outgoing>CC1-LC1</outgoing>
    </task>
    <task id="LC1" name="Launch campaign">
      <incoming>CC1-LC1</incoming>
      <outgoing>LC1-TPRT1</outgoing>
    </task>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>LC1-TPRT1</incoming>
      <outgoing>TPRT1-Par6</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>TPRT1-Par6</incoming>
      <outgoing>Par6-CPE1</outgoing>
      <outgoing>Par6-G2</outgoing>
    </parallelGateway>
    <task id="CPE1" name="Campaign period ends">
      <incoming>Par6-CPE1</incoming>
      <outgoing>CPE1-CLCRM1</outgoing>
    </task>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>CPE1-CLCRM1</incoming>
      <outgoing>CLCRM1-G3</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par6-G2</incoming>
      <outgoing>G2-APFO1</outgoing>
      <outgoing>G2-XORCLOSE15</outgoing>
    </exclusiveGateway>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>G2-APFO1</incoming>
      <outgoing>APFO1-XORCLOSE15</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>CLCRM1-G3</incoming>
      <outgoing>G3-STFL1</outgoing>
      <outgoing>G3-XORCLOSE16</outgoing>
    </exclusiveGateway>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>G3-STFL1</incoming>
      <outgoing>STFL1-XORCLOSE16</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE15" name="XORCLOSE15">
      <incoming>G2-XORCLOSE15</incoming>
      <incoming>APFO1-XORCLOSE15</incoming>
      <outgoing>XORCLOSE15-PARCLOSE17</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
      <incoming>G3-XORCLOSE16</incoming>
      <incoming>STFL1-XORCLOSE16</incoming>
      <outgoing>XORCLOSE16-PARCLOSE17</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>XORCLOSE15-PARCLOSE17</incoming>
      <incoming>XORCLOSE16-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE17-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DV1" sourceRef="Default_init" targetRef="DV1"/>
    <sequenceFlow id="DV1-DCO1" sourceRef="DV1" targetRef="DCO1"/>
    <sequenceFlow id="DCO1-SPC1" sourceRef="DCO1" targetRef="SPC1"/>
    <sequenceFlow id="SPC1-CC1" sourceRef="SPC1" targetRef="CC1"/>
    <sequenceFlow id="CC1-LC1" sourceRef="CC1" targetRef="LC1"/>
    <sequenceFlow id="LC1-TPRT1" sourceRef="LC1" targetRef="TPRT1"/>
    <sequenceFlow id="TPRT1-Par6" sourceRef="TPRT1" targetRef="Par6"/>
    <sequenceFlow id="Par6-CPE1" sourceRef="Par6" targetRef="CPE1"/>
    <sequenceFlow id="Par6-G2" sourceRef="Par6" targetRef="G2"/>
    <sequenceFlow id="CPE1-CLCRM1" sourceRef="CPE1" targetRef="CLCRM1"/>
    <sequenceFlow id="CLCRM1-G3" sourceRef="CLCRM1" targetRef="G3"/>
    <sequenceFlow id="G2-APFO1" sourceRef="G2" targetRef="APFO1"/>
    <sequenceFlow id="G2-XORCLOSE15" sourceRef="G2" targetRef="XORCLOSE15"/>
    <sequenceFlow id="APFO1-XORCLOSE15" sourceRef="APFO1" targetRef="XORCLOSE15"/>
    <sequenceFlow id="G3-STFL1" sourceRef="G3" targetRef="STFL1"/>
    <sequenceFlow id="G3-XORCLOSE16" sourceRef="G3" targetRef="XORCLOSE16"/>
    <sequenceFlow id="STFL1-XORCLOSE16" sourceRef="STFL1" targetRef="XORCLOSE16"/>
    <sequenceFlow id="XORCLOSE15-PARCLOSE17" sourceRef="XORCLOSE15" targetRef="PARCLOSE17"/>
    <sequenceFlow id="XORCLOSE16-PARCLOSE17" sourceRef="XORCLOSE16" targetRef="PARCLOSE17"/>
    <sequenceFlow id="PARCLOSE17-END" sourceRef="PARCLOSE17" targetRef="END"/>
  </process>
