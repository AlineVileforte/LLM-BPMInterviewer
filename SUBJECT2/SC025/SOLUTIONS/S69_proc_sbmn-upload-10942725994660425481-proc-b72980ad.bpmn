<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_b79ddc9b-7481-4703-8d7f-516d923241db" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DV1</outgoing>
    </startEvent>
    <task id="DV1" name="Design visuals">
      <incoming>Default_init-DV1</incoming>
      <outgoing>DV1-DCO1</outgoing>
    </task>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>DV1-DCO1</incoming>
      <outgoing>DCO1-SPC1</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>DCO1-SPC1</incoming>
      <outgoing>SPC1-CC1</outgoing>
    </task>
    <task id="CC1" name="Create content">
      <incoming>SPC1-CC1</incoming>
      <outgoing>CC1-LC1</outgoing>
    </task>
    <task id="LC1" name="Launch campaign">
      <incoming>CC1-LC1</incoming>
      <outgoing>LC1-TPRT1</outgoing>
    </task>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>LC1-TPRT1</incoming>
      <outgoing>TPRT1-Par6</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>TPRT1-Par6</incoming>
      <outgoing>Par6-CLCRM1</outgoing>
      <outgoing>Par6-G3</outgoing>
    </parallelGateway>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>Par6-CLCRM1</incoming>
      <outgoing>CLCRM1-Par8</outgoing>
    </task>
    <parallelGateway id="Par8" name="PAR">
      <incoming>CLCRM1-Par8</incoming>
      <outgoing>Par8-CPE1</outgoing>
      <outgoing>Par8-G1</outgoing>
    </parallelGateway>
    <task id="CPE1" name="Campaign period ends">
      <incoming>Par8-CPE1</incoming>
      <outgoing>CPE1-PARCLOSE18</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par8-G1</incoming>
      <outgoing>G1-APFO1</outgoing>
      <outgoing>G1-XORCLOSE16</outgoing>
    </exclusiveGateway>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>G1-APFO1</incoming>
      <outgoing>APFO1-XORCLOSE16</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>Par6-G3</incoming>
      <outgoing>G3-STFL1</outgoing>
      <outgoing>G3-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>G3-STFL1</incoming>
      <outgoing>STFL1-XORCLOSE17</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
      <incoming>G1-XORCLOSE16</incoming>
      <incoming>APFO1-XORCLOSE16</incoming>
      <outgoing>XORCLOSE16-PARCLOSE18</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE17" name="XORCLOSE17">
      <incoming>G3-XORCLOSE17</incoming>
      <incoming>STFL1-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-PARCLOSE19</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>CPE1-PARCLOSE18</incoming>
      <incoming>XORCLOSE16-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-PARCLOSE19</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>XORCLOSE17-PARCLOSE19</incoming>
      <incoming>PARCLOSE18-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE19-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DV1" sourceRef="Default_init" targetRef="DV1"/>
    <sequenceFlow id="DV1-DCO1" sourceRef="DV1" targetRef="DCO1"/>
    <sequenceFlow id="DCO1-SPC1" sourceRef="DCO1" targetRef="SPC1"/>
    <sequenceFlow id="SPC1-CC1" sourceRef="SPC1" targetRef="CC1"/>
    <sequenceFlow id="CC1-LC1" sourceRef="CC1" targetRef="LC1"/>
    <sequenceFlow id="LC1-TPRT1" sourceRef="LC1" targetRef="TPRT1"/>
    <sequenceFlow id="TPRT1-Par6" sourceRef="TPRT1" targetRef="Par6"/>
    <sequenceFlow id="Par6-CLCRM1" sourceRef="Par6" targetRef="CLCRM1"/>
    <sequenceFlow id="Par6-G3" sourceRef="Par6" targetRef="G3"/>
    <sequenceFlow id="CLCRM1-Par8" sourceRef="CLCRM1" targetRef="Par8"/>
    <sequenceFlow id="Par8-CPE1" sourceRef="Par8" targetRef="CPE1"/>
    <sequenceFlow id="Par8-G1" sourceRef="Par8" targetRef="G1"/>
    <sequenceFlow id="CPE1-PARCLOSE18" sourceRef="CPE1" targetRef="PARCLOSE18"/>
    <sequenceFlow id="G1-APFO1" sourceRef="G1" targetRef="APFO1"/>
    <sequenceFlow id="G1-XORCLOSE16" sourceRef="G1" targetRef="XORCLOSE16"/>
    <sequenceFlow id="APFO1-XORCLOSE16" sourceRef="APFO1" targetRef="XORCLOSE16"/>
    <sequenceFlow id="G3-STFL1" sourceRef="G3" targetRef="STFL1"/>
    <sequenceFlow id="G3-XORCLOSE17" sourceRef="G3" targetRef="XORCLOSE17"/>
    <sequenceFlow id="STFL1-XORCLOSE17" sourceRef="STFL1" targetRef="XORCLOSE17"/>
    <sequenceFlow id="XORCLOSE16-PARCLOSE18" sourceRef="XORCLOSE16" targetRef="PARCLOSE18"/>
    <sequenceFlow id="XORCLOSE17-PARCLOSE19" sourceRef="XORCLOSE17" targetRef="PARCLOSE19"/>
    <sequenceFlow id="PARCLOSE18-PARCLOSE19" sourceRef="PARCLOSE18" targetRef="PARCLOSE19"/>
    <sequenceFlow id="PARCLOSE19-END" sourceRef="PARCLOSE19" targetRef="END"/>
  </process>
