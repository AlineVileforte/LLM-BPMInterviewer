    <sequenceFlow id="CPE1-CLCRM1" sourceRef="CPE1" targetRef="CLCRM1"/>
    <sequenceFlow id="CLCRM1-G0" sourceRef="CLCRM1" targetRef="G0"/>
    <sequenceFlow id="TPRT1-G1" sourceRef="TPRT1" targetRef="G1"/>
    <sequenceFlow id="G0-STFL1" sourceRef="G0" targetRef="STFL1"/>
    <sequenceFlow id="G0-XORCLOSE15" sourceRef="G0" targetRef="XORCLOSE15"/>
    <sequenceFlow id="STFL1-XORCLOSE15" sourceRef="STFL1" targetRef="XORCLOSE15"/>
    <sequenceFlow id="G1-APFO1" sourceRef="G1" targetRef="APFO1"/>
    <sequenceFlow id="G1-XORCLOSE16" sourceRef="G1" targetRef="XORCLOSE16"/>
    <sequenceFlow id="APFO1-XORCLOSE16" sourceRef="APFO1" targetRef="XORCLOSE16"/>
    <sequenceFlow id="XORCLOSE15-PARCLOSE17" sourceRef="XORCLOSE15" targetRef="PARCLOSE17"/>
    <sequenceFlow id="XORCLOSE16-PARCLOSE17" sourceRef="XORCLOSE16" targetRef="PARCLOSE17"/>
    <sequenceFlow id="PARCLOSE17-END" sourceRef="PARCLOSE17" targetRef="END"/>
  </process>
