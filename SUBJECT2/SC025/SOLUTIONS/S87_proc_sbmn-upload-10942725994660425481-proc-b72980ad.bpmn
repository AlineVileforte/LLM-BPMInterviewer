<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_dc21dd4a-6048-4603-bc74-8972ac7a1df0" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DCO1</outgoing>
    </startEvent>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>Default_init-DCO1</incoming>
      <outgoing>DCO1-SPC1</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>DCO1-SPC1</incoming>
      <outgoing>SPC1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>SPC1-Par3</incoming>
      <outgoing>Par3-CC1</outgoing>
      <outgoing>Par3-DV1</outgoing>
    </parallelGateway>
    <task id="CC1" name="Create content">
      <incoming>Par3-CC1</incoming>
      <outgoing>CC1-PARCLOSE10</outgoing>
    </task>
    <task id="DV1" name="Design visuals">
      <incoming>Par3-DV1</incoming>
      <outgoing>DV1-PARCLOSE10</outgoing>
    </task>
    <parallelGateway id="PARCLOSE10" name="PARCLOSE10">
      <incoming>CC1-PARCLOSE10</incoming>
      <incoming>DV1-PARCLOSE10</incoming>
      <outgoing>PARCLOSE10-LC1</outgoing>
    </parallelGateway>
    <task id="LC1" name="Launch campaign">
      <incoming>PARCLOSE10-LC1</incoming>
      <outgoing>LC1-Par13</outgoing>
    </task>
    <parallelGateway id="Par13" name="PAR">
      <incoming>LC1-Par13</incoming>
      <outgoing>Par13-CLCRM1</outgoing>
      <outgoing>Par13-TPRT1</outgoing>
    </parallelGateway>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>Par13-CLCRM1</incoming>
      <outgoing>CLCRM1-STFL1</outgoing>
    </task>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>CLCRM1-STFL1</incoming>
      <outgoing>STFL1-CPE1</outgoing>
    </task>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>Par13-TPRT1</incoming>
      <outgoing>TPRT1-APFO1</outgoing>
    </task>
    <task id="CPE1" name="Campaign period ends">
      <incoming>STFL1-CPE1</incoming>
      <outgoing>CPE1-PARCLOSE19</outgoing>
    </task>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>TPRT1-APFO1</incoming>
      <outgoing>APFO1-PARCLOSE19</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>CPE1-PARCLOSE19</incoming>
      <incoming>APFO1-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE19-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DCO1" sourceRef="Default_init" targetRef="DCO1"/>
    <sequenceFlow id="DCO1-SPC1" sourceRef="DCO1" targetRef="SPC1"/>
    <sequenceFlow id="SPC1-Par3" sourceRef="SPC1" targetRef="Par3"/>
    <sequenceFlow id="Par3-CC1" sourceRef="Par3" targetRef="CC1"/>
    <sequenceFlow id="Par3-DV1" sourceRef="Par3" targetRef="DV1"/>
    <sequenceFlow id="CC1-PARCLOSE10" sourceRef="CC1" targetRef="PARCLOSE10"/>
    <sequenceFlow id="DV1-PARCLOSE10" sourceRef="DV1" targetRef="PARCLOSE10"/>
    <sequenceFlow id="PARCLOSE10-LC1" sourceRef="PARCLOSE10" targetRef="LC1"/>
    <sequenceFlow id="LC1-Par13" sourceRef="LC1" targetRef="Par13"/>
    <sequenceFlow id="Par13-CLCRM1" sourceRef="Par13" targetRef="CLCRM1"/>
    <sequenceFlow id="Par13-TPRT1" sourceRef="Par13" targetRef="TPRT1"/>
    <sequenceFlow id="CLCRM1-STFL1" sourceRef="CLCRM1" targetRef="STFL1"/>
    <sequenceFlow id="STFL1-CPE1" sourceRef="STFL1" targetRef="CPE1"/>
    <sequenceFlow id="TPRT1-APFO1" sourceRef="TPRT1" targetRef="APFO1"/>
    <sequenceFlow id="CPE1-PARCLOSE19" sourceRef="CPE1" targetRef="PARCLOSE19"/>
    <sequenceFlow id="APFO1-PARCLOSE19" sourceRef="APFO1" targetRef="PARCLOSE19"/>
    <sequenceFlow id="PARCLOSE19-END" sourceRef="PARCLOSE19" targetRef="END"/>
  </process>
