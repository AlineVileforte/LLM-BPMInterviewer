    <sequenceFlow id="Par8-CPE1" sourceRef="Par8" targetRef="CPE1"/>
    <sequenceFlow id="CLCRM1-G2" sourceRef="CLCRM1" targetRef="G2"/>
    <sequenceFlow id="CPE1-PARCLOSE20" sourceRef="CPE1" targetRef="PARCLOSE20"/>
    <sequenceFlow id="G1-APFO1" sourceRef="G1" targetRef="APFO1"/>
    <sequenceFlow id="G1-XORCLOSE18" sourceRef="G1" targetRef="XORCLOSE18"/>
    <sequenceFlow id="APFO1-XORCLOSE18" sourceRef="APFO1" targetRef="XORCLOSE18"/>
    <sequenceFlow id="G2-STFL1" sourceRef="G2" targetRef="STFL1"/>
    <sequenceFlow id="G2-XORCLOSE19" sourceRef="G2" targetRef="XORCLOSE19"/>
    <sequenceFlow id="STFL1-XORCLOSE19" sourceRef="STFL1" targetRef="XORCLOSE19"/>
    <sequenceFlow id="XORCLOSE18-PARCLOSE21" sourceRef="XORCLOSE18" targetRef="PARCLOSE21"/>
    <sequenceFlow id="XORCLOSE19-PARCLOSE20" sourceRef="XORCLOSE19" targetRef="PARCLOSE20"/>
    <sequenceFlow id="PARCLOSE20-PARCLOSE21" sourceRef="PARCLOSE20" targetRef="PARCLOSE21"/>
    <sequenceFlow id="PARCLOSE21-PARCLOSE22" sourceRef="PARCLOSE21" targetRef="PARCLOSE22"/>
    <sequenceFlow id="PARCLOSE22-END" sourceRef="PARCLOSE22" targetRef="END"/>
  </process>
