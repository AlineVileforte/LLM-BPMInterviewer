<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_d3d3660f-95df-4fc3-89a4-6fa305c354a4" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-DCO1</outgoing>
      <outgoing>Par0-DV1</outgoing>
    </parallelGateway>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>Par0-DCO1</incoming>
      <outgoing>DCO1-SPC1</outgoing>
    </task>
    <task id="DV1" name="Design visuals">
      <incoming>Par0-DV1</incoming>
      <outgoing>DV1-PARCLOSE11</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>DCO1-SPC1</incoming>
      <outgoing>SPC1-CC1</outgoing>
    </task>
    <task id="CC1" name="Create content">
      <incoming>SPC1-CC1</incoming>
      <outgoing>CC1-PARCLOSE11</outgoing>
    </task>
    <parallelGateway id="PARCLOSE11" name="PARCLOSE11">
      <incoming>DV1-PARCLOSE11</incoming>
      <incoming>CC1-PARCLOSE11</incoming>
      <outgoing>PARCLOSE11-LC1</outgoing>
    </parallelGateway>
    <task id="LC1" name="Launch campaign">
      <incoming>PARCLOSE11-LC1</incoming>
      <outgoing>LC1-TPRT1</outgoing>
    </task>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>LC1-TPRT1</incoming>
      <outgoing>TPRT1-APFO1</outgoing>
    </task>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>TPRT1-APFO1</incoming>
      <outgoing>APFO1-Par15</outgoing>
    </task>
    <parallelGateway id="Par15" name="PAR">
      <incoming>APFO1-Par15</incoming>
      <outgoing>Par15-CLCRM1</outgoing>
      <outgoing>Par15-CPE1</outgoing>
    </parallelGateway>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>Par15-CLCRM1</incoming>
      <outgoing>CLCRM1-PARCLOSE18</outgoing>
    </task>
    <task id="CPE1" name="Campaign period ends">
      <incoming>Par15-CPE1</incoming>
      <outgoing>CPE1-PARCLOSE18</outgoing>
    </task>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>CLCRM1-PARCLOSE18</incoming>
      <incoming>CPE1-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-STFL1</outgoing>
    </parallelGateway>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>PARCLOSE18-STFL1</incoming>
      <outgoing>STFL1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>STFL1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
    <sequenceFlow id="Par0-DCO1" sourceRef="Par0" targetRef="DCO1"/>
    <sequenceFlow id="Par0-DV1" sourceRef="Par0" targetRef="DV1"/>
    <sequenceFlow id="DCO1-SPC1" sourceRef="DCO1" targetRef="SPC1"/>
    <sequenceFlow id="DV1-PARCLOSE11" sourceRef="DV1" targetRef="PARCLOSE11"/>
    <sequenceFlow id="SPC1-CC1" sourceRef="SPC1" targetRef="CC1"/>
    <sequenceFlow id="CC1-PARCLOSE11" sourceRef="CC1" targetRef="PARCLOSE11"/>
    <sequenceFlow id="PARCLOSE11-LC1" sourceRef="PARCLOSE11" targetRef="LC1"/>
    <sequenceFlow id="LC1-TPRT1" sourceRef="LC1" targetRef="TPRT1"/>
    <sequenceFlow id="TPRT1-APFO1" sourceRef="TPRT1" targetRef="APFO1"/>
    <sequenceFlow id="APFO1-Par15" sourceRef="APFO1" targetRef="Par15"/>
    <sequenceFlow id="Par15-CLCRM1" sourceRef="Par15" targetRef="CLCRM1"/>
    <sequenceFlow id="Par15-CPE1" sourceRef="Par15" targetRef="CPE1"/>
    <sequenceFlow id="CLCRM1-PARCLOSE18" sourceRef="CLCRM1" targetRef="PARCLOSE18"/>
    <sequenceFlow id="CPE1-PARCLOSE18" sourceRef="CPE1" targetRef="PARCLOSE18"/>
    <sequenceFlow id="PARCLOSE18-STFL1" sourceRef="PARCLOSE18" targetRef="STFL1"/>
    <sequenceFlow id="STFL1-END" sourceRef="STFL1" targetRef="END"/>
  </process>
