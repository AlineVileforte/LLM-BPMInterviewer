<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_a223ee3a-ad80-432d-a284-a65de670fcde" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DV1</outgoing>
    </startEvent>
    <task id="DV1" name="Design visuals">
      <incoming>Default_init-DV1</incoming>
      <outgoing>DV1-DCO1</outgoing>
    </task>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>DV1-DCO1</incoming>
      <outgoing>DCO1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>DCO1-Par2</incoming>
      <outgoing>Par2-CC1</outgoing>
      <outgoing>Par2-SPC1</outgoing>
    </parallelGateway>
    <task id="CC1" name="Create content">
      <incoming>Par2-CC1</incoming>
      <outgoing>CC1-PARCLOSE7</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>Par2-SPC1</incoming>
      <outgoing>SPC1-PARCLOSE7</outgoing>
    </task>
    <parallelGateway id="PARCLOSE7" name="PARCLOSE7">
      <incoming>CC1-PARCLOSE7</incoming>
      <incoming>SPC1-PARCLOSE7</incoming>
      <outgoing>PARCLOSE7-LC1</outgoing>
    </parallelGateway>
    <task id="LC1" name="Launch campaign">
      <incoming>PARCLOSE7-LC1</incoming>
      <outgoing>LC1-TPRT1</outgoing>
    </task>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>LC1-TPRT1</incoming>
      <outgoing>TPRT1-APFO1</outgoing>
    </task>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>TPRT1-APFO1</incoming>
      <outgoing>APFO1-CLCRM1</outgoing>
    </task>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>APFO1-CLCRM1</incoming>
      <outgoing>CLCRM1-Par12</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>CLCRM1-Par12</incoming>
      <outgoing>Par12-STFL1</outgoing>
      <outgoing>Par12-CPE1</outgoing>
    </parallelGateway>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>Par12-STFL1</incoming>
      <outgoing>STFL1-PARCLOSE15</outgoing>
    </task>
    <task id="CPE1" name="Campaign period ends">
      <incoming>Par12-CPE1</incoming>
      <outgoing>CPE1-PARCLOSE15</outgoing>
    </task>
    <parallelGateway id="PARCLOSE15" name="PARCLOSE15">
      <incoming>STFL1-PARCLOSE15</incoming>
      <incoming>CPE1-PARCLOSE15</incoming>
      <outgoing>PARCLOSE15-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE15-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DV1" sourceRef="Default_init" targetRef="DV1"/>
    <sequenceFlow id="DV1-DCO1" sourceRef="DV1" targetRef="DCO1"/>
    <sequenceFlow id="DCO1-Par2" sourceRef="DCO1" targetRef="Par2"/>
    <sequenceFlow id="Par2-CC1" sourceRef="Par2" targetRef="CC1"/>
    <sequenceFlow id="Par2-SPC1" sourceRef="Par2" targetRef="SPC1"/>
    <sequenceFlow id="CC1-PARCLOSE7" sourceRef="CC1" targetRef="PARCLOSE7"/>
    <sequenceFlow id="SPC1-PARCLOSE7" sourceRef="SPC1" targetRef="PARCLOSE7"/>
    <sequenceFlow id="PARCLOSE7-LC1" sourceRef="PARCLOSE7" targetRef="LC1"/>
    <sequenceFlow id="LC1-TPRT1" sourceRef="LC1" targetRef="TPRT1"/>
    <sequenceFlow id="TPRT1-APFO1" sourceRef="TPRT1" targetRef="APFO1"/>
    <sequenceFlow id="APFO1-CLCRM1" sourceRef="APFO1" targetRef="CLCRM1"/>
    <sequenceFlow id="CLCRM1-Par12" sourceRef="CLCRM1" targetRef="Par12"/>
    <sequenceFlow id="Par12-STFL1" sourceRef="Par12" targetRef="STFL1"/>
    <sequenceFlow id="Par12-CPE1" sourceRef="Par12" targetRef="CPE1"/>
    <sequenceFlow id="STFL1-PARCLOSE15" sourceRef="STFL1" targetRef="PARCLOSE15"/>
    <sequenceFlow id="CPE1-PARCLOSE15" sourceRef="CPE1" targetRef="PARCLOSE15"/>
    <sequenceFlow id="PARCLOSE15-END" sourceRef="PARCLOSE15" targetRef="END"/>
  </process>
