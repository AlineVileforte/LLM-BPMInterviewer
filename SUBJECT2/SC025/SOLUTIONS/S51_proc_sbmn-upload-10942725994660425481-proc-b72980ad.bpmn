<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_e3f0ca3b-b6a2-4356-abc6-80dafa565914" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DCO1</outgoing>
    </startEvent>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>Default_init-DCO1</incoming>
      <outgoing>DCO1-CC1</outgoing>
    </task>
    <task id="CC1" name="Create content">
      <incoming>DCO1-CC1</incoming>
      <outgoing>CC1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>CC1-Par3</incoming>
      <outgoing>Par3-DV1</outgoing>
      <outgoing>Par3-SPC1</outgoing>
    </parallelGateway>
    <task id="DV1" name="Design visuals">
      <incoming>Par3-DV1</incoming>
      <outgoing>DV1-PARCLOSE10</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>Par3-SPC1</incoming>
      <outgoing>SPC1-PARCLOSE10</outgoing>
    </task>
    <parallelGateway id="PARCLOSE10" name="PARCLOSE10">
      <incoming>DV1-PARCLOSE10</incoming>
      <incoming>SPC1-PARCLOSE10</incoming>
      <outgoing>PARCLOSE10-LC1</outgoing>
    </parallelGateway>
    <task id="LC1" name="Launch campaign">
      <incoming>PARCLOSE10-LC1</incoming>
      <outgoing>LC1-Par13</outgoing>
    </task>
    <parallelGateway id="Par13" name="PAR">
      <incoming>LC1-Par13</incoming>
      <outgoing>Par13-CLCRM1</outgoing>
      <outgoing>Par13-CPE1</outgoing>
    </parallelGateway>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>Par13-CLCRM1</incoming>
      <outgoing>CLCRM1-TPRT1</outgoing>
    </task>
    <task id="CPE1" name="Campaign period ends">
      <incoming>Par13-CPE1</incoming>
      <outgoing>CPE1-PARCLOSE18</outgoing>
    </task>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>CLCRM1-TPRT1</incoming>
      <outgoing>TPRT1-STFL1</outgoing>
    </task>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>TPRT1-STFL1</incoming>
      <outgoing>STFL1-PARCLOSE18</outgoing>
    </task>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>CPE1-PARCLOSE18</incoming>
      <incoming>STFL1-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-APFO1</outgoing>
    </parallelGateway>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>PARCLOSE18-APFO1</incoming>
      <outgoing>APFO1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>APFO1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DCO1" sourceRef="Default_init" targetRef="DCO1"/>
    <sequenceFlow id="DCO1-CC1" sourceRef="DCO1" targetRef="CC1"/>
    <sequenceFlow id="CC1-Par3" sourceRef="CC1" targetRef="Par3"/>
    <sequenceFlow id="Par3-DV1" sourceRef="Par3" targetRef="DV1"/>
    <sequenceFlow id="Par3-SPC1" sourceRef="Par3" targetRef="SPC1"/>
    <sequenceFlow id="DV1-PARCLOSE10" sourceRef="DV1" targetRef="PARCLOSE10"/>
    <sequenceFlow id="SPC1-PARCLOSE10" sourceRef="SPC1" targetRef="PARCLOSE10"/>
    <sequenceFlow id="PARCLOSE10-LC1" sourceRef="PARCLOSE10" targetRef="LC1"/>
    <sequenceFlow id="LC1-Par13" sourceRef="LC1" targetRef="Par13"/>
    <sequenceFlow id="Par13-CLCRM1" sourceRef="Par13" targetRef="CLCRM1"/>
    <sequenceFlow id="Par13-CPE1" sourceRef="Par13" targetRef="CPE1"/>
    <sequenceFlow id="CLCRM1-TPRT1" sourceRef="CLCRM1" targetRef="TPRT1"/>
    <sequenceFlow id="CPE1-PARCLOSE18" sourceRef="CPE1" targetRef="PARCLOSE18"/>
    <sequenceFlow id="TPRT1-STFL1" sourceRef="TPRT1" targetRef="STFL1"/>
    <sequenceFlow id="STFL1-PARCLOSE18" sourceRef="STFL1" targetRef="PARCLOSE18"/>
    <sequenceFlow id="PARCLOSE18-APFO1" sourceRef="PARCLOSE18" targetRef="APFO1"/>
    <sequenceFlow id="APFO1-END" sourceRef="APFO1" targetRef="END"/>
  </process>
