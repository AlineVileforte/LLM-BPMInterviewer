<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_98013060-bc55-471b-9383-63f61dd53fe0" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-DCO1</outgoing>
      <outgoing>Par0-DV1</outgoing>
    </parallelGateway>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>Par0-DCO1</incoming>
      <outgoing>DCO1-PARCLOSE5</outgoing>
    </task>
    <task id="DV1" name="Design visuals">
      <incoming>Par0-DV1</incoming>
      <outgoing>DV1-PARCLOSE5</outgoing>
    </task>
    <parallelGateway id="PARCLOSE5" name="PARCLOSE5">
      <incoming>DCO1-PARCLOSE5</incoming>
      <incoming>DV1-PARCLOSE5</incoming>
      <outgoing>PARCLOSE5-CC1</outgoing>
    </parallelGateway>
    <task id="CC1" name="Create content">
      <incoming>PARCLOSE5-CC1</incoming>
      <outgoing>CC1-SPC1</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>CC1-SPC1</incoming>
      <outgoing>SPC1-LC1</outgoing>
    </task>
    <task id="LC1" name="Launch campaign">
      <incoming>SPC1-LC1</incoming>
      <outgoing>LC1-TPRT1</outgoing>
    </task>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>LC1-TPRT1</incoming>
      <outgoing>TPRT1-Par10</outgoing>
    </task>
    <parallelGateway id="Par10" name="PAR">
      <incoming>TPRT1-Par10</incoming>
      <outgoing>Par10-CPE1</outgoing>
      <outgoing>Par10-CLCRM1</outgoing>
    </parallelGateway>
    <task id="CPE1" name="Campaign period ends">
      <incoming>Par10-CPE1</incoming>
      <outgoing>CPE1-APFO1</outgoing>
    </task>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>CPE1-APFO1</incoming>
      <outgoing>APFO1-PARCLOSE14</outgoing>
    </task>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>Par10-CLCRM1</incoming>
      <outgoing>CLCRM1-PARCLOSE14</outgoing>
    </task>
    <parallelGateway id="PARCLOSE14" name="PARCLOSE14">
      <incoming>APFO1-PARCLOSE14</incoming>
      <incoming>CLCRM1-PARCLOSE14</incoming>
      <outgoing>PARCLOSE14-STFL1</outgoing>
    </parallelGateway>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>PARCLOSE14-STFL1</incoming>
      <outgoing>STFL1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>STFL1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
    <sequenceFlow id="Par0-DCO1" sourceRef="Par0" targetRef="DCO1"/>
    <sequenceFlow id="Par0-DV1" sourceRef="Par0" targetRef="DV1"/>
    <sequenceFlow id="DCO1-PARCLOSE5" sourceRef="DCO1" targetRef="PARCLOSE5"/>
    <sequenceFlow id="DV1-PARCLOSE5" sourceRef="DV1" targetRef="PARCLOSE5"/>
    <sequenceFlow id="PARCLOSE5-CC1" sourceRef="PARCLOSE5" targetRef="CC1"/>
    <sequenceFlow id="CC1-SPC1" sourceRef="CC1" targetRef="SPC1"/>
    <sequenceFlow id="SPC1-LC1" sourceRef="SPC1" targetRef="LC1"/>
    <sequenceFlow id="LC1-TPRT1" sourceRef="LC1" targetRef="TPRT1"/>
    <sequenceFlow id="TPRT1-Par10" sourceRef="TPRT1" targetRef="Par10"/>
    <sequenceFlow id="Par10-CPE1" sourceRef="Par10" targetRef="CPE1"/>
    <sequenceFlow id="Par10-CLCRM1" sourceRef="Par10" targetRef="CLCRM1"/>
    <sequenceFlow id="CPE1-APFO1" sourceRef="CPE1" targetRef="APFO1"/>
    <sequenceFlow id="APFO1-PARCLOSE14" sourceRef="APFO1" targetRef="PARCLOSE14"/>
    <sequenceFlow id="CLCRM1-PARCLOSE14" sourceRef="CLCRM1" targetRef="PARCLOSE14"/>
    <sequenceFlow id="PARCLOSE14-STFL1" sourceRef="PARCLOSE14" targetRef="STFL1"/>
    <sequenceFlow id="STFL1-END" sourceRef="STFL1" targetRef="END"/>
  </process>
