    <sequenceFlow id="Par6-TPRT1" sourceRef="Par6" targetRef="TPRT1"/>
    <sequenceFlow id="CPE1-G1" sourceRef="CPE1" targetRef="G1"/>
    <sequenceFlow id="G1-STFL1" sourceRef="G1" targetRef="STFL1"/>
    <sequenceFlow id="G1-XORCLOSE12" sourceRef="G1" targetRef="XORCLOSE12"/>
    <sequenceFlow id="STFL1-XORCLOSE12" sourceRef="STFL1" targetRef="XORCLOSE12"/>
    <sequenceFlow id="TPRT1-G2" sourceRef="TPRT1" targetRef="G2"/>
    <sequenceFlow id="XORCLOSE12-PARCLOSE17" sourceRef="XORCLOSE12" targetRef="PARCLOSE17"/>
    <sequenceFlow id="G2-APFO1" sourceRef="G2" targetRef="APFO1"/>
    <sequenceFlow id="G2-XORCLOSE16" sourceRef="G2" targetRef="XORCLOSE16"/>
    <sequenceFlow id="APFO1-XORCLOSE16" sourceRef="APFO1" targetRef="XORCLOSE16"/>
    <sequenceFlow id="XORCLOSE16-PARCLOSE17" sourceRef="XORCLOSE16" targetRef="PARCLOSE17"/>
    <sequenceFlow id="PARCLOSE17-END" sourceRef="PARCLOSE17" targetRef="END"/>
  </process>
