<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_e11dd05b-a0e9-4fcc-9c5c-4470ade8336f" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-DCO1</outgoing>
      <outgoing>Par0-DV1</outgoing>
    </parallelGateway>
    <task id="DCO1" name="Define campaign objectives">
      <incoming>Par0-DCO1</incoming>
      <outgoing>DCO1-SPC1</outgoing>
    </task>
    <task id="DV1" name="Design visuals">
      <incoming>Par0-DV1</incoming>
      <outgoing>DV1-PARCLOSE6</outgoing>
    </task>
    <task id="SPC1" name="Select promotion channels">
      <incoming>DCO1-SPC1</incoming>
      <outgoing>SPC1-PARCLOSE6</outgoing>
    </task>
    <parallelGateway id="PARCLOSE6" name="PARCLOSE6">
      <incoming>DV1-PARCLOSE6</incoming>
      <incoming>SPC1-PARCLOSE6</incoming>
      <outgoing>PARCLOSE6-CC1</outgoing>
    </parallelGateway>
    <task id="CC1" name="Create content">
      <incoming>PARCLOSE6-CC1</incoming>
      <outgoing>CC1-LC1</outgoing>
    </task>
    <task id="LC1" name="Launch campaign">
      <incoming>CC1-LC1</incoming>
      <outgoing>LC1-Par9</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>LC1-Par9</incoming>
      <outgoing>Par9-CLCRM1</outgoing>
      <outgoing>Par9-STFL1</outgoing>
    </parallelGateway>
    <task id="CLCRM1" name="Collect leads in CRM system">
      <incoming>Par9-CLCRM1</incoming>
      <outgoing>CLCRM1-Par11</outgoing>
    </task>
    <parallelGateway id="Par11" name="PAR">
      <incoming>CLCRM1-Par11</incoming>
      <outgoing>Par11-TPRT1</outgoing>
      <outgoing>Par11-CPE1</outgoing>
    </parallelGateway>
    <task id="TPRT1" name="Track performance in real-time">
      <incoming>Par11-TPRT1</incoming>
      <outgoing>TPRT1-APFO1</outgoing>
    </task>
    <task id="CPE1" name="Campaign period ends">
      <incoming>Par11-CPE1</incoming>
      <outgoing>CPE1-PARCLOSE16</outgoing>
    </task>
    <task id="STFL1" name="Sales teams follows up on leads">
      <incoming>Par9-STFL1</incoming>
      <outgoing>STFL1-PARCLOSE17</outgoing>
    </task>
    <task id="APFO1" name="Analyze performance for future optimization">
      <incoming>TPRT1-APFO1</incoming>
      <outgoing>APFO1-PARCLOSE16</outgoing>
    </task>
    <parallelGateway id="PARCLOSE16" name="PARCLOSE16">
      <incoming>CPE1-PARCLOSE16</incoming>
      <incoming>APFO1-PARCLOSE16</incoming>
      <outgoing>PARCLOSE16-PARCLOSE17</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>STFL1-PARCLOSE17</incoming>
      <incoming>PARCLOSE16-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE17-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
