<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_abfe6a41-da92-477b-b009-69b5a4d0f6f9" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-LVC1</outgoing>
      <outgoing>Par0-Par3</outgoing>
    </parallelGateway>
    <task id="LVC1" name="Land valuation check">
      <incoming>Par0-LVC1</incoming>
      <outgoing>LVC1-NTC1</outgoing>
    </task>
    <task id="NTC1" name="Native title check">
      <incoming>LVC1-NTC1</incoming>
      <outgoing>NTC1-SPRC1</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>Par0-Par3</incoming>
      <outgoing>Par3-DALAP1</outgoing>
      <outgoing>Par3-TAC1</outgoing>
    </parallelGateway>
    <task id="DALAP1" name="Determine any land action planned">
      <incoming>Par3-DALAP1</incoming>
      <outgoing>DALAP1-PC1</outgoing>
    </task>
    <task id="TAC1" name="Title administrative check">
      <incoming>Par3-TAC1</incoming>
      <outgoing>TAC1-PARCLOSE8</outgoing>
    </task>
    <task id="SPRC1" name="Survey plan registration check">
      <incoming>NTC1-SPRC1</incoming>
      <outgoing>SPRC1-PARCLOSE10</outgoing>
    </task>
    <task id="PC1" name="Parcel check">
      <incoming>DALAP1-PC1</incoming>
      <outgoing>PC1-PARCLOSE8</outgoing>
    </task>
    <parallelGateway id="PARCLOSE8" name="PARCLOSE8">
      <incoming>TAC1-PARCLOSE8</incoming>
      <incoming>PC1-PARCLOSE8</incoming>
      <outgoing>PARCLOSE8-FCR1</outgoing>
    </parallelGateway>
    <task id="FCR1" name="Finalize check result">
      <incoming>PARCLOSE8-FCR1</incoming>
      <outgoing>FCR1-PARCLOSE10</outgoing>
    </task>
    <parallelGateway id="PARCLOSE10" name="PARCLOSE10">
      <incoming>SPRC1-PARCLOSE10</incoming>
      <incoming>FCR1-PARCLOSE10</incoming>
      <outgoing>PARCLOSE10-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE10-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
    <sequenceFlow id="Par0-LVC1" sourceRef="Par0" targetRef="LVC1"/>
    <sequenceFlow id="Par0-Par3" sourceRef="Par0" targetRef="Par3"/>
    <sequenceFlow id="LVC1-NTC1" sourceRef="LVC1" targetRef="NTC1"/>
