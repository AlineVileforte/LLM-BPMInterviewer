    <sequenceFlow id="Par3-DALAP1" sourceRef="Par3" targetRef="DALAP1"/>
    <sequenceFlow id="Par3-TAC1" sourceRef="Par3" targetRef="TAC1"/>
    <sequenceFlow id="DALAP1-PC1" sourceRef="DALAP1" targetRef="PC1"/>
    <sequenceFlow id="TAC1-PARCLOSE8" sourceRef="TAC1" targetRef="PARCLOSE8"/>
    <sequenceFlow id="SPRC1-PARCLOSE10" sourceRef="SPRC1" targetRef="PARCLOSE10"/>
    <sequenceFlow id="PC1-PARCLOSE8" sourceRef="PC1" targetRef="PARCLOSE8"/>
    <sequenceFlow id="PARCLOSE8-FCR1" sourceRef="PARCLOSE8" targetRef="FCR1"/>
    <sequenceFlow id="FCR1-PARCLOSE10" sourceRef="FCR1" targetRef="PARCLOSE10"/>
    <sequenceFlow id="PARCLOSE10-END" sourceRef="PARCLOSE10" targetRef="END"/>
  </process>
