<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_4159e234-2fbf-4369-942f-eaa52886aa02" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-SPRC1</outgoing>
    </startEvent>
    <task id="SPRC1" name="Survey plan registration check">
      <incoming>Default_init-SPRC1</incoming>
      <outgoing>SPRC1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>SPRC1-Par1</incoming>
      <outgoing>Par1-DALAP1</outgoing>
      <outgoing>Par1-NTC1</outgoing>
    </parallelGateway>
    <task id="DALAP1" name="Determine any land action planned">
      <incoming>Par1-DALAP1</incoming>
      <outgoing>DALAP1-Par4</outgoing>
    </task>
    <task id="NTC1" name="Native title check">
      <incoming>Par1-NTC1</incoming>
      <outgoing>NTC1-PC1</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>DALAP1-Par4</incoming>
      <outgoing>Par4-TAC1</outgoing>
      <outgoing>Par4-LVC1</outgoing>
    </parallelGateway>
    <task id="TAC1" name="Title administrative check">
      <incoming>Par4-TAC1</incoming>
      <outgoing>TAC1-PARCLOSE8</outgoing>
    </task>
    <task id="LVC1" name="Land valuation check">
      <incoming>Par4-LVC1</incoming>
      <outgoing>LVC1-PARCLOSE8</outgoing>
    </task>
    <task id="PC1" name="Parcel check">
      <incoming>NTC1-PC1</incoming>
      <outgoing>PC1-PARCLOSE9</outgoing>
    </task>
    <parallelGateway id="PARCLOSE8" name="PARCLOSE8">
      <incoming>TAC1-PARCLOSE8</incoming>
      <incoming>LVC1-PARCLOSE8</incoming>
      <outgoing>PARCLOSE8-PARCLOSE9</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE9" name="PARCLOSE9">
      <incoming>PC1-PARCLOSE9</incoming>
      <incoming>PARCLOSE8-PARCLOSE9</incoming>
      <outgoing>PARCLOSE9-FCR1</outgoing>
    </parallelGateway>
    <task id="FCR1" name="Finalize check result">
      <incoming>PARCLOSE9-FCR1</incoming>
      <outgoing>FCR1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>FCR1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-SPRC1" sourceRef="Default_init" targetRef="SPRC1"/>
    <sequenceFlow id="SPRC1-Par1" sourceRef="SPRC1" targetRef="Par1"/>
    <sequenceFlow id="Par1-DALAP1" sourceRef="Par1" targetRef="DALAP1"/>
    <sequenceFlow id="Par1-NTC1" sourceRef="Par1" targetRef="NTC1"/>
    <sequenceFlow id="DALAP1-Par4" sourceRef="DALAP1" targetRef="Par4"/>
    <sequenceFlow id="NTC1-PC1" sourceRef="NTC1" targetRef="PC1"/>
    <sequenceFlow id="Par4-TAC1" sourceRef="Par4" targetRef="TAC1"/>
    <sequenceFlow id="Par4-LVC1" sourceRef="Par4" targetRef="LVC1"/>
    <sequenceFlow id="TAC1-PARCLOSE8" sourceRef="TAC1" targetRef="PARCLOSE8"/>
    <sequenceFlow id="LVC1-PARCLOSE8" sourceRef="LVC1" targetRef="PARCLOSE8"/>
    <sequenceFlow id="PC1-PARCLOSE9" sourceRef="PC1" targetRef="PARCLOSE9"/>
    <sequenceFlow id="PARCLOSE8-PARCLOSE9" sourceRef="PARCLOSE8" targetRef="PARCLOSE9"/>
    <sequenceFlow id="PARCLOSE9-FCR1" sourceRef="PARCLOSE9" targetRef="FCR1"/>
    <sequenceFlow id="FCR1-END" sourceRef="FCR1" targetRef="END"/>
  </process>
