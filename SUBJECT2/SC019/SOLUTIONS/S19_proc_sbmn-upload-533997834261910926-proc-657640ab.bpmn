<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_4ceca9d2-8cbb-4236-8770-c466ac9007d8" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-NTC1</outgoing>
      <outgoing>Par0-LVC1</outgoing>
    </parallelGateway>
    <task id="NTC1" name="Native title check">
      <incoming>Par0-NTC1</incoming>
      <outgoing>NTC1-PC1</outgoing>
    </task>
    <task id="LVC1" name="Land valuation check">
      <incoming>Par0-LVC1</incoming>
      <outgoing>LVC1-SPRC1</outgoing>
    </task>
    <task id="PC1" name="Parcel check">
      <incoming>NTC1-PC1</incoming>
      <outgoing>PC1-DALAP1</outgoing>
    </task>
    <task id="SPRC1" name="Survey plan registration check">
      <incoming>LVC1-SPRC1</incoming>
      <outgoing>SPRC1-TAC1</outgoing>
    </task>
    <task id="DALAP1" name="Determine any land action planned">
      <incoming>PC1-DALAP1</incoming>
      <outgoing>DALAP1-PARCLOSE7</outgoing>
    </task>
    <task id="TAC1" name="Title administrative check">
      <incoming>SPRC1-TAC1</incoming>
      <outgoing>TAC1-PARCLOSE7</outgoing>
    </task>
    <parallelGateway id="PARCLOSE7" name="PARCLOSE7">
      <incoming>DALAP1-PARCLOSE7</incoming>
      <incoming>TAC1-PARCLOSE7</incoming>
      <outgoing>PARCLOSE7-FCR1</outgoing>
    </parallelGateway>
    <task id="FCR1" name="Finalize check result">
      <incoming>PARCLOSE7-FCR1</incoming>
      <outgoing>FCR1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>FCR1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
    <sequenceFlow id="Par0-NTC1" sourceRef="Par0" targetRef="NTC1"/>
    <sequenceFlow id="Par0-LVC1" sourceRef="Par0" targetRef="LVC1"/>
    <sequenceFlow id="NTC1-PC1" sourceRef="NTC1" targetRef="PC1"/>
    <sequenceFlow id="LVC1-SPRC1" sourceRef="LVC1" targetRef="SPRC1"/>
    <sequenceFlow id="PC1-DALAP1" sourceRef="PC1" targetRef="DALAP1"/>
    <sequenceFlow id="SPRC1-TAC1" sourceRef="SPRC1" targetRef="TAC1"/>
    <sequenceFlow id="DALAP1-PARCLOSE7" sourceRef="DALAP1" targetRef="PARCLOSE7"/>
    <sequenceFlow id="TAC1-PARCLOSE7" sourceRef="TAC1" targetRef="PARCLOSE7"/>
    <sequenceFlow id="PARCLOSE7-FCR1" sourceRef="PARCLOSE7" targetRef="FCR1"/>
    <sequenceFlow id="FCR1-END" sourceRef="FCR1" targetRef="END"/>
  </process>
