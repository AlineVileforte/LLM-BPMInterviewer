  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-SPRC1</outgoing>
    </startEvent>
    <task id="SPRC1" name="Survey plan registration check">
      <incoming>Default_init-SPRC1</incoming>
      <outgoing>SPRC1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>SPRC1-Par1</incoming>
      <outgoing>Par1-NTC1</outgoing>
      <outgoing>Par1-Par6</outgoing>
    </parallelGateway>
    <task id="NTC1" name="Native title check">
      <incoming>Par1-NTC1</incoming>
      <outgoing>NTC1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>NTC1-Par3</incoming>
      <outgoing>Par3-TAC1</outgoing>
      <outgoing>Par3-LVC1</outgoing>
    </parallelGateway>
    <task id="TAC1" name="Title administrative check">
      <incoming>Par3-TAC1</incoming>
      <outgoing>TAC1-PARCLOSE9</outgoing>
    </task>
    <task id="LVC1" name="Land valuation check">
      <incoming>Par3-LVC1</incoming>
      <outgoing>LVC1-PARCLOSE9</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>Par1-Par6</incoming>
      <outgoing>Par6-DALAP1</outgoing>
      <outgoing>Par6-PC1</outgoing>
    </parallelGateway>
    <task id="DALAP1" name="Determine any land action planned">
      <incoming>Par6-DALAP1</incoming>
      <outgoing>DALAP1-PARCLOSE10</outgoing>
    </task>
    <task id="PC1" name="Parcel check">
      <incoming>Par6-PC1</incoming>
      <outgoing>PC1-PARCLOSE10</outgoing>
    </task>
    <parallelGateway id="PARCLOSE9" name="PARCLOSE9">
      <incoming>TAC1-PARCLOSE9</incoming>
      <incoming>LVC1-PARCLOSE9</incoming>
      <outgoing>PARCLOSE9-FCR1</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE10" name="PARCLOSE10">
      <incoming>DALAP1-PARCLOSE10</incoming>
      <incoming>PC1-PARCLOSE10</incoming>
      <outgoing>PARCLOSE10-PARCLOSE12</outgoing>
    </parallelGateway>
    <task id="FCR1" name="Finalize check result">
      <incoming>PARCLOSE9-FCR1</incoming>
      <outgoing>FCR1-PARCLOSE12</outgoing>
    </task>
    <parallelGateway id="PARCLOSE12" name="PARCLOSE12">
      <incoming>PARCLOSE10-PARCLOSE12</incoming>
      <incoming>FCR1-PARCLOSE12</incoming>
      <outgoing>PARCLOSE12-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE12-END</incoming>
    </endEvent>
