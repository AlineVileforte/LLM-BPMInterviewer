<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_4be61b2d-8889-484a-b8ea-bc63a88156eb" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-NTC1</outgoing>
      <outgoing>Par0-PC1</outgoing>
    </parallelGateway>
    <task id="NTC1" name="Native title check">
      <incoming>Par0-NTC1</incoming>
      <outgoing>NTC1-SPRC1</outgoing>
    </task>
    <task id="PC1" name="Parcel check">
      <incoming>Par0-PC1</incoming>
      <outgoing>PC1-Par5</outgoing>
    </task>
    <task id="SPRC1" name="Survey plan registration check">
      <incoming>NTC1-SPRC1</incoming>
      <outgoing>SPRC1-TAC1</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>PC1-Par5</incoming>
      <outgoing>Par5-DALAP1</outgoing>
      <outgoing>Par5-LVC1</outgoing>
    </parallelGateway>
    <task id="DALAP1" name="Determine any land action planned">
      <incoming>Par5-DALAP1</incoming>
      <outgoing>DALAP1-PARCLOSE10</outgoing>
    </task>
    <task id="LVC1" name="Land valuation check">
      <incoming>Par5-LVC1</incoming>
      <outgoing>LVC1-PARCLOSE10</outgoing>
    </task>
    <task id="TAC1" name="Title administrative check">
      <incoming>SPRC1-TAC1</incoming>
      <outgoing>TAC1-PARCLOSE11</outgoing>
    </task>
    <parallelGateway id="PARCLOSE10" name="PARCLOSE10">
      <incoming>DALAP1-PARCLOSE10</incoming>
      <incoming>LVC1-PARCLOSE10</incoming>
      <outgoing>PARCLOSE10-PARCLOSE11</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE11" name="PARCLOSE11">
      <incoming>TAC1-PARCLOSE11</incoming>
      <incoming>PARCLOSE10-PARCLOSE11</incoming>
      <outgoing>PARCLOSE11-FCR1</outgoing>
    </parallelGateway>
    <task id="FCR1" name="Finalize check result">
      <incoming>PARCLOSE11-FCR1</incoming>
      <outgoing>FCR1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>FCR1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
    <sequenceFlow id="Par0-NTC1" sourceRef="Par0" targetRef="NTC1"/>
    <sequenceFlow id="Par0-PC1" sourceRef="Par0" targetRef="PC1"/>
    <sequenceFlow id="NTC1-SPRC1" sourceRef="NTC1" targetRef="SPRC1"/>
    <sequenceFlow id="PC1-Par5" sourceRef="PC1" targetRef="Par5"/>
    <sequenceFlow id="SPRC1-TAC1" sourceRef="SPRC1" targetRef="TAC1"/>
    <sequenceFlow id="Par5-DALAP1" sourceRef="Par5" targetRef="DALAP1"/>
    <sequenceFlow id="Par5-LVC1" sourceRef="Par5" targetRef="LVC1"/>
    <sequenceFlow id="DALAP1-PARCLOSE10" sourceRef="DALAP1" targetRef="PARCLOSE10"/>
    <sequenceFlow id="LVC1-PARCLOSE10" sourceRef="LVC1" targetRef="PARCLOSE10"/>
    <sequenceFlow id="TAC1-PARCLOSE11" sourceRef="TAC1" targetRef="PARCLOSE11"/>
    <sequenceFlow id="PARCLOSE10-PARCLOSE11" sourceRef="PARCLOSE10" targetRef="PARCLOSE11"/>
    <sequenceFlow id="PARCLOSE11-FCR1" sourceRef="PARCLOSE11" targetRef="FCR1"/>
    <sequenceFlow id="FCR1-END" sourceRef="FCR1" targetRef="END"/>
  </process>
