    <sequenceFlow id="TAC1-LVC1" sourceRef="TAC1" targetRef="LVC1"/>
    <sequenceFlow id="PC1-PARCLOSE9" sourceRef="PC1" targetRef="PARCLOSE9"/>
    <sequenceFlow id="LVC1-PARCLOSE8" sourceRef="LVC1" targetRef="PARCLOSE8"/>
    <sequenceFlow id="NTC1-PARCLOSE8" sourceRef="NTC1" targetRef="PARCLOSE8"/>
    <sequenceFlow id="PARCLOSE8-PARCLOSE9" sourceRef="PARCLOSE8" targetRef="PARCLOSE9"/>
    <sequenceFlow id="PARCLOSE9-FCR1" sourceRef="PARCLOSE9" targetRef="FCR1"/>
    <sequenceFlow id="FCR1-END" sourceRef="FCR1" targetRef="END"/>
  </process>
