<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_c6a58f8b-29aa-44c1-b9f9-c2f90a567c67" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-TAC1</outgoing>
      <outgoing>Par0-NTC1</outgoing>
    </parallelGateway>
    <task id="TAC1" name="Title administrative check">
      <incoming>Par0-TAC1</incoming>
      <outgoing>TAC1-Par3</outgoing>
    </task>
    <task id="NTC1" name="Native title check">
      <incoming>Par0-NTC1</incoming>
      <outgoing>NTC1-DALAP1</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>TAC1-Par3</incoming>
      <outgoing>Par3-LVC1</outgoing>
      <outgoing>Par3-SPRC1</outgoing>
    </parallelGateway>
    <task id="LVC1" name="Land valuation check">
      <incoming>Par3-LVC1</incoming>
      <outgoing>LVC1-PC1</outgoing>
    </task>
    <task id="SPRC1" name="Survey plan registration check">
      <incoming>Par3-SPRC1</incoming>
      <outgoing>SPRC1-PARCLOSE8</outgoing>
    </task>
    <task id="DALAP1" name="Determine any land action planned">
      <incoming>NTC1-DALAP1</incoming>
      <outgoing>DALAP1-PARCLOSE9</outgoing>
    </task>
    <task id="PC1" name="Parcel check">
      <incoming>LVC1-PC1</incoming>
      <outgoing>PC1-PARCLOSE8</outgoing>
    </task>
    <parallelGateway id="PARCLOSE8" name="PARCLOSE8">
      <incoming>SPRC1-PARCLOSE8</incoming>
      <incoming>PC1-PARCLOSE8</incoming>
      <outgoing>PARCLOSE8-PARCLOSE9</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE9" name="PARCLOSE9">
      <incoming>DALAP1-PARCLOSE9</incoming>
      <incoming>PARCLOSE8-PARCLOSE9</incoming>
      <outgoing>PARCLOSE9-FCR1</outgoing>
    </parallelGateway>
    <task id="FCR1" name="Finalize check result">
      <incoming>PARCLOSE9-FCR1</incoming>
      <outgoing>FCR1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>FCR1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
