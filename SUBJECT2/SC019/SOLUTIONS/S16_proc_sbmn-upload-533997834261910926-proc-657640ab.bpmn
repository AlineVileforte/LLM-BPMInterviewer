  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-LVC1</outgoing>
      <outgoing>Par0-SPRC1</outgoing>
    </parallelGateway>
    <task id="LVC1" name="Land valuation check">
      <incoming>Par0-LVC1</incoming>
      <outgoing>LVC1-NTC1</outgoing>
    </task>
    <task id="SPRC1" name="Survey plan registration check">
      <incoming>Par0-SPRC1</incoming>
      <outgoing>SPRC1-PC1</outgoing>
    </task>
    <task id="NTC1" name="Native title check">
      <incoming>LVC1-NTC1</incoming>
      <outgoing>NTC1-DALAP1</outgoing>
    </task>
    <task id="PC1" name="Parcel check">
      <incoming>SPRC1-PC1</incoming>
      <outgoing>PC1-TAC1</outgoing>
    </task>
    <task id="DALAP1" name="Determine any land action planned">
      <incoming>NTC1-DALAP1</incoming>
      <outgoing>DALAP1-PARCLOSE9</outgoing>
    </task>
    <task id="TAC1" name="Title administrative check">
      <incoming>PC1-TAC1</incoming>
      <outgoing>TAC1-PARCLOSE9</outgoing>
    </task>
    <parallelGateway id="PARCLOSE9" name="PARCLOSE9">
      <incoming>DALAP1-PARCLOSE9</incoming>
      <incoming>TAC1-PARCLOSE9</incoming>
      <outgoing>PARCLOSE9-FCR1</outgoing>
    </parallelGateway>
    <task id="FCR1" name="Finalize check result">
      <incoming>PARCLOSE9-FCR1</incoming>
      <outgoing>FCR1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>FCR1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
    <sequenceFlow id="Par0-LVC1" sourceRef="Par0" targetRef="LVC1"/>
    <sequenceFlow id="Par0-SPRC1" sourceRef="Par0" targetRef="SPRC1"/>
    <sequenceFlow id="LVC1-NTC1" sourceRef="LVC1" targetRef="NTC1"/>
    <sequenceFlow id="SPRC1-PC1" sourceRef="SPRC1" targetRef="PC1"/>
