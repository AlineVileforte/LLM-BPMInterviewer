  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-NTC1</outgoing>
      <outgoing>Par0-TAC1</outgoing>
    </parallelGateway>
    <task id="NTC1" name="Native title check">
      <incoming>Par0-NTC1</incoming>
      <outgoing>NTC1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>NTC1-Par2</incoming>
      <outgoing>Par2-DALAP1</outgoing>
      <outgoing>Par2-LVC1</outgoing>
    </parallelGateway>
    <task id="DALAP1" name="Determine any land action planned">
      <incoming>Par2-DALAP1</incoming>
      <outgoing>DALAP1-Par6</outgoing>
    </task>
    <task id="LVC1" name="Land valuation check">
      <incoming>Par2-LVC1</incoming>
      <outgoing>LVC1-PARCLOSE10</outgoing>
    </task>
    <task id="TAC1" name="Title administrative check">
      <incoming>Par0-TAC1</incoming>
      <outgoing>TAC1-PARCLOSE12</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>DALAP1-Par6</incoming>
      <outgoing>Par6-PC1</outgoing>
      <outgoing>Par6-SPRC1</outgoing>
    </parallelGateway>
    <task id="PC1" name="Parcel check">
      <incoming>Par6-PC1</incoming>
      <outgoing>PC1-PARCLOSE9</outgoing>
    </task>
    <task id="SPRC1" name="Survey plan registration check">
      <incoming>Par6-SPRC1</incoming>
      <outgoing>SPRC1-PARCLOSE9</outgoing>
    </task>
    <parallelGateway id="PARCLOSE9" name="PARCLOSE9">
      <incoming>PC1-PARCLOSE9</incoming>
      <incoming>SPRC1-PARCLOSE9</incoming>
      <outgoing>PARCLOSE9-PARCLOSE10</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE10" name="PARCLOSE10">
      <incoming>LVC1-PARCLOSE10</incoming>
      <incoming>PARCLOSE9-PARCLOSE10</incoming>
      <outgoing>PARCLOSE10-FCR1</outgoing>
    </parallelGateway>
    <task id="FCR1" name="Finalize check result">
      <incoming>PARCLOSE10-FCR1</incoming>
      <outgoing>FCR1-PARCLOSE12</outgoing>
    </task>
    <parallelGateway id="PARCLOSE12" name="PARCLOSE12">
      <incoming>TAC1-PARCLOSE12</incoming>
      <incoming>FCR1-PARCLOSE12</incoming>
      <outgoing>PARCLOSE12-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE12-END</incoming>
    </endEvent>
