  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-DALAP1</outgoing>
      <outgoing>Par0-PC1</outgoing>
    </parallelGateway>
    <task id="DALAP1" name="Determine any land action planned">
      <incoming>Par0-DALAP1</incoming>
      <outgoing>DALAP1-TAC1</outgoing>
    </task>
    <task id="PC1" name="Parcel check">
      <incoming>Par0-PC1</incoming>
      <outgoing>PC1-NTC1</outgoing>
    </task>
    <task id="TAC1" name="Title administrative check">
      <incoming>DALAP1-TAC1</incoming>
      <outgoing>TAC1-LVC1</outgoing>
    </task>
    <task id="NTC1" name="Native title check">
      <incoming>PC1-NTC1</incoming>
      <outgoing>NTC1-SPRC1</outgoing>
    </task>
    <task id="LVC1" name="Land valuation check">
      <incoming>TAC1-LVC1</incoming>
      <outgoing>LVC1-PARCLOSE9</outgoing>
    </task>
    <task id="SPRC1" name="Survey plan registration check">
      <incoming>NTC1-SPRC1</incoming>
      <outgoing>SPRC1-PARCLOSE9</outgoing>
    </task>
    <parallelGateway id="PARCLOSE9" name="PARCLOSE9">
      <incoming>LVC1-PARCLOSE9</incoming>
      <incoming>SPRC1-PARCLOSE9</incoming>
      <outgoing>PARCLOSE9-FCR1</outgoing>
    </parallelGateway>
    <task id="FCR1" name="Finalize check result">
      <incoming>PARCLOSE9-FCR1</incoming>
      <outgoing>FCR1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>FCR1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
    <sequenceFlow id="Par0-DALAP1" sourceRef="Par0" targetRef="DALAP1"/>
    <sequenceFlow id="Par0-PC1" sourceRef="Par0" targetRef="PC1"/>
    <sequenceFlow id="DALAP1-TAC1" sourceRef="DALAP1" targetRef="TAC1"/>
    <sequenceFlow id="PC1-NTC1" sourceRef="PC1" targetRef="NTC1"/>
    <sequenceFlow id="TAC1-LVC1" sourceRef="TAC1" targetRef="LVC1"/>
    <sequenceFlow id="NTC1-SPRC1" sourceRef="NTC1" targetRef="SPRC1"/>
    <sequenceFlow id="LVC1-PARCLOSE9" sourceRef="LVC1" targetRef="PARCLOSE9"/>
    <sequenceFlow id="SPRC1-PARCLOSE9" sourceRef="SPRC1" targetRef="PARCLOSE9"/>
    <sequenceFlow id="PARCLOSE9-FCR1" sourceRef="PARCLOSE9" targetRef="FCR1"/>
    <sequenceFlow id="FCR1-END" sourceRef="FCR1" targetRef="END"/>
  </process>
