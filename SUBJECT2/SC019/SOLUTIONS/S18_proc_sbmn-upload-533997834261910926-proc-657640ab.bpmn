  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-PC1</outgoing>
      <outgoing>Par0-Par4</outgoing>
    </parallelGateway>
    <task id="PC1" name="Parcel check">
      <incoming>Par0-PC1</incoming>
      <outgoing>PC1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>PC1-Par2</incoming>
      <outgoing>Par2-SPRC1</outgoing>
      <outgoing>Par2-NTC1</outgoing>
    </parallelGateway>
    <task id="SPRC1" name="Survey plan registration check">
      <incoming>Par2-SPRC1</incoming>
      <outgoing>SPRC1-TAC1</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>Par0-Par4</incoming>
      <outgoing>Par4-DALAP1</outgoing>
      <outgoing>Par4-LVC1</outgoing>
    </parallelGateway>
    <task id="DALAP1" name="Determine any land action planned">
      <incoming>Par4-DALAP1</incoming>
      <outgoing>DALAP1-PARCLOSE9</outgoing>
    </task>
    <task id="LVC1" name="Land valuation check">
      <incoming>Par4-LVC1</incoming>
      <outgoing>LVC1-PARCLOSE9</outgoing>
    </task>
    <task id="TAC1" name="Title administrative check">
      <incoming>SPRC1-TAC1</incoming>
      <outgoing>TAC1-PARCLOSE11</outgoing>
    </task>
    <task id="NTC1" name="Native title check">
      <incoming>Par2-NTC1</incoming>
      <outgoing>NTC1-FCR1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE9" name="PARCLOSE9">
      <incoming>DALAP1-PARCLOSE9</incoming>
      <incoming>LVC1-PARCLOSE9</incoming>
      <outgoing>PARCLOSE9-PARCLOSE12</outgoing>
    </parallelGateway>
    <task id="FCR1" name="Finalize check result">
      <incoming>NTC1-FCR1</incoming>
      <outgoing>FCR1-PARCLOSE11</outgoing>
    </task>
    <parallelGateway id="PARCLOSE11" name="PARCLOSE11">
      <incoming>TAC1-PARCLOSE11</incoming>
      <incoming>FCR1-PARCLOSE11</incoming>
      <outgoing>PARCLOSE11-PARCLOSE12</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE12" name="PARCLOSE12">
      <incoming>PARCLOSE9-PARCLOSE12</incoming>
      <incoming>PARCLOSE11-PARCLOSE12</incoming>
      <outgoing>PARCLOSE12-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE12-END</incoming>
    </endEvent>
