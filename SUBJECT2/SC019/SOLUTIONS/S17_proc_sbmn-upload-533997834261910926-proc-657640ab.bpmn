<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_45c4ec51-592d-42c3-bf81-0be3bb74c636" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-TAC1</outgoing>
      <outgoing>Par0-Par3</outgoing>
    </parallelGateway>
    <task id="TAC1" name="Title administrative check">
      <incoming>Par0-TAC1</incoming>
      <outgoing>TAC1-DALAP1</outgoing>
    </task>
    <task id="DALAP1" name="Determine any land action planned">
      <incoming>TAC1-DALAP1</incoming>
      <outgoing>DALAP1-SPRC1</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>Par0-Par3</incoming>
      <outgoing>Par3-PC1</outgoing>
      <outgoing>Par3-LVC1</outgoing>
    </parallelGateway>
    <task id="PC1" name="Parcel check">
      <incoming>Par3-PC1</incoming>
      <outgoing>PC1-NTC1</outgoing>
    </task>
    <task id="SPRC1" name="Survey plan registration check">
      <incoming>DALAP1-SPRC1</incoming>
      <outgoing>SPRC1-FCR1</outgoing>
    </task>
    <task id="NTC1" name="Native title check">
      <incoming>PC1-NTC1</incoming>
      <outgoing>NTC1-PARCLOSE10</outgoing>
    </task>
    <task id="LVC1" name="Land valuation check">
      <incoming>Par3-LVC1</incoming>
      <outgoing>LVC1-PARCLOSE10</outgoing>
    </task>
    <parallelGateway id="PARCLOSE10" name="PARCLOSE10">
      <incoming>NTC1-PARCLOSE10</incoming>
      <incoming>LVC1-PARCLOSE10</incoming>
      <outgoing>PARCLOSE10-PARCLOSE12</outgoing>
    </parallelGateway>
    <task id="FCR1" name="Finalize check result">
      <incoming>SPRC1-FCR1</incoming>
      <outgoing>FCR1-PARCLOSE12</outgoing>
    </task>
    <parallelGateway id="PARCLOSE12" name="PARCLOSE12">
      <incoming>PARCLOSE10-PARCLOSE12</incoming>
      <incoming>FCR1-PARCLOSE12</incoming>
      <outgoing>PARCLOSE12-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE12-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
    <sequenceFlow id="Par0-TAC1" sourceRef="Par0" targetRef="TAC1"/>
    <sequenceFlow id="Par0-Par3" sourceRef="Par0" targetRef="Par3"/>
    <sequenceFlow id="TAC1-DALAP1" sourceRef="TAC1" targetRef="DALAP1"/>
    <sequenceFlow id="DALAP1-SPRC1" sourceRef="DALAP1" targetRef="SPRC1"/>
    <sequenceFlow id="Par3-PC1" sourceRef="Par3" targetRef="PC1"/>
    <sequenceFlow id="Par3-LVC1" sourceRef="Par3" targetRef="LVC1"/>
    <sequenceFlow id="PC1-NTC1" sourceRef="PC1" targetRef="NTC1"/>
    <sequenceFlow id="SPRC1-FCR1" sourceRef="SPRC1" targetRef="FCR1"/>
    <sequenceFlow id="NTC1-PARCLOSE10" sourceRef="NTC1" targetRef="PARCLOSE10"/>
    <sequenceFlow id="LVC1-PARCLOSE10" sourceRef="LVC1" targetRef="PARCLOSE10"/>
    <sequenceFlow id="PARCLOSE10-PARCLOSE12" sourceRef="PARCLOSE10" targetRef="PARCLOSE12"/>
    <sequenceFlow id="FCR1-PARCLOSE12" sourceRef="FCR1" targetRef="PARCLOSE12"/>
    <sequenceFlow id="PARCLOSE12-END" sourceRef="PARCLOSE12" targetRef="END"/>
  </process>
