<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_1d7d28f3-98bc-4ded-91da-cbacba1023c1" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-INH1</outgoing>
    </startEvent>
    <task id="INH1" name="Identify need for new hire">
      <incoming>Default_init-INH1</incoming>
      <outgoing>INH1-CJD1</outgoing>
    </task>
    <task id="CJD1" name="Create job description">
      <incoming>INH1-CJD1</incoming>
      <outgoing>CJD1-PJD1</outgoing>
    </task>
    <task id="PJD1" name="Post job description">
      <incoming>CJD1-PJD1</incoming>
      <outgoing>PJD1-CR1</outgoing>
    </task>
    <task id="CR1" name="Collect resumes">
      <incoming>PJD1-CR1</incoming>
      <outgoing>CR1-SR1</outgoing>
    </task>
    <task id="SR1" name="Screen resumes">
      <incoming>CR1-SR1</incoming>
      <outgoing>SR1-CIPI1</outgoing>
    </task>
    <task id="CIPI1" name="Conduct initial phone interviews">
      <incoming>SR1-CIPI1</incoming>
      <outgoing>CIPI1-ICI1</outgoing>
    </task>
    <task id="ICI1" name="Invite candidates for interviews">
      <incoming>CIPI1-ICI1</incoming>
      <outgoing>ICI1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>ICI1-G0</incoming>
      <outgoing>G0-CIPI2</outgoing>
      <outgoing>G0-CVI1</outgoing>
    </exclusiveGateway>
    <task id="CIPI2" name="Conduct an in-person interview">
      <incoming>G0-CIPI2</incoming>
      <outgoing>CIPI2-XORCLOSE10</outgoing>
    </task>
    <task id="CVI1" name="Conduct a virtual interview">
      <incoming>G0-CVI1</incoming>
      <outgoing>CVI1-XORCLOSE10</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE10" name="XORCLOSE10">
      <incoming>CIPI2-XORCLOSE10</incoming>
      <incoming>CVI1-XORCLOSE10</incoming>
      <outgoing>XORCLOSE10-CC1</outgoing>
    </exclusiveGateway>
    <task id="CC1" name="Choose candidate">
      <incoming>XORCLOSE10-CC1</incoming>
      <outgoing>CC1-EO1</outgoing>
    </task>
    <task id="EO1" name="Extend offer">
      <incoming>CC1-EO1</incoming>
      <outgoing>EO1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>EO1-G1</incoming>
      <outgoing>G1-NS1</outgoing>
      <outgoing>G1-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="NS1" name="Negotiate salary">
      <incoming>G1-NS1</incoming>
      <outgoing>NS1-XORCLOSE17</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE17" name="XORCLOSE17">
      <incoming>G1-XORCLOSE17</incoming>
      <incoming>NS1-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-BOP1</outgoing>
    </exclusiveGateway>
    <task id="BOP1" name="Begin onboarding process">
      <incoming>XORCLOSE17-BOP1</incoming>
      <outgoing>BOP1-Par19</outgoing>
    </task>
    <parallelGateway id="Par19" name="PAR">
      <incoming>BOP1-Par19</incoming>
      <outgoing>Par19-CO1</outgoing>
      <outgoing>Par19-CT1</outgoing>
    </parallelGateway>
    <task id="CO1" name="Complete orientation">
      <incoming>Par19-CO1</incoming>
      <outgoing>CO1-CP1</outgoing>
    </task>
    <task id="CT1" name="Complete training">
      <incoming>Par19-CT1</incoming>
      <outgoing>CT1-PARCLOSE23</outgoing>
    </task>
    <task id="CP1" name="Complete paperwork">
      <incoming>CO1-CP1</incoming>
      <outgoing>CP1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>CT1-PARCLOSE23</incoming>
      <incoming>CP1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE23-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-INH1" sourceRef="Default_init" targetRef="INH1"/>
    <sequenceFlow id="INH1-CJD1" sourceRef="INH1" targetRef="CJD1"/>
    <sequenceFlow id="CJD1-PJD1" sourceRef="CJD1" targetRef="PJD1"/>
    <sequenceFlow id="PJD1-CR1" sourceRef="PJD1" targetRef="CR1"/>
    <sequenceFlow id="CR1-SR1" sourceRef="CR1" targetRef="SR1"/>
    <sequenceFlow id="SR1-CIPI1" sourceRef="SR1" targetRef="CIPI1"/>
    <sequenceFlow id="CIPI1-ICI1" sourceRef="CIPI1" targetRef="ICI1"/>
    <sequenceFlow id="ICI1-G0" sourceRef="ICI1" targetRef="G0"/>
    <sequenceFlow id="G0-CIPI2" sourceRef="G0" targetRef="CIPI2"/>
    <sequenceFlow id="G0-CVI1" sourceRef="G0" targetRef="CVI1"/>
    <sequenceFlow id="CIPI2-XORCLOSE10" sourceRef="CIPI2" targetRef="XORCLOSE10"/>
    <sequenceFlow id="CVI1-XORCLOSE10" sourceRef="CVI1" targetRef="XORCLOSE10"/>
    <sequenceFlow id="XORCLOSE10-CC1" sourceRef="XORCLOSE10" targetRef="CC1"/>
    <sequenceFlow id="CC1-EO1" sourceRef="CC1" targetRef="EO1"/>
    <sequenceFlow id="EO1-G1" sourceRef="EO1" targetRef="G1"/>
    <sequenceFlow id="G1-NS1" sourceRef="G1" targetRef="NS1"/>
    <sequenceFlow id="G1-XORCLOSE17" sourceRef="G1" targetRef="XORCLOSE17"/>
    <sequenceFlow id="NS1-XORCLOSE17" sourceRef="NS1" targetRef="XORCLOSE17"/>
    <sequenceFlow id="XORCLOSE17-BOP1" sourceRef="XORCLOSE17" targetRef="BOP1"/>
    <sequenceFlow id="BOP1-Par19" sourceRef="BOP1" targetRef="Par19"/>
    <sequenceFlow id="Par19-CO1" sourceRef="Par19" targetRef="CO1"/>
    <sequenceFlow id="Par19-CT1" sourceRef="Par19" targetRef="CT1"/>
    <sequenceFlow id="CO1-CP1" sourceRef="CO1" targetRef="CP1"/>
    <sequenceFlow id="CT1-PARCLOSE23" sourceRef="CT1" targetRef="PARCLOSE23"/>
    <sequenceFlow id="CP1-PARCLOSE23" sourceRef="CP1" targetRef="PARCLOSE23"/>
    <sequenceFlow id="PARCLOSE23-END" sourceRef="PARCLOSE23" targetRef="END"/>
  </process>
