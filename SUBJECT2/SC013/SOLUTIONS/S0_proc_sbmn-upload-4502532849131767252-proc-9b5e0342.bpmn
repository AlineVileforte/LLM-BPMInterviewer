<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_d01c2a2b-ae05-4543-ac89-c0a8d97fccea" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-AONPT1</outgoing>
    </startEvent>
    <task id="AONPT1" name="Ask old and new pick-up time">
      <incoming>Default_init-AONPT1</incoming>
      <outgoing>AONPT1-XOR_JMPBB_ANPT1_CSPD1</outgoing>
    </task>
    <task id="CSPD1" name="Check if script still pending data entry">
      <incoming>XOR_JMPBB_ANPT1_CSPD1-CSPD1</incoming>
      <outgoing>CSPD1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CSPD1-G0</incoming>
      <outgoing>G0-DEPT1</outgoing>
      <outgoing>G0-CPTS1</outgoing>
    </exclusiveGateway>
    <task id="DEPT1" name="Decline earlier pick-up time">
      <incoming>G0-DEPT1</incoming>
      <outgoing>DEPT1-XORCLOSE6</outgoing>
    </task>
    <task id="CPTS1" name="Change pick-up time on script">
      <incoming>G0-CPTS1</incoming>
      <outgoing>CPTS1-ANPT1</outgoing>
    </task>
    <task id="ANPT1" name="Approve new pickup time">
      <incoming>CPTS1-ANPT1</incoming>
      <outgoing>ANPT1-XOR_JMPAA_ANPT1_CSPD1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE6" name="XORCLOSE6">
      <incoming>DEPT1-XORCLOSE6</incoming>
      <incoming>XOR_JMPAA_ANPT1_CSPD1-XORCLOSE6</incoming>
      <outgoing>XORCLOSE6-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE6-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_ANPT1_CSPD1" name="XOR_JMPAA_Approve new pickup time">
      <incoming>ANPT1-XOR_JMPAA_ANPT1_CSPD1</incoming>
      <outgoing>XOR_JMPAA_ANPT1_CSPD1-XORCLOSE6</outgoing>
      <outgoing>XOR_JMPAA_ANPT1_CSPD1-XOR_JMPBB_ANPT1_CSPD1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_ANPT1_CSPD1" name="XOR_JMPBB_Check if script still pending data entry">
      <incoming>AONPT1-XOR_JMPBB_ANPT1_CSPD1</incoming>
      <incoming>XOR_JMPAA_ANPT1_CSPD1-XOR_JMPBB_ANPT1_CSPD1</incoming>
      <outgoing>XOR_JMPBB_ANPT1_CSPD1-CSPD1</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Default_init-AONPT1" sourceRef="Default_init" targetRef="AONPT1"/>
    <sequenceFlow id="AONPT1-XOR_JMPBB_ANPT1_CSPD1" sourceRef="AONPT1" targetRef="XOR_JMPBB_ANPT1_CSPD1"/>
    <sequenceFlow id="CSPD1-G0" sourceRef="CSPD1" targetRef="G0"/>
    <sequenceFlow id="G0-DEPT1" sourceRef="G0" targetRef="DEPT1"/>
    <sequenceFlow id="G0-CPTS1" sourceRef="G0" targetRef="CPTS1"/>
    <sequenceFlow id="DEPT1-XORCLOSE6" sourceRef="DEPT1" targetRef="XORCLOSE6"/>
    <sequenceFlow id="CPTS1-ANPT1" sourceRef="CPTS1" targetRef="ANPT1"/>
    <sequenceFlow id="ANPT1-XOR_JMPAA_ANPT1_CSPD1" sourceRef="ANPT1" targetRef="XOR_JMPAA_ANPT1_CSPD1"/>
    <sequenceFlow id="XORCLOSE6-END" sourceRef="XORCLOSE6" targetRef="END"/>
    <sequenceFlow id="XOR_JMPAA_ANPT1_CSPD1-XORCLOSE6" sourceRef="XOR_JMPAA_ANPT1_CSPD1" targetRef="XORCLOSE6"/>
    <sequenceFlow id="XOR_JMPAA_ANPT1_CSPD1-XOR_JMPBB_ANPT1_CSPD1" sourceRef="XOR_JMPAA_ANPT1_CSPD1" targetRef="XOR_JMPBB_ANPT1_CSPD1"/>
    <sequenceFlow id="XOR_JMPBB_ANPT1_CSPD1-CSPD1" sourceRef="XOR_JMPBB_ANPT1_CSPD1" targetRef="CSPD1"/>
  </process>
