<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_56539813-3368-4e02-a1be-e1d63433227a" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-AONPT1</outgoing>
    </startEvent>
    <task id="AONPT1" name="Ask old and new pick-up time">
      <incoming>Default_init-AONPT1</incoming>
      <outgoing>AONPT1-XOR_JMPBB_ANPT1_CSPD1</outgoing>
    </task>
    <task id="CSPD1" name="Check if script still pending data entry">
      <incoming>XOR_JMPBB_ANPT1_CSPD1-CSPD1</incoming>
      <outgoing>CSPD1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CSPD1-G0</incoming>
      <outgoing>G0-DEPT1</outgoing>
      <outgoing>G0-Par4</outgoing>
    </exclusiveGateway>
    <task id="DEPT1" name="Decline earlier pick-up time">
      <incoming>G0-DEPT1</incoming>
      <outgoing>DEPT1-XORCLOSE8</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>G0-Par4</incoming>
      <outgoing>Par4-CPTS1</outgoing>
      <outgoing>Par4-ANPT1</outgoing>
    </parallelGateway>
    <task id="CPTS1" name="Change pick-up time on script">
      <incoming>Par4-CPTS1</incoming>
      <outgoing>CPTS1-PARCLOSE7</outgoing>
    </task>
    <task id="ANPT1" name="Approve new pickup time">
      <incoming>Par4-ANPT1</incoming>
      <outgoing>ANPT1-XOR_JMPAA_ANPT1_CSPD1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE7" name="PARCLOSE7">
      <incoming>CPTS1-PARCLOSE7</incoming>
      <incoming>XOR_JMPAA_ANPT1_CSPD1-PARCLOSE7</incoming>
      <outgoing>PARCLOSE7-XORCLOSE8</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE8" name="XORCLOSE8">
      <incoming>DEPT1-XORCLOSE8</incoming>
      <incoming>PARCLOSE7-XORCLOSE8</incoming>
      <outgoing>XORCLOSE8-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE8-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_ANPT1_CSPD1" name="XOR_JMPAA_Approve new pickup time">
      <incoming>ANPT1-XOR_JMPAA_ANPT1_CSPD1</incoming>
      <outgoing>XOR_JMPAA_ANPT1_CSPD1-PARCLOSE7</outgoing>
      <outgoing>XOR_JMPAA_ANPT1_CSPD1-XOR_JMPBB_ANPT1_CSPD1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_ANPT1_CSPD1" name="XOR_JMPBB_Check if script still pending data entry">
      <incoming>AONPT1-XOR_JMPBB_ANPT1_CSPD1</incoming>
      <incoming>XOR_JMPAA_ANPT1_CSPD1-XOR_JMPBB_ANPT1_CSPD1</incoming>
      <outgoing>XOR_JMPBB_ANPT1_CSPD1-CSPD1</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Default_init-AONPT1" sourceRef="Default_init" targetRef="AONPT1"/>
    <sequenceFlow id="AONPT1-XOR_JMPBB_ANPT1_CSPD1" sourceRef="AONPT1" targetRef="XOR_JMPBB_ANPT1_CSPD1"/>
