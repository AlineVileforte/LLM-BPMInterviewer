    <sequenceFlow id="Par4-ANPT1" sourceRef="Par4" targetRef="ANPT1"/>
    <sequenceFlow id="CPTS1-PARCLOSE7" sourceRef="CPTS1" targetRef="PARCLOSE7"/>
    <sequenceFlow id="ANPT1-XOR_JMPAA_ANPT1_CSPD1" sourceRef="ANPT1" targetRef="XOR_JMPAA_ANPT1_CSPD1"/>
    <sequenceFlow id="PARCLOSE7-XORCLOSE8" sourceRef="PARCLOSE7" targetRef="XORCLOSE8"/>
    <sequenceFlow id="XORCLOSE8-END" sourceRef="XORCLOSE8" targetRef="END"/>
    <sequenceFlow id="XOR_JMPAA_ANPT1_CSPD1-PARCLOSE7" sourceRef="XOR_JMPAA_ANPT1_CSPD1" targetRef="PARCLOSE7"/>
    <sequenceFlow id="XOR_JMPAA_ANPT1_CSPD1-XOR_JMPBB_ANPT1_CSPD1" sourceRef="XOR_JMPAA_ANPT1_CSPD1" targetRef="XOR_JMPBB_ANPT1_CSPD1"/>
    <sequenceFlow id="XOR_JMPBB_ANPT1_CSPD1-CSPD1" sourceRef="XOR_JMPBB_ANPT1_CSPD1" targetRef="CSPD1"/>
  </process>
