<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_5525d6a4-eb04-4a93-bc29-c0d6a872373f" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CCIL1</outgoing>
    </startEvent>
    <task id="CCIL1" name="Check current inventory level">
      <incoming>Default_init-CCIL1</incoming>
      <outgoing>CCIL1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CCIL1-G0</incoming>
      <outgoing>G0-SAA1</outgoing>
      <outgoing>G0-SMA1</outgoing>
    </exclusiveGateway>
    <task id="SAA1" name="Send an automated alert">
      <incoming>G0-SAA1</incoming>
      <outgoing>SAA1-XORCLOSE4</outgoing>
    </task>
    <task id="SMA1" name="Send a manual alert">
      <incoming>G0-SMA1</incoming>
      <outgoing>SMA1-XORCLOSE4</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE4" name="XORCLOSE4">
      <incoming>SAA1-XORCLOSE4</incoming>
      <incoming>SMA1-XORCLOSE4</incoming>
      <outgoing>XORCLOSE4-POS1</outgoing>
    </exclusiveGateway>
    <task id="POS1" name="Place order with suppliers">
      <incoming>XORCLOSE4-POS1</incoming>
      <outgoing>POS1-UIS1</outgoing>
    </task>
    <task id="UIS1" name="Update inventory system with expected delivery dates">
      <incoming>POS1-UIS1</incoming>
      <outgoing>UIS1-RS1</outgoing>
    </task>
    <task id="RS1" name="Receive stock">
      <incoming>UIS1-RS1</incoming>
      <outgoing>RS1-RSS1</outgoing>
    </task>
    <task id="RSS1" name="Record stock in system">
      <incoming>RS1-RSS1</incoming>
      <outgoing>RSS1-ISQ1</outgoing>
    </task>
    <task id="ISQ1" name="Inspect stock for quality">
      <incoming>RSS1-ISQ1</incoming>
      <outgoing>ISQ1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>ISQ1-G1</incoming>
      <outgoing>G1-PSOS1</outgoing>
      <outgoing>G1-PSIS1</outgoing>
    </exclusiveGateway>
    <task id="PSOS1" name="Place stock on shelves">
      <incoming>G1-PSOS1</incoming>
      <outgoing>PSOS1-XORCLOSE13</outgoing>
    </task>
    <task id="PSIS1" name="Place stock in storage">
      <incoming>G1-PSIS1</incoming>
      <outgoing>PSIS1-XORCLOSE13</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE13" name="XORCLOSE13">
      <incoming>PSOS1-XORCLOSE13</incoming>
      <incoming>PSIS1-XORCLOSE13</incoming>
      <outgoing>XORCLOSE13-G2</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G2" name="G2">
      <incoming>XORCLOSE13-G2</incoming>
      <outgoing>G2-UIL1</outgoing>
      <outgoing>G2-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="UIL1" name="Update inventory levels">
      <incoming>G2-UIL1</incoming>
      <outgoing>UIL1-XORCLOSE18</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>G2-XORCLOSE18</incoming>
      <incoming>UIL1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE18-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-CCIL1" sourceRef="Default_init" targetRef="CCIL1"/>
    <sequenceFlow id="CCIL1-G0" sourceRef="CCIL1" targetRef="G0"/>
    <sequenceFlow id="G0-SAA1" sourceRef="G0" targetRef="SAA1"/>
    <sequenceFlow id="G0-SMA1" sourceRef="G0" targetRef="SMA1"/>
    <sequenceFlow id="SAA1-XORCLOSE4" sourceRef="SAA1" targetRef="XORCLOSE4"/>
    <sequenceFlow id="SMA1-XORCLOSE4" sourceRef="SMA1" targetRef="XORCLOSE4"/>
    <sequenceFlow id="XORCLOSE4-POS1" sourceRef="XORCLOSE4" targetRef="POS1"/>
    <sequenceFlow id="POS1-UIS1" sourceRef="POS1" targetRef="UIS1"/>
    <sequenceFlow id="UIS1-RS1" sourceRef="UIS1" targetRef="RS1"/>
    <sequenceFlow id="RS1-RSS1" sourceRef="RS1" targetRef="RSS1"/>
    <sequenceFlow id="RSS1-ISQ1" sourceRef="RSS1" targetRef="ISQ1"/>
    <sequenceFlow id="ISQ1-G1" sourceRef="ISQ1" targetRef="G1"/>
    <sequenceFlow id="G1-PSOS1" sourceRef="G1" targetRef="PSOS1"/>
    <sequenceFlow id="G1-PSIS1" sourceRef="G1" targetRef="PSIS1"/>
    <sequenceFlow id="PSOS1-XORCLOSE13" sourceRef="PSOS1" targetRef="XORCLOSE13"/>
    <sequenceFlow id="PSIS1-XORCLOSE13" sourceRef="PSIS1" targetRef="XORCLOSE13"/>
    <sequenceFlow id="XORCLOSE13-G2" sourceRef="XORCLOSE13" targetRef="G2"/>
    <sequenceFlow id="G2-UIL1" sourceRef="G2" targetRef="UIL1"/>
    <sequenceFlow id="G2-XORCLOSE18" sourceRef="G2" targetRef="XORCLOSE18"/>
    <sequenceFlow id="UIL1-XORCLOSE18" sourceRef="UIL1" targetRef="XORCLOSE18"/>
    <sequenceFlow id="XORCLOSE18-END" sourceRef="XORCLOSE18" targetRef="END"/>
  </process>
