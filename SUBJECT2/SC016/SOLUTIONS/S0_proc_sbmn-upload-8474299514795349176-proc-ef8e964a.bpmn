<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_54afa7bd-a63c-4fdb-9598-5e2417aedef9" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-EHW1</outgoing>
    </startEvent>
    <task id="EHW1" name="Enter the Hoyts website">
      <incoming>Default_init-EHW1</incoming>
      <outgoing>EHW1-XOR_JMPBB_LNCD1_LNCD1</outgoing>
    </task>
    <task id="LNCD1" name="Look for the La Nacion card for the discount">
      <incoming>XOR_JMPBB_LNCD1_LNCD1-LNCD1</incoming>
      <outgoing>LNCD1-XOR_JMPAA_LNCD1_LNCD1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>XOR_JMPAA_LNCD1_LNCD1-G0</incoming>
      <outgoing>G0-CCCD1</outgoing>
      <outgoing>G0-XORCLOSE15</outgoing>
    </exclusiveGateway>
    <task id="CCCD1" name="Look for the Citi card for the discount">
      <incoming>G0-CCCD1</incoming>
      <outgoing>CCCD1-XOR_JMPAA_CCCD1_PTW1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>XOR_JMPAA_CCCD1_PTW1-G1</incoming>
      <outgoing>G1-SML1</outgoing>
      <outgoing>G1-XORCLOSE14</outgoing>
    </exclusiveGateway>
    <task id="SML1" name="Search for a movie I like at a convenient time">
      <incoming>G1-SML1</incoming>
      <outgoing>SML1-XOR_JMPBB_CCCD1_PTW1</outgoing>
    </task>
    <task id="PTW1" name="Pay for the tickets through the website">
      <incoming>XOR_JMPBB_CCCD1_PTW1-PTW1</incoming>
      <outgoing>PTW1-PT1</outgoing>
    </task>
    <task id="PT1" name="Print the tickets">
      <incoming>PTW1-PT1</incoming>
      <outgoing>PT1-BP1</outgoing>
    </task>
    <task id="BP1" name="Buy popcorn">
      <incoming>PT1-BP1</incoming>
      <outgoing>BP1-HTC1</outgoing>
    </task>
    <task id="HTC1" name="Hand the tickets to the ticket clerk">
      <incoming>BP1-HTC1</incoming>
      <outgoing>HTC1-SDT1</outgoing>
    </task>
    <task id="SDT1" name="Sit down in the theater">
      <incoming>HTC1-SDT1</incoming>
      <outgoing>SDT1-DTC1</outgoing>
    </task>
    <task id="DTC1" name="Drive to the cinema">
      <incoming>SDT1-DTC1</incoming>
      <outgoing>DTC1-XORCLOSE14</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>G1-XORCLOSE14</incoming>
      <incoming>DTC1-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-XORCLOSE15</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE15" name="XORCLOSE15">
      <incoming>G0-XORCLOSE15</incoming>
      <incoming>XORCLOSE14-XORCLOSE15</incoming>
      <outgoing>XORCLOSE15-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE15-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_LNCD1_LNCD1" name="XOR_JMPAA_Look for the La Nacion card for the discount">
