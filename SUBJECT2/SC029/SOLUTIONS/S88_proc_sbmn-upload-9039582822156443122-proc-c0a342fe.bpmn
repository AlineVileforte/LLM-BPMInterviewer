    <sequenceFlow id="XORCLOSE7-LR1" sourceRef="XORCLOSE7" targetRef="LR1"/>
    <sequenceFlow id="LR1-CF1" sourceRef="LR1" targetRef="CF1"/>
    <sequenceFlow id="CF1-AR1" sourceRef="CF1" targetRef="AR1"/>
    <sequenceFlow id="AR1-Par11" sourceRef="AR1" targetRef="Par11"/>
    <sequenceFlow id="Par11-GI1" sourceRef="Par11" targetRef="GI1"/>
    <sequenceFlow id="Par11-CR1" sourceRef="Par11" targetRef="CR1"/>
    <sequenceFlow id="GI1-IC1" sourceRef="GI1" targetRef="IC1"/>
    <sequenceFlow id="IC1-PC1" sourceRef="IC1" targetRef="PC1"/>
    <sequenceFlow id="CR1-NS1" sourceRef="CR1" targetRef="NS1"/>
    <sequenceFlow id="PC1-PARCLOSE17" sourceRef="PC1" targetRef="PARCLOSE17"/>
    <sequenceFlow id="NS1-PARCLOSE17" sourceRef="NS1" targetRef="PARCLOSE17"/>
    <sequenceFlow id="PARCLOSE17-END" sourceRef="PARCLOSE17" targetRef="END"/>
  </process>
