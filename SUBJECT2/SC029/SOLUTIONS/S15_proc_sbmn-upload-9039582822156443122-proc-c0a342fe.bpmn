<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_1fd338c1-f73d-4e44-942c-e87447caeec5" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-RI1</outgoing>
    </startEvent>
    <task id="RI1" name="Report incident">
      <incoming>Default_init-RI1</incoming>
      <outgoing>RI1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>RI1-G1</incoming>
      <outgoing>G1-IF1</outgoing>
      <outgoing>G1-G2</outgoing>
    </exclusiveGateway>
    <task id="IF1" name="Implement fix">
      <incoming>G1-IF1</incoming>
      <outgoing>IF1-XORCLOSE7</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>G1-G2</incoming>
      <outgoing>G2-CT1</outgoing>
      <outgoing>G2-CP1</outgoing>
    </exclusiveGateway>
    <task id="CT1" name="Conduct training">
      <incoming>G2-CT1</incoming>
      <outgoing>CT1-XORCLOSE6</outgoing>
    </task>
    <task id="CP1" name="Change policy">
      <incoming>G2-CP1</incoming>
      <outgoing>CP1-XORCLOSE6</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE6" name="XORCLOSE6">
      <incoming>CT1-XORCLOSE6</incoming>
      <incoming>CP1-XORCLOSE6</incoming>
      <outgoing>XORCLOSE6-XORCLOSE7</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE7" name="XORCLOSE7">
      <incoming>IF1-XORCLOSE7</incoming>
      <incoming>XORCLOSE6-XORCLOSE7</incoming>
      <outgoing>XORCLOSE7-Par8</outgoing>
    </exclusiveGateway>
    <parallelGateway id="Par8" name="PAR">
      <incoming>XORCLOSE7-Par8</incoming>
      <outgoing>Par8-LR1</outgoing>
      <outgoing>Par8-CF1</outgoing>
    </parallelGateway>
    <task id="LR1" name="Log report into tracking system">
      <incoming>Par8-LR1</incoming>
      <outgoing>LR1-AR1</outgoing>
    </task>
    <task id="CF1" name="Conduct follow-up">
      <incoming>Par8-CF1</incoming>
      <outgoing>CF1-CR1</outgoing>
    </task>
    <task id="AR1" name="Assign report to appropriate team">
      <incoming>LR1-AR1</incoming>
      <outgoing>AR1-Par13</outgoing>
    </task>
    <task id="CR1" name="Close incident report">
      <incoming>CF1-CR1</incoming>
      <outgoing>CR1-NS1</outgoing>
    </task>
    <parallelGateway id="Par13" name="PAR">
      <incoming>AR1-Par13</incoming>
      <outgoing>Par13-GI1</outgoing>
      <outgoing>Par13-IC1</outgoing>
    </parallelGateway>
    <task id="GI1" name="Gather necessary information">
      <incoming>Par13-GI1</incoming>
      <outgoing>GI1-PARCLOSE18</outgoing>
    </task>
    <task id="IC1" name="Identify cause of incident">
      <incoming>Par13-IC1</incoming>
      <outgoing>IC1-PC1</outgoing>
    </task>
    <task id="NS1" name="Notify all stakeholders">
      <incoming>CR1-NS1</incoming>
      <outgoing>NS1-PARCLOSE19</outgoing>
    </task>
    <task id="PC1" name="Propose corrective actions">
      <incoming>IC1-PC1</incoming>
      <outgoing>PC1-PARCLOSE18</outgoing>
    </task>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>GI1-PARCLOSE18</incoming>
      <incoming>PC1-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-PARCLOSE19</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>NS1-PARCLOSE19</incoming>
      <incoming>PARCLOSE18-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE19-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-RI1" sourceRef="Default_init" targetRef="RI1"/>
