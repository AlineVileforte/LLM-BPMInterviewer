    <sequenceFlow id="AR1-PARCLOSE14" sourceRef="AR1" targetRef="PARCLOSE14"/>
    <sequenceFlow id="NS1-PARCLOSE14" sourceRef="NS1" targetRef="PARCLOSE14"/>
    <sequenceFlow id="PARCLOSE14-GI1" sourceRef="PARCLOSE14" targetRef="GI1"/>
    <sequenceFlow id="GI1-IC1" sourceRef="GI1" targetRef="IC1"/>
    <sequenceFlow id="IC1-PC1" sourceRef="IC1" targetRef="PC1"/>
    <sequenceFlow id="PC1-END" sourceRef="PC1" targetRef="END"/>
  </process>
