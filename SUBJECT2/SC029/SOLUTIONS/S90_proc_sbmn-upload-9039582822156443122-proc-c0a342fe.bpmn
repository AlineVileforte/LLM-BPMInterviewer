    <sequenceFlow id="XORCLOSE7-LR1" sourceRef="XORCLOSE7" targetRef="LR1"/>
    <sequenceFlow id="LR1-AR1" sourceRef="LR1" targetRef="AR1"/>
    <sequenceFlow id="AR1-Par10" sourceRef="AR1" targetRef="Par10"/>
    <sequenceFlow id="Par10-CF1" sourceRef="Par10" targetRef="CF1"/>
    <sequenceFlow id="Par10-Par14" sourceRef="Par10" targetRef="Par14"/>
    <sequenceFlow id="CF1-GI1" sourceRef="CF1" targetRef="GI1"/>
    <sequenceFlow id="GI1-NS1" sourceRef="GI1" targetRef="NS1"/>
    <sequenceFlow id="Par14-IC1" sourceRef="Par14" targetRef="IC1"/>
    <sequenceFlow id="Par14-CR1" sourceRef="Par14" targetRef="CR1"/>
    <sequenceFlow id="IC1-PC1" sourceRef="IC1" targetRef="PC1"/>
    <sequenceFlow id="CR1-PARCLOSE19" sourceRef="CR1" targetRef="PARCLOSE19"/>
    <sequenceFlow id="PC1-PARCLOSE19" sourceRef="PC1" targetRef="PARCLOSE19"/>
    <sequenceFlow id="PARCLOSE19-PARCLOSE21" sourceRef="PARCLOSE19" targetRef="PARCLOSE21"/>
    <sequenceFlow id="NS1-PARCLOSE21" sourceRef="NS1" targetRef="PARCLOSE21"/>
    <sequenceFlow id="PARCLOSE21-END" sourceRef="PARCLOSE21" targetRef="END"/>
  </process>
