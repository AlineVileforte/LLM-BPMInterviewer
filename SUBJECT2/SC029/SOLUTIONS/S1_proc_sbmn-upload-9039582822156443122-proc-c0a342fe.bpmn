    <sequenceFlow id="XORCLOSE7-LR1" sourceRef="XORCLOSE7" targetRef="LR1"/>
    <sequenceFlow id="LR1-Par9" sourceRef="LR1" targetRef="Par9"/>
    <sequenceFlow id="Par9-AR1" sourceRef="Par9" targetRef="AR1"/>
    <sequenceFlow id="Par9-CF1" sourceRef="Par9" targetRef="CF1"/>
    <sequenceFlow id="AR1-Par12" sourceRef="AR1" targetRef="Par12"/>
    <sequenceFlow id="CF1-CR1" sourceRef="CF1" targetRef="CR1"/>
    <sequenceFlow id="Par12-GI1" sourceRef="Par12" targetRef="GI1"/>
    <sequenceFlow id="Par12-IC1" sourceRef="Par12" targetRef="IC1"/>
    <sequenceFlow id="GI1-PARCLOSE16" sourceRef="GI1" targetRef="PARCLOSE16"/>
    <sequenceFlow id="IC1-PARCLOSE16" sourceRef="IC1" targetRef="PARCLOSE16"/>
    <sequenceFlow id="CR1-NS1" sourceRef="CR1" targetRef="NS1"/>
    <sequenceFlow id="PARCLOSE16-PARCLOSE18" sourceRef="PARCLOSE16" targetRef="PARCLOSE18"/>
    <sequenceFlow id="NS1-PARCLOSE18" sourceRef="NS1" targetRef="PARCLOSE18"/>
    <sequenceFlow id="PARCLOSE18-PC1" sourceRef="PARCLOSE18" targetRef="PC1"/>
    <sequenceFlow id="PC1-END" sourceRef="PC1" targetRef="END"/>
  </process>
