    <sequenceFlow id="PC1-PARCLOSE17" sourceRef="PC1" targetRef="PARCLOSE17"/>
    <sequenceFlow id="PARCLOSE17-END" sourceRef="PARCLOSE17" targetRef="END"/>
  </process>
