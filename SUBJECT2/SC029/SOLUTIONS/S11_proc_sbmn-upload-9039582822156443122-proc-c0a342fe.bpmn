    <sequenceFlow id="AR1-GI1" sourceRef="AR1" targetRef="GI1"/>
    <sequenceFlow id="GI1-PARCLOSE15" sourceRef="GI1" targetRef="PARCLOSE15"/>
    <sequenceFlow id="PARCLOSE15-IC1" sourceRef="PARCLOSE15" targetRef="IC1"/>
    <sequenceFlow id="IC1-PC1" sourceRef="IC1" targetRef="PC1"/>
    <sequenceFlow id="PC1-END" sourceRef="PC1" targetRef="END"/>
  </process>
