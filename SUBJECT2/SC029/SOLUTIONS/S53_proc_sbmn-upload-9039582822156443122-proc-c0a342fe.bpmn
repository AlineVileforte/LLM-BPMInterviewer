    <sequenceFlow id="RI1-Par8" sourceRef="RI1" targetRef="Par8"/>
    <sequenceFlow id="Par8-LR1" sourceRef="Par8" targetRef="LR1"/>
    <sequenceFlow id="Par8-CF1" sourceRef="Par8" targetRef="CF1"/>
    <sequenceFlow id="LR1-AR1" sourceRef="LR1" targetRef="AR1"/>
    <sequenceFlow id="CF1-CR1" sourceRef="CF1" targetRef="CR1"/>
    <sequenceFlow id="AR1-IC1" sourceRef="AR1" targetRef="IC1"/>
    <sequenceFlow id="CR1-NS1" sourceRef="CR1" targetRef="NS1"/>
    <sequenceFlow id="IC1-GI1" sourceRef="IC1" targetRef="GI1"/>
    <sequenceFlow id="NS1-PARCLOSE16" sourceRef="NS1" targetRef="PARCLOSE16"/>
    <sequenceFlow id="GI1-PARCLOSE16" sourceRef="GI1" targetRef="PARCLOSE16"/>
    <sequenceFlow id="PARCLOSE16-PC1" sourceRef="PARCLOSE16" targetRef="PC1"/>
    <sequenceFlow id="PC1-END" sourceRef="PC1" targetRef="END"/>
  </process>
