<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_0be312e1-5397-4a33-9705-4520b1b55b0f" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-RI1</outgoing>
    </startEvent>
    <task id="RI1" name="Report incident">
      <incoming>Default_init-RI1</incoming>
      <outgoing>RI1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>RI1-G1</incoming>
      <outgoing>G1-IF1</outgoing>
      <outgoing>G1-G2</outgoing>
    </exclusiveGateway>
    <task id="IF1" name="Implement fix">
      <incoming>G1-IF1</incoming>
      <outgoing>IF1-XORCLOSE7</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>G1-G2</incoming>
      <outgoing>G2-CT1</outgoing>
      <outgoing>G2-CP1</outgoing>
    </exclusiveGateway>
    <task id="CT1" name="Conduct training">
      <incoming>G2-CT1</incoming>
      <outgoing>CT1-XORCLOSE6</outgoing>
    </task>
    <task id="CP1" name="Change policy">
      <incoming>G2-CP1</incoming>
      <outgoing>CP1-XORCLOSE6</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE6" name="XORCLOSE6">
      <incoming>CT1-XORCLOSE6</incoming>
      <incoming>CP1-XORCLOSE6</incoming>
      <outgoing>XORCLOSE6-XORCLOSE7</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE7" name="XORCLOSE7">
      <incoming>IF1-XORCLOSE7</incoming>
      <incoming>XORCLOSE6-XORCLOSE7</incoming>
      <outgoing>XORCLOSE7-CF1</outgoing>
    </exclusiveGateway>
    <task id="CF1" name="Conduct follow-up">
      <incoming>XORCLOSE7-CF1</incoming>
      <outgoing>CF1-CR1</outgoing>
    </task>
    <task id="CR1" name="Close incident report">
      <incoming>CF1-CR1</incoming>
      <outgoing>CR1-NS1</outgoing>
    </task>
    <task id="NS1" name="Notify all stakeholders">
      <incoming>CR1-NS1</incoming>
      <outgoing>NS1-LR1</outgoing>
    </task>
    <task id="LR1" name="Log report into tracking system">
      <incoming>NS1-LR1</incoming>
      <outgoing>LR1-AR1</outgoing>
    </task>
    <task id="AR1" name="Assign report to appropriate team">
      <incoming>LR1-AR1</incoming>
      <outgoing>AR1-IC1</outgoing>
    </task>
    <task id="IC1" name="Identify cause of incident">
      <incoming>AR1-IC1</incoming>
      <outgoing>IC1-PC1</outgoing>
    </task>
    <task id="PC1" name="Propose corrective actions">
      <incoming>IC1-PC1</incoming>
      <outgoing>PC1-GI1</outgoing>
    </task>
    <task id="GI1" name="Gather necessary information">
      <incoming>PC1-GI1</incoming>
      <outgoing>GI1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>GI1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-RI1" sourceRef="Default_init" targetRef="RI1"/>
    <sequenceFlow id="RI1-G1" sourceRef="RI1" targetRef="G1"/>
    <sequenceFlow id="G1-IF1" sourceRef="G1" targetRef="IF1"/>
    <sequenceFlow id="G1-G2" sourceRef="G1" targetRef="G2"/>
    <sequenceFlow id="IF1-XORCLOSE7" sourceRef="IF1" targetRef="XORCLOSE7"/>
    <sequenceFlow id="G2-CT1" sourceRef="G2" targetRef="CT1"/>
    <sequenceFlow id="G2-CP1" sourceRef="G2" targetRef="CP1"/>
    <sequenceFlow id="CT1-XORCLOSE6" sourceRef="CT1" targetRef="XORCLOSE6"/>
    <sequenceFlow id="CP1-XORCLOSE6" sourceRef="CP1" targetRef="XORCLOSE6"/>
    <sequenceFlow id="XORCLOSE6-XORCLOSE7" sourceRef="XORCLOSE6" targetRef="XORCLOSE7"/>
    <sequenceFlow id="XORCLOSE7-CF1" sourceRef="XORCLOSE7" targetRef="CF1"/>
    <sequenceFlow id="CF1-CR1" sourceRef="CF1" targetRef="CR1"/>
    <sequenceFlow id="CR1-NS1" sourceRef="CR1" targetRef="NS1"/>
    <sequenceFlow id="NS1-LR1" sourceRef="NS1" targetRef="LR1"/>
    <sequenceFlow id="LR1-AR1" sourceRef="LR1" targetRef="AR1"/>
    <sequenceFlow id="AR1-IC1" sourceRef="AR1" targetRef="IC1"/>
    <sequenceFlow id="IC1-PC1" sourceRef="IC1" targetRef="PC1"/>
    <sequenceFlow id="PC1-GI1" sourceRef="PC1" targetRef="GI1"/>
    <sequenceFlow id="GI1-END" sourceRef="GI1" targetRef="END"/>
  </process>
