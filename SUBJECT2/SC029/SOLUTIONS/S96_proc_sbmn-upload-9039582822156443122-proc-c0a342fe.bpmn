    <sequenceFlow id="NS1-PARCLOSE17" sourceRef="NS1" targetRef="PARCLOSE17"/>
    <sequenceFlow id="PARCLOSE17-END" sourceRef="PARCLOSE17" targetRef="END"/>
  </process>
