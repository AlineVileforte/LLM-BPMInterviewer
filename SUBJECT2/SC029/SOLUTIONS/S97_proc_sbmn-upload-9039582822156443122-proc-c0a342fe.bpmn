    <sequenceFlow id="AR1-Par15" sourceRef="AR1" targetRef="Par15"/>
    <sequenceFlow id="Par15-GI1" sourceRef="Par15" targetRef="GI1"/>
    <sequenceFlow id="Par15-IC1" sourceRef="Par15" targetRef="IC1"/>
    <sequenceFlow id="GI1-PARCLOSE19" sourceRef="GI1" targetRef="PARCLOSE19"/>
    <sequenceFlow id="IC1-PC1" sourceRef="IC1" targetRef="PC1"/>
    <sequenceFlow id="PC1-PARCLOSE19" sourceRef="PC1" targetRef="PARCLOSE19"/>
    <sequenceFlow id="PARCLOSE19-END" sourceRef="PARCLOSE19" targetRef="END"/>
  </process>
