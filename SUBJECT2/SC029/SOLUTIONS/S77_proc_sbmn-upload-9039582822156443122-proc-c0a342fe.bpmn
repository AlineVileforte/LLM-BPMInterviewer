    <sequenceFlow id="AR1-Par14" sourceRef="AR1" targetRef="Par14"/>
    <sequenceFlow id="NS1-PARCLOSE18" sourceRef="NS1" targetRef="PARCLOSE18"/>
    <sequenceFlow id="Par14-GI1" sourceRef="Par14" targetRef="GI1"/>
    <sequenceFlow id="Par14-IC1" sourceRef="Par14" targetRef="IC1"/>
    <sequenceFlow id="GI1-PARCLOSE17" sourceRef="GI1" targetRef="PARCLOSE17"/>
    <sequenceFlow id="IC1-PARCLOSE17" sourceRef="IC1" targetRef="PARCLOSE17"/>
    <sequenceFlow id="PARCLOSE17-PARCLOSE18" sourceRef="PARCLOSE17" targetRef="PARCLOSE18"/>
    <sequenceFlow id="PARCLOSE18-PC1" sourceRef="PARCLOSE18" targetRef="PC1"/>
    <sequenceFlow id="PC1-END" sourceRef="PC1" targetRef="END"/>
  </process>
