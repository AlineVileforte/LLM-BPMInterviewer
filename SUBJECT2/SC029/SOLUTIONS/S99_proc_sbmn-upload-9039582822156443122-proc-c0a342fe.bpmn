    <sequenceFlow id="XORCLOSE6-RI1" sourceRef="XORCLOSE6" targetRef="RI1"/>
    <sequenceFlow id="RI1-CF1" sourceRef="RI1" targetRef="CF1"/>
    <sequenceFlow id="CF1-Par9" sourceRef="CF1" targetRef="Par9"/>
    <sequenceFlow id="Par9-LR1" sourceRef="Par9" targetRef="LR1"/>
    <sequenceFlow id="Par9-CR1" sourceRef="Par9" targetRef="CR1"/>
    <sequenceFlow id="LR1-AR1" sourceRef="LR1" targetRef="AR1"/>
    <sequenceFlow id="CR1-NS1" sourceRef="CR1" targetRef="NS1"/>
    <sequenceFlow id="AR1-IC1" sourceRef="AR1" targetRef="IC1"/>
    <sequenceFlow id="NS1-PARCLOSE15" sourceRef="NS1" targetRef="PARCLOSE15"/>
    <sequenceFlow id="IC1-PARCLOSE15" sourceRef="IC1" targetRef="PARCLOSE15"/>
    <sequenceFlow id="PARCLOSE15-GI1" sourceRef="PARCLOSE15" targetRef="GI1"/>
    <sequenceFlow id="GI1-PC1" sourceRef="GI1" targetRef="PC1"/>
    <sequenceFlow id="PC1-END" sourceRef="PC1" targetRef="END"/>
  </process>
