<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_fc8cfa3a-1d9e-4699-9c3b-4e48a9f9b917" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-G0</outgoing>
    </startEvent>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Default_init-G0</incoming>
      <outgoing>G0-IF1</outgoing>
      <outgoing>G0-G1</outgoing>
    </exclusiveGateway>
    <task id="IF1" name="Implement fix">
      <incoming>G0-IF1</incoming>
      <outgoing>IF1-XORCLOSE6</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>G0-G1</incoming>
      <outgoing>G1-CT1</outgoing>
      <outgoing>G1-CP1</outgoing>
    </exclusiveGateway>
    <task id="CT1" name="Conduct training">
      <incoming>G1-CT1</incoming>
      <outgoing>CT1-XORCLOSE5</outgoing>
    </task>
    <task id="CP1" name="Change policy">
      <incoming>G1-CP1</incoming>
      <outgoing>CP1-XORCLOSE5</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE5" name="XORCLOSE5">
      <incoming>CT1-XORCLOSE5</incoming>
      <incoming>CP1-XORCLOSE5</incoming>
      <outgoing>XORCLOSE5-XORCLOSE6</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE6" name="XORCLOSE6">
      <incoming>IF1-XORCLOSE6</incoming>
      <incoming>XORCLOSE5-XORCLOSE6</incoming>
      <outgoing>XORCLOSE6-RI1</outgoing>
    </exclusiveGateway>
    <task id="RI1" name="Report incident">
      <incoming>XORCLOSE6-RI1</incoming>
      <outgoing>RI1-CF1</outgoing>
    </task>
    <task id="CF1" name="Conduct follow-up">
      <incoming>RI1-CF1</incoming>
      <outgoing>CF1-Par9</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>CF1-Par9</incoming>
      <outgoing>Par9-LR1</outgoing>
      <outgoing>Par9-CR1</outgoing>
    </parallelGateway>
    <task id="LR1" name="Log report into tracking system">
      <incoming>Par9-LR1</incoming>
      <outgoing>LR1-AR1</outgoing>
    </task>
    <task id="CR1" name="Close incident report">
      <incoming>Par9-CR1</incoming>
      <outgoing>CR1-NS1</outgoing>
    </task>
    <task id="AR1" name="Assign report to appropriate team">
      <incoming>LR1-AR1</incoming>
      <outgoing>AR1-IC1</outgoing>
    </task>
    <task id="NS1" name="Notify all stakeholders">
      <incoming>CR1-NS1</incoming>
      <outgoing>NS1-PARCLOSE15</outgoing>
    </task>
    <task id="IC1" name="Identify cause of incident">
      <incoming>AR1-IC1</incoming>
      <outgoing>IC1-PARCLOSE15</outgoing>
    </task>
    <parallelGateway id="PARCLOSE15" name="PARCLOSE15">
      <incoming>NS1-PARCLOSE15</incoming>
      <incoming>IC1-PARCLOSE15</incoming>
      <outgoing>PARCLOSE15-GI1</outgoing>
    </parallelGateway>
    <task id="GI1" name="Gather necessary information">
      <incoming>PARCLOSE15-GI1</incoming>
      <outgoing>GI1-PC1</outgoing>
    </task>
    <task id="PC1" name="Propose corrective actions">
      <incoming>GI1-PC1</incoming>
      <outgoing>PC1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PC1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-G0" sourceRef="Default_init" targetRef="G0"/>
