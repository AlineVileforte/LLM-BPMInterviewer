<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_19d674aa-acfe-4ba4-9f0a-e70d9b42d624" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-RI1</outgoing>
    </startEvent>
    <task id="RI1" name="Report incident">
      <incoming>Default_init-RI1</incoming>
      <outgoing>RI1-LR1</outgoing>
    </task>
    <task id="LR1" name="Log report into tracking system">
      <incoming>RI1-LR1</incoming>
      <outgoing>LR1-AR1</outgoing>
    </task>
    <task id="AR1" name="Assign report to appropriate team">
      <incoming>LR1-AR1</incoming>
      <outgoing>AR1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>AR1-Par3</incoming>
      <outgoing>Par3-IC1</outgoing>
      <outgoing>Par3-G3</outgoing>
    </parallelGateway>
    <task id="IC1" name="Identify cause of incident">
      <incoming>Par3-IC1</incoming>
      <outgoing>IC1-PC1</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>Par3-G3</incoming>
      <outgoing>G3-IF1</outgoing>
      <outgoing>G3-G4</outgoing>
    </exclusiveGateway>
    <task id="IF1" name="Implement fix">
      <incoming>G3-IF1</incoming>
      <outgoing>IF1-XORCLOSE13</outgoing>
    </task>
    <task id="PC1" name="Propose corrective actions">
      <incoming>IC1-PC1</incoming>
      <outgoing>PC1-GI1</outgoing>
    </task>
    <exclusiveGateway id="G4" name="G4">
      <incoming>G3-G4</incoming>
      <outgoing>G4-CT1</outgoing>
      <outgoing>G4-CP1</outgoing>
    </exclusiveGateway>
    <task id="CT1" name="Conduct training">
      <incoming>G4-CT1</incoming>
      <outgoing>CT1-XORCLOSE12</outgoing>
    </task>
    <task id="CP1" name="Change policy">
      <incoming>G4-CP1</incoming>
      <outgoing>CP1-XORCLOSE12</outgoing>
    </task>
    <task id="GI1" name="Gather necessary information">
      <incoming>PC1-GI1</incoming>
      <outgoing>GI1-PARCLOSE17</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE12" name="XORCLOSE12">
      <incoming>CT1-XORCLOSE12</incoming>
      <incoming>CP1-XORCLOSE12</incoming>
      <outgoing>XORCLOSE12-XORCLOSE13</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE13" name="XORCLOSE13">
      <incoming>IF1-XORCLOSE13</incoming>
      <incoming>XORCLOSE12-XORCLOSE13</incoming>
      <outgoing>XORCLOSE13-CF1</outgoing>
    </exclusiveGateway>
    <task id="CF1" name="Conduct follow-up">
      <incoming>XORCLOSE13-CF1</incoming>
      <outgoing>CF1-CR1</outgoing>
    </task>
    <task id="CR1" name="Close incident report">
      <incoming>CF1-CR1</incoming>
      <outgoing>CR1-NS1</outgoing>
    </task>
    <task id="NS1" name="Notify all stakeholders">
      <incoming>CR1-NS1</incoming>
      <outgoing>NS1-PARCLOSE17</outgoing>
    </task>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>GI1-PARCLOSE17</incoming>
      <incoming>NS1-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE17-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-RI1" sourceRef="Default_init" targetRef="RI1"/>
    <sequenceFlow id="RI1-LR1" sourceRef="RI1" targetRef="LR1"/>
    <sequenceFlow id="LR1-AR1" sourceRef="LR1" targetRef="AR1"/>
