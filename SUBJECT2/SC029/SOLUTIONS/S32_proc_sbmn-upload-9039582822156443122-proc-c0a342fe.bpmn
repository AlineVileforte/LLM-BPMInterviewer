    <sequenceFlow id="IC1-PC1" sourceRef="IC1" targetRef="PC1"/>
    <sequenceFlow id="G3-IF1" sourceRef="G3" targetRef="IF1"/>
    <sequenceFlow id="G3-G4" sourceRef="G3" targetRef="G4"/>
    <sequenceFlow id="IF1-XORCLOSE13" sourceRef="IF1" targetRef="XORCLOSE13"/>
    <sequenceFlow id="PC1-GI1" sourceRef="PC1" targetRef="GI1"/>
    <sequenceFlow id="G4-CT1" sourceRef="G4" targetRef="CT1"/>
    <sequenceFlow id="G4-CP1" sourceRef="G4" targetRef="CP1"/>
    <sequenceFlow id="CT1-XORCLOSE12" sourceRef="CT1" targetRef="XORCLOSE12"/>
    <sequenceFlow id="CP1-XORCLOSE12" sourceRef="CP1" targetRef="XORCLOSE12"/>
    <sequenceFlow id="GI1-PARCLOSE17" sourceRef="GI1" targetRef="PARCLOSE17"/>
    <sequenceFlow id="XORCLOSE12-XORCLOSE13" sourceRef="XORCLOSE12" targetRef="XORCLOSE13"/>
    <sequenceFlow id="XORCLOSE13-CF1" sourceRef="XORCLOSE13" targetRef="CF1"/>
    <sequenceFlow id="CF1-CR1" sourceRef="CF1" targetRef="CR1"/>
    <sequenceFlow id="CR1-NS1" sourceRef="CR1" targetRef="NS1"/>
    <sequenceFlow id="NS1-PARCLOSE17" sourceRef="NS1" targetRef="PARCLOSE17"/>
    <sequenceFlow id="PARCLOSE17-END" sourceRef="PARCLOSE17" targetRef="END"/>
  </process>
