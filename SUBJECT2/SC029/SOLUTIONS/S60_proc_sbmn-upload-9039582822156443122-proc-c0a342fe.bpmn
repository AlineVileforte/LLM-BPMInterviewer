    <sequenceFlow id="Par9-GI1" sourceRef="Par9" targetRef="GI1"/>
    <sequenceFlow id="Par9-IC1" sourceRef="Par9" targetRef="IC1"/>
    <sequenceFlow id="GI1-PARCLOSE13" sourceRef="GI1" targetRef="PARCLOSE13"/>
    <sequenceFlow id="IC1-PARCLOSE13" sourceRef="IC1" targetRef="PARCLOSE13"/>
    <sequenceFlow id="XORCLOSE12-XORCLOSE14" sourceRef="XORCLOSE12" targetRef="XORCLOSE14"/>
    <sequenceFlow id="PARCLOSE13-PC1" sourceRef="PARCLOSE13" targetRef="PC1"/>
    <sequenceFlow id="XORCLOSE14-PARCLOSE16" sourceRef="XORCLOSE14" targetRef="PARCLOSE16"/>
    <sequenceFlow id="PC1-PARCLOSE16" sourceRef="PC1" targetRef="PARCLOSE16"/>
    <sequenceFlow id="PARCLOSE16-CF1" sourceRef="PARCLOSE16" targetRef="CF1"/>
    <sequenceFlow id="CF1-CR1" sourceRef="CF1" targetRef="CR1"/>
    <sequenceFlow id="CR1-NS1" sourceRef="CR1" targetRef="NS1"/>
    <sequenceFlow id="NS1-END" sourceRef="NS1" targetRef="END"/>
  </process>
