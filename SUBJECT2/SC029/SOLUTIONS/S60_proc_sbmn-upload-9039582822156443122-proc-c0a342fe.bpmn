<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_9b5f7baf-04dc-4bb3-b0cf-1296ff5734c7" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-RI1</outgoing>
    </startEvent>
    <task id="RI1" name="Report incident">
      <incoming>Default_init-RI1</incoming>
      <outgoing>RI1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>RI1-Par1</incoming>
      <outgoing>Par1-LR1</outgoing>
      <outgoing>Par1-G1</outgoing>
    </parallelGateway>
    <task id="LR1" name="Log report into tracking system">
      <incoming>Par1-LR1</incoming>
      <outgoing>LR1-AR1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par1-G1</incoming>
      <outgoing>G1-IF1</outgoing>
      <outgoing>G1-G2</outgoing>
    </exclusiveGateway>
    <task id="IF1" name="Implement fix">
      <incoming>G1-IF1</incoming>
      <outgoing>IF1-XORCLOSE14</outgoing>
    </task>
    <task id="AR1" name="Assign report to appropriate team">
      <incoming>LR1-AR1</incoming>
      <outgoing>AR1-Par9</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>G1-G2</incoming>
      <outgoing>G2-CT1</outgoing>
      <outgoing>G2-CP1</outgoing>
    </exclusiveGateway>
    <task id="CT1" name="Conduct training">
      <incoming>G2-CT1</incoming>
      <outgoing>CT1-XORCLOSE12</outgoing>
    </task>
    <task id="CP1" name="Change policy">
      <incoming>G2-CP1</incoming>
      <outgoing>CP1-XORCLOSE12</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>AR1-Par9</incoming>
      <outgoing>Par9-GI1</outgoing>
      <outgoing>Par9-IC1</outgoing>
    </parallelGateway>
    <task id="GI1" name="Gather necessary information">
      <incoming>Par9-GI1</incoming>
      <outgoing>GI1-PARCLOSE13</outgoing>
    </task>
    <task id="IC1" name="Identify cause of incident">
      <incoming>Par9-IC1</incoming>
      <outgoing>IC1-PARCLOSE13</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE12" name="XORCLOSE12">
      <incoming>CT1-XORCLOSE12</incoming>
      <incoming>CP1-XORCLOSE12</incoming>
      <outgoing>XORCLOSE12-XORCLOSE14</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE13" name="PARCLOSE13">
      <incoming>GI1-PARCLOSE13</incoming>
      <incoming>IC1-PARCLOSE13</incoming>
      <outgoing>PARCLOSE13-PC1</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>IF1-XORCLOSE14</incoming>
      <incoming>XORCLOSE12-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-PARCLOSE16</outgoing>
    </exclusiveGateway>
    <task id="PC1" name="Propose corrective actions">
      <incoming>PARCLOSE13-PC1</incoming>
      <outgoing>PC1-PARCLOSE16</outgoing>
    </task>
    <parallelGateway id="PARCLOSE16" name="PARCLOSE16">
      <incoming>XORCLOSE14-PARCLOSE16</incoming>
      <incoming>PC1-PARCLOSE16</incoming>
      <outgoing>PARCLOSE16-CF1</outgoing>
    </parallelGateway>
    <task id="CF1" name="Conduct follow-up">
      <incoming>PARCLOSE16-CF1</incoming>
      <outgoing>CF1-CR1</outgoing>
    </task>
    <task id="CR1" name="Close incident report">
      <incoming>CF1-CR1</incoming>
      <outgoing>CR1-NS1</outgoing>
    </task>
    <task id="NS1" name="Notify all stakeholders">
      <incoming>CR1-NS1</incoming>
      <outgoing>NS1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>NS1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-RI1" sourceRef="Default_init" targetRef="RI1"/>
    <sequenceFlow id="RI1-Par1" sourceRef="RI1" targetRef="Par1"/>
    <sequenceFlow id="Par1-LR1" sourceRef="Par1" targetRef="LR1"/>
