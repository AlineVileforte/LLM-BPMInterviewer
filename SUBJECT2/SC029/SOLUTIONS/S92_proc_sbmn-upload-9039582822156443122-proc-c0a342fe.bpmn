    <sequenceFlow id="CT1-XORCLOSE13" sourceRef="CT1" targetRef="XORCLOSE13"/>
    <sequenceFlow id="CP1-XORCLOSE13" sourceRef="CP1" targetRef="XORCLOSE13"/>
    <sequenceFlow id="Par10-GI1" sourceRef="Par10" targetRef="GI1"/>
    <sequenceFlow id="Par10-PC1" sourceRef="Par10" targetRef="PC1"/>
    <sequenceFlow id="GI1-PARCLOSE14" sourceRef="GI1" targetRef="PARCLOSE14"/>
    <sequenceFlow id="PC1-PARCLOSE14" sourceRef="PC1" targetRef="PARCLOSE14"/>
    <sequenceFlow id="XORCLOSE13-XORCLOSE15" sourceRef="XORCLOSE13" targetRef="XORCLOSE15"/>
    <sequenceFlow id="PARCLOSE14-PARCLOSE16" sourceRef="PARCLOSE14" targetRef="PARCLOSE16"/>
    <sequenceFlow id="XORCLOSE15-PARCLOSE16" sourceRef="XORCLOSE15" targetRef="PARCLOSE16"/>
    <sequenceFlow id="PARCLOSE16-CF1" sourceRef="PARCLOSE16" targetRef="CF1"/>
    <sequenceFlow id="CF1-CR1" sourceRef="CF1" targetRef="CR1"/>
    <sequenceFlow id="CR1-NS1" sourceRef="CR1" targetRef="NS1"/>
    <sequenceFlow id="NS1-END" sourceRef="NS1" targetRef="END"/>
  </process>
