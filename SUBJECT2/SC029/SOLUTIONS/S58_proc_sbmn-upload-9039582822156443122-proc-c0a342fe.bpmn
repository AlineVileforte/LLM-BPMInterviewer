    <sequenceFlow id="PARCLOSE14-IC1" sourceRef="PARCLOSE14" targetRef="IC1"/>
    <sequenceFlow id="IC1-Par16" sourceRef="IC1" targetRef="Par16"/>
    <sequenceFlow id="Par16-GI1" sourceRef="Par16" targetRef="GI1"/>
    <sequenceFlow id="Par16-PC1" sourceRef="Par16" targetRef="PC1"/>
    <sequenceFlow id="GI1-PARCLOSE19" sourceRef="GI1" targetRef="PARCLOSE19"/>
    <sequenceFlow id="PC1-PARCLOSE19" sourceRef="PC1" targetRef="PARCLOSE19"/>
    <sequenceFlow id="PARCLOSE19-END" sourceRef="PARCLOSE19" targetRef="END"/>
  </process>
