    <sequenceFlow id="PARCLOSE12-LR1" sourceRef="PARCLOSE12" targetRef="LR1"/>
    <sequenceFlow id="LR1-AR1" sourceRef="LR1" targetRef="AR1"/>
    <sequenceFlow id="AR1-Par15" sourceRef="AR1" targetRef="Par15"/>
    <sequenceFlow id="Par15-GI1" sourceRef="Par15" targetRef="GI1"/>
    <sequenceFlow id="Par15-IC1" sourceRef="Par15" targetRef="IC1"/>
    <sequenceFlow id="GI1-PARCLOSE18" sourceRef="GI1" targetRef="PARCLOSE18"/>
    <sequenceFlow id="IC1-PARCLOSE18" sourceRef="IC1" targetRef="PARCLOSE18"/>
    <sequenceFlow id="PARCLOSE18-PC1" sourceRef="PARCLOSE18" targetRef="PC1"/>
    <sequenceFlow id="PC1-END" sourceRef="PC1" targetRef="END"/>
  </process>
