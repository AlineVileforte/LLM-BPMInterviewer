    <sequenceFlow id="CF1-CR1" sourceRef="CF1" targetRef="CR1"/>
    <sequenceFlow id="PARCLOSE16-PARCLOSE18" sourceRef="PARCLOSE16" targetRef="PARCLOSE18"/>
    <sequenceFlow id="CR1-PARCLOSE18" sourceRef="CR1" targetRef="PARCLOSE18"/>
    <sequenceFlow id="PARCLOSE18-NS1" sourceRef="PARCLOSE18" targetRef="NS1"/>
    <sequenceFlow id="NS1-END" sourceRef="NS1" targetRef="END"/>
  </process>
