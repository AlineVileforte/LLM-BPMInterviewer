    <sequenceFlow id="CT1-XORCLOSE10" sourceRef="CT1" targetRef="XORCLOSE10"/>
    <sequenceFlow id="CP1-XORCLOSE10" sourceRef="CP1" targetRef="XORCLOSE10"/>
    <sequenceFlow id="IC1-Par11" sourceRef="IC1" targetRef="Par11"/>
    <sequenceFlow id="XORCLOSE10-XORCLOSE14" sourceRef="XORCLOSE10" targetRef="XORCLOSE14"/>
    <sequenceFlow id="Par11-GI1" sourceRef="Par11" targetRef="GI1"/>
    <sequenceFlow id="Par11-PC1" sourceRef="Par11" targetRef="PC1"/>
    <sequenceFlow id="GI1-PARCLOSE15" sourceRef="GI1" targetRef="PARCLOSE15"/>
    <sequenceFlow id="PC1-PARCLOSE15" sourceRef="PC1" targetRef="PARCLOSE15"/>
    <sequenceFlow id="XORCLOSE14-PARCLOSE16" sourceRef="XORCLOSE14" targetRef="PARCLOSE16"/>
    <sequenceFlow id="PARCLOSE15-PARCLOSE16" sourceRef="PARCLOSE15" targetRef="PARCLOSE16"/>
    <sequenceFlow id="PARCLOSE16-CF1" sourceRef="PARCLOSE16" targetRef="CF1"/>
    <sequenceFlow id="CF1-CR1" sourceRef="CF1" targetRef="CR1"/>
    <sequenceFlow id="CR1-NS1" sourceRef="CR1" targetRef="NS1"/>
    <sequenceFlow id="NS1-END" sourceRef="NS1" targetRef="END"/>
  </process>
