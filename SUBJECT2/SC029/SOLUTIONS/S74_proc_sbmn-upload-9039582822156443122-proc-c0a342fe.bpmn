    <sequenceFlow id="LR1-AR1" sourceRef="LR1" targetRef="AR1"/>
    <sequenceFlow id="CR1-NS1" sourceRef="CR1" targetRef="NS1"/>
    <sequenceFlow id="AR1-Par14" sourceRef="AR1" targetRef="Par14"/>
    <sequenceFlow id="NS1-PARCLOSE19" sourceRef="NS1" targetRef="PARCLOSE19"/>
    <sequenceFlow id="Par14-GI1" sourceRef="Par14" targetRef="GI1"/>
    <sequenceFlow id="Par14-IC1" sourceRef="Par14" targetRef="IC1"/>
    <sequenceFlow id="GI1-PARCLOSE18" sourceRef="GI1" targetRef="PARCLOSE18"/>
    <sequenceFlow id="IC1-PC1" sourceRef="IC1" targetRef="PC1"/>
    <sequenceFlow id="PC1-PARCLOSE18" sourceRef="PC1" targetRef="PARCLOSE18"/>
    <sequenceFlow id="PARCLOSE18-PARCLOSE19" sourceRef="PARCLOSE18" targetRef="PARCLOSE19"/>
    <sequenceFlow id="PARCLOSE19-END" sourceRef="PARCLOSE19" targetRef="END"/>
  </process>
