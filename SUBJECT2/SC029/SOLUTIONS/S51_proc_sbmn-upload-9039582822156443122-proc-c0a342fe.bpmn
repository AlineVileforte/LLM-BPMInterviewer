    <sequenceFlow id="CF1-LR1" sourceRef="CF1" targetRef="LR1"/>
    <sequenceFlow id="LR1-CR1" sourceRef="LR1" targetRef="CR1"/>
    <sequenceFlow id="CR1-NS1" sourceRef="CR1" targetRef="NS1"/>
    <sequenceFlow id="NS1-AR1" sourceRef="NS1" targetRef="AR1"/>
    <sequenceFlow id="AR1-Par13" sourceRef="AR1" targetRef="Par13"/>
    <sequenceFlow id="Par13-GI1" sourceRef="Par13" targetRef="GI1"/>
    <sequenceFlow id="Par13-IC1" sourceRef="Par13" targetRef="IC1"/>
    <sequenceFlow id="GI1-PARCLOSE16" sourceRef="GI1" targetRef="PARCLOSE16"/>
    <sequenceFlow id="IC1-PARCLOSE16" sourceRef="IC1" targetRef="PARCLOSE16"/>
    <sequenceFlow id="PARCLOSE16-PC1" sourceRef="PARCLOSE16" targetRef="PC1"/>
    <sequenceFlow id="PC1-END" sourceRef="PC1" targetRef="END"/>
  </process>
