    <sequenceFlow id="AR1-GI1" sourceRef="AR1" targetRef="GI1"/>
    <sequenceFlow id="G2-IF1" sourceRef="G2" targetRef="IF1"/>
    <sequenceFlow id="G2-G3" sourceRef="G2" targetRef="G3"/>
    <sequenceFlow id="IF1-XORCLOSE13" sourceRef="IF1" targetRef="XORCLOSE13"/>
    <sequenceFlow id="GI1-IC1" sourceRef="GI1" targetRef="IC1"/>
    <sequenceFlow id="G3-CT1" sourceRef="G3" targetRef="CT1"/>
    <sequenceFlow id="G3-CP1" sourceRef="G3" targetRef="CP1"/>
    <sequenceFlow id="CT1-XORCLOSE11" sourceRef="CT1" targetRef="XORCLOSE11"/>
    <sequenceFlow id="CP1-XORCLOSE11" sourceRef="CP1" targetRef="XORCLOSE11"/>
    <sequenceFlow id="IC1-PC1" sourceRef="IC1" targetRef="PC1"/>
    <sequenceFlow id="XORCLOSE11-XORCLOSE13" sourceRef="XORCLOSE11" targetRef="XORCLOSE13"/>
    <sequenceFlow id="PC1-PARCLOSE14" sourceRef="PC1" targetRef="PARCLOSE14"/>
    <sequenceFlow id="XORCLOSE13-PARCLOSE14" sourceRef="XORCLOSE13" targetRef="PARCLOSE14"/>
    <sequenceFlow id="PARCLOSE14-CF1" sourceRef="PARCLOSE14" targetRef="CF1"/>
    <sequenceFlow id="CF1-CR1" sourceRef="CF1" targetRef="CR1"/>
    <sequenceFlow id="CR1-NS1" sourceRef="CR1" targetRef="NS1"/>
    <sequenceFlow id="NS1-END" sourceRef="NS1" targetRef="END"/>
  </process>
