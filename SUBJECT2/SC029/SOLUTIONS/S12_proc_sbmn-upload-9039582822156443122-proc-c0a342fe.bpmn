<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_a98e609c-0a1e-4362-a98d-dd7a04f7edf8" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-RI1</outgoing>
    </startEvent>
    <task id="RI1" name="Report incident">
      <incoming>Default_init-RI1</incoming>
      <outgoing>RI1-LR1</outgoing>
    </task>
    <task id="LR1" name="Log report into tracking system">
      <incoming>RI1-LR1</incoming>
      <outgoing>LR1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>LR1-Par2</incoming>
      <outgoing>Par2-AR1</outgoing>
      <outgoing>Par2-G2</outgoing>
    </parallelGateway>
    <task id="AR1" name="Assign report to appropriate team">
      <incoming>Par2-AR1</incoming>
      <outgoing>AR1-GI1</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par2-G2</incoming>
      <outgoing>G2-IF1</outgoing>
      <outgoing>G2-G3</outgoing>
    </exclusiveGateway>
    <task id="IF1" name="Implement fix">
      <incoming>G2-IF1</incoming>
      <outgoing>IF1-XORCLOSE13</outgoing>
    </task>
    <task id="GI1" name="Gather necessary information">
      <incoming>AR1-GI1</incoming>
      <outgoing>GI1-IC1</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>G2-G3</incoming>
      <outgoing>G3-CT1</outgoing>
      <outgoing>G3-CP1</outgoing>
    </exclusiveGateway>
    <task id="CT1" name="Conduct training">
      <incoming>G3-CT1</incoming>
      <outgoing>CT1-XORCLOSE11</outgoing>
    </task>
    <task id="CP1" name="Change policy">
      <incoming>G3-CP1</incoming>
      <outgoing>CP1-XORCLOSE11</outgoing>
    </task>
    <task id="IC1" name="Identify cause of incident">
      <incoming>GI1-IC1</incoming>
      <outgoing>IC1-PC1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE11" name="XORCLOSE11">
      <incoming>CT1-XORCLOSE11</incoming>
      <incoming>CP1-XORCLOSE11</incoming>
      <outgoing>XORCLOSE11-XORCLOSE13</outgoing>
    </exclusiveGateway>
    <task id="PC1" name="Propose corrective actions">
      <incoming>IC1-PC1</incoming>
      <outgoing>PC1-PARCLOSE14</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE13" name="XORCLOSE13">
      <incoming>IF1-XORCLOSE13</incoming>
      <incoming>XORCLOSE11-XORCLOSE13</incoming>
      <outgoing>XORCLOSE13-PARCLOSE14</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE14" name="PARCLOSE14">
      <incoming>PC1-PARCLOSE14</incoming>
      <incoming>XORCLOSE13-PARCLOSE14</incoming>
      <outgoing>PARCLOSE14-CF1</outgoing>
    </parallelGateway>
    <task id="CF1" name="Conduct follow-up">
      <incoming>PARCLOSE14-CF1</incoming>
      <outgoing>CF1-CR1</outgoing>
    </task>
    <task id="CR1" name="Close incident report">
      <incoming>CF1-CR1</incoming>
      <outgoing>CR1-NS1</outgoing>
    </task>
    <task id="NS1" name="Notify all stakeholders">
      <incoming>CR1-NS1</incoming>
      <outgoing>NS1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>NS1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-RI1" sourceRef="Default_init" targetRef="RI1"/>
    <sequenceFlow id="RI1-LR1" sourceRef="RI1" targetRef="LR1"/>
    <sequenceFlow id="LR1-Par2" sourceRef="LR1" targetRef="Par2"/>
    <sequenceFlow id="Par2-AR1" sourceRef="Par2" targetRef="AR1"/>
