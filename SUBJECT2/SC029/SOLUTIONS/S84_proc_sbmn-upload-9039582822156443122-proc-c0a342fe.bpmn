    <sequenceFlow id="PC1-PARCLOSE18" sourceRef="PC1" targetRef="PARCLOSE18"/>
    <sequenceFlow id="PARCLOSE18-END" sourceRef="PARCLOSE18" targetRef="END"/>
  </process>
