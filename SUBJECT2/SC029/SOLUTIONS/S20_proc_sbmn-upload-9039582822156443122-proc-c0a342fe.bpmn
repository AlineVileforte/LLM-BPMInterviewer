<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_220a9a26-99aa-4748-9233-09d95b23bb27" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-RI1</outgoing>
      <outgoing>Par0-G0</outgoing>
    </parallelGateway>
    <task id="RI1" name="Report incident">
      <incoming>Par0-RI1</incoming>
      <outgoing>RI1-LR1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par0-G0</incoming>
      <outgoing>G0-IF1</outgoing>
      <outgoing>G0-G1</outgoing>
    </exclusiveGateway>
    <task id="IF1" name="Implement fix">
      <incoming>G0-IF1</incoming>
      <outgoing>IF1-XORCLOSE11</outgoing>
    </task>
    <task id="LR1" name="Log report into tracking system">
      <incoming>RI1-LR1</incoming>
      <outgoing>LR1-AR1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>G0-G1</incoming>
      <outgoing>G1-CT1</outgoing>
      <outgoing>G1-CP1</outgoing>
    </exclusiveGateway>
    <task id="CT1" name="Conduct training">
      <incoming>G1-CT1</incoming>
      <outgoing>CT1-XORCLOSE9</outgoing>
    </task>
    <task id="CP1" name="Change policy">
      <incoming>G1-CP1</incoming>
      <outgoing>CP1-XORCLOSE9</outgoing>
    </task>
    <task id="AR1" name="Assign report to appropriate team">
      <incoming>LR1-AR1</incoming>
      <outgoing>AR1-IC1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE9" name="XORCLOSE9">
      <incoming>CT1-XORCLOSE9</incoming>
      <incoming>CP1-XORCLOSE9</incoming>
      <outgoing>XORCLOSE9-XORCLOSE11</outgoing>
    </exclusiveGateway>
    <task id="IC1" name="Identify cause of incident">
      <incoming>AR1-IC1</incoming>
      <outgoing>IC1-GI1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE11" name="XORCLOSE11">
      <incoming>IF1-XORCLOSE11</incoming>
      <incoming>XORCLOSE9-XORCLOSE11</incoming>
      <outgoing>XORCLOSE11-CF1</outgoing>
    </exclusiveGateway>
    <task id="GI1" name="Gather necessary information">
      <incoming>IC1-GI1</incoming>
      <outgoing>GI1-PC1</outgoing>
    </task>
    <task id="CF1" name="Conduct follow-up">
      <incoming>XORCLOSE11-CF1</incoming>
      <outgoing>CF1-PARCLOSE15</outgoing>
    </task>
    <task id="PC1" name="Propose corrective actions">
      <incoming>GI1-PC1</incoming>
      <outgoing>PC1-PARCLOSE15</outgoing>
    </task>
    <parallelGateway id="PARCLOSE15" name="PARCLOSE15">
      <incoming>CF1-PARCLOSE15</incoming>
      <incoming>PC1-PARCLOSE15</incoming>
      <outgoing>PARCLOSE15-CR1</outgoing>
    </parallelGateway>
    <task id="CR1" name="Close incident report">
      <incoming>PARCLOSE15-CR1</incoming>
      <outgoing>CR1-NS1</outgoing>
    </task>
    <task id="NS1" name="Notify all stakeholders">
      <incoming>CR1-NS1</incoming>
      <outgoing>NS1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>NS1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
