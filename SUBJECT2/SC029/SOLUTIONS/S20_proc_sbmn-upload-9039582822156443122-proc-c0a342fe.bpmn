    <sequenceFlow id="CF1-PARCLOSE15" sourceRef="CF1" targetRef="PARCLOSE15"/>
    <sequenceFlow id="PC1-PARCLOSE15" sourceRef="PC1" targetRef="PARCLOSE15"/>
    <sequenceFlow id="PARCLOSE15-CR1" sourceRef="PARCLOSE15" targetRef="CR1"/>
    <sequenceFlow id="CR1-NS1" sourceRef="CR1" targetRef="NS1"/>
    <sequenceFlow id="NS1-END" sourceRef="NS1" targetRef="END"/>
  </process>
