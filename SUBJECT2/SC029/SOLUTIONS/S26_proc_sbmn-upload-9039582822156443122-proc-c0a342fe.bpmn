<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_1dc4d6b7-1a1d-4c35-9659-ece606b04e3c" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-RI1</outgoing>
    </startEvent>
    <task id="RI1" name="Report incident">
      <incoming>Default_init-RI1</incoming>
      <outgoing>RI1-LR1</outgoing>
    </task>
    <task id="LR1" name="Log report into tracking system">
      <incoming>RI1-LR1</incoming>
      <outgoing>LR1-G2</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>LR1-G2</incoming>
      <outgoing>G2-IF1</outgoing>
      <outgoing>G2-G3</outgoing>
    </exclusiveGateway>
    <task id="IF1" name="Implement fix">
      <incoming>G2-IF1</incoming>
      <outgoing>IF1-XORCLOSE8</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>G2-G3</incoming>
      <outgoing>G3-CT1</outgoing>
      <outgoing>G3-CP1</outgoing>
    </exclusiveGateway>
    <task id="CT1" name="Conduct training">
      <incoming>G3-CT1</incoming>
      <outgoing>CT1-XORCLOSE7</outgoing>
    </task>
    <task id="CP1" name="Change policy">
      <incoming>G3-CP1</incoming>
      <outgoing>CP1-XORCLOSE7</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE7" name="XORCLOSE7">
      <incoming>CT1-XORCLOSE7</incoming>
      <incoming>CP1-XORCLOSE7</incoming>
      <outgoing>XORCLOSE7-XORCLOSE8</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE8" name="XORCLOSE8">
      <incoming>IF1-XORCLOSE8</incoming>
      <incoming>XORCLOSE7-XORCLOSE8</incoming>
      <outgoing>XORCLOSE8-CF1</outgoing>
    </exclusiveGateway>
    <task id="CF1" name="Conduct follow-up">
      <incoming>XORCLOSE8-CF1</incoming>
      <outgoing>CF1-CR1</outgoing>
    </task>
    <task id="CR1" name="Close incident report">
      <incoming>CF1-CR1</incoming>
      <outgoing>CR1-NS1</outgoing>
    </task>
    <task id="NS1" name="Notify all stakeholders">
      <incoming>CR1-NS1</incoming>
      <outgoing>NS1-AR1</outgoing>
    </task>
    <task id="AR1" name="Assign report to appropriate team">
      <incoming>NS1-AR1</incoming>
      <outgoing>AR1-GI1</outgoing>
    </task>
    <task id="GI1" name="Gather necessary information">
      <incoming>AR1-GI1</incoming>
      <outgoing>GI1-IC1</outgoing>
    </task>
    <task id="IC1" name="Identify cause of incident">
      <incoming>GI1-IC1</incoming>
      <outgoing>IC1-PC1</outgoing>
    </task>
    <task id="PC1" name="Propose corrective actions">
      <incoming>IC1-PC1</incoming>
      <outgoing>PC1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PC1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-RI1" sourceRef="Default_init" targetRef="RI1"/>
    <sequenceFlow id="RI1-LR1" sourceRef="RI1" targetRef="LR1"/>
    <sequenceFlow id="LR1-G2" sourceRef="LR1" targetRef="G2"/>
    <sequenceFlow id="G2-IF1" sourceRef="G2" targetRef="IF1"/>
    <sequenceFlow id="G2-G3" sourceRef="G2" targetRef="G3"/>
    <sequenceFlow id="IF1-XORCLOSE8" sourceRef="IF1" targetRef="XORCLOSE8"/>
    <sequenceFlow id="G3-CT1" sourceRef="G3" targetRef="CT1"/>
    <sequenceFlow id="G3-CP1" sourceRef="G3" targetRef="CP1"/>
    <sequenceFlow id="CT1-XORCLOSE7" sourceRef="CT1" targetRef="XORCLOSE7"/>
    <sequenceFlow id="CP1-XORCLOSE7" sourceRef="CP1" targetRef="XORCLOSE7"/>
    <sequenceFlow id="XORCLOSE7-XORCLOSE8" sourceRef="XORCLOSE7" targetRef="XORCLOSE8"/>
    <sequenceFlow id="XORCLOSE8-CF1" sourceRef="XORCLOSE8" targetRef="CF1"/>
    <sequenceFlow id="CF1-CR1" sourceRef="CF1" targetRef="CR1"/>
    <sequenceFlow id="CR1-NS1" sourceRef="CR1" targetRef="NS1"/>
    <sequenceFlow id="NS1-AR1" sourceRef="NS1" targetRef="AR1"/>
    <sequenceFlow id="AR1-GI1" sourceRef="AR1" targetRef="GI1"/>
    <sequenceFlow id="GI1-IC1" sourceRef="GI1" targetRef="IC1"/>
    <sequenceFlow id="IC1-PC1" sourceRef="IC1" targetRef="PC1"/>
    <sequenceFlow id="PC1-END" sourceRef="PC1" targetRef="END"/>
  </process>
