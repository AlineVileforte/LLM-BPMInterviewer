    <sequenceFlow id="G1-IF1" sourceRef="G1" targetRef="IF1"/>
    <sequenceFlow id="G1-G2" sourceRef="G1" targetRef="G2"/>
    <sequenceFlow id="IF1-XORCLOSE12" sourceRef="IF1" targetRef="XORCLOSE12"/>
    <sequenceFlow id="AR1-GI1" sourceRef="AR1" targetRef="GI1"/>
    <sequenceFlow id="G2-CT1" sourceRef="G2" targetRef="CT1"/>
    <sequenceFlow id="G2-CP1" sourceRef="G2" targetRef="CP1"/>
    <sequenceFlow id="CT1-XORCLOSE10" sourceRef="CT1" targetRef="XORCLOSE10"/>
    <sequenceFlow id="CP1-XORCLOSE10" sourceRef="CP1" targetRef="XORCLOSE10"/>
    <sequenceFlow id="GI1-IC1" sourceRef="GI1" targetRef="IC1"/>
    <sequenceFlow id="XORCLOSE10-XORCLOSE12" sourceRef="XORCLOSE10" targetRef="XORCLOSE12"/>
    <sequenceFlow id="IC1-PC1" sourceRef="IC1" targetRef="PC1"/>
    <sequenceFlow id="XORCLOSE12-CF1" sourceRef="XORCLOSE12" targetRef="CF1"/>
    <sequenceFlow id="PC1-PARCLOSE16" sourceRef="PC1" targetRef="PARCLOSE16"/>
    <sequenceFlow id="CF1-CR1" sourceRef="CF1" targetRef="CR1"/>
    <sequenceFlow id="CR1-PARCLOSE16" sourceRef="CR1" targetRef="PARCLOSE16"/>
    <sequenceFlow id="PARCLOSE16-NS1" sourceRef="PARCLOSE16" targetRef="NS1"/>
    <sequenceFlow id="NS1-END" sourceRef="NS1" targetRef="END"/>
  </process>
