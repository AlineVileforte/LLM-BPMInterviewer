    <sequenceFlow id="XORCLOSE7-CF1" sourceRef="XORCLOSE7" targetRef="CF1"/>
    <sequenceFlow id="CF1-CR1" sourceRef="CF1" targetRef="CR1"/>
    <sequenceFlow id="CR1-Par10" sourceRef="CR1" targetRef="Par10"/>
    <sequenceFlow id="Par10-LR1" sourceRef="Par10" targetRef="LR1"/>
    <sequenceFlow id="Par10-NS1" sourceRef="Par10" targetRef="NS1"/>
    <sequenceFlow id="LR1-PARCLOSE13" sourceRef="LR1" targetRef="PARCLOSE13"/>
    <sequenceFlow id="NS1-PARCLOSE13" sourceRef="NS1" targetRef="PARCLOSE13"/>
    <sequenceFlow id="PARCLOSE13-AR1" sourceRef="PARCLOSE13" targetRef="AR1"/>
    <sequenceFlow id="AR1-IC1" sourceRef="AR1" targetRef="IC1"/>
    <sequenceFlow id="IC1-GI1" sourceRef="IC1" targetRef="GI1"/>
    <sequenceFlow id="GI1-PC1" sourceRef="GI1" targetRef="PC1"/>
    <sequenceFlow id="PC1-END" sourceRef="PC1" targetRef="END"/>
  </process>
