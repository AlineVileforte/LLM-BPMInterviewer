  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-DF1</outgoing>
      <outgoing>Par0-Par5</outgoing>
    </parallelGateway>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par0-DF1</incoming>
      <outgoing>DF1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>DF1-Par2</incoming>
      <outgoing>Par2-IIS1</outgoing>
      <outgoing>Par2-PVA1</outgoing>
    </parallelGateway>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par2-IIS1</incoming>
      <outgoing>IIS1-IM1</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par2-PVA1</incoming>
      <outgoing>PVA1-PPV1</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>Par0-Par5</incoming>
      <outgoing>Par5-APP1</outgoing>
      <outgoing>Par5-G1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par5-APP1</incoming>
      <outgoing>APP1-Par12</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par5-G1</incoming>
      <outgoing>G1-CAI1</outgoing>
      <outgoing>G1-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G1-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE17</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>IIS1-IM1</incoming>
      <outgoing>IM1-G4</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>PVA1-PPV1</incoming>
      <outgoing>PPV1-PIP1</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>APP1-Par12</incoming>
      <outgoing>Par12-MDEI1</outgoing>
      <outgoing>Par12-G3</outgoing>
    </parallelGateway>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par12-MDEI1</incoming>
      <outgoing>MDEI1-PARCLOSE26</outgoing>
