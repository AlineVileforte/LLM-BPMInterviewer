  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-PVA1</outgoing>
    </startEvent>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Default_init-PVA1</incoming>
      <outgoing>PVA1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>PVA1-G0</incoming>
      <outgoing>G0-CTV1</outgoing>
      <outgoing>G0-XORCLOSE4</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G0-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE4</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE4" name="XORCLOSE4">
      <incoming>G0-XORCLOSE4</incoming>
      <incoming>CTV1-XORCLOSE4</incoming>
      <outgoing>XORCLOSE4-Par5</outgoing>
    </exclusiveGateway>
    <parallelGateway id="Par5" name="PAR">
      <incoming>XORCLOSE4-Par5</incoming>
      <outgoing>Par5-APP1</outgoing>
      <outgoing>Par5-DF1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par5-APP1</incoming>
      <outgoing>APP1-PIP1</outgoing>
    </task>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par5-DF1</incoming>
      <outgoing>DF1-Par9</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>DF1-Par9</incoming>
      <outgoing>Par9-PPV1</outgoing>
      <outgoing>Par9-G1</outgoing>
    </parallelGateway>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par9-PPV1</incoming>
      <outgoing>PPV1-MDEI1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par9-G1</incoming>
      <outgoing>G1-CAI1</outgoing>
      <outgoing>G1-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G1-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE18</outgoing>
    </task>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>APP1-PIP1</incoming>
      <outgoing>PIP1-Par19</outgoing>
    </task>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>PPV1-MDEI1</incoming>
      <outgoing>MDEI1-PARCLOSE26</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>G1-XORCLOSE18</incoming>
      <incoming>CAI1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-CEI1</outgoing>
    </exclusiveGateway>
    <parallelGateway id="Par19" name="PAR">
      <incoming>PIP1-Par19</incoming>
      <outgoing>Par19-IIS1</outgoing>
      <outgoing>Par19-DSE1</outgoing>
    </parallelGateway>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par19-IIS1</incoming>
      <outgoing>IIS1-IM1</outgoing>
    </task>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>Par19-DSE1</incoming>
      <outgoing>DSE1-PARCLOSE25</outgoing>
    </task>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>XORCLOSE18-CEI1</incoming>
      <outgoing>CEI1-PARCLOSE26</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>IIS1-IM1</incoming>
      <outgoing>IM1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>DSE1-PARCLOSE25</incoming>
      <incoming>IM1-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-FRP1</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>MDEI1-PARCLOSE26</incoming>
      <incoming>CEI1-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-PARCLOSE29</outgoing>
    </parallelGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>PARCLOSE25-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE29</outgoing>
    </task>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>PARCLOSE26-PARCLOSE29</incoming>
      <incoming>FRP1-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE29-END</incoming>
    </endEvent>
