  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-IIS1</outgoing>
    </startEvent>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Default_init-IIS1</incoming>
      <outgoing>IIS1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>IIS1-Par1</incoming>
      <outgoing>Par1-IM1</outgoing>
      <outgoing>Par1-PPV1</outgoing>
    </parallelGateway>
    <task id="IM1" name="Integrate Modules">
      <incoming>Par1-IM1</incoming>
      <outgoing>IM1-PVA1</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par1-PPV1</incoming>
      <outgoing>PPV1-DF1</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>IM1-PVA1</incoming>
      <outgoing>PVA1-APP1</outgoing>
    </task>
    <task id="DF1" name="Detail Functionalities">
      <incoming>PPV1-DF1</incoming>
      <outgoing>DF1-Par7</outgoing>
    </task>
    <task id="APP1" name="Approve Platform Project">
      <incoming>PVA1-APP1</incoming>
      <outgoing>APP1-Par14</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>DF1-Par7</incoming>
      <outgoing>Par7-G1</outgoing>
      <outgoing>Par7-G2</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par7-G1</incoming>
      <outgoing>G1-CTV1</outgoing>
      <outgoing>G1-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G1-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE17</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par7-G2</incoming>
      <outgoing>G2-CAI1</outgoing>
      <outgoing>G2-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G2-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE18</outgoing>
    </task>
    <parallelGateway id="Par14" name="PAR">
      <incoming>APP1-Par14</incoming>
      <outgoing>Par14-PIP1</outgoing>
      <outgoing>Par14-MDEI1</outgoing>
    </parallelGateway>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>Par14-PIP1</incoming>
      <outgoing>PIP1-DSE1</outgoing>
    </task>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par14-MDEI1</incoming>
      <outgoing>MDEI1-G4</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE17" name="XORCLOSE17">
      <incoming>G1-XORCLOSE17</incoming>
      <incoming>CTV1-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-PARCLOSE23</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>G2-XORCLOSE18</incoming>
      <incoming>CAI1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-PARCLOSE23</outgoing>
    </exclusiveGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>PIP1-DSE1</incoming>
      <outgoing>DSE1-PARCLOSE26</outgoing>
    </task>
    <exclusiveGateway id="G4" name="G4">
      <incoming>MDEI1-G4</incoming>
      <outgoing>G4-CEI1</outgoing>
      <outgoing>G4-XORCLOSE24</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G4-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE24</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>XORCLOSE17-PARCLOSE23</incoming>
      <incoming>XORCLOSE18-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-FRP1</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE24" name="XORCLOSE24">
      <incoming>G4-XORCLOSE24</incoming>
      <incoming>CEI1-XORCLOSE24</incoming>
      <outgoing>XORCLOSE24-PARCLOSE26</outgoing>
    </exclusiveGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>PARCLOSE23-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE27</outgoing>
    </task>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>DSE1-PARCLOSE26</incoming>
      <incoming>XORCLOSE24-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-PARCLOSE27</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>FRP1-PARCLOSE27</incoming>
      <incoming>PARCLOSE26-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE27-END</incoming>
    </endEvent>
