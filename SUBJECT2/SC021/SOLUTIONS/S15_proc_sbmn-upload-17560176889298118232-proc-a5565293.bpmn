  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-APP1</outgoing>
      <outgoing>Par0-PPV1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par0-APP1</incoming>
      <outgoing>APP1-Par3</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par0-PPV1</incoming>
      <outgoing>PPV1-Par6</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>APP1-Par3</incoming>
      <outgoing>Par3-PIP1</outgoing>
      <outgoing>Par3-IIS1</outgoing>
    </parallelGateway>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>Par3-PIP1</incoming>
      <outgoing>PIP1-PARCLOSE9</outgoing>
    </task>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par3-IIS1</incoming>
      <outgoing>IIS1-PARCLOSE9</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>PPV1-Par6</incoming>
      <outgoing>Par6-DF1</outgoing>
      <outgoing>Par6-PVA1</outgoing>
    </parallelGateway>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par6-DF1</incoming>
      <outgoing>DF1-Par10</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par6-PVA1</incoming>
      <outgoing>PVA1-PARCLOSE26</outgoing>
    </task>
    <parallelGateway id="PARCLOSE9" name="PARCLOSE9">
      <incoming>PIP1-PARCLOSE9</incoming>
      <incoming>IIS1-PARCLOSE9</incoming>
      <outgoing>PARCLOSE9-G2</outgoing>
    </parallelGateway>
    <parallelGateway id="Par10" name="PAR">
      <incoming>DF1-Par10</incoming>
      <outgoing>Par10-IM1</outgoing>
      <outgoing>Par10-G0</outgoing>
    </parallelGateway>
    <task id="IM1" name="Integrate Modules">
      <incoming>Par10-IM1</incoming>
      <outgoing>IM1-MDEI1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par10-G0</incoming>
      <outgoing>G0-CAI1</outgoing>
      <outgoing>G0-XORCLOSE20</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G0-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE20</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>PARCLOSE9-G2</incoming>
      <outgoing>G2-CTV1</outgoing>
      <outgoing>G2-XORCLOSE21</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G2-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE21</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>G0-XORCLOSE20</incoming>
      <incoming>CAI1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-PARCLOSE23</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE21" name="XORCLOSE21">
      <incoming>G2-XORCLOSE21</incoming>
      <incoming>CTV1-XORCLOSE21</incoming>
      <outgoing>XORCLOSE21-DSE1</outgoing>
    </exclusiveGateway>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>IM1-MDEI1</incoming>
      <outgoing>MDEI1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>XORCLOSE20-PARCLOSE23</incoming>
      <incoming>MDEI1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-CEI1</outgoing>
    </parallelGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>XORCLOSE21-DSE1</incoming>
      <outgoing>DSE1-PARCLOSE28</outgoing>
    </task>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>PARCLOSE23-CEI1</incoming>
      <outgoing>CEI1-PARCLOSE26</outgoing>
    </task>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>PVA1-PARCLOSE26</incoming>
      <incoming>CEI1-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-FRP1</outgoing>
    </parallelGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>PARCLOSE26-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE28</outgoing>
    </task>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>DSE1-PARCLOSE28</incoming>
      <incoming>FRP1-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE28-END</incoming>
    </endEvent>
