    <sequenceFlow id="XORCLOSE22-DSE1" sourceRef="XORCLOSE22" targetRef="DSE1"/>
    <sequenceFlow id="DSE1-PARCLOSE24" sourceRef="DSE1" targetRef="PARCLOSE24"/>
    <sequenceFlow id="PARCLOSE24-FRP1" sourceRef="PARCLOSE24" targetRef="FRP1"/>
    <sequenceFlow id="FRP1-END" sourceRef="FRP1" targetRef="END"/>
  </process>
