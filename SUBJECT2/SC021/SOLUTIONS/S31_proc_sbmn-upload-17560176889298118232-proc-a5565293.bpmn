<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_93caa6b0-f272-4e14-8082-43cd59b81510" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DF1</outgoing>
    </startEvent>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Default_init-DF1</incoming>
      <outgoing>DF1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>DF1-Par1</incoming>
      <outgoing>Par1-PVA1</outgoing>
      <outgoing>Par1-G0</outgoing>
    </parallelGateway>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par1-PVA1</incoming>
      <outgoing>PVA1-PPV1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par1-G0</incoming>
      <outgoing>G0-CAI1</outgoing>
      <outgoing>G0-XORCLOSE7</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G0-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE7</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>PVA1-PPV1</incoming>
      <outgoing>PPV1-MDEI1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE7" name="XORCLOSE7">
      <incoming>G0-XORCLOSE7</incoming>
      <incoming>CAI1-XORCLOSE7</incoming>
      <outgoing>XORCLOSE7-Par9</outgoing>
    </exclusiveGateway>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>PPV1-MDEI1</incoming>
      <outgoing>MDEI1-APP1</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>XORCLOSE7-Par9</incoming>
      <outgoing>Par9-IIS1</outgoing>
      <outgoing>Par9-G3</outgoing>
    </parallelGateway>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par9-IIS1</incoming>
      <outgoing>IIS1-IM1</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>Par9-G3</incoming>
      <outgoing>G3-CEI1</outgoing>
      <outgoing>G3-XORCLOSE16</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G3-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE16</outgoing>
    </task>
    <task id="APP1" name="Approve Platform Project">
      <incoming>MDEI1-APP1</incoming>
      <outgoing>APP1-G5</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>IIS1-IM1</incoming>
      <outgoing>IM1-PIP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
      <incoming>G3-XORCLOSE16</incoming>
      <incoming>CEI1-XORCLOSE16</incoming>
      <outgoing>XORCLOSE16-PARCLOSE21</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G5" name="G5">
      <incoming>APP1-G5</incoming>
      <outgoing>G5-CTV1</outgoing>
      <outgoing>G5-XORCLOSE22</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G5-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE22</outgoing>
    </task>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>IM1-PIP1</incoming>
      <outgoing>PIP1-PARCLOSE21</outgoing>
    </task>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>XORCLOSE16-PARCLOSE21</incoming>
      <incoming>PIP1-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-PARCLOSE24</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE22" name="XORCLOSE22">
      <incoming>G5-XORCLOSE22</incoming>
      <incoming>CTV1-XORCLOSE22</incoming>
      <outgoing>XORCLOSE22-DSE1</outgoing>
    </exclusiveGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>XORCLOSE22-DSE1</incoming>
      <outgoing>DSE1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>PARCLOSE21-PARCLOSE24</incoming>
      <incoming>DSE1-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-FRP1</outgoing>
    </parallelGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>PARCLOSE24-FRP1</incoming>
      <outgoing>FRP1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>FRP1-END</incoming>
    </endEvent>
