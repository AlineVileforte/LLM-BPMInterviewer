    <sequenceFlow id="G5-XORCLOSE22" sourceRef="G5" targetRef="XORCLOSE22"/>
    <sequenceFlow id="CTV1-XORCLOSE22" sourceRef="CTV1" targetRef="XORCLOSE22"/>
