  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-APP1</outgoing>
      <outgoing>Par0-PIP1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par0-APP1</incoming>
      <outgoing>APP1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>APP1-Par2</incoming>
      <outgoing>Par2-DF1</outgoing>
      <outgoing>Par2-PVA1</outgoing>
    </parallelGateway>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par2-DF1</incoming>
      <outgoing>DF1-IIS1</outgoing>
    </task>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>Par0-PIP1</incoming>
      <outgoing>PIP1-Par7</outgoing>
    </task>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>DF1-IIS1</incoming>
      <outgoing>IIS1-MDEI1</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par2-PVA1</incoming>
      <outgoing>PVA1-Par13</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>PIP1-Par7</incoming>
      <outgoing>Par7-PPV1</outgoing>
      <outgoing>Par7-G2</outgoing>
    </parallelGateway>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par7-PPV1</incoming>
      <outgoing>PPV1-PARCLOSE26</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par7-G2</incoming>
      <outgoing>G2-CAI1</outgoing>
      <outgoing>G2-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G2-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE18</outgoing>
    </task>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>IIS1-MDEI1</incoming>
      <outgoing>MDEI1-G4</outgoing>
    </task>
    <parallelGateway id="Par13" name="PAR">
      <incoming>PVA1-Par13</incoming>
      <outgoing>Par13-IM1</outgoing>
      <outgoing>Par13-G3</outgoing>
    </parallelGateway>
    <task id="IM1" name="Integrate Modules">
      <incoming>Par13-IM1</incoming>
      <outgoing>IM1-PARCLOSE25</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>Par13-G3</incoming>
      <outgoing>G3-CTV1</outgoing>
      <outgoing>G3-XORCLOSE22</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G3-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE22</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>G2-XORCLOSE18</incoming>
      <incoming>CAI1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-DSE1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G4" name="G4">
      <incoming>MDEI1-G4</incoming>
      <outgoing>G4-CEI1</outgoing>
      <outgoing>G4-XORCLOSE24</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G4-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE24</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE22" name="XORCLOSE22">
      <incoming>G3-XORCLOSE22</incoming>
      <incoming>CTV1-XORCLOSE22</incoming>
      <outgoing>XORCLOSE22-PARCLOSE25</outgoing>
    </exclusiveGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>XORCLOSE18-DSE1</incoming>
      <outgoing>DSE1-PARCLOSE26</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE24" name="XORCLOSE24">
      <incoming>G4-XORCLOSE24</incoming>
      <incoming>CEI1-XORCLOSE24</incoming>
      <outgoing>XORCLOSE24-FRP1</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>IM1-PARCLOSE25</incoming>
      <incoming>XORCLOSE22-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-PARCLOSE28</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>PPV1-PARCLOSE26</incoming>
      <incoming>DSE1-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-PARCLOSE29</outgoing>
    </parallelGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>XORCLOSE24-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE28</outgoing>
    </task>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>PARCLOSE25-PARCLOSE28</incoming>
      <incoming>FRP1-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-PARCLOSE29</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>PARCLOSE26-PARCLOSE29</incoming>
      <incoming>PARCLOSE28-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE29-END</incoming>
    </endEvent>
