  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-PVA1</outgoing>
    </startEvent>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Default_init-PVA1</incoming>
      <outgoing>PVA1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>PVA1-Par1</incoming>
      <outgoing>Par1-IIS1</outgoing>
      <outgoing>Par1-Par6</outgoing>
    </parallelGateway>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par1-IIS1</incoming>
      <outgoing>IIS1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>IIS1-G1</incoming>
      <outgoing>G1-CTV1</outgoing>
      <outgoing>G1-XORCLOSE9</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G1-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE9</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>Par1-Par6</incoming>
      <outgoing>Par6-DF1</outgoing>
      <outgoing>Par6-IM1</outgoing>
    </parallelGateway>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par6-DF1</incoming>
      <outgoing>DF1-Par10</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>Par6-IM1</incoming>
      <outgoing>IM1-FRP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE9" name="XORCLOSE9">
      <incoming>G1-XORCLOSE9</incoming>
      <incoming>CTV1-XORCLOSE9</incoming>
      <outgoing>XORCLOSE9-Par14</outgoing>
    </exclusiveGateway>
    <parallelGateway id="Par10" name="PAR">
      <incoming>DF1-Par10</incoming>
      <outgoing>Par10-APP1</outgoing>
      <outgoing>Par10-DSE1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par10-APP1</incoming>
      <outgoing>APP1-Par17</outgoing>
    </task>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>Par10-DSE1</incoming>
      <outgoing>DSE1-PARCLOSE28</outgoing>
    </task>
    <parallelGateway id="Par14" name="PAR">
      <incoming>XORCLOSE9-Par14</incoming>
      <outgoing>Par14-MDEI1</outgoing>
      <outgoing>Par14-PPV1</outgoing>
