    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par14-MDEI1</incoming>
      <outgoing>MDEI1-PARCLOSE23</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par14-PPV1</incoming>
      <outgoing>PPV1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="Par17" name="PAR">
      <incoming>APP1-Par17</incoming>
      <outgoing>Par17-PIP1</outgoing>
      <outgoing>Par17-G4</outgoing>
    </parallelGateway>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>Par17-PIP1</incoming>
      <outgoing>PIP1-PARCLOSE27</outgoing>
    </task>
    <exclusiveGateway id="G4" name="G4">
      <incoming>Par17-G4</incoming>
      <outgoing>G4-CAI1</outgoing>
      <outgoing>G4-XORCLOSE24</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G4-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE24</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>MDEI1-PARCLOSE23</incoming>
      <incoming>PPV1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-CEI1</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE24" name="XORCLOSE24">
      <incoming>G4-XORCLOSE24</incoming>
      <incoming>CAI1-XORCLOSE24</incoming>
      <outgoing>XORCLOSE24-PARCLOSE27</outgoing>
