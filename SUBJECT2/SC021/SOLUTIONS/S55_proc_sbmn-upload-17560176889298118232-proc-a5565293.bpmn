  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-PVA1</outgoing>
      <outgoing>Par0-PPV1</outgoing>
    </parallelGateway>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par0-PVA1</incoming>
      <outgoing>PVA1-DF1</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par0-PPV1</incoming>
      <outgoing>PPV1-APP1</outgoing>
    </task>
    <task id="DF1" name="Detail Functionalities">
      <incoming>PVA1-DF1</incoming>
      <outgoing>DF1-Par5</outgoing>
    </task>
    <task id="APP1" name="Approve Platform Project">
      <incoming>PPV1-APP1</incoming>
      <outgoing>APP1-Par10</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>DF1-Par5</incoming>
      <outgoing>Par5-IIS1</outgoing>
      <outgoing>Par5-G1</outgoing>
    </parallelGateway>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par5-IIS1</incoming>
      <outgoing>IIS1-Par15</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par5-G1</incoming>
      <outgoing>G1-CTV1</outgoing>
      <outgoing>G1-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G1-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE18</outgoing>
    </task>
    <parallelGateway id="Par10" name="PAR">
      <incoming>APP1-Par10</incoming>
      <outgoing>Par10-G3</outgoing>
      <outgoing>Par10-PIP1</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G3" name="G3">
      <incoming>Par10-G3</incoming>
      <outgoing>G3-CAI1</outgoing>
      <outgoing>G3-XORCLOSE20</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G3-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE20</outgoing>
    </task>
    <parallelGateway id="Par15" name="PAR">
      <incoming>IIS1-Par15</incoming>
      <outgoing>Par15-MDEI1</outgoing>
      <outgoing>Par15-IM1</outgoing>
    </parallelGateway>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par15-MDEI1</incoming>
      <outgoing>MDEI1-G4</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>Par15-IM1</incoming>
      <outgoing>IM1-PARCLOSE27</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>G1-XORCLOSE18</incoming>
      <incoming>CTV1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-DSE1</outgoing>
    </exclusiveGateway>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>Par10-PIP1</incoming>
      <outgoing>PIP1-PARCLOSE25</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>G3-XORCLOSE20</incoming>
      <incoming>CAI1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-PARCLOSE25</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G4" name="G4">
      <incoming>MDEI1-G4</incoming>
      <outgoing>G4-CEI1</outgoing>
      <outgoing>G4-XORCLOSE26</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G4-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE26</outgoing>
    </task>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>XORCLOSE18-DSE1</incoming>
      <outgoing>DSE1-PARCLOSE28</outgoing>
    </task>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>PIP1-PARCLOSE25</incoming>
      <incoming>XORCLOSE20-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-PARCLOSE29</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE26" name="XORCLOSE26">
      <incoming>G4-XORCLOSE26</incoming>
      <incoming>CEI1-XORCLOSE26</incoming>
      <outgoing>XORCLOSE26-PARCLOSE27</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>IM1-PARCLOSE27</incoming>
      <incoming>XORCLOSE26-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-PARCLOSE28</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>DSE1-PARCLOSE28</incoming>
      <incoming>PARCLOSE27-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-PARCLOSE29</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>PARCLOSE25-PARCLOSE29</incoming>
      <incoming>PARCLOSE28-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-FRP1</outgoing>
    </parallelGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>PARCLOSE29-FRP1</incoming>
      <outgoing>FRP1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>FRP1-END</incoming>
    </endEvent>
