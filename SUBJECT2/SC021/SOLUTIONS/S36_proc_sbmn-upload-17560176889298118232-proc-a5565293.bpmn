    <task id="APP1" name="Approve Platform Project">
      <incoming>Par6-APP1</incoming>
      <outgoing>APP1-PIP1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par6-G0</incoming>
      <outgoing>G0-CTV1</outgoing>
      <outgoing>G0-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G0-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE18</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>Par3-IM1</incoming>
      <outgoing>IM1-DSE1</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>DF1-Par12</incoming>
      <outgoing>Par12-MDEI1</outgoing>
      <outgoing>Par12-G1</outgoing>
