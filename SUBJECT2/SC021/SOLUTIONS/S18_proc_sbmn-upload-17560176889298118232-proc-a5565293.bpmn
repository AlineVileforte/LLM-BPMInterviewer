    <sequenceFlow id="IM1-CAI1" sourceRef="IM1" targetRef="CAI1"/>
    <sequenceFlow id="XORCLOSE17-DSE1" sourceRef="XORCLOSE17" targetRef="DSE1"/>
    <sequenceFlow id="CAI1-CEI1" sourceRef="CAI1" targetRef="CEI1"/>
    <sequenceFlow id="PARCLOSE19-PARCLOSE24" sourceRef="PARCLOSE19" targetRef="PARCLOSE24"/>
    <sequenceFlow id="DSE1-FRP1" sourceRef="DSE1" targetRef="FRP1"/>
    <sequenceFlow id="CEI1-PARCLOSE23" sourceRef="CEI1" targetRef="PARCLOSE23"/>
    <sequenceFlow id="FRP1-PARCLOSE23" sourceRef="FRP1" targetRef="PARCLOSE23"/>
    <sequenceFlow id="PARCLOSE23-PARCLOSE24" sourceRef="PARCLOSE23" targetRef="PARCLOSE24"/>
    <sequenceFlow id="PARCLOSE24-END" sourceRef="PARCLOSE24" targetRef="END"/>
  </process>
