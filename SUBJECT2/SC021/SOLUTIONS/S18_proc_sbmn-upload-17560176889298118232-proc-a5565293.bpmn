<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_0625972f-3eba-4cf6-bca6-6b0a5211062a" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-APP1</outgoing>
    </startEvent>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Default_init-APP1</incoming>
      <outgoing>APP1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>APP1-Par1</incoming>
      <outgoing>Par1-PIP1</outgoing>
      <outgoing>Par1-DF1</outgoing>
    </parallelGateway>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>Par1-PIP1</incoming>
      <outgoing>PIP1-Par4</outgoing>
    </task>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par1-DF1</incoming>
      <outgoing>DF1-Par7</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>PIP1-Par4</incoming>
      <outgoing>Par4-PVA1</outgoing>
      <outgoing>Par4-PPV1</outgoing>
    </parallelGateway>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par4-PVA1</incoming>
      <outgoing>PVA1-PARCLOSE19</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par4-PPV1</incoming>
      <outgoing>PPV1-PARCLOSE19</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>DF1-Par7</incoming>
      <outgoing>Par7-MDEI1</outgoing>
      <outgoing>Par7-IIS1</outgoing>
    </parallelGateway>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par7-MDEI1</incoming>
      <outgoing>MDEI1-G2</outgoing>
    </task>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par7-IIS1</incoming>
      <outgoing>IIS1-IM1</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>MDEI1-G2</incoming>
      <outgoing>G2-CTV1</outgoing>
      <outgoing>G2-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G2-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE17</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>IIS1-IM1</incoming>
      <outgoing>IM1-CAI1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE17" name="XORCLOSE17">
      <incoming>G2-XORCLOSE17</incoming>
      <incoming>CTV1-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-DSE1</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>IM1-CAI1</incoming>
      <outgoing>CAI1-CEI1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>PVA1-PARCLOSE19</incoming>
      <incoming>PPV1-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-PARCLOSE24</outgoing>
    </parallelGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>XORCLOSE17-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
    </task>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>CAI1-CEI1</incoming>
      <outgoing>CEI1-PARCLOSE23</outgoing>
    </task>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>DSE1-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>CEI1-PARCLOSE23</incoming>
      <incoming>FRP1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-PARCLOSE24</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>PARCLOSE19-PARCLOSE24</incoming>
      <incoming>PARCLOSE23-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE24-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-APP1" sourceRef="Default_init" targetRef="APP1"/>
