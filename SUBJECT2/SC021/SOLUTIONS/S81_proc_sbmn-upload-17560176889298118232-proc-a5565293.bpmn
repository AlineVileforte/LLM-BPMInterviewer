  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-PVA1</outgoing>
    </startEvent>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Default_init-PVA1</incoming>
      <outgoing>PVA1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>PVA1-Par1</incoming>
      <outgoing>Par1-DF1</outgoing>
      <outgoing>Par1-IIS1</outgoing>
    </parallelGateway>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par1-DF1</incoming>
      <outgoing>DF1-Par4</outgoing>
    </task>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par1-IIS1</incoming>
      <outgoing>IIS1-Par6</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>DF1-Par4</incoming>
      <outgoing>Par4-PPV1</outgoing>
      <outgoing>Par4-G5</outgoing>
    </parallelGateway>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par4-PPV1</incoming>
      <outgoing>PPV1-Par11</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>IIS1-Par6</incoming>
      <outgoing>Par6-G3</outgoing>
      <outgoing>Par6-IM1</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G3" name="G3">
      <incoming>Par6-G3</incoming>
      <outgoing>G3-CTV1</outgoing>
      <outgoing>G3-XORCLOSE19</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G3-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE19</outgoing>
    </task>
    <parallelGateway id="Par11" name="PAR">
      <incoming>PPV1-Par11</incoming>
      <outgoing>Par11-APP1</outgoing>
      <outgoing>Par11-MDEI1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par11-APP1</incoming>
      <outgoing>APP1-DSE1</outgoing>
    </task>
    <exclusiveGateway id="G5" name="G5">
      <incoming>Par4-G5</incoming>
      <outgoing>G5-CAI1</outgoing>
      <outgoing>G5-XORCLOSE22</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G5-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE22</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>Par6-IM1</incoming>
      <outgoing>IM1-PIP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE19" name="XORCLOSE19">
      <incoming>G3-XORCLOSE19</incoming>
      <incoming>CTV1-XORCLOSE19</incoming>
      <outgoing>XORCLOSE19-PARCLOSE25</outgoing>
    </exclusiveGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>APP1-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
    </task>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par11-MDEI1</incoming>
      <outgoing>MDEI1-CEI1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE22" name="XORCLOSE22">
      <incoming>G5-XORCLOSE22</incoming>
      <incoming>CAI1-XORCLOSE22</incoming>
      <outgoing>XORCLOSE22-PARCLOSE29</outgoing>
    </exclusiveGateway>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>IM1-PIP1</incoming>
      <outgoing>PIP1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>XORCLOSE19-PARCLOSE25</incoming>
      <incoming>PIP1-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-PARCLOSE30</outgoing>
    </parallelGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>DSE1-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE28</outgoing>
    </task>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>MDEI1-CEI1</incoming>
      <outgoing>CEI1-PARCLOSE28</outgoing>
    </task>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>FRP1-PARCLOSE28</incoming>
      <incoming>CEI1-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-PARCLOSE29</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>XORCLOSE22-PARCLOSE29</incoming>
      <incoming>PARCLOSE28-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-PARCLOSE30</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE30" name="PARCLOSE30">
      <incoming>PARCLOSE25-PARCLOSE30</incoming>
      <incoming>PARCLOSE29-PARCLOSE30</incoming>
      <outgoing>PARCLOSE30-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE30-END</incoming>
    </endEvent>
