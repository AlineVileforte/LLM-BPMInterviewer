  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-APP1</outgoing>
      <outgoing>Par0-IIS1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par0-APP1</incoming>
      <outgoing>APP1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>APP1-Par2</incoming>
      <outgoing>Par2-DF1</outgoing>
      <outgoing>Par2-PVA1</outgoing>
    </parallelGateway>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par2-DF1</incoming>
      <outgoing>DF1-Par6</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par2-PVA1</incoming>
      <outgoing>PVA1-PARCLOSE25</outgoing>
    </task>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par0-IIS1</incoming>
      <outgoing>IIS1-PPV1</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>DF1-Par6</incoming>
      <outgoing>Par6-MDEI1</outgoing>
      <outgoing>Par6-IM1</outgoing>
    </parallelGateway>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par6-MDEI1</incoming>
      <outgoing>MDEI1-PIP1</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>IIS1-PPV1</incoming>
      <outgoing>PPV1-G7</outgoing>
    </task>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>MDEI1-PIP1</incoming>
      <outgoing>PIP1-G9</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>Par6-IM1</incoming>
      <outgoing>IM1-CEI1</outgoing>
    </task>
    <exclusiveGateway id="G7" name="G7">
      <incoming>PPV1-G7</incoming>
      <outgoing>G7-CTV1</outgoing>
      <outgoing>G7-XORCLOSE20</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G7-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE20</outgoing>
    </task>
    <exclusiveGateway id="G9" name="G9">
      <incoming>PIP1-G9</incoming>
      <outgoing>G9-CAI1</outgoing>
      <outgoing>G9-XORCLOSE21</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G9-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE21</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>G7-XORCLOSE20</incoming>
      <incoming>CTV1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-DSE1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE21" name="XORCLOSE21">
      <incoming>G9-XORCLOSE21</incoming>
      <incoming>CAI1-XORCLOSE21</incoming>
      <outgoing>XORCLOSE21-PARCLOSE24</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>IM1-CEI1</incoming>
      <outgoing>CEI1-PARCLOSE24</outgoing>
    </task>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>XORCLOSE20-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>XORCLOSE21-PARCLOSE24</incoming>
      <incoming>CEI1-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-PARCLOSE25</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>PVA1-PARCLOSE25</incoming>
      <incoming>PARCLOSE24-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-PARCLOSE27</outgoing>
    </parallelGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>DSE1-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE27</outgoing>
    </task>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>PARCLOSE25-PARCLOSE27</incoming>
      <incoming>FRP1-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE27-END</incoming>
    </endEvent>
