      <incoming>DF1-MDEI1</incoming>
      <outgoing>MDEI1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>MDEI1-Par2</incoming>
      <outgoing>Par2-IIS1</outgoing>
      <outgoing>Par2-Par9</outgoing>
    </parallelGateway>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par2-IIS1</incoming>
      <outgoing>IIS1-Par4</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>IIS1-Par4</incoming>
      <outgoing>Par4-IM1</outgoing>
      <outgoing>Par4-G2</outgoing>
    </parallelGateway>
    <task id="IM1" name="Integrate Modules">
      <incoming>Par4-IM1</incoming>
      <outgoing>IM1-PPV1</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par4-G2</incoming>
      <outgoing>G2-CAI1</outgoing>
      <outgoing>G2-XORCLOSE13</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G2-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE13</outgoing>
