  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-IIS1</outgoing>
      <outgoing>Par0-APP1</outgoing>
    </parallelGateway>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par0-IIS1</incoming>
      <outgoing>IIS1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>IIS1-Par2</incoming>
      <outgoing>Par2-PVA1</outgoing>
      <outgoing>Par2-PPV1</outgoing>
    </parallelGateway>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par2-PVA1</incoming>
      <outgoing>PVA1-Par6</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par2-PPV1</incoming>
      <outgoing>PPV1-DF1</outgoing>
    </task>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par0-APP1</incoming>
      <outgoing>APP1-PIP1</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>PVA1-Par6</incoming>
      <outgoing>Par6-IM1</outgoing>
      <outgoing>Par6-G0</outgoing>
    </parallelGateway>
    <task id="IM1" name="Integrate Modules">
      <incoming>Par6-IM1</incoming>
      <outgoing>IM1-PARCLOSE21</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par6-G0</incoming>
      <outgoing>G0-CTV1</outgoing>
      <outgoing>G0-XORCLOSE15</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G0-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE15</outgoing>
    </task>
    <task id="DF1" name="Detail Functionalities">
      <incoming>PPV1-DF1</incoming>
      <outgoing>DF1-G1</outgoing>
    </task>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>APP1-PIP1</incoming>
      <outgoing>PIP1-MDEI1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE15" name="XORCLOSE15">
      <incoming>G0-XORCLOSE15</incoming>
      <incoming>CTV1-XORCLOSE15</incoming>
      <outgoing>XORCLOSE15-PARCLOSE21</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G1" name="G1">
      <incoming>DF1-G1</incoming>
      <outgoing>G1-CAI1</outgoing>
      <outgoing>G1-XORCLOSE22</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G1-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE22</outgoing>
    </task>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>PIP1-MDEI1</incoming>
      <outgoing>MDEI1-Par24</outgoing>
    </task>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>IM1-PARCLOSE21</incoming>
      <incoming>XORCLOSE15-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-PARCLOSE32</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE22" name="XORCLOSE22">
      <incoming>G1-XORCLOSE22</incoming>
      <incoming>CAI1-XORCLOSE22</incoming>
      <outgoing>XORCLOSE22-PARCLOSE32</outgoing>
    </exclusiveGateway>
    <parallelGateway id="Par24" name="PAR">
      <incoming>MDEI1-Par24</incoming>
      <outgoing>Par24-DSE1</outgoing>
      <outgoing>Par24-G2</outgoing>
    </parallelGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>Par24-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par24-G2</incoming>
      <outgoing>G2-CEI1</outgoing>
      <outgoing>G2-XORCLOSE31</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G2-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE31</outgoing>
    </task>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>DSE1-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE33</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE31" name="XORCLOSE31">
      <incoming>G2-XORCLOSE31</incoming>
      <incoming>CEI1-XORCLOSE31</incoming>
      <outgoing>XORCLOSE31-PARCLOSE33</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE32" name="PARCLOSE32">
      <incoming>PARCLOSE21-PARCLOSE32</incoming>
      <incoming>XORCLOSE22-PARCLOSE32</incoming>
      <outgoing>PARCLOSE32-PARCLOSE34</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE33" name="PARCLOSE33">
      <incoming>FRP1-PARCLOSE33</incoming>
      <incoming>XORCLOSE31-PARCLOSE33</incoming>
      <outgoing>PARCLOSE33-PARCLOSE34</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE34" name="PARCLOSE34">
      <incoming>PARCLOSE32-PARCLOSE34</incoming>
      <incoming>PARCLOSE33-PARCLOSE34</incoming>
      <outgoing>PARCLOSE34-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE34-END</incoming>
    </endEvent>
