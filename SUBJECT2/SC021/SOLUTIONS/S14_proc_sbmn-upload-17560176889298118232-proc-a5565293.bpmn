<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_3f7cb35c-43fa-43ed-bc8b-751732447fbc" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-IIS1</outgoing>
      <outgoing>Par0-PPV1</outgoing>
    </parallelGateway>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par0-IIS1</incoming>
      <outgoing>IIS1-APP1</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par0-PPV1</incoming>
      <outgoing>PPV1-PVA1</outgoing>
    </task>
    <task id="APP1" name="Approve Platform Project">
      <incoming>IIS1-APP1</incoming>
      <outgoing>APP1-PIP1</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>PPV1-PVA1</incoming>
      <outgoing>PVA1-G0</outgoing>
    </task>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>APP1-PIP1</incoming>
      <outgoing>PIP1-Par9</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>PVA1-G0</incoming>
      <outgoing>G0-CTV1</outgoing>
      <outgoing>G0-XORCLOSE12</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G0-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE12</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>PIP1-Par9</incoming>
      <outgoing>Par9-DF1</outgoing>
      <outgoing>Par9-IM1</outgoing>
    </parallelGateway>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par9-DF1</incoming>
      <outgoing>DF1-DSE1</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>Par9-IM1</incoming>
      <outgoing>IM1-PARCLOSE25</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE12" name="XORCLOSE12">
      <incoming>G0-XORCLOSE12</incoming>
      <incoming>CTV1-XORCLOSE12</incoming>
      <outgoing>XORCLOSE12-MDEI1</outgoing>
    </exclusiveGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>DF1-DSE1</incoming>
      <outgoing>DSE1-G3</outgoing>
    </task>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>XORCLOSE12-MDEI1</incoming>
      <outgoing>MDEI1-FRP1</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>DSE1-G3</incoming>
      <outgoing>G3-CAI1</outgoing>
      <outgoing>G3-XORCLOSE23</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G3-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE23</outgoing>
    </task>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>MDEI1-FRP1</incoming>
      <outgoing>FRP1-CEI1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE23" name="XORCLOSE23">
      <incoming>G3-XORCLOSE23</incoming>
      <incoming>CAI1-XORCLOSE23</incoming>
      <outgoing>XORCLOSE23-PARCLOSE25</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>FRP1-CEI1</incoming>
      <outgoing>CEI1-PARCLOSE26</outgoing>
    </task>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>IM1-PARCLOSE25</incoming>
      <incoming>XORCLOSE23-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-PARCLOSE26</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>CEI1-PARCLOSE26</incoming>
      <incoming>PARCLOSE25-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE26-END</incoming>
    </endEvent>
