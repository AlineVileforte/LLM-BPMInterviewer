  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-PPV1</outgoing>
    </startEvent>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Default_init-PPV1</incoming>
      <outgoing>PPV1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>PPV1-Par1</incoming>
      <outgoing>Par1-APP1</outgoing>
      <outgoing>Par1-IIS1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par1-APP1</incoming>
      <outgoing>APP1-PIP1</outgoing>
    </task>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par1-IIS1</incoming>
      <outgoing>IIS1-Par5</outgoing>
    </task>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>APP1-PIP1</incoming>
      <outgoing>PIP1-PVA1</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>IIS1-Par5</incoming>
      <outgoing>Par5-DF1</outgoing>
      <outgoing>Par5-IM1</outgoing>
    </parallelGateway>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par5-DF1</incoming>
      <outgoing>DF1-Par9</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>Par5-IM1</incoming>
      <outgoing>IM1-PARCLOSE24</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>PIP1-PVA1</incoming>
      <outgoing>PVA1-G1</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>DF1-Par9</incoming>
      <outgoing>Par9-MDEI1</outgoing>
      <outgoing>Par9-G0</outgoing>
    </parallelGateway>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par9-MDEI1</incoming>
      <outgoing>MDEI1-PARCLOSE22</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par9-G0</incoming>
      <outgoing>G0-CAI1</outgoing>
      <outgoing>G0-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G0-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE18</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>PVA1-G1</incoming>
      <outgoing>G1-CTV1</outgoing>
      <outgoing>G1-XORCLOSE19</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G1-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE19</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>G0-XORCLOSE18</incoming>
      <incoming>CAI1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-CEI1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE19" name="XORCLOSE19">
      <incoming>G1-XORCLOSE19</incoming>
      <incoming>CTV1-XORCLOSE19</incoming>
      <outgoing>XORCLOSE19-DSE1</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>XORCLOSE18-CEI1</incoming>
      <outgoing>CEI1-PARCLOSE22</outgoing>
    </task>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>XORCLOSE19-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>MDEI1-PARCLOSE22</incoming>
      <incoming>CEI1-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-PARCLOSE24</outgoing>
    </parallelGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>DSE1-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>IM1-PARCLOSE24</incoming>
      <incoming>PARCLOSE22-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-PARCLOSE25</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>FRP1-PARCLOSE25</incoming>
      <incoming>PARCLOSE24-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE25-END</incoming>
    </endEvent>
