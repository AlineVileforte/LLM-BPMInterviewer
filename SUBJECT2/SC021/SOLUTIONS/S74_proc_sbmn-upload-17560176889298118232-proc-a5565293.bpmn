<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_fa04c42c-e7f1-427f-ad8f-0745621c1046" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DF1</outgoing>
    </startEvent>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Default_init-DF1</incoming>
      <outgoing>DF1-PPV1</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>DF1-PPV1</incoming>
      <outgoing>PPV1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>PPV1-Par2</incoming>
      <outgoing>Par2-APP1</outgoing>
      <outgoing>Par2-G1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par2-APP1</incoming>
      <outgoing>APP1-Par7</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par2-G1</incoming>
      <outgoing>G1-CAI1</outgoing>
      <outgoing>G1-XORCLOSE10</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G1-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE10</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>APP1-Par7</incoming>
      <outgoing>Par7-MDEI1</outgoing>
      <outgoing>Par7-IIS1</outgoing>
    </parallelGateway>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par7-MDEI1</incoming>
      <outgoing>MDEI1-PVA1</outgoing>
    </task>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par7-IIS1</incoming>
      <outgoing>IIS1-Par12</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE10" name="XORCLOSE10">
      <incoming>G1-XORCLOSE10</incoming>
      <incoming>CAI1-XORCLOSE10</incoming>
      <outgoing>XORCLOSE10-G2</outgoing>
    </exclusiveGateway>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>MDEI1-PVA1</incoming>
      <outgoing>PVA1-G3</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>IIS1-Par12</incoming>
      <outgoing>Par12-PIP1</outgoing>
      <outgoing>Par12-IM1</outgoing>
    </parallelGateway>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>Par12-PIP1</incoming>
      <outgoing>PIP1-PARCLOSE21</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>Par12-IM1</incoming>
      <outgoing>IM1-PARCLOSE21</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>XORCLOSE10-G2</incoming>
      <outgoing>G2-CEI1</outgoing>
      <outgoing>G2-XORCLOSE22</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G2-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE22</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>PVA1-G3</incoming>
      <outgoing>G3-CTV1</outgoing>
      <outgoing>G3-XORCLOSE23</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G3-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE23</outgoing>
    </task>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>PIP1-PARCLOSE21</incoming>
      <incoming>IM1-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-DSE1</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE22" name="XORCLOSE22">
      <incoming>G2-XORCLOSE22</incoming>
      <incoming>CEI1-XORCLOSE22</incoming>
      <outgoing>XORCLOSE22-PARCLOSE26</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE23" name="XORCLOSE23">
      <incoming>G3-XORCLOSE23</incoming>
      <incoming>CTV1-XORCLOSE23</incoming>
      <outgoing>XORCLOSE23-PARCLOSE25</outgoing>
    </exclusiveGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>PARCLOSE21-DSE1</incoming>
      <outgoing>DSE1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>XORCLOSE23-PARCLOSE25</incoming>
      <incoming>DSE1-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-PARCLOSE26</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>XORCLOSE22-PARCLOSE26</incoming>
      <incoming>PARCLOSE25-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-FRP1</outgoing>
    </parallelGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>PARCLOSE26-FRP1</incoming>
      <outgoing>FRP1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>FRP1-END</incoming>
    </endEvent>
