    <sequenceFlow id="XORCLOSE22-PARCLOSE26" sourceRef="XORCLOSE22" targetRef="PARCLOSE26"/>
    <sequenceFlow id="XORCLOSE23-PARCLOSE25" sourceRef="XORCLOSE23" targetRef="PARCLOSE25"/>
    <sequenceFlow id="DSE1-PARCLOSE25" sourceRef="DSE1" targetRef="PARCLOSE25"/>
    <sequenceFlow id="PARCLOSE25-PARCLOSE26" sourceRef="PARCLOSE25" targetRef="PARCLOSE26"/>
    <sequenceFlow id="PARCLOSE26-FRP1" sourceRef="PARCLOSE26" targetRef="FRP1"/>
    <sequenceFlow id="FRP1-END" sourceRef="FRP1" targetRef="END"/>
  </process>
