      <outgoing>XORCLOSE29-PARCLOSE30</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE30" name="PARCLOSE30">
      <incoming>DSE1-PARCLOSE30</incoming>
      <incoming>XORCLOSE29-PARCLOSE30</incoming>
      <outgoing>PARCLOSE30-FRP1</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE31" name="PARCLOSE31">
      <incoming>PIP1-PARCLOSE31</incoming>
      <incoming>PARCLOSE28-PARCLOSE31</incoming>
      <outgoing>PARCLOSE31-PARCLOSE34</outgoing>
    </parallelGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>PARCLOSE30-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE34</outgoing>
    </task>
    <parallelGateway id="PARCLOSE34" name="PARCLOSE34">
      <incoming>PARCLOSE31-PARCLOSE34</incoming>
      <incoming>FRP1-PARCLOSE34</incoming>
      <outgoing>PARCLOSE34-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE34-END</incoming>
    </endEvent>
