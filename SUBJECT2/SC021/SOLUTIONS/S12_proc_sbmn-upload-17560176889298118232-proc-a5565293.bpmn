  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-IIS1</outgoing>
      <outgoing>Par0-IM1</outgoing>
    </parallelGateway>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par0-IIS1</incoming>
      <outgoing>IIS1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>IIS1-Par2</incoming>
      <outgoing>Par2-APP1</outgoing>
      <outgoing>Par2-PPV1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par2-APP1</incoming>
      <outgoing>APP1-PVA1</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par2-PPV1</incoming>
      <outgoing>PPV1-DF1</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>Par0-IM1</incoming>
      <outgoing>IM1-PIP1</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>APP1-PVA1</incoming>
      <outgoing>PVA1-G0</outgoing>
    </task>
    <task id="DF1" name="Detail Functionalities">
      <incoming>PPV1-DF1</incoming>
      <outgoing>DF1-MDEI1</outgoing>
    </task>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>IM1-PIP1</incoming>
      <outgoing>PIP1-PARCLOSE25</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>PVA1-G0</incoming>
      <outgoing>G0-CTV1</outgoing>
      <outgoing>G0-XORCLOSE15</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G0-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE15</outgoing>
    </task>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>DF1-MDEI1</incoming>
      <outgoing>MDEI1-Par16</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE15" name="XORCLOSE15">
      <incoming>G0-XORCLOSE15</incoming>
      <incoming>CTV1-XORCLOSE15</incoming>
      <outgoing>XORCLOSE15-PARCLOSE24</outgoing>
    </exclusiveGateway>
    <parallelGateway id="Par16" name="PAR">
      <incoming>MDEI1-Par16</incoming>
      <outgoing>Par16-DSE1</outgoing>
      <outgoing>Par16-G3</outgoing>
    </parallelGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>Par16-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>Par16-G3</incoming>
      <outgoing>G3-CAI1</outgoing>
      <outgoing>G3-XORCLOSE22</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G3-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE22</outgoing>
    </task>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>DSE1-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE23</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE22" name="XORCLOSE22">
      <incoming>G3-XORCLOSE22</incoming>
      <incoming>CAI1-XORCLOSE22</incoming>
      <outgoing>XORCLOSE22-PARCLOSE23</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>FRP1-PARCLOSE23</incoming>
      <incoming>XORCLOSE22-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-PARCLOSE24</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>XORCLOSE15-PARCLOSE24</incoming>
      <incoming>PARCLOSE23-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-PARCLOSE25</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>PIP1-PARCLOSE25</incoming>
      <incoming>PARCLOSE24-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-G7</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G7" name="G7">
      <incoming>PARCLOSE25-G7</incoming>
      <outgoing>G7-CEI1</outgoing>
      <outgoing>G7-XORCLOSE29</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G7-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE29</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE29" name="XORCLOSE29">
      <incoming>G7-XORCLOSE29</incoming>
      <incoming>CEI1-XORCLOSE29</incoming>
      <outgoing>XORCLOSE29-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE29-END</incoming>
    </endEvent>
