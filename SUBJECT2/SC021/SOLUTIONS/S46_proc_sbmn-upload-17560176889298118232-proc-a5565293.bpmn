  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DF1</outgoing>
    </startEvent>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Default_init-DF1</incoming>
      <outgoing>DF1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>DF1-Par1</incoming>
      <outgoing>Par1-PVA1</outgoing>
      <outgoing>Par1-PPV1</outgoing>
    </parallelGateway>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par1-PVA1</incoming>
      <outgoing>PVA1-Par4</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par1-PPV1</incoming>
      <outgoing>PPV1-MDEI1</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>PVA1-Par4</incoming>
      <outgoing>Par4-APP1</outgoing>
      <outgoing>Par4-IIS1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par4-APP1</incoming>
      <outgoing>APP1-Par10</outgoing>
    </task>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par4-IIS1</incoming>
      <outgoing>IIS1-IM1</outgoing>
    </task>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>PPV1-MDEI1</incoming>
      <outgoing>MDEI1-PIP1</outgoing>
    </task>
    <parallelGateway id="Par10" name="PAR">
      <incoming>APP1-Par10</incoming>
      <outgoing>Par10-CTV1</outgoing>
      <outgoing>Par10-G5</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G5" name="G5">
      <incoming>Par10-G5</incoming>
      <outgoing>G5-CAI1</outgoing>
      <outgoing>G5-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G5-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE17</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>IIS1-IM1</incoming>
      <outgoing>IM1-G7</outgoing>
    </task>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>MDEI1-PIP1</incoming>
      <outgoing>PIP1-PARCLOSE26</outgoing>
    </task>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>Par10-CTV1</incoming>
      <outgoing>CTV1-DSE1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE17" name="XORCLOSE17">
      <incoming>G5-XORCLOSE17</incoming>
      <incoming>CAI1-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-PARCLOSE23</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G7" name="G7">
      <incoming>IM1-G7</incoming>
      <outgoing>G7-CEI1</outgoing>
      <outgoing>G7-XORCLOSE24</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G7-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE24</outgoing>
    </task>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>CTV1-DSE1</incoming>
      <outgoing>DSE1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>XORCLOSE17-PARCLOSE23</incoming>
      <incoming>DSE1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-PARCLOSE25</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE24" name="XORCLOSE24">
      <incoming>G7-XORCLOSE24</incoming>
      <incoming>CEI1-XORCLOSE24</incoming>
      <outgoing>XORCLOSE24-PARCLOSE25</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>PARCLOSE23-PARCLOSE25</incoming>
      <incoming>XORCLOSE24-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-PARCLOSE26</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>PIP1-PARCLOSE26</incoming>
      <incoming>PARCLOSE25-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-FRP1</outgoing>
    </parallelGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>PARCLOSE26-FRP1</incoming>
      <outgoing>FRP1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>FRP1-END</incoming>
    </endEvent>
