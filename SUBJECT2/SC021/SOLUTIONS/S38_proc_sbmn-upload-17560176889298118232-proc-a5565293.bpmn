  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-DF1</outgoing>
      <outgoing>Par0-PVA1</outgoing>
    </parallelGateway>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par0-DF1</incoming>
      <outgoing>DF1-IIS1</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par0-PVA1</incoming>
      <outgoing>PVA1-IM1</outgoing>
    </task>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>DF1-IIS1</incoming>
      <outgoing>IIS1-Par5</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>IIS1-Par5</incoming>
      <outgoing>Par5-APP1</outgoing>
      <outgoing>Par5-MDEI1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par5-APP1</incoming>
      <outgoing>APP1-Par10</outgoing>
    </task>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par5-MDEI1</incoming>
      <outgoing>MDEI1-PPV1</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>PVA1-IM1</incoming>
      <outgoing>IM1-G4</outgoing>
    </task>
    <parallelGateway id="Par10" name="PAR">
      <incoming>APP1-Par10</incoming>
      <outgoing>Par10-PIP1</outgoing>
      <outgoing>Par10-CAI1</outgoing>
    </parallelGateway>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>Par10-PIP1</incoming>
      <outgoing>PIP1-PARCLOSE23</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>MDEI1-PPV1</incoming>
      <outgoing>PPV1-PARCLOSE24</outgoing>
    </task>
    <exclusiveGateway id="G4" name="G4">
      <incoming>IM1-G4</incoming>
      <outgoing>G4-CTV1</outgoing>
      <outgoing>G4-XORCLOSE20</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G4-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE20</outgoing>
    </task>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>Par10-CAI1</incoming>
      <outgoing>CAI1-CEI1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>G4-XORCLOSE20</incoming>
      <incoming>CTV1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-DSE1</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>CAI1-CEI1</incoming>
      <outgoing>CEI1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>PIP1-PARCLOSE23</incoming>
      <incoming>CEI1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-PARCLOSE24</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>PPV1-PARCLOSE24</incoming>
      <incoming>PARCLOSE23-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-PARCLOSE28</outgoing>
    </parallelGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>XORCLOSE20-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
    </task>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>DSE1-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE28</outgoing>
    </task>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>PARCLOSE24-PARCLOSE28</incoming>
      <incoming>FRP1-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE28-END</incoming>
    </endEvent>
