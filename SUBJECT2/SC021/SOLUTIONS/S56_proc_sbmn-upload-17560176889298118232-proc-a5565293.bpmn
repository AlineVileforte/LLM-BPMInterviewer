<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_8126f84e-06d1-4419-8e6e-350dc6be7892" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-APP1</outgoing>
      <outgoing>Par0-IIS1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par0-APP1</incoming>
      <outgoing>APP1-PVA1</outgoing>
    </task>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par0-IIS1</incoming>
      <outgoing>IIS1-IM1</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>APP1-PVA1</incoming>
      <outgoing>PVA1-Par5</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>IIS1-IM1</incoming>
      <outgoing>IM1-DF1</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>PVA1-Par5</incoming>
      <outgoing>Par5-PPV1</outgoing>
      <outgoing>Par5-G0</outgoing>
    </parallelGateway>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par5-PPV1</incoming>
      <outgoing>PPV1-PIP1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par5-G0</incoming>
      <outgoing>G0-CTV1</outgoing>
      <outgoing>G0-XORCLOSE12</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G0-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE12</outgoing>
    </task>
    <task id="DF1" name="Detail Functionalities">
      <incoming>IM1-DF1</incoming>
      <outgoing>DF1-Par13</outgoing>
    </task>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>PPV1-PIP1</incoming>
      <outgoing>PIP1-MDEI1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE12" name="XORCLOSE12">
      <incoming>G0-XORCLOSE12</incoming>
      <incoming>CTV1-XORCLOSE12</incoming>
      <outgoing>XORCLOSE12-PARCLOSE21</outgoing>
    </exclusiveGateway>
    <parallelGateway id="Par13" name="PAR">
      <incoming>DF1-Par13</incoming>
      <outgoing>Par13-DSE1</outgoing>
      <outgoing>Par13-G1</outgoing>
    </parallelGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>Par13-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par13-G1</incoming>
      <outgoing>G1-CAI1</outgoing>
      <outgoing>G1-XORCLOSE20</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G1-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE20</outgoing>
    </task>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>PIP1-MDEI1</incoming>
      <outgoing>MDEI1-PARCLOSE21</outgoing>
    </task>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>DSE1-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE26</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>G1-XORCLOSE20</incoming>
      <incoming>CAI1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-G3</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>XORCLOSE12-PARCLOSE21</incoming>
      <incoming>MDEI1-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-PARCLOSE27</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G3" name="G3">
      <incoming>XORCLOSE20-G3</incoming>
      <outgoing>G3-CEI1</outgoing>
      <outgoing>G3-XORCLOSE25</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G3-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE25</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE25" name="XORCLOSE25">
      <incoming>G3-XORCLOSE25</incoming>
      <incoming>CEI1-XORCLOSE25</incoming>
      <outgoing>XORCLOSE25-PARCLOSE26</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>FRP1-PARCLOSE26</incoming>
      <incoming>XORCLOSE25-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-PARCLOSE27</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>PARCLOSE21-PARCLOSE27</incoming>
      <incoming>PARCLOSE26-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE27-END</incoming>
    </endEvent>
