    <sequenceFlow id="G4-XORCLOSE18" sourceRef="G4" targetRef="XORCLOSE18"/>
    <sequenceFlow id="CAI1-XORCLOSE18" sourceRef="CAI1" targetRef="XORCLOSE18"/>
    <sequenceFlow id="CTV1-DSE1" sourceRef="CTV1" targetRef="DSE1"/>
    <sequenceFlow id="PIP1-FRP1" sourceRef="PIP1" targetRef="FRP1"/>
    <sequenceFlow id="XORCLOSE18-CEI1" sourceRef="XORCLOSE18" targetRef="CEI1"/>
    <sequenceFlow id="DSE1-PARCLOSE23" sourceRef="DSE1" targetRef="PARCLOSE23"/>
    <sequenceFlow id="CEI1-PARCLOSE23" sourceRef="CEI1" targetRef="PARCLOSE23"/>
    <sequenceFlow id="PARCLOSE23-PARCLOSE25" sourceRef="PARCLOSE23" targetRef="PARCLOSE25"/>
    <sequenceFlow id="FRP1-PARCLOSE25" sourceRef="FRP1" targetRef="PARCLOSE25"/>
    <sequenceFlow id="PARCLOSE25-END" sourceRef="PARCLOSE25" targetRef="END"/>
  </process>
