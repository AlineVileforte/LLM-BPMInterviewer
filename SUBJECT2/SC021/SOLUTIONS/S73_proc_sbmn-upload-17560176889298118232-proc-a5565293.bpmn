<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_1cd1c048-2c43-402a-ac67-67b70bf3d223" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-IIS1</outgoing>
    </startEvent>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Default_init-IIS1</incoming>
      <outgoing>IIS1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>IIS1-Par1</incoming>
      <outgoing>Par1-IM1</outgoing>
      <outgoing>Par1-PPV1</outgoing>
    </parallelGateway>
    <task id="IM1" name="Integrate Modules">
      <incoming>Par1-IM1</incoming>
      <outgoing>IM1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>IM1-Par3</incoming>
      <outgoing>Par3-DF1</outgoing>
      <outgoing>Par3-PVA1</outgoing>
    </parallelGateway>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par3-DF1</incoming>
      <outgoing>DF1-MDEI1</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par3-PVA1</incoming>
      <outgoing>PVA1-CTV1</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par1-PPV1</incoming>
      <outgoing>PPV1-APP1</outgoing>
    </task>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>DF1-MDEI1</incoming>
      <outgoing>MDEI1-G4</outgoing>
    </task>
    <task id="APP1" name="Approve Platform Project">
      <incoming>PPV1-APP1</incoming>
      <outgoing>APP1-PIP1</outgoing>
    </task>
    <exclusiveGateway id="G4" name="G4">
      <incoming>MDEI1-G4</incoming>
      <outgoing>G4-CAI1</outgoing>
      <outgoing>G4-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G4-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE18</outgoing>
    </task>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>PVA1-CTV1</incoming>
      <outgoing>CTV1-DSE1</outgoing>
    </task>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>APP1-PIP1</incoming>
      <outgoing>PIP1-FRP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>G4-XORCLOSE18</incoming>
      <incoming>CAI1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-CEI1</outgoing>
    </exclusiveGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>CTV1-DSE1</incoming>
      <outgoing>DSE1-PARCLOSE23</outgoing>
    </task>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>XORCLOSE18-CEI1</incoming>
      <outgoing>CEI1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>DSE1-PARCLOSE23</incoming>
      <incoming>CEI1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-PARCLOSE25</outgoing>
    </parallelGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>PIP1-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>PARCLOSE23-PARCLOSE25</incoming>
      <incoming>FRP1-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE25-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-IIS1" sourceRef="Default_init" targetRef="IIS1"/>
    <sequenceFlow id="IIS1-Par1" sourceRef="IIS1" targetRef="Par1"/>
