    <parallelGateway id="Par16" name="PAR">
      <incoming>APP1-Par16</incoming>
      <outgoing>Par16-PIP1</outgoing>
      <outgoing>Par16-PPV1</outgoing>
    </parallelGateway>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>Par16-PIP1</incoming>
      <outgoing>PIP1-PARCLOSE24</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par16-PPV1</incoming>
      <outgoing>PPV1-PARCLOSE24</outgoing>
    </task>
    <exclusiveGateway id="G7" name="G7">
      <incoming>IM1-G7</incoming>
      <outgoing>G7-CEI1</outgoing>
      <outgoing>G7-XORCLOSE25</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G7-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE25</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE22" name="XORCLOSE22">
      <incoming>G5-XORCLOSE22</incoming>
      <incoming>CTV1-XORCLOSE22</incoming>
      <outgoing>XORCLOSE22-PARCLOSE28</outgoing>
    </exclusiveGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>XORCLOSE15-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
