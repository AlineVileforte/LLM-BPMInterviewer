  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-PVA1</outgoing>
      <outgoing>Par0-IIS1</outgoing>
    </parallelGateway>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par0-PVA1</incoming>
      <outgoing>PVA1-DF1</outgoing>
    </task>
    <task id="DF1" name="Detail Functionalities">
      <incoming>PVA1-DF1</incoming>
      <outgoing>DF1-Par4</outgoing>
    </task>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par0-IIS1</incoming>
      <outgoing>IIS1-Par9</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>DF1-Par4</incoming>
      <outgoing>Par4-MDEI1</outgoing>
      <outgoing>Par4-G3</outgoing>
    </parallelGateway>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par4-MDEI1</incoming>
      <outgoing>MDEI1-G5</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>Par4-G3</incoming>
      <outgoing>G3-CAI1</outgoing>
      <outgoing>G3-XORCLOSE15</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G3-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE15</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>IIS1-Par9</incoming>
      <outgoing>Par9-APP1</outgoing>
      <outgoing>Par9-IM1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par9-APP1</incoming>
      <outgoing>APP1-Par16</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>Par9-IM1</incoming>
      <outgoing>IM1-G7</outgoing>
    </task>
    <exclusiveGateway id="G5" name="G5">
      <incoming>MDEI1-G5</incoming>
      <outgoing>G5-CTV1</outgoing>
      <outgoing>G5-XORCLOSE22</outgoing>
