  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-DF1</outgoing>
      <outgoing>Par0-IIS1</outgoing>
    </parallelGateway>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par0-DF1</incoming>
      <outgoing>DF1-Par3</outgoing>
    </task>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par0-IIS1</incoming>
      <outgoing>IIS1-PPV1</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>DF1-Par3</incoming>
      <outgoing>Par3-APP1</outgoing>
      <outgoing>Par3-MDEI1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par3-APP1</incoming>
      <outgoing>APP1-Par7</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>IIS1-PPV1</incoming>
      <outgoing>PPV1-IM1</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>APP1-Par7</incoming>
      <outgoing>Par7-PIP1</outgoing>
      <outgoing>Par7-G1</outgoing>
    </parallelGateway>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>Par7-PIP1</incoming>
      <outgoing>PIP1-PVA1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par7-G1</incoming>
      <outgoing>G1-CAI1</outgoing>
      <outgoing>G1-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G1-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE17</outgoing>
    </task>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par3-MDEI1</incoming>
      <outgoing>MDEI1-G2</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>PPV1-IM1</incoming>
      <outgoing>IM1-PARCLOSE33</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>PIP1-PVA1</incoming>
      <outgoing>PVA1-G3</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE17" name="XORCLOSE17">
      <incoming>G1-XORCLOSE17</incoming>
      <incoming>CAI1-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-PARCLOSE30</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G2" name="G2">
      <incoming>MDEI1-G2</incoming>
      <outgoing>G2-CEI1</outgoing>
      <outgoing>G2-XORCLOSE25</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G2-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE25</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>PVA1-G3</incoming>
      <outgoing>G3-CTV1</outgoing>
      <outgoing>G3-XORCLOSE27</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G3-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE27</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE25" name="XORCLOSE25">
      <incoming>G2-XORCLOSE25</incoming>
      <incoming>CEI1-XORCLOSE25</incoming>
      <outgoing>XORCLOSE25-DSE1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE27" name="XORCLOSE27">
      <incoming>G3-XORCLOSE27</incoming>
      <incoming>CTV1-XORCLOSE27</incoming>
      <outgoing>XORCLOSE27-PARCLOSE30</outgoing>
    </exclusiveGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>XORCLOSE25-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE30" name="PARCLOSE30">
      <incoming>XORCLOSE17-PARCLOSE30</incoming>
      <incoming>XORCLOSE27-PARCLOSE30</incoming>
      <outgoing>PARCLOSE30-PARCLOSE32</outgoing>
    </parallelGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>DSE1-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE32</outgoing>
    </task>
    <parallelGateway id="PARCLOSE32" name="PARCLOSE32">
      <incoming>PARCLOSE30-PARCLOSE32</incoming>
      <incoming>FRP1-PARCLOSE32</incoming>
      <outgoing>PARCLOSE32-PARCLOSE33</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE33" name="PARCLOSE33">
      <incoming>IM1-PARCLOSE33</incoming>
      <incoming>PARCLOSE32-PARCLOSE33</incoming>
      <outgoing>PARCLOSE33-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE33-END</incoming>
    </endEvent>
