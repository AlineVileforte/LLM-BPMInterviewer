    </parallelGateway>
    <parallelGateway id="PARCLOSE30" name="PARCLOSE30">
      <incoming>PIP1-PARCLOSE30</incoming>
      <incoming>PARCLOSE29-PARCLOSE30</incoming>
      <outgoing>PARCLOSE30-PARCLOSE32</outgoing>
    </parallelGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>PARCLOSE28-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE32</outgoing>
    </task>
    <parallelGateway id="PARCLOSE32" name="PARCLOSE32">
      <incoming>PARCLOSE30-PARCLOSE32</incoming>
      <incoming>FRP1-PARCLOSE32</incoming>
      <outgoing>PARCLOSE32-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE32-END</incoming>
    </endEvent>
