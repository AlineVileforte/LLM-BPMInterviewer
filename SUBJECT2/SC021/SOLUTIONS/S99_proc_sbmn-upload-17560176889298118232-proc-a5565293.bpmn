      <outgoing>PIP1-PARCLOSE30</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE25" name="XORCLOSE25">
      <incoming>G3-XORCLOSE25</incoming>
      <incoming>CTV1-XORCLOSE25</incoming>
      <outgoing>XORCLOSE25-PARCLOSE28</outgoing>
    </exclusiveGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>XORCLOSE17-DSE1</incoming>
      <outgoing>DSE1-PARCLOSE28</outgoing>
