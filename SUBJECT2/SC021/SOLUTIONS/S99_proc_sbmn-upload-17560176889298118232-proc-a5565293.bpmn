      <incoming>Par5-G1</incoming>
      <outgoing>G1-CAI1</outgoing>
      <outgoing>G1-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G1-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE17</outgoing>
    </task>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>PVA1-IIS1</incoming>
      <outgoing>IIS1-Par18</outgoing>
    </task>
    <task id="APP1" name="Approve Platform Project">
      <incoming>PPV1-APP1</incoming>
      <outgoing>APP1-PIP1</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>MDEI1-G3</incoming>
      <outgoing>G3-CTV1</outgoing>
      <outgoing>G3-XORCLOSE25</outgoing>
