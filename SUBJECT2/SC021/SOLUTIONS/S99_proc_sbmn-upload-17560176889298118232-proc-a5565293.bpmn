    <parallelGateway id="Par18" name="PAR">
      <incoming>IIS1-Par18</incoming>
      <outgoing>Par18-IM1</outgoing>
      <outgoing>Par18-G4</outgoing>
    </parallelGateway>
    <task id="IM1" name="Integrate Modules">
      <incoming>Par18-IM1</incoming>
      <outgoing>IM1-PARCLOSE29</outgoing>
    </task>
    <exclusiveGateway id="G4" name="G4">
      <incoming>Par18-G4</incoming>
      <outgoing>G4-CEI1</outgoing>
      <outgoing>G4-XORCLOSE27</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G4-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE27</outgoing>
    </task>
    <task id="PIP1" name="Prepare Interface Prototypes">
