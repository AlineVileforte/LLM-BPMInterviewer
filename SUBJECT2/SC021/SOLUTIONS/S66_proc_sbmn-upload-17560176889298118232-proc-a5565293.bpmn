    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G2-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE18</outgoing>
    </task>
    <exclusiveGateway id="G4" name="G4">
      <incoming>MDEI1-G4</incoming>
      <outgoing>G4-CAI1</outgoing>
      <outgoing>G4-XORCLOSE19</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G4-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE19</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>Par5-IM1</incoming>
      <outgoing>IM1-G5</outgoing>
    </task>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par8-APP1</incoming>
      <outgoing>APP1-PIP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>G2-XORCLOSE18</incoming>
      <incoming>CTV1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-DSE1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE19" name="XORCLOSE19">
      <incoming>G4-XORCLOSE19</incoming>
      <incoming>CAI1-XORCLOSE19</incoming>
      <outgoing>XORCLOSE19-PARCLOSE28</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G5" name="G5">
      <incoming>IM1-G5</incoming>
      <outgoing>G5-CEI1</outgoing>
      <outgoing>G5-XORCLOSE26</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
