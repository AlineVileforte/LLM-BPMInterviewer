      <outgoing>CEI1-XORCLOSE26</outgoing>
    </task>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>APP1-PIP1</incoming>
      <outgoing>PIP1-PARCLOSE27</outgoing>
    </task>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>XORCLOSE18-DSE1</incoming>
      <outgoing>DSE1-PARCLOSE27</outgoing>
