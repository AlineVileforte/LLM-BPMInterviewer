      <incoming>PVA1-Par8</incoming>
      <outgoing>Par8-APP1</outgoing>
      <outgoing>Par8-G2</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par8-G2</incoming>
      <outgoing>G2-CTV1</outgoing>
      <outgoing>G2-XORCLOSE18</outgoing>
