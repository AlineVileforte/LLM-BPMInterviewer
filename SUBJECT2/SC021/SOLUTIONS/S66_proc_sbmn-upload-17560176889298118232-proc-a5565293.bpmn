  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-PPV1</outgoing>
    </startEvent>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Default_init-PPV1</incoming>
      <outgoing>PPV1-DF1</outgoing>
    </task>
    <task id="DF1" name="Detail Functionalities">
      <incoming>PPV1-DF1</incoming>
      <outgoing>DF1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>DF1-Par2</incoming>
      <outgoing>Par2-IIS1</outgoing>
      <outgoing>Par2-PVA1</outgoing>
    </parallelGateway>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par2-IIS1</incoming>
      <outgoing>IIS1-Par5</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par2-PVA1</incoming>
      <outgoing>PVA1-Par8</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>IIS1-Par5</incoming>
      <outgoing>Par5-MDEI1</outgoing>
      <outgoing>Par5-IM1</outgoing>
    </parallelGateway>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par5-MDEI1</incoming>
      <outgoing>MDEI1-G4</outgoing>
    </task>
