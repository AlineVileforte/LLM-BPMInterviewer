    <sequenceFlow id="MDEI1-CEI1" sourceRef="MDEI1" targetRef="CEI1"/>
    <sequenceFlow id="XORCLOSE21-PARCLOSE26" sourceRef="XORCLOSE21" targetRef="PARCLOSE26"/>
    <sequenceFlow id="PIP1-DSE1" sourceRef="PIP1" targetRef="DSE1"/>
    <sequenceFlow id="XORCLOSE23-PARCLOSE30" sourceRef="XORCLOSE23" targetRef="PARCLOSE30"/>
    <sequenceFlow id="CEI1-PARCLOSE26" sourceRef="CEI1" targetRef="PARCLOSE26"/>
    <sequenceFlow id="PARCLOSE26-PARCLOSE29" sourceRef="PARCLOSE26" targetRef="PARCLOSE29"/>
    <sequenceFlow id="DSE1-PARCLOSE29" sourceRef="DSE1" targetRef="PARCLOSE29"/>
    <sequenceFlow id="PARCLOSE29-PARCLOSE30" sourceRef="PARCLOSE29" targetRef="PARCLOSE30"/>
    <sequenceFlow id="PARCLOSE30-FRP1" sourceRef="PARCLOSE30" targetRef="FRP1"/>
    <sequenceFlow id="FRP1-END" sourceRef="FRP1" targetRef="END"/>
  </process>
