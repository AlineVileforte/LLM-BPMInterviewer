      <incoming>PARCLOSE22-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-PARCLOSE29</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G8" name="G8">
      <incoming>PARCLOSE23-G8</incoming>
      <outgoing>G8-CEI1</outgoing>
      <outgoing>G8-XORCLOSE28</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G8-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE28</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE28" name="XORCLOSE28">
      <incoming>G8-XORCLOSE28</incoming>
      <incoming>CEI1-XORCLOSE28</incoming>
      <outgoing>XORCLOSE28-PARCLOSE29</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>PARCLOSE24-PARCLOSE29</incoming>
      <incoming>XORCLOSE28-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE29-END</incoming>
    </endEvent>
