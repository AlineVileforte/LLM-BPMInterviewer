  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-PVA1</outgoing>
      <outgoing>Par0-Par3</outgoing>
    </parallelGateway>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par0-PVA1</incoming>
      <outgoing>PVA1-APP1</outgoing>
    </task>
    <task id="APP1" name="Approve Platform Project">
      <incoming>PVA1-APP1</incoming>
      <outgoing>APP1-Par6</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>Par0-Par3</incoming>
      <outgoing>Par3-IIS1</outgoing>
      <outgoing>Par3-PPV1</outgoing>
    </parallelGateway>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par3-IIS1</incoming>
      <outgoing>IIS1-DF1</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par3-PPV1</incoming>
      <outgoing>PPV1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>APP1-Par6</incoming>
      <outgoing>Par6-PIP1</outgoing>
      <outgoing>Par6-G2</outgoing>
    </parallelGateway>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>Par6-PIP1</incoming>
      <outgoing>PIP1-IM1</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par6-G2</incoming>
      <outgoing>G2-CTV1</outgoing>
      <outgoing>G2-XORCLOSE13</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G2-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE13</outgoing>
    </task>
    <task id="DF1" name="Detail Functionalities">
      <incoming>IIS1-DF1</incoming>
      <outgoing>DF1-Par14</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>PIP1-IM1</incoming>
      <outgoing>IM1-PARCLOSE23</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE13" name="XORCLOSE13">
      <incoming>G2-XORCLOSE13</incoming>
      <incoming>CTV1-XORCLOSE13</incoming>
      <outgoing>XORCLOSE13-DSE1</outgoing>
    </exclusiveGateway>
    <parallelGateway id="Par14" name="PAR">
      <incoming>DF1-Par14</incoming>
      <outgoing>Par14-MDEI1</outgoing>
      <outgoing>Par14-G3</outgoing>
    </parallelGateway>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par14-MDEI1</incoming>
      <outgoing>MDEI1-PARCLOSE22</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>Par14-G3</incoming>
      <outgoing>G3-CAI1</outgoing>
      <outgoing>G3-XORCLOSE20</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G3-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE20</outgoing>
    </task>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>XORCLOSE13-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>G3-XORCLOSE20</incoming>
      <incoming>CAI1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-PARCLOSE22</outgoing>
    </exclusiveGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>DSE1-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>MDEI1-PARCLOSE22</incoming>
      <incoming>XORCLOSE20-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-PARCLOSE24</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
