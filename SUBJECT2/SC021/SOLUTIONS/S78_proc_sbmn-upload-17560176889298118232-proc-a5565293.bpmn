<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_8cde98a0-9d2b-4f57-8d67-2dc34baa3e91" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DF1</outgoing>
    </startEvent>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Default_init-DF1</incoming>
      <outgoing>DF1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>DF1-Par1</incoming>
      <outgoing>Par1-IIS1</outgoing>
      <outgoing>Par1-G0</outgoing>
    </parallelGateway>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par1-IIS1</incoming>
      <outgoing>IIS1-APP1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par1-G0</incoming>
      <outgoing>G0-CAI1</outgoing>
      <outgoing>G0-XORCLOSE7</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G0-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE7</outgoing>
    </task>
    <task id="APP1" name="Approve Platform Project">
      <incoming>IIS1-APP1</incoming>
      <outgoing>APP1-IM1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE7" name="XORCLOSE7">
      <incoming>G0-XORCLOSE7</incoming>
      <incoming>CAI1-XORCLOSE7</incoming>
      <outgoing>XORCLOSE7-Par9</outgoing>
    </exclusiveGateway>
    <task id="IM1" name="Integrate Modules">
      <incoming>APP1-IM1</incoming>
      <outgoing>IM1-MDEI1</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>XORCLOSE7-Par9</incoming>
      <outgoing>Par9-PIP1</outgoing>
      <outgoing>Par9-PPV1</outgoing>
    </parallelGateway>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>Par9-PIP1</incoming>
      <outgoing>PIP1-PVA1</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par9-PPV1</incoming>
      <outgoing>PPV1-G3</outgoing>
    </task>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>IM1-MDEI1</incoming>
      <outgoing>MDEI1-PARCLOSE25</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>PIP1-PVA1</incoming>
      <outgoing>PVA1-G4</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>PPV1-G3</incoming>
      <outgoing>G3-CEI1</outgoing>
      <outgoing>G3-XORCLOSE20</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G3-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE20</outgoing>
    </task>
    <exclusiveGateway id="G4" name="G4">
      <incoming>PVA1-G4</incoming>
      <outgoing>G4-CTV1</outgoing>
      <outgoing>G4-XORCLOSE21</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G4-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE21</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>G3-XORCLOSE20</incoming>
      <incoming>CEI1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-DSE1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE21" name="XORCLOSE21">
      <incoming>G4-XORCLOSE21</incoming>
      <incoming>CTV1-XORCLOSE21</incoming>
      <outgoing>XORCLOSE21-PARCLOSE23</outgoing>
    </exclusiveGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>XORCLOSE20-DSE1</incoming>
      <outgoing>DSE1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>XORCLOSE21-PARCLOSE23</incoming>
      <incoming>DSE1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-FRP1</outgoing>
    </parallelGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>PARCLOSE23-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>MDEI1-PARCLOSE25</incoming>
      <incoming>FRP1-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE25-END</incoming>
    </endEvent>
