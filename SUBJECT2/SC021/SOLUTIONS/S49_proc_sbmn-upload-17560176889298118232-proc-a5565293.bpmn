<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_2f94361b-03e5-48e7-a55c-f3d39ec0ebd7" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-APP1</outgoing>
      <outgoing>Par0-PVA1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par0-APP1</incoming>
      <outgoing>APP1-Par3</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par0-PVA1</incoming>
      <outgoing>PVA1-IIS1</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>APP1-Par3</incoming>
      <outgoing>Par3-DF1</outgoing>
      <outgoing>Par3-IM1</outgoing>
    </parallelGateway>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par3-DF1</incoming>
      <outgoing>DF1-PIP1</outgoing>
    </task>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>PVA1-IIS1</incoming>
      <outgoing>IIS1-Par11</outgoing>
    </task>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>DF1-PIP1</incoming>
      <outgoing>PIP1-PPV1</outgoing>
    </task>
    <parallelGateway id="Par11" name="PAR">
      <incoming>IIS1-Par11</incoming>
      <outgoing>Par11-MDEI1</outgoing>
      <outgoing>Par11-G2</outgoing>
    </parallelGateway>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par11-MDEI1</incoming>
      <outgoing>MDEI1-CTV1</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par11-G2</incoming>
      <outgoing>G2-CAI1</outgoing>
      <outgoing>G2-XORCLOSE20</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G2-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE20</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>PIP1-PPV1</incoming>
      <outgoing>PPV1-PARCLOSE21</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>Par3-IM1</incoming>
      <outgoing>IM1-PARCLOSE21</outgoing>
    </task>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>MDEI1-CTV1</incoming>
      <outgoing>CTV1-DSE1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>G2-XORCLOSE20</incoming>
      <incoming>CAI1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-CEI1</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>PPV1-PARCLOSE21</incoming>
      <incoming>IM1-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-PARCLOSE26</outgoing>
    </parallelGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>CTV1-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
    </task>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>XORCLOSE20-CEI1</incoming>
      <outgoing>CEI1-PARCLOSE25</outgoing>
    </task>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>DSE1-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>CEI1-PARCLOSE25</incoming>
      <incoming>FRP1-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-PARCLOSE26</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>PARCLOSE21-PARCLOSE26</incoming>
      <incoming>PARCLOSE25-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE26-END</incoming>
    </endEvent>
