<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_87720147-8129-4c84-8a13-91b51f0ea363" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-APP1</outgoing>
      <outgoing>Par0-DF1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par0-APP1</incoming>
      <outgoing>APP1-Par3</outgoing>
    </task>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par0-DF1</incoming>
      <outgoing>DF1-Par6</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>APP1-Par3</incoming>
      <outgoing>Par3-PIP1</outgoing>
      <outgoing>Par3-PVA1</outgoing>
    </parallelGateway>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>Par3-PIP1</incoming>
      <outgoing>PIP1-PARCLOSE23</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par3-PVA1</incoming>
      <outgoing>PVA1-CTV1</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>DF1-Par6</incoming>
      <outgoing>Par6-IIS1</outgoing>
      <outgoing>Par6-PPV1</outgoing>
    </parallelGateway>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par6-IIS1</incoming>
      <outgoing>IIS1-IM1</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par6-PPV1</incoming>
      <outgoing>PPV1-MDEI1</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>IIS1-IM1</incoming>
      <outgoing>IM1-CAI1</outgoing>
    </task>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>PPV1-MDEI1</incoming>
      <outgoing>MDEI1-PARCLOSE22</outgoing>
    </task>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>PVA1-CTV1</incoming>
      <outgoing>CTV1-DSE1</outgoing>
    </task>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>IM1-CAI1</incoming>
      <outgoing>CAI1-CEI1</outgoing>
    </task>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>CTV1-DSE1</incoming>
      <outgoing>DSE1-PARCLOSE23</outgoing>
    </task>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>CAI1-CEI1</incoming>
      <outgoing>CEI1-PARCLOSE22</outgoing>
    </task>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>MDEI1-PARCLOSE22</incoming>
      <incoming>CEI1-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-FRP1</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>PIP1-PARCLOSE23</incoming>
      <incoming>DSE1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-PARCLOSE25</outgoing>
    </parallelGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>PARCLOSE22-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>PARCLOSE23-PARCLOSE25</incoming>
      <incoming>FRP1-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE25-END</incoming>
    </endEvent>
