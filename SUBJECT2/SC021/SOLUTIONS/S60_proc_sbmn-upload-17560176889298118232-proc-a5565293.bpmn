<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_de904485-8b8e-4d03-b9b5-b894abeaadc4" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-IIS1</outgoing>
      <outgoing>Par0-PPV1</outgoing>
    </parallelGateway>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par0-IIS1</incoming>
      <outgoing>IIS1-Par3</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par0-PPV1</incoming>
      <outgoing>PPV1-PVA1</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>IIS1-Par3</incoming>
      <outgoing>Par3-APP1</outgoing>
      <outgoing>Par3-DF1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par3-APP1</incoming>
      <outgoing>APP1-PIP1</outgoing>
    </task>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par3-DF1</incoming>
      <outgoing>DF1-IM1</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>PPV1-PVA1</incoming>
      <outgoing>PVA1-G1</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>DF1-IM1</incoming>
      <outgoing>IM1-MDEI1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>PVA1-G1</incoming>
      <outgoing>G1-CTV1</outgoing>
      <outgoing>G1-XORCLOSE16</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G1-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE16</outgoing>
    </task>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>APP1-PIP1</incoming>
      <outgoing>PIP1-DSE1</outgoing>
    </task>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>IM1-MDEI1</incoming>
      <outgoing>MDEI1-CAI1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
      <incoming>G1-XORCLOSE16</incoming>
      <incoming>CTV1-XORCLOSE16</incoming>
      <outgoing>XORCLOSE16-PARCLOSE22</outgoing>
    </exclusiveGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>PIP1-DSE1</incoming>
      <outgoing>DSE1-PARCLOSE20</outgoing>
    </task>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>MDEI1-CAI1</incoming>
      <outgoing>CAI1-PARCLOSE20</outgoing>
    </task>
    <parallelGateway id="PARCLOSE20" name="PARCLOSE20">
      <incoming>DSE1-PARCLOSE20</incoming>
      <incoming>CAI1-PARCLOSE20</incoming>
      <outgoing>PARCLOSE20-CEI1</outgoing>
    </parallelGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>PARCLOSE20-CEI1</incoming>
      <outgoing>CEI1-PARCLOSE22</outgoing>
    </task>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>XORCLOSE16-PARCLOSE22</incoming>
      <incoming>CEI1-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-FRP1</outgoing>
    </parallelGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>PARCLOSE22-FRP1</incoming>
      <outgoing>FRP1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>FRP1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
    <sequenceFlow id="Par0-IIS1" sourceRef="Par0" targetRef="IIS1"/>
