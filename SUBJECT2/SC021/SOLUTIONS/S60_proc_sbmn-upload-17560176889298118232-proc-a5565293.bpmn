    <sequenceFlow id="PIP1-DSE1" sourceRef="PIP1" targetRef="DSE1"/>
    <sequenceFlow id="MDEI1-CAI1" sourceRef="MDEI1" targetRef="CAI1"/>
    <sequenceFlow id="XORCLOSE16-PARCLOSE22" sourceRef="XORCLOSE16" targetRef="PARCLOSE22"/>
    <sequenceFlow id="DSE1-PARCLOSE20" sourceRef="DSE1" targetRef="PARCLOSE20"/>
    <sequenceFlow id="CAI1-PARCLOSE20" sourceRef="CAI1" targetRef="PARCLOSE20"/>
    <sequenceFlow id="PARCLOSE20-CEI1" sourceRef="PARCLOSE20" targetRef="CEI1"/>
    <sequenceFlow id="CEI1-PARCLOSE22" sourceRef="CEI1" targetRef="PARCLOSE22"/>
    <sequenceFlow id="PARCLOSE22-FRP1" sourceRef="PARCLOSE22" targetRef="FRP1"/>
    <sequenceFlow id="FRP1-END" sourceRef="FRP1" targetRef="END"/>
  </process>
