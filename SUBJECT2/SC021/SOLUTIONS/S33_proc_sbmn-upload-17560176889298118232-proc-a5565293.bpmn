  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-DF1</outgoing>
      <outgoing>Par0-Par5</outgoing>
    </parallelGateway>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par0-DF1</incoming>
      <outgoing>DF1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>DF1-Par2</incoming>
      <outgoing>Par2-IIS1</outgoing>
      <outgoing>Par2-PPV1</outgoing>
    </parallelGateway>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par2-IIS1</incoming>
      <outgoing>IIS1-APP1</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par2-PPV1</incoming>
      <outgoing>PPV1-PVA1</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>Par0-Par5</incoming>
      <outgoing>Par5-MDEI1</outgoing>
      <outgoing>Par5-G1</outgoing>
    </parallelGateway>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par5-MDEI1</incoming>
      <outgoing>MDEI1-IM1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par5-G1</incoming>
      <outgoing>G1-CAI1</outgoing>
      <outgoing>G1-XORCLOSE13</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G1-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE13</outgoing>
    </task>
    <task id="APP1" name="Approve Platform Project">
      <incoming>IIS1-APP1</incoming>
      <outgoing>APP1-G2</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>PPV1-PVA1</incoming>
      <outgoing>PVA1-G3</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>MDEI1-IM1</incoming>
      <outgoing>IM1-PIP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE13" name="XORCLOSE13">
      <incoming>G1-XORCLOSE13</incoming>
      <incoming>CAI1-XORCLOSE13</incoming>
      <outgoing>XORCLOSE13-PARCLOSE26</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G2" name="G2">
      <incoming>APP1-G2</incoming>
      <outgoing>G2-CEI1</outgoing>
      <outgoing>G2-XORCLOSE21</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G2-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE21</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>PVA1-G3</incoming>
      <outgoing>G3-CTV1</outgoing>
      <outgoing>G3-XORCLOSE22</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G3-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE22</outgoing>
    </task>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>IM1-PIP1</incoming>
      <outgoing>PIP1-DSE1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE21" name="XORCLOSE21">
      <incoming>G2-XORCLOSE21</incoming>
      <incoming>CEI1-XORCLOSE21</incoming>
      <outgoing>XORCLOSE21-PARCLOSE24</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE22" name="XORCLOSE22">
      <incoming>G3-XORCLOSE22</incoming>
      <incoming>CTV1-XORCLOSE22</incoming>
      <outgoing>XORCLOSE22-PARCLOSE24</outgoing>
    </exclusiveGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>PIP1-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>XORCLOSE21-PARCLOSE24</incoming>
      <incoming>XORCLOSE22-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-PARCLOSE27</outgoing>
    </parallelGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>DSE1-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE26</outgoing>
    </task>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>XORCLOSE13-PARCLOSE26</incoming>
      <incoming>FRP1-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-PARCLOSE27</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>PARCLOSE24-PARCLOSE27</incoming>
      <incoming>PARCLOSE26-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE27-END</incoming>
    </endEvent>
