  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-DF1</outgoing>
      <outgoing>Par0-IIS1</outgoing>
    </parallelGateway>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par0-DF1</incoming>
      <outgoing>DF1-Par3</outgoing>
    </task>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par0-IIS1</incoming>
      <outgoing>IIS1-Par7</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>DF1-Par3</incoming>
      <outgoing>Par3-G0</outgoing>
      <outgoing>Par3-MDEI1</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par3-G0</incoming>
      <outgoing>G0-CAI1</outgoing>
      <outgoing>G0-XORCLOSE12</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G0-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE12</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>IIS1-Par7</incoming>
      <outgoing>Par7-APP1</outgoing>
      <outgoing>Par7-PVA1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par7-APP1</incoming>
      <outgoing>APP1-Par13</outgoing>
    </task>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par3-MDEI1</incoming>
      <outgoing>MDEI1-PIP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE12" name="XORCLOSE12">
      <incoming>G0-XORCLOSE12</incoming>
      <incoming>CAI1-XORCLOSE12</incoming>
      <outgoing>XORCLOSE12-CEI1</outgoing>
    </exclusiveGateway>
    <parallelGateway id="Par13" name="PAR">
      <incoming>APP1-Par13</incoming>
      <outgoing>Par13-IM1</outgoing>
      <outgoing>Par13-PPV1</outgoing>
    </parallelGateway>
    <task id="IM1" name="Integrate Modules">
      <incoming>Par13-IM1</incoming>
      <outgoing>IM1-PARCLOSE19</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par13-PPV1</incoming>
      <outgoing>PPV1-PARCLOSE19</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par7-PVA1</incoming>
      <outgoing>PVA1-G1</outgoing>
    </task>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>MDEI1-PIP1</incoming>
      <outgoing>PIP1-DSE1</outgoing>
    </task>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>XORCLOSE12-CEI1</incoming>
      <outgoing>CEI1-PARCLOSE28</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>IM1-PARCLOSE19</incoming>
      <incoming>PPV1-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-PARCLOSE26</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G1" name="G1">
      <incoming>PVA1-G1</incoming>
      <outgoing>G1-CTV1</outgoing>
      <outgoing>G1-XORCLOSE24</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G1-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE24</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE24" name="XORCLOSE24">
      <incoming>G1-XORCLOSE24</incoming>
      <incoming>CTV1-XORCLOSE24</incoming>
      <outgoing>XORCLOSE24-PARCLOSE26</outgoing>
    </exclusiveGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>PIP1-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>PARCLOSE19-PARCLOSE26</incoming>
      <incoming>XORCLOSE24-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-PARCLOSE29</outgoing>
    </parallelGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>DSE1-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE28</outgoing>
    </task>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>CEI1-PARCLOSE28</incoming>
      <incoming>FRP1-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-PARCLOSE29</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>PARCLOSE26-PARCLOSE29</incoming>
      <incoming>PARCLOSE28-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE29-END</incoming>
    </endEvent>
