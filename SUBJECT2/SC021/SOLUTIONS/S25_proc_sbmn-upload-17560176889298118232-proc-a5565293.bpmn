  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-DF1</outgoing>
      <outgoing>Par0-Par4</outgoing>
    </parallelGateway>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par0-DF1</incoming>
      <outgoing>DF1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>DF1-Par2</incoming>
      <outgoing>Par2-MDEI1</outgoing>
      <outgoing>Par2-Par11</outgoing>
    </parallelGateway>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par2-MDEI1</incoming>
      <outgoing>MDEI1-PPV1</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>Par0-Par4</incoming>
      <outgoing>Par4-IIS1</outgoing>
      <outgoing>Par4-G1</outgoing>
    </parallelGateway>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par4-IIS1</incoming>
      <outgoing>IIS1-IM1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par4-G1</incoming>
      <outgoing>G1-CAI1</outgoing>
      <outgoing>G1-XORCLOSE15</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G1-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE15</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>MDEI1-PPV1</incoming>
      <outgoing>PPV1-G2</outgoing>
    </task>
    <parallelGateway id="Par11" name="PAR">
      <incoming>Par2-Par11</incoming>
      <outgoing>Par11-APP1</outgoing>
      <outgoing>Par11-PVA1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par11-APP1</incoming>
      <outgoing>APP1-PIP1</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par11-PVA1</incoming>
      <outgoing>PVA1-G3</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>IIS1-IM1</incoming>
      <outgoing>IM1-PARCLOSE23</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE15" name="XORCLOSE15">
      <incoming>G1-XORCLOSE15</incoming>
      <incoming>CAI1-XORCLOSE15</incoming>
      <outgoing>XORCLOSE15-PARCLOSE23</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G2" name="G2">
      <incoming>PPV1-G2</incoming>
      <outgoing>G2-CEI1</outgoing>
      <outgoing>G2-XORCLOSE24</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G2-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE24</outgoing>
    </task>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>APP1-PIP1</incoming>
      <outgoing>PIP1-PARCLOSE29</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>PVA1-G3</incoming>
      <outgoing>G3-CTV1</outgoing>
      <outgoing>G3-XORCLOSE26</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G3-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE26</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>IM1-PARCLOSE23</incoming>
      <incoming>XORCLOSE15-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-DSE1</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE24" name="XORCLOSE24">
      <incoming>G2-XORCLOSE24</incoming>
      <incoming>CEI1-XORCLOSE24</incoming>
      <outgoing>XORCLOSE24-PARCLOSE31</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE26" name="XORCLOSE26">
      <incoming>G3-XORCLOSE26</incoming>
      <incoming>CTV1-XORCLOSE26</incoming>
      <outgoing>XORCLOSE26-PARCLOSE29</outgoing>
    </exclusiveGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>PARCLOSE23-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>PIP1-PARCLOSE29</incoming>
      <incoming>XORCLOSE26-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-PARCLOSE31</outgoing>
    </parallelGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>DSE1-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE32</outgoing>
    </task>
    <parallelGateway id="PARCLOSE31" name="PARCLOSE31">
      <incoming>XORCLOSE24-PARCLOSE31</incoming>
      <incoming>PARCLOSE29-PARCLOSE31</incoming>
      <outgoing>PARCLOSE31-PARCLOSE32</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE32" name="PARCLOSE32">
      <incoming>FRP1-PARCLOSE32</incoming>
      <incoming>PARCLOSE31-PARCLOSE32</incoming>
      <outgoing>PARCLOSE32-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE32-END</incoming>
    </endEvent>
