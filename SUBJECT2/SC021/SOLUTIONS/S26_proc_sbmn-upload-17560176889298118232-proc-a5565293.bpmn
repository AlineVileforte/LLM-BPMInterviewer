  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-APP1</outgoing>
    </startEvent>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Default_init-APP1</incoming>
      <outgoing>APP1-PPV1</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>APP1-PPV1</incoming>
      <outgoing>PPV1-DF1</outgoing>
    </task>
    <task id="DF1" name="Detail Functionalities">
      <incoming>PPV1-DF1</incoming>
      <outgoing>DF1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>DF1-Par3</incoming>
      <outgoing>Par3-IIS1</outgoing>
      <outgoing>Par3-G0</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par3-G0</incoming>
      <outgoing>G0-CAI1</outgoing>
      <outgoing>G0-XORCLOSE8</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G0-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE8</outgoing>
    </task>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par3-IIS1</incoming>
      <outgoing>IIS1-Par9</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE8" name="XORCLOSE8">
      <incoming>G0-XORCLOSE8</incoming>
      <incoming>CAI1-XORCLOSE8</incoming>
      <outgoing>XORCLOSE8-Par12</outgoing>
    </exclusiveGateway>
    <parallelGateway id="Par9" name="PAR">
      <incoming>IIS1-Par9</incoming>
      <outgoing>Par9-IM1</outgoing>
      <outgoing>Par9-PVA1</outgoing>
    </parallelGateway>
    <task id="IM1" name="Integrate Modules">
      <incoming>Par9-IM1</incoming>
      <outgoing>IM1-PIP1</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par9-PVA1</incoming>
      <outgoing>PVA1-G2</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>XORCLOSE8-Par12</incoming>
      <outgoing>Par12-MDEI1</outgoing>
      <outgoing>Par12-G1</outgoing>
    </parallelGateway>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par12-MDEI1</incoming>
      <outgoing>MDEI1-PARCLOSE24</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par12-G1</incoming>
      <outgoing>G1-CEI1</outgoing>
      <outgoing>G1-XORCLOSE21</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G1-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE21</outgoing>
    </task>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>IM1-PIP1</incoming>
      <outgoing>PIP1-PARCLOSE27</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>PVA1-G2</incoming>
      <outgoing>G2-CTV1</outgoing>
      <outgoing>G2-XORCLOSE23</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G2-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE23</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE21" name="XORCLOSE21">
      <incoming>G1-XORCLOSE21</incoming>
      <incoming>CEI1-XORCLOSE21</incoming>
      <outgoing>XORCLOSE21-PARCLOSE24</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE23" name="XORCLOSE23">
      <incoming>G2-XORCLOSE23</incoming>
      <incoming>CTV1-XORCLOSE23</incoming>
      <outgoing>XORCLOSE23-DSE1</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>MDEI1-PARCLOSE24</incoming>
      <incoming>XORCLOSE21-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-PARCLOSE28</outgoing>
    </parallelGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>XORCLOSE23-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
    </task>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>DSE1-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE27</outgoing>
    </task>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>PIP1-PARCLOSE27</incoming>
      <incoming>FRP1-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-PARCLOSE28</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>PARCLOSE24-PARCLOSE28</incoming>
      <incoming>PARCLOSE27-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE28-END</incoming>
    </endEvent>
