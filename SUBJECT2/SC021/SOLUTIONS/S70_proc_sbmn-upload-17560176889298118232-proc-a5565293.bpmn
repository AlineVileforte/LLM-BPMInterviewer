  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-PPV1</outgoing>
    </startEvent>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Default_init-PPV1</incoming>
      <outgoing>PPV1-PVA1</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>PPV1-PVA1</incoming>
      <outgoing>PVA1-IIS1</outgoing>
    </task>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>PVA1-IIS1</incoming>
      <outgoing>IIS1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>IIS1-Par3</incoming>
      <outgoing>Par3-APP1</outgoing>
      <outgoing>Par3-G1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par3-APP1</incoming>
      <outgoing>APP1-Par8</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par3-G1</incoming>
      <outgoing>G1-CTV1</outgoing>
      <outgoing>G1-XORCLOSE11</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G1-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE11</outgoing>
    </task>
    <parallelGateway id="Par8" name="PAR">
      <incoming>APP1-Par8</incoming>
      <outgoing>Par8-DF1</outgoing>
      <outgoing>Par8-IM1</outgoing>
    </parallelGateway>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par8-DF1</incoming>
      <outgoing>DF1-G2</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>Par8-IM1</incoming>
      <outgoing>IM1-PIP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE11" name="XORCLOSE11">
      <incoming>G1-XORCLOSE11</incoming>
      <incoming>CTV1-XORCLOSE11</incoming>
      <outgoing>XORCLOSE11-Par19</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G2" name="G2">
      <incoming>DF1-G2</incoming>
      <outgoing>G2-CAI1</outgoing>
      <outgoing>G2-XORCLOSE22</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G2-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE22</outgoing>
    </task>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>IM1-PIP1</incoming>
      <outgoing>PIP1-PARCLOSE30</outgoing>
    </task>
    <parallelGateway id="Par19" name="PAR">
      <incoming>XORCLOSE11-Par19</incoming>
      <outgoing>Par19-MDEI1</outgoing>
      <outgoing>Par19-DSE1</outgoing>
    </parallelGateway>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par19-MDEI1</incoming>
      <outgoing>MDEI1-G3</outgoing>
    </task>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>Par19-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE22" name="XORCLOSE22">
      <incoming>G2-XORCLOSE22</incoming>
      <incoming>CAI1-XORCLOSE22</incoming>
      <outgoing>XORCLOSE22-PARCLOSE30</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G3" name="G3">
      <incoming>MDEI1-G3</incoming>
      <outgoing>G3-CEI1</outgoing>
      <outgoing>G3-XORCLOSE31</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G3-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE31</outgoing>
    </task>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>DSE1-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE32</outgoing>
    </task>
    <parallelGateway id="PARCLOSE30" name="PARCLOSE30">
      <incoming>PIP1-PARCLOSE30</incoming>
      <incoming>XORCLOSE22-PARCLOSE30</incoming>
      <outgoing>PARCLOSE30-PARCLOSE33</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE31" name="XORCLOSE31">
      <incoming>G3-XORCLOSE31</incoming>
      <incoming>CEI1-XORCLOSE31</incoming>
      <outgoing>XORCLOSE31-PARCLOSE32</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE32" name="PARCLOSE32">
      <incoming>FRP1-PARCLOSE32</incoming>
      <incoming>XORCLOSE31-PARCLOSE32</incoming>
      <outgoing>PARCLOSE32-PARCLOSE33</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE33" name="PARCLOSE33">
      <incoming>PARCLOSE30-PARCLOSE33</incoming>
      <incoming>PARCLOSE32-PARCLOSE33</incoming>
      <outgoing>PARCLOSE33-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE33-END</incoming>
    </endEvent>
