  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-IIS1</outgoing>
      <outgoing>Par0-Par3</outgoing>
    </parallelGateway>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par0-IIS1</incoming>
      <outgoing>IIS1-PVA1</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>IIS1-PVA1</incoming>
      <outgoing>PVA1-IM1</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>Par0-Par3</incoming>
      <outgoing>Par3-PPV1</outgoing>
      <outgoing>Par3-G2</outgoing>
    </parallelGateway>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par3-PPV1</incoming>
      <outgoing>PPV1-DF1</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>PVA1-IM1</incoming>
      <outgoing>IM1-APP1</outgoing>
    </task>
    <task id="DF1" name="Detail Functionalities">
      <incoming>PPV1-DF1</incoming>
      <outgoing>DF1-Par13</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par3-G2</incoming>
      <outgoing>G2-CTV1</outgoing>
      <outgoing>G2-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G2-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE18</outgoing>
    </task>
    <task id="APP1" name="Approve Platform Project">
      <incoming>IM1-APP1</incoming>
      <outgoing>APP1-G5</outgoing>
    </task>
    <parallelGateway id="Par13" name="PAR">
      <incoming>DF1-Par13</incoming>
      <outgoing>Par13-MDEI1</outgoing>
      <outgoing>Par13-G3</outgoing>
    </parallelGateway>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par13-MDEI1</incoming>
      <outgoing>MDEI1-PIP1</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>Par13-G3</incoming>
      <outgoing>G3-CAI1</outgoing>
      <outgoing>G3-XORCLOSE21</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G3-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE21</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>G2-XORCLOSE18</incoming>
      <incoming>CTV1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-DSE1</outgoing>
    </exclusiveGateway>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>MDEI1-PIP1</incoming>
      <outgoing>PIP1-PARCLOSE26</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE21" name="XORCLOSE21">
      <incoming>G3-XORCLOSE21</incoming>
      <incoming>CAI1-XORCLOSE21</incoming>
      <outgoing>XORCLOSE21-PARCLOSE26</outgoing>
    </exclusiveGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>XORCLOSE18-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
    </task>
    <exclusiveGateway id="G5" name="G5">
      <incoming>APP1-G5</incoming>
      <outgoing>G5-CEI1</outgoing>
      <outgoing>G5-XORCLOSE28</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G5-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE28</outgoing>
    </task>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>PIP1-PARCLOSE26</incoming>
      <incoming>XORCLOSE21-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-PARCLOSE30</outgoing>
    </parallelGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>DSE1-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE30</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE28" name="XORCLOSE28">
      <incoming>G5-XORCLOSE28</incoming>
      <incoming>CEI1-XORCLOSE28</incoming>
      <outgoing>XORCLOSE28-PARCLOSE31</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE30" name="PARCLOSE30">
      <incoming>PARCLOSE26-PARCLOSE30</incoming>
      <incoming>FRP1-PARCLOSE30</incoming>
      <outgoing>PARCLOSE30-PARCLOSE31</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE31" name="PARCLOSE31">
      <incoming>XORCLOSE28-PARCLOSE31</incoming>
      <incoming>PARCLOSE30-PARCLOSE31</incoming>
      <outgoing>PARCLOSE31-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE31-END</incoming>
    </endEvent>
