    <sequenceFlow id="FRP1-PARCLOSE28" sourceRef="FRP1" targetRef="PARCLOSE28"/>
    <sequenceFlow id="PARCLOSE28-END" sourceRef="PARCLOSE28" targetRef="END"/>
  </process>
