  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-IIS1</outgoing>
      <outgoing>Par0-PVA1</outgoing>
    </parallelGateway>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par0-IIS1</incoming>
      <outgoing>IIS1-IM1</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par0-PVA1</incoming>
      <outgoing>PVA1-DF1</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>IIS1-IM1</incoming>
      <outgoing>IM1-APP1</outgoing>
    </task>
    <task id="DF1" name="Detail Functionalities">
      <incoming>PVA1-DF1</incoming>
      <outgoing>DF1-Par6</outgoing>
    </task>
    <task id="APP1" name="Approve Platform Project">
      <incoming>IM1-APP1</incoming>
      <outgoing>APP1-Par11</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>DF1-Par6</incoming>
      <outgoing>Par6-PPV1</outgoing>
      <outgoing>Par6-G1</outgoing>
    </parallelGateway>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par6-PPV1</incoming>
      <outgoing>PPV1-PIP1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par6-G1</incoming>
      <outgoing>G1-CTV1</outgoing>
      <outgoing>G1-XORCLOSE14</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G1-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE14</outgoing>
    </task>
    <parallelGateway id="Par11" name="PAR">
      <incoming>APP1-Par11</incoming>
      <outgoing>Par11-MDEI1</outgoing>
      <outgoing>Par11-G5</outgoing>
    </parallelGateway>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>PPV1-PIP1</incoming>
      <outgoing>PIP1-PARCLOSE19</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>G1-XORCLOSE14</incoming>
      <incoming>CTV1-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-PARCLOSE19</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G5" name="G5">
      <incoming>Par11-G5</incoming>
      <outgoing>G5-CAI1</outgoing>
      <outgoing>G5-XORCLOSE20</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G5-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE20</outgoing>
    </task>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par11-MDEI1</incoming>
      <outgoing>MDEI1-G6</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>PIP1-PARCLOSE19</incoming>
      <incoming>XORCLOSE14-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-DSE1</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>G5-XORCLOSE20</incoming>
      <incoming>CAI1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-PARCLOSE27</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G6" name="G6">
      <incoming>MDEI1-G6</incoming>
      <outgoing>G6-CEI1</outgoing>
      <outgoing>G6-XORCLOSE25</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G6-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE25</outgoing>
    </task>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>PARCLOSE19-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE25" name="XORCLOSE25">
      <incoming>G6-XORCLOSE25</incoming>
      <incoming>CEI1-XORCLOSE25</incoming>
      <outgoing>XORCLOSE25-PARCLOSE27</outgoing>
    </exclusiveGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>DSE1-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE28</outgoing>
    </task>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>XORCLOSE20-PARCLOSE27</incoming>
      <incoming>XORCLOSE25-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-PARCLOSE28</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>FRP1-PARCLOSE28</incoming>
      <incoming>PARCLOSE27-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE28-END</incoming>
    </endEvent>
