<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_69410344-269c-46a6-9987-92d89429e48e" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-APP1</outgoing>
      <outgoing>Par0-PVA1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par0-APP1</incoming>
      <outgoing>APP1-IIS1</outgoing>
    </task>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>APP1-IIS1</incoming>
      <outgoing>IIS1-Par4</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par0-PVA1</incoming>
      <outgoing>PVA1-G0</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>IIS1-Par4</incoming>
      <outgoing>Par4-IM1</outgoing>
      <outgoing>Par4-DF1</outgoing>
    </parallelGateway>
    <task id="IM1" name="Integrate Modules">
      <incoming>Par4-IM1</incoming>
      <outgoing>IM1-Par9</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>PVA1-G0</incoming>
      <outgoing>G0-CTV1</outgoing>
      <outgoing>G0-XORCLOSE12</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G0-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE12</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>IM1-Par9</incoming>
      <outgoing>Par9-PPV1</outgoing>
      <outgoing>Par9-DSE1</outgoing>
    </parallelGateway>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par9-PPV1</incoming>
      <outgoing>PPV1-PIP1</outgoing>
    </task>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par4-DF1</incoming>
      <outgoing>DF1-G1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE12" name="XORCLOSE12">
      <incoming>G0-XORCLOSE12</incoming>
      <incoming>CTV1-XORCLOSE12</incoming>
      <outgoing>XORCLOSE12-MDEI1</outgoing>
    </exclusiveGateway>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>PPV1-PIP1</incoming>
      <outgoing>PIP1-PARCLOSE24</outgoing>
    </task>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>Par9-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>DF1-G1</incoming>
      <outgoing>G1-CAI1</outgoing>
      <outgoing>G1-XORCLOSE20</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G1-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE20</outgoing>
    </task>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>XORCLOSE12-MDEI1</incoming>
      <outgoing>MDEI1-G2</outgoing>
    </task>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>DSE1-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE24</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>G1-XORCLOSE20</incoming>
      <incoming>CAI1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-PARCLOSE25</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G2" name="G2">
      <incoming>MDEI1-G2</incoming>
      <outgoing>G2-CEI1</outgoing>
      <outgoing>G2-XORCLOSE26</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G2-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE26</outgoing>
    </task>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>PIP1-PARCLOSE24</incoming>
      <incoming>FRP1-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-PARCLOSE25</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>XORCLOSE20-PARCLOSE25</incoming>
      <incoming>PARCLOSE24-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-PARCLOSE27</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE26" name="XORCLOSE26">
      <incoming>G2-XORCLOSE26</incoming>
      <incoming>CEI1-XORCLOSE26</incoming>
      <outgoing>XORCLOSE26-PARCLOSE27</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>PARCLOSE25-PARCLOSE27</incoming>
      <incoming>XORCLOSE26-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE27-END</incoming>
    </endEvent>
