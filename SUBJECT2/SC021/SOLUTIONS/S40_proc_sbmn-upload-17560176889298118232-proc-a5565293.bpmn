  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-PPV1</outgoing>
    </startEvent>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Default_init-PPV1</incoming>
      <outgoing>PPV1-APP1</outgoing>
    </task>
    <task id="APP1" name="Approve Platform Project">
      <incoming>PPV1-APP1</incoming>
      <outgoing>APP1-PIP1</outgoing>
    </task>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>APP1-PIP1</incoming>
      <outgoing>PIP1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>PIP1-Par3</incoming>
      <outgoing>Par3-IIS1</outgoing>
      <outgoing>Par3-PVA1</outgoing>
    </parallelGateway>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par3-IIS1</incoming>
      <outgoing>IIS1-IM1</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par3-PVA1</incoming>
      <outgoing>PVA1-DF1</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>IIS1-IM1</incoming>
      <outgoing>IM1-MDEI1</outgoing>
    </task>
    <task id="DF1" name="Detail Functionalities">
      <incoming>PVA1-DF1</incoming>
      <outgoing>DF1-Par9</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>DF1-Par9</incoming>
      <outgoing>Par9-G1</outgoing>
      <outgoing>Par9-G2</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par9-G1</incoming>
      <outgoing>G1-CTV1</outgoing>
      <outgoing>G1-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G1-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE17</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par9-G2</incoming>
      <outgoing>G2-CAI1</outgoing>
      <outgoing>G2-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G2-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE18</outgoing>
    </task>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>IM1-MDEI1</incoming>
      <outgoing>MDEI1-G3</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE17" name="XORCLOSE17">
      <incoming>G1-XORCLOSE17</incoming>
      <incoming>CTV1-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-DSE1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>G2-XORCLOSE18</incoming>
      <incoming>CAI1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-PARCLOSE25</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G3" name="G3">
      <incoming>MDEI1-G3</incoming>
      <outgoing>G3-CEI1</outgoing>
      <outgoing>G3-XORCLOSE23</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G3-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE23</outgoing>
    </task>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>XORCLOSE17-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE23" name="XORCLOSE23">
      <incoming>G3-XORCLOSE23</incoming>
      <incoming>CEI1-XORCLOSE23</incoming>
      <outgoing>XORCLOSE23-PARCLOSE26</outgoing>
    </exclusiveGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>DSE1-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>XORCLOSE18-PARCLOSE25</incoming>
      <incoming>FRP1-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-PARCLOSE26</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>XORCLOSE23-PARCLOSE26</incoming>
      <incoming>PARCLOSE25-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE26-END</incoming>
    </endEvent>
