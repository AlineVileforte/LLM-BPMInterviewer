    <task id="IM1" name="Integrate Modules">
      <incoming>Par9-IM1</incoming>
      <outgoing>IM1-PARCLOSE27</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par9-G1</incoming>
      <outgoing>G1-CAI1</outgoing>
      <outgoing>G1-XORCLOSE21</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G1-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE21</outgoing>
