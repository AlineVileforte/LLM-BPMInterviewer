      <outgoing>MDEI1-G3</outgoing>
    </task>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>APP1-PIP1</incoming>
      <outgoing>PIP1-DSE1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE21" name="XORCLOSE21">
      <incoming>G1-XORCLOSE21</incoming>
      <incoming>CAI1-XORCLOSE21</incoming>
      <outgoing>XORCLOSE21-PARCLOSE27</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE22" name="XORCLOSE22">
