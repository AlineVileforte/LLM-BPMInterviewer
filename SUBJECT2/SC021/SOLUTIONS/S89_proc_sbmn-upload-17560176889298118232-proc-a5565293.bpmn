  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-APP1</outgoing>
      <outgoing>Par0-Par4</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par0-APP1</incoming>
      <outgoing>APP1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>APP1-Par2</incoming>
      <outgoing>Par2-PPV1</outgoing>
      <outgoing>Par2-IIS1</outgoing>
    </parallelGateway>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par2-PPV1</incoming>
      <outgoing>PPV1-PVA1</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>Par0-Par4</incoming>
      <outgoing>Par4-PIP1</outgoing>
      <outgoing>Par4-DF1</outgoing>
    </parallelGateway>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>Par4-PIP1</incoming>
      <outgoing>PIP1-DSE1</outgoing>
    </task>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par4-DF1</incoming>
      <outgoing>DF1-Par12</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>PPV1-PVA1</incoming>
      <outgoing>PVA1-G1</outgoing>
    </task>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par2-IIS1</incoming>
      <outgoing>IIS1-IM1</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>DF1-Par12</incoming>
      <outgoing>Par12-MDEI1</outgoing>
      <outgoing>Par12-G0</outgoing>
    </parallelGateway>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par12-MDEI1</incoming>
      <outgoing>MDEI1-PARCLOSE26</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par12-G0</incoming>
      <outgoing>G0-CAI1</outgoing>
      <outgoing>G0-XORCLOSE22</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G0-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE22</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>PVA1-G1</incoming>
      <outgoing>G1-CTV1</outgoing>
      <outgoing>G1-XORCLOSE23</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G1-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE23</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>IIS1-IM1</incoming>
      <outgoing>IM1-CEI1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE22" name="XORCLOSE22">
      <incoming>G0-XORCLOSE22</incoming>
      <incoming>CAI1-XORCLOSE22</incoming>
      <outgoing>XORCLOSE22-PARCLOSE26</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE23" name="XORCLOSE23">
      <incoming>G1-XORCLOSE23</incoming>
      <incoming>CTV1-XORCLOSE23</incoming>
      <outgoing>XORCLOSE23-PARCLOSE27</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>IM1-CEI1</incoming>
      <outgoing>CEI1-PARCLOSE27</outgoing>
    </task>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>PIP1-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>MDEI1-PARCLOSE26</incoming>
      <incoming>XORCLOSE22-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-PARCLOSE29</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>XORCLOSE23-PARCLOSE27</incoming>
      <incoming>CEI1-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-PARCLOSE30</outgoing>
    </parallelGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>DSE1-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE29</outgoing>
    </task>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>PARCLOSE26-PARCLOSE29</incoming>
      <incoming>FRP1-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-PARCLOSE30</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE30" name="PARCLOSE30">
      <incoming>PARCLOSE27-PARCLOSE30</incoming>
      <incoming>PARCLOSE29-PARCLOSE30</incoming>
      <outgoing>PARCLOSE30-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE30-END</incoming>
    </endEvent>
