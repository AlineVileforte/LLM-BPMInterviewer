      <outgoing>Par9-MDEI1</outgoing>
    </parallelGateway>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par9-DF1</incoming>
      <outgoing>DF1-G1</outgoing>
    </task>
    <parallelGateway id="Par11" name="PAR">
      <incoming>PPV1-Par11</incoming>
      <outgoing>Par11-APP1</outgoing>
      <outgoing>Par11-DSE1</outgoing>
