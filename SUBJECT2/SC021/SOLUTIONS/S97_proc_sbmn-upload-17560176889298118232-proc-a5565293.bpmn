<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_24304d6f-be5e-4f25-a274-db561ee286d5" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-PVA1</outgoing>
      <outgoing>Par0-PPV1</outgoing>
    </parallelGateway>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par0-PVA1</incoming>
      <outgoing>PVA1-IIS1</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par0-PPV1</incoming>
      <outgoing>PPV1-Par4</outgoing>
    </task>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>PVA1-IIS1</incoming>
      <outgoing>IIS1-Par6</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>PPV1-Par4</incoming>
      <outgoing>Par4-DF1</outgoing>
      <outgoing>Par4-APP1</outgoing>
    </parallelGateway>
    <parallelGateway id="Par6" name="PAR">
      <incoming>IIS1-Par6</incoming>
      <outgoing>Par6-IM1</outgoing>
      <outgoing>Par6-G1</outgoing>
    </parallelGateway>
    <task id="IM1" name="Integrate Modules">
      <incoming>Par6-IM1</incoming>
      <outgoing>IM1-PARCLOSE16</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par6-G1</incoming>
      <outgoing>G1-CTV1</outgoing>
      <outgoing>G1-XORCLOSE13</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G1-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE13</outgoing>
    </task>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par4-APP1</incoming>
      <outgoing>APP1-PIP1</outgoing>
    </task>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par4-DF1</incoming>
      <outgoing>DF1-MDEI1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE13" name="XORCLOSE13">
      <incoming>G1-XORCLOSE13</incoming>
      <incoming>CTV1-XORCLOSE13</incoming>
      <outgoing>XORCLOSE13-PARCLOSE16</outgoing>
    </exclusiveGateway>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>APP1-PIP1</incoming>
      <outgoing>PIP1-G4</outgoing>
    </task>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>DF1-MDEI1</incoming>
      <outgoing>MDEI1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="PARCLOSE16" name="PARCLOSE16">
      <incoming>IM1-PARCLOSE16</incoming>
      <incoming>XORCLOSE13-PARCLOSE16</incoming>
      <outgoing>PARCLOSE16-DSE1</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G4" name="G4">
      <incoming>PIP1-G4</incoming>
      <outgoing>G4-CAI1</outgoing>
      <outgoing>G4-XORCLOSE21</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G4-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE21</outgoing>
    </task>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>PARCLOSE16-DSE1</incoming>
      <outgoing>DSE1-G5</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE21" name="XORCLOSE21">
      <incoming>G4-XORCLOSE21</incoming>
      <incoming>CAI1-XORCLOSE21</incoming>
      <outgoing>XORCLOSE21-PARCLOSE25</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G5" name="G5">
      <incoming>DSE1-G5</incoming>
      <outgoing>G5-CEI1</outgoing>
      <outgoing>G5-XORCLOSE26</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G5-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE26</outgoing>
    </task>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>MDEI1-PARCLOSE25</incoming>
      <incoming>XORCLOSE21-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-PARCLOSE27</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE26" name="XORCLOSE26">
      <incoming>G5-XORCLOSE26</incoming>
      <incoming>CEI1-XORCLOSE26</incoming>
      <outgoing>XORCLOSE26-PARCLOSE27</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>PARCLOSE25-PARCLOSE27</incoming>
      <incoming>XORCLOSE26-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-FRP1</outgoing>
    </parallelGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>PARCLOSE27-FRP1</incoming>
      <outgoing>FRP1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>FRP1-END</incoming>
    </endEvent>
