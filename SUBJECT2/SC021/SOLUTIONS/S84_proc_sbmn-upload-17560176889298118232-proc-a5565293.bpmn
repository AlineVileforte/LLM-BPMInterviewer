  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-PPV1</outgoing>
      <outgoing>Par0-Par4</outgoing>
    </parallelGateway>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par0-PPV1</incoming>
      <outgoing>PPV1-PVA1</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>PPV1-PVA1</incoming>
      <outgoing>PVA1-Par7</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>Par0-Par4</incoming>
      <outgoing>Par4-DF1</outgoing>
      <outgoing>Par4-IIS1</outgoing>
    </parallelGateway>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par4-DF1</incoming>
      <outgoing>DF1-Par12</outgoing>
    </task>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par4-IIS1</incoming>
      <outgoing>IIS1-IM1</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>PVA1-Par7</incoming>
      <outgoing>Par7-APP1</outgoing>
      <outgoing>Par7-G0</outgoing>
