    </parallelGateway>
    <parallelGateway id="PARCLOSE34" name="PARCLOSE34">
      <incoming>IM1-PARCLOSE34</incoming>
      <incoming>PARCLOSE29-PARCLOSE34</incoming>
      <outgoing>PARCLOSE34-PARCLOSE35</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE35" name="PARCLOSE35">
      <incoming>PARCLOSE32-PARCLOSE35</incoming>
      <incoming>PARCLOSE34-PARCLOSE35</incoming>
      <outgoing>PARCLOSE35-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
