    <task id="IM1" name="Integrate Modules">
      <incoming>IIS1-IM1</incoming>
      <outgoing>IM1-PARCLOSE34</outgoing>
    </task>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>APP1-PIP1</incoming>
      <outgoing>PIP1-G2</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE21" name="XORCLOSE21">
      <incoming>G0-XORCLOSE21</incoming>
      <incoming>CTV1-XORCLOSE21</incoming>
      <outgoing>XORCLOSE21-PARCLOSE32</outgoing>
    </exclusiveGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>MDEI1-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE23" name="XORCLOSE23">
      <incoming>G1-XORCLOSE23</incoming>
      <incoming>CAI1-XORCLOSE23</incoming>
      <outgoing>XORCLOSE23-PARCLOSE29</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G2" name="G2">
      <incoming>PIP1-G2</incoming>
      <outgoing>G2-CEI1</outgoing>
      <outgoing>G2-XORCLOSE31</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G2-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE31</outgoing>
    </task>
    <task id="FRP1" name="Finalize and Release to Production">
