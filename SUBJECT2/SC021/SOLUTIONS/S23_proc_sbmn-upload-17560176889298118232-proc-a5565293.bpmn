  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-DF1</outgoing>
      <outgoing>Par0-PPV1</outgoing>
    </parallelGateway>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par0-DF1</incoming>
      <outgoing>DF1-Par3</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par0-PPV1</incoming>
      <outgoing>PPV1-APP1</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>DF1-Par3</incoming>
      <outgoing>Par3-MDEI1</outgoing>
      <outgoing>Par3-PVA1</outgoing>
    </parallelGateway>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par3-MDEI1</incoming>
      <outgoing>MDEI1-G5</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par3-PVA1</incoming>
      <outgoing>PVA1-IIS1</outgoing>
    </task>
    <task id="APP1" name="Approve Platform Project">
      <incoming>PPV1-APP1</incoming>
      <outgoing>APP1-Par10</outgoing>
    </task>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>PVA1-IIS1</incoming>
      <outgoing>IIS1-IM1</outgoing>
    </task>
    <parallelGateway id="Par10" name="PAR">
      <incoming>APP1-Par10</incoming>
      <outgoing>Par10-PIP1</outgoing>
      <outgoing>Par10-CTV1</outgoing>
    </parallelGateway>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>Par10-PIP1</incoming>
      <outgoing>PIP1-PARCLOSE28</outgoing>
    </task>
    <exclusiveGateway id="G5" name="G5">
      <incoming>MDEI1-G5</incoming>
      <outgoing>G5-CAI1</outgoing>
      <outgoing>G5-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G5-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE18</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>IIS1-IM1</incoming>
      <outgoing>IM1-G6</outgoing>
    </task>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>Par10-CTV1</incoming>
      <outgoing>CTV1-DSE1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>G5-XORCLOSE18</incoming>
      <incoming>CAI1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-PARCLOSE27</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G6" name="G6">
      <incoming>IM1-G6</incoming>
      <outgoing>G6-CEI1</outgoing>
      <outgoing>G6-XORCLOSE25</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G6-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE25</outgoing>
    </task>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>CTV1-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE25" name="XORCLOSE25">
      <incoming>G6-XORCLOSE25</incoming>
      <incoming>CEI1-XORCLOSE25</incoming>
      <outgoing>XORCLOSE25-PARCLOSE27</outgoing>
    </exclusiveGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>DSE1-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE28</outgoing>
    </task>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>XORCLOSE18-PARCLOSE27</incoming>
      <incoming>XORCLOSE25-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-PARCLOSE29</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>PIP1-PARCLOSE28</incoming>
      <incoming>FRP1-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-PARCLOSE29</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>PARCLOSE27-PARCLOSE29</incoming>
      <incoming>PARCLOSE28-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE29-END</incoming>
    </endEvent>
