  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-APP1</outgoing>
      <outgoing>Par0-IIS1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par0-APP1</incoming>
      <outgoing>APP1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>APP1-Par2</incoming>
      <outgoing>Par2-DF1</outgoing>
      <outgoing>Par2-PVA1</outgoing>
    </parallelGateway>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par2-DF1</incoming>
      <outgoing>DF1-G3</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par2-PVA1</incoming>
      <outgoing>PVA1-Par7</outgoing>
    </task>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par0-IIS1</incoming>
      <outgoing>IIS1-PIP1</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>PVA1-Par7</incoming>
      <outgoing>Par7-PPV1</outgoing>
      <outgoing>Par7-G1</outgoing>
    </parallelGateway>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par7-PPV1</incoming>
      <outgoing>PPV1-IM1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par7-G1</incoming>
      <outgoing>G1-CTV1</outgoing>
      <outgoing>G1-XORCLOSE20</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G1-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE20</outgoing>
    </task>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>IIS1-PIP1</incoming>
      <outgoing>PIP1-MDEI1</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>DF1-G3</incoming>
      <outgoing>G3-CAI1</outgoing>
      <outgoing>G3-XORCLOSE22</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G3-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE22</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>PPV1-IM1</incoming>
      <outgoing>IM1-PARCLOSE25</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>G1-XORCLOSE20</incoming>
      <incoming>CTV1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-PARCLOSE25</outgoing>
    </exclusiveGateway>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>PIP1-MDEI1</incoming>
      <outgoing>MDEI1-Par26</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE22" name="XORCLOSE22">
      <incoming>G3-XORCLOSE22</incoming>
      <incoming>CAI1-XORCLOSE22</incoming>
      <outgoing>XORCLOSE22-PARCLOSE32</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>IM1-PARCLOSE25</incoming>
      <incoming>XORCLOSE20-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-PARCLOSE32</outgoing>
    </parallelGateway>
    <parallelGateway id="Par26" name="PAR">
      <incoming>MDEI1-Par26</incoming>
      <outgoing>Par26-DSE1</outgoing>
      <outgoing>Par26-G4</outgoing>
    </parallelGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>Par26-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
    </task>
    <exclusiveGateway id="G4" name="G4">
      <incoming>Par26-G4</incoming>
      <outgoing>G4-CEI1</outgoing>
      <outgoing>G4-XORCLOSE34</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G4-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE34</outgoing>
    </task>
    <parallelGateway id="PARCLOSE32" name="PARCLOSE32">
      <incoming>XORCLOSE22-PARCLOSE32</incoming>
      <incoming>PARCLOSE25-PARCLOSE32</incoming>
      <outgoing>PARCLOSE32-PARCLOSE36</outgoing>
    </parallelGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>DSE1-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE35</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE34" name="XORCLOSE34">
      <incoming>G4-XORCLOSE34</incoming>
      <incoming>CEI1-XORCLOSE34</incoming>
      <outgoing>XORCLOSE34-PARCLOSE35</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE35" name="PARCLOSE35">
      <incoming>FRP1-PARCLOSE35</incoming>
      <incoming>XORCLOSE34-PARCLOSE35</incoming>
      <outgoing>PARCLOSE35-PARCLOSE36</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE36" name="PARCLOSE36">
      <incoming>PARCLOSE32-PARCLOSE36</incoming>
      <incoming>PARCLOSE35-PARCLOSE36</incoming>
      <outgoing>PARCLOSE36-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE36-END</incoming>
    </endEvent>
