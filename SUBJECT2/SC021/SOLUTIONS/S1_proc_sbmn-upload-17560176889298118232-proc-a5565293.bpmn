  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-PVA1</outgoing>
      <outgoing>Par0-Par7</outgoing>
    </parallelGateway>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par0-PVA1</incoming>
      <outgoing>PVA1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>PVA1-Par2</incoming>
      <outgoing>Par2-APP1</outgoing>
      <outgoing>Par2-G0</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par2-APP1</incoming>
      <outgoing>APP1-PIP1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par2-G0</incoming>
      <outgoing>G0-CTV1</outgoing>
      <outgoing>G0-XORCLOSE11</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G0-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE11</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>Par0-Par7</incoming>
      <outgoing>Par7-IIS1</outgoing>
      <outgoing>Par7-PPV1</outgoing>
    </parallelGateway>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par7-IIS1</incoming>
      <outgoing>IIS1-DSE1</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par7-PPV1</incoming>
      <outgoing>PPV1-DF1</outgoing>
    </task>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>APP1-PIP1</incoming>
      <outgoing>PIP1-IM1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE11" name="XORCLOSE11">
      <incoming>G0-XORCLOSE11</incoming>
      <incoming>CTV1-XORCLOSE11</incoming>
      <outgoing>XORCLOSE11-PARCLOSE30</outgoing>
    </exclusiveGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>IIS1-DSE1</incoming>
      <outgoing>DSE1-PARCLOSE32</outgoing>
    </task>
    <task id="DF1" name="Detail Functionalities">
      <incoming>PPV1-DF1</incoming>
      <outgoing>DF1-FRP1</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>PIP1-IM1</incoming>
      <outgoing>IM1-Par19</outgoing>
    </task>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>DF1-FRP1</incoming>
      <outgoing>FRP1-G3</outgoing>
    </task>
    <parallelGateway id="Par19" name="PAR">
      <incoming>IM1-Par19</incoming>
      <outgoing>Par19-MDEI1</outgoing>
      <outgoing>Par19-G2</outgoing>
    </parallelGateway>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par19-MDEI1</incoming>
      <outgoing>MDEI1-PARCLOSE29</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par19-G2</incoming>
      <outgoing>G2-CAI1</outgoing>
      <outgoing>G2-XORCLOSE25</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G2-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE25</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE25" name="XORCLOSE25">
      <incoming>G2-XORCLOSE25</incoming>
      <incoming>CAI1-XORCLOSE25</incoming>
      <outgoing>XORCLOSE25-PARCLOSE29</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G3" name="G3">
      <incoming>FRP1-G3</incoming>
      <outgoing>G3-CEI1</outgoing>
      <outgoing>G3-XORCLOSE31</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G3-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE31</outgoing>
    </task>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>MDEI1-PARCLOSE29</incoming>
      <incoming>XORCLOSE25-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-PARCLOSE30</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE30" name="PARCLOSE30">
      <incoming>XORCLOSE11-PARCLOSE30</incoming>
      <incoming>PARCLOSE29-PARCLOSE30</incoming>
      <outgoing>PARCLOSE30-PARCLOSE33</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE31" name="XORCLOSE31">
      <incoming>G3-XORCLOSE31</incoming>
      <incoming>CEI1-XORCLOSE31</incoming>
      <outgoing>XORCLOSE31-PARCLOSE32</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE32" name="PARCLOSE32">
      <incoming>DSE1-PARCLOSE32</incoming>
      <incoming>XORCLOSE31-PARCLOSE32</incoming>
      <outgoing>PARCLOSE32-PARCLOSE33</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE33" name="PARCLOSE33">
      <incoming>PARCLOSE30-PARCLOSE33</incoming>
      <incoming>PARCLOSE32-PARCLOSE33</incoming>
      <outgoing>PARCLOSE33-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE33-END</incoming>
    </endEvent>
