  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-APP1</outgoing>
      <outgoing>Par0-PPV1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par0-APP1</incoming>
      <outgoing>APP1-IIS1</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par0-PPV1</incoming>
      <outgoing>PPV1-DF1</outgoing>
    </task>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>APP1-IIS1</incoming>
      <outgoing>IIS1-PVA1</outgoing>
    </task>
    <task id="DF1" name="Detail Functionalities">
      <incoming>PPV1-DF1</incoming>
      <outgoing>DF1-Par6</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>IIS1-PVA1</incoming>
      <outgoing>PVA1-Par10</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>DF1-Par6</incoming>
      <outgoing>Par6-Par13</outgoing>
      <outgoing>Par6-G0</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par6-G0</incoming>
      <outgoing>G0-CAI1</outgoing>
      <outgoing>G0-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G0-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE18</outgoing>
    </task>
    <parallelGateway id="Par10" name="PAR">
      <incoming>PVA1-Par10</incoming>
      <outgoing>Par10-PIP1</outgoing>
      <outgoing>Par10-MDEI1</outgoing>
    </parallelGateway>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>Par10-PIP1</incoming>
      <outgoing>PIP1-G3</outgoing>
    </task>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par10-MDEI1</incoming>
      <outgoing>MDEI1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="Par13" name="PAR">
      <incoming>Par6-Par13</incoming>
      <outgoing>Par13-IM1</outgoing>
      <outgoing>Par13-G2</outgoing>
    </parallelGateway>
    <task id="IM1" name="Integrate Modules">
      <incoming>Par13-IM1</incoming>
      <outgoing>IM1-PARCLOSE26</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par13-G2</incoming>
      <outgoing>G2-CTV1</outgoing>
      <outgoing>G2-XORCLOSE22</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G2-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE22</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>G0-XORCLOSE18</incoming>
      <incoming>CAI1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-DSE1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G3" name="G3">
      <incoming>PIP1-G3</incoming>
      <outgoing>G3-CEI1</outgoing>
      <outgoing>G3-XORCLOSE24</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G3-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE24</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE22" name="XORCLOSE22">
      <incoming>G2-XORCLOSE22</incoming>
      <incoming>CTV1-XORCLOSE22</incoming>
      <outgoing>XORCLOSE22-PARCLOSE26</outgoing>
    </exclusiveGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>XORCLOSE18-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE24" name="XORCLOSE24">
      <incoming>G3-XORCLOSE24</incoming>
      <incoming>CEI1-XORCLOSE24</incoming>
      <outgoing>XORCLOSE24-PARCLOSE25</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
