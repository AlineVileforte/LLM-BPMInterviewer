    <exclusiveGateway id="XORCLOSE32" name="XORCLOSE32">
      <incoming>G4-XORCLOSE32</incoming>
      <incoming>CEI1-XORCLOSE32</incoming>
      <outgoing>XORCLOSE32-PARCLOSE34</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE33" name="PARCLOSE33">
      <incoming>PPV1-PARCLOSE33</incoming>
      <incoming>PARCLOSE31-PARCLOSE33</incoming>
      <outgoing>PARCLOSE33-PARCLOSE34</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE34" name="PARCLOSE34">
      <incoming>XORCLOSE32-PARCLOSE34</incoming>
      <incoming>PARCLOSE33-PARCLOSE34</incoming>
      <outgoing>PARCLOSE34-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
