  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-APP1</outgoing>
      <outgoing>Par0-IIS1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par0-APP1</incoming>
      <outgoing>APP1-Par3</outgoing>
    </task>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par0-IIS1</incoming>
      <outgoing>IIS1-IM1</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>APP1-Par3</incoming>
      <outgoing>Par3-PIP1</outgoing>
      <outgoing>Par3-PVA1</outgoing>
    </parallelGateway>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>Par3-PIP1</incoming>
      <outgoing>PIP1-PPV1</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par3-PVA1</incoming>
      <outgoing>PVA1-Par11</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>IIS1-IM1</incoming>
      <outgoing>IM1-DSE1</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>PIP1-PPV1</incoming>
      <outgoing>PPV1-PARCLOSE33</outgoing>
    </task>
    <parallelGateway id="Par11" name="PAR">
      <incoming>PVA1-Par11</incoming>
      <outgoing>Par11-DF1</outgoing>
      <outgoing>Par11-G0</outgoing>
    </parallelGateway>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par11-DF1</incoming>
      <outgoing>DF1-Par18</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par11-G0</incoming>
      <outgoing>G0-CTV1</outgoing>
      <outgoing>G0-XORCLOSE23</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G0-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE23</outgoing>
    </task>
    <parallelGateway id="Par18" name="PAR">
      <incoming>DF1-Par18</incoming>
      <outgoing>Par18-MDEI1</outgoing>
      <outgoing>Par18-G1</outgoing>
    </parallelGateway>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par18-MDEI1</incoming>
      <outgoing>MDEI1-PARCLOSE27</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par18-G1</incoming>
      <outgoing>G1-CAI1</outgoing>
      <outgoing>G1-XORCLOSE25</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G1-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE25</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE23" name="XORCLOSE23">
      <incoming>G0-XORCLOSE23</incoming>
      <incoming>CTV1-XORCLOSE23</incoming>
      <outgoing>XORCLOSE23-PARCLOSE31</outgoing>
    </exclusiveGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>IM1-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE25" name="XORCLOSE25">
      <incoming>G1-XORCLOSE25</incoming>
      <incoming>CAI1-XORCLOSE25</incoming>
      <outgoing>XORCLOSE25-PARCLOSE27</outgoing>
    </exclusiveGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>DSE1-FRP1</incoming>
      <outgoing>FRP1-G4</outgoing>
    </task>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>MDEI1-PARCLOSE27</incoming>
      <incoming>XORCLOSE25-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-PARCLOSE31</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G4" name="G4">
      <incoming>FRP1-G4</incoming>
      <outgoing>G4-CEI1</outgoing>
      <outgoing>G4-XORCLOSE32</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
