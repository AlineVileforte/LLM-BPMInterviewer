  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-PPV1</outgoing>
      <outgoing>Par0-Par5</outgoing>
    </parallelGateway>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par0-PPV1</incoming>
      <outgoing>PPV1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>PPV1-Par2</incoming>
      <outgoing>Par2-APP1</outgoing>
      <outgoing>Par2-DF1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par2-APP1</incoming>
      <outgoing>APP1-G2</outgoing>
    </task>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par2-DF1</incoming>
      <outgoing>DF1-G0</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>Par0-Par5</incoming>
      <outgoing>Par5-IIS1</outgoing>
      <outgoing>Par5-PVA1</outgoing>
    </parallelGateway>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par5-IIS1</incoming>
      <outgoing>IIS1-Par12</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par5-PVA1</incoming>
      <outgoing>PVA1-MDEI1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>DF1-G0</incoming>
      <outgoing>G0-CAI1</outgoing>
      <outgoing>G0-XORCLOSE19</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G0-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE19</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>IIS1-Par12</incoming>
      <outgoing>Par12-PIP1</outgoing>
      <outgoing>Par12-IM1</outgoing>
    </parallelGateway>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>Par12-PIP1</incoming>
      <outgoing>PIP1-PARCLOSE28</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>Par12-IM1</incoming>
      <outgoing>IM1-G4</outgoing>
    </task>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>PVA1-MDEI1</incoming>
      <outgoing>MDEI1-PARCLOSE29</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>APP1-G2</incoming>
      <outgoing>G2-CTV1</outgoing>
      <outgoing>G2-XORCLOSE24</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G2-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE24</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE19" name="XORCLOSE19">
      <incoming>G0-XORCLOSE19</incoming>
      <incoming>CAI1-XORCLOSE19</incoming>
      <outgoing>XORCLOSE19-DSE1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G4" name="G4">
      <incoming>IM1-G4</incoming>
      <outgoing>G4-CEI1</outgoing>
      <outgoing>G4-XORCLOSE26</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G4-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE26</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE24" name="XORCLOSE24">
      <incoming>G2-XORCLOSE24</incoming>
      <incoming>CTV1-XORCLOSE24</incoming>
      <outgoing>XORCLOSE24-PARCLOSE30</outgoing>
    </exclusiveGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>XORCLOSE19-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE26" name="XORCLOSE26">
      <incoming>G4-XORCLOSE26</incoming>
      <incoming>CEI1-XORCLOSE26</incoming>
      <outgoing>XORCLOSE26-PARCLOSE28</outgoing>
    </exclusiveGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>DSE1-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE30</outgoing>
    </task>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>PIP1-PARCLOSE28</incoming>
      <incoming>XORCLOSE26-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-PARCLOSE29</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>MDEI1-PARCLOSE29</incoming>
      <incoming>PARCLOSE28-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-PARCLOSE31</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE30" name="PARCLOSE30">
      <incoming>XORCLOSE24-PARCLOSE30</incoming>
      <incoming>FRP1-PARCLOSE30</incoming>
      <outgoing>PARCLOSE30-PARCLOSE31</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE31" name="PARCLOSE31">
      <incoming>PARCLOSE29-PARCLOSE31</incoming>
      <incoming>PARCLOSE30-PARCLOSE31</incoming>
      <outgoing>PARCLOSE31-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE31-END</incoming>
    </endEvent>
