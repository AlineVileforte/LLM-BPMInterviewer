<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_20e66969-4eb3-458f-93ad-d601588a113f" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-APP1</outgoing>
    </startEvent>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Default_init-APP1</incoming>
      <outgoing>APP1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>APP1-Par1</incoming>
      <outgoing>Par1-IIS1</outgoing>
      <outgoing>Par1-PPV1</outgoing>
    </parallelGateway>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par1-IIS1</incoming>
      <outgoing>IIS1-Par4</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par1-PPV1</incoming>
      <outgoing>PPV1-PVA1</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>IIS1-Par4</incoming>
      <outgoing>Par4-DF1</outgoing>
      <outgoing>Par4-IM1</outgoing>
    </parallelGateway>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par4-DF1</incoming>
      <outgoing>DF1-G0</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>Par4-IM1</incoming>
      <outgoing>IM1-PIP1</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>PPV1-PVA1</incoming>
      <outgoing>PVA1-Par12</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>DF1-G0</incoming>
      <outgoing>G0-CAI1</outgoing>
      <outgoing>G0-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G0-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE17</outgoing>
    </task>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>IM1-PIP1</incoming>
      <outgoing>PIP1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>PVA1-Par12</incoming>
      <outgoing>Par12-MDEI1</outgoing>
      <outgoing>Par12-G1</outgoing>
    </parallelGateway>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par12-MDEI1</incoming>
      <outgoing>MDEI1-G2</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par12-G1</incoming>
      <outgoing>G1-CTV1</outgoing>
      <outgoing>G1-XORCLOSE22</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G1-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE22</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE17" name="XORCLOSE17">
      <incoming>G0-XORCLOSE17</incoming>
      <incoming>CAI1-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-DSE1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G2" name="G2">
      <incoming>MDEI1-G2</incoming>
      <outgoing>G2-CEI1</outgoing>
      <outgoing>G2-XORCLOSE25</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G2-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE25</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE22" name="XORCLOSE22">
      <incoming>G1-XORCLOSE22</incoming>
      <incoming>CTV1-XORCLOSE22</incoming>
      <outgoing>XORCLOSE22-PARCLOSE26</outgoing>
    </exclusiveGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>XORCLOSE17-DSE1</incoming>
      <outgoing>DSE1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>PIP1-PARCLOSE24</incoming>
      <incoming>DSE1-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-PARCLOSE28</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE25" name="XORCLOSE25">
      <incoming>G2-XORCLOSE25</incoming>
      <incoming>CEI1-XORCLOSE25</incoming>
      <outgoing>XORCLOSE25-PARCLOSE26</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>XORCLOSE22-PARCLOSE26</incoming>
      <incoming>XORCLOSE25-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-FRP1</outgoing>
    </parallelGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>PARCLOSE26-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE28</outgoing>
    </task>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>PARCLOSE24-PARCLOSE28</incoming>
      <incoming>FRP1-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE28-END</incoming>
    </endEvent>
