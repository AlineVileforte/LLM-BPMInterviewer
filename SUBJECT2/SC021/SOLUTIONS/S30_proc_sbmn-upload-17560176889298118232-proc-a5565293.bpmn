  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-APP1</outgoing>
      <outgoing>Par0-Par5</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par0-APP1</incoming>
      <outgoing>APP1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>APP1-Par2</incoming>
      <outgoing>Par2-IIS1</outgoing>
      <outgoing>Par2-PVA1</outgoing>
    </parallelGateway>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par2-IIS1</incoming>
      <outgoing>IIS1-Par7</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par2-PVA1</incoming>
      <outgoing>PVA1-G0</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>Par0-Par5</incoming>
      <outgoing>Par5-PPV1</outgoing>
      <outgoing>Par5-PIP1</outgoing>
    </parallelGateway>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par5-PPV1</incoming>
      <outgoing>PPV1-IM1</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>IIS1-Par7</incoming>
      <outgoing>Par7-DF1</outgoing>
      <outgoing>Par7-G2</outgoing>
    </parallelGateway>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par7-DF1</incoming>
      <outgoing>DF1-MDEI1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>PVA1-G0</incoming>
      <outgoing>G0-CTV1</outgoing>
      <outgoing>G0-XORCLOSE21</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G0-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE21</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>PPV1-IM1</incoming>
      <outgoing>IM1-DSE1</outgoing>
    </task>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>Par5-PIP1</incoming>
      <outgoing>PIP1-PARCLOSE28</outgoing>
    </task>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>DF1-MDEI1</incoming>
      <outgoing>MDEI1-PARCLOSE32</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par7-G2</incoming>
      <outgoing>G2-CAI1</outgoing>
      <outgoing>G2-XORCLOSE24</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G2-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE24</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE21" name="XORCLOSE21">
      <incoming>G0-XORCLOSE21</incoming>
      <incoming>CTV1-XORCLOSE21</incoming>
      <outgoing>XORCLOSE21-G3</outgoing>
    </exclusiveGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>IM1-DSE1</incoming>
      <outgoing>DSE1-PARCLOSE28</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE24" name="XORCLOSE24">
      <incoming>G2-XORCLOSE24</incoming>
      <incoming>CAI1-XORCLOSE24</incoming>
      <outgoing>XORCLOSE24-PARCLOSE32</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G3" name="G3">
      <incoming>XORCLOSE21-G3</incoming>
      <outgoing>G3-CEI1</outgoing>
      <outgoing>G3-XORCLOSE30</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G3-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE30</outgoing>
    </task>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>PIP1-PARCLOSE28</incoming>
      <incoming>DSE1-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-FRP1</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE30" name="XORCLOSE30">
      <incoming>G3-XORCLOSE30</incoming>
      <incoming>CEI1-XORCLOSE30</incoming>
      <outgoing>XORCLOSE30-PARCLOSE33</outgoing>
    </exclusiveGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>PARCLOSE28-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE34</outgoing>
    </task>
    <parallelGateway id="PARCLOSE32" name="PARCLOSE32">
      <incoming>MDEI1-PARCLOSE32</incoming>
      <incoming>XORCLOSE24-PARCLOSE32</incoming>
      <outgoing>PARCLOSE32-PARCLOSE33</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE33" name="PARCLOSE33">
      <incoming>XORCLOSE30-PARCLOSE33</incoming>
      <incoming>PARCLOSE32-PARCLOSE33</incoming>
      <outgoing>PARCLOSE33-PARCLOSE34</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE34" name="PARCLOSE34">
      <incoming>FRP1-PARCLOSE34</incoming>
      <incoming>PARCLOSE33-PARCLOSE34</incoming>
      <outgoing>PARCLOSE34-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE34-END</incoming>
    </endEvent>
