  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-APP1</outgoing>
      <outgoing>Par0-DF1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par0-APP1</incoming>
      <outgoing>APP1-Par3</outgoing>
    </task>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par0-DF1</incoming>
      <outgoing>DF1-Par6</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>APP1-Par3</incoming>
      <outgoing>Par3-PIP1</outgoing>
      <outgoing>Par3-PPV1</outgoing>
    </parallelGateway>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>Par3-PIP1</incoming>
      <outgoing>PIP1-IIS1</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par3-PPV1</incoming>
      <outgoing>PPV1-PVA1</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>DF1-Par6</incoming>
      <outgoing>Par6-MDEI1</outgoing>
      <outgoing>Par6-G0</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par6-G0</incoming>
      <outgoing>G0-CAI1</outgoing>
      <outgoing>G0-XORCLOSE16</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G0-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE16</outgoing>
    </task>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>PIP1-IIS1</incoming>
      <outgoing>IIS1-IM1</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>PPV1-PVA1</incoming>
      <outgoing>PVA1-G1</outgoing>
    </task>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par6-MDEI1</incoming>
      <outgoing>MDEI1-PARCLOSE27</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
      <incoming>G0-XORCLOSE16</incoming>
      <incoming>CAI1-XORCLOSE16</incoming>
      <outgoing>XORCLOSE16-CEI1</outgoing>
    </exclusiveGateway>
    <task id="IM1" name="Integrate Modules">
      <incoming>IIS1-IM1</incoming>
      <outgoing>IM1-PARCLOSE28</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>PVA1-G1</incoming>
      <outgoing>G1-CTV1</outgoing>
      <outgoing>G1-XORCLOSE24</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G1-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE24</outgoing>
    </task>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>XORCLOSE16-CEI1</incoming>
      <outgoing>CEI1-DSE1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE24" name="XORCLOSE24">
      <incoming>G1-XORCLOSE24</incoming>
      <incoming>CTV1-XORCLOSE24</incoming>
      <outgoing>XORCLOSE24-PARCLOSE28</outgoing>
    </exclusiveGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>CEI1-DSE1</incoming>
      <outgoing>DSE1-PARCLOSE27</outgoing>
    </task>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>MDEI1-PARCLOSE27</incoming>
      <incoming>DSE1-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-FRP1</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>IM1-PARCLOSE28</incoming>
      <incoming>XORCLOSE24-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-PARCLOSE30</outgoing>
    </parallelGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>PARCLOSE27-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE30</outgoing>
    </task>
    <parallelGateway id="PARCLOSE30" name="PARCLOSE30">
      <incoming>PARCLOSE28-PARCLOSE30</incoming>
      <incoming>FRP1-PARCLOSE30</incoming>
      <outgoing>PARCLOSE30-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE30-END</incoming>
    </endEvent>
