<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_4c4635be-ad06-447f-a3c2-af9201a9878e" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-PVA1</outgoing>
    </startEvent>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Default_init-PVA1</incoming>
      <outgoing>PVA1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>PVA1-Par1</incoming>
      <outgoing>Par1-IIS1</outgoing>
      <outgoing>Par1-PPV1</outgoing>
    </parallelGateway>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par1-IIS1</incoming>
      <outgoing>IIS1-Par4</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par1-PPV1</incoming>
      <outgoing>PPV1-APP1</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>IIS1-Par4</incoming>
      <outgoing>Par4-IM1</outgoing>
      <outgoing>Par4-G1</outgoing>
    </parallelGateway>
    <task id="IM1" name="Integrate Modules">
      <incoming>Par4-IM1</incoming>
      <outgoing>IM1-DF1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par4-G1</incoming>
      <outgoing>G1-CTV1</outgoing>
      <outgoing>G1-XORCLOSE11</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G1-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE11</outgoing>
    </task>
    <task id="APP1" name="Approve Platform Project">
      <incoming>PPV1-APP1</incoming>
      <outgoing>APP1-DSE1</outgoing>
    </task>
    <task id="DF1" name="Detail Functionalities">
      <incoming>IM1-DF1</incoming>
      <outgoing>DF1-Par13</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE11" name="XORCLOSE11">
      <incoming>G1-XORCLOSE11</incoming>
      <incoming>CTV1-XORCLOSE11</incoming>
      <outgoing>XORCLOSE11-PIP1</outgoing>
    </exclusiveGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>APP1-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
    </task>
    <parallelGateway id="Par13" name="PAR">
      <incoming>DF1-Par13</incoming>
      <outgoing>Par13-MDEI1</outgoing>
      <outgoing>Par13-G2</outgoing>
    </parallelGateway>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par13-MDEI1</incoming>
      <outgoing>MDEI1-PARCLOSE24</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par13-G2</incoming>
      <outgoing>G2-CAI1</outgoing>
      <outgoing>G2-XORCLOSE20</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G2-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE20</outgoing>
    </task>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>XORCLOSE11-PIP1</incoming>
      <outgoing>PIP1-G3</outgoing>
    </task>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>DSE1-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE27</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>G2-XORCLOSE20</incoming>
      <incoming>CAI1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-PARCLOSE24</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G3" name="G3">
      <incoming>PIP1-G3</incoming>
      <outgoing>G3-CEI1</outgoing>
      <outgoing>G3-XORCLOSE25</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G3-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE25</outgoing>
    </task>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>MDEI1-PARCLOSE24</incoming>
      <incoming>XORCLOSE20-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-PARCLOSE26</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE25" name="XORCLOSE25">
      <incoming>G3-XORCLOSE25</incoming>
      <incoming>CEI1-XORCLOSE25</incoming>
      <outgoing>XORCLOSE25-PARCLOSE26</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>PARCLOSE24-PARCLOSE26</incoming>
      <incoming>XORCLOSE25-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-PARCLOSE27</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>FRP1-PARCLOSE27</incoming>
      <incoming>PARCLOSE26-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE27-END</incoming>
    </endEvent>
