<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_5444050b-8837-4765-8adb-217b959da9f0" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-APP1</outgoing>
    </startEvent>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Default_init-APP1</incoming>
      <outgoing>APP1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>APP1-Par1</incoming>
      <outgoing>Par1-PPV1</outgoing>
      <outgoing>Par1-PIP1</outgoing>
    </parallelGateway>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par1-PPV1</incoming>
      <outgoing>PPV1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>PPV1-Par3</incoming>
      <outgoing>Par3-DF1</outgoing>
      <outgoing>Par3-Par7</outgoing>
    </parallelGateway>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par3-DF1</incoming>
      <outgoing>DF1-MDEI1</outgoing>
    </task>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>Par1-PIP1</incoming>
      <outgoing>PIP1-IIS1</outgoing>
    </task>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>DF1-MDEI1</incoming>
      <outgoing>MDEI1-PARCLOSE26</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>Par3-Par7</incoming>
      <outgoing>Par7-PVA1</outgoing>
      <outgoing>Par7-G1</outgoing>
    </parallelGateway>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par7-PVA1</incoming>
      <outgoing>PVA1-G2</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par7-G1</incoming>
      <outgoing>G1-CAI1</outgoing>
      <outgoing>G1-XORCLOSE16</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G1-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE16</outgoing>
    </task>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>PIP1-IIS1</incoming>
      <outgoing>IIS1-G3</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>PVA1-G2</incoming>
      <outgoing>G2-CTV1</outgoing>
      <outgoing>G2-XORCLOSE20</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G2-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE20</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
      <incoming>G1-XORCLOSE16</incoming>
      <incoming>CAI1-XORCLOSE16</incoming>
      <outgoing>XORCLOSE16-IM1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G3" name="G3">
      <incoming>IIS1-G3</incoming>
      <outgoing>G3-CEI1</outgoing>
      <outgoing>G3-XORCLOSE22</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G3-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE22</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>G2-XORCLOSE20</incoming>
      <incoming>CTV1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-DSE1</outgoing>
    </exclusiveGateway>
    <task id="IM1" name="Integrate Modules">
      <incoming>XORCLOSE16-IM1</incoming>
      <outgoing>IM1-PARCLOSE24</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE22" name="XORCLOSE22">
      <incoming>G3-XORCLOSE22</incoming>
      <incoming>CEI1-XORCLOSE22</incoming>
      <outgoing>XORCLOSE22-PARCLOSE27</outgoing>
    </exclusiveGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>XORCLOSE20-DSE1</incoming>
      <outgoing>DSE1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>IM1-PARCLOSE24</incoming>
      <incoming>DSE1-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-FRP1</outgoing>
    </parallelGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>PARCLOSE24-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE26</outgoing>
    </task>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>MDEI1-PARCLOSE26</incoming>
      <incoming>FRP1-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-PARCLOSE27</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>XORCLOSE22-PARCLOSE27</incoming>
      <incoming>PARCLOSE26-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE27-END</incoming>
    </endEvent>
