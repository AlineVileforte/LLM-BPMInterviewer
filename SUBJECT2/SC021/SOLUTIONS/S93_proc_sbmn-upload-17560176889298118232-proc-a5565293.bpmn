  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-APP1</outgoing>
      <outgoing>Par0-IIS1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par0-APP1</incoming>
      <outgoing>APP1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>APP1-Par2</incoming>
      <outgoing>Par2-DF1</outgoing>
      <outgoing>Par2-PPV1</outgoing>
    </parallelGateway>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par2-DF1</incoming>
      <outgoing>DF1-PVA1</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par2-PPV1</incoming>
      <outgoing>PPV1-Par7</outgoing>
    </task>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par0-IIS1</incoming>
      <outgoing>IIS1-Par9</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>DF1-PVA1</incoming>
      <outgoing>PVA1-MDEI1</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>PPV1-Par7</incoming>
      <outgoing>Par7-DSE1</outgoing>
      <outgoing>Par7-G3</outgoing>
    </parallelGateway>
    <parallelGateway id="Par9" name="PAR">
      <incoming>IIS1-Par9</incoming>
      <outgoing>Par9-PIP1</outgoing>
      <outgoing>Par9-G1</outgoing>
    </parallelGateway>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>Par9-PIP1</incoming>
      <outgoing>PIP1-IM1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par9-G1</incoming>
      <outgoing>G1-CAI1</outgoing>
      <outgoing>G1-XORCLOSE22</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G1-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE22</outgoing>
    </task>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>PVA1-MDEI1</incoming>
      <outgoing>MDEI1-CEI1</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>Par7-G3</incoming>
      <outgoing>G3-CTV1</outgoing>
      <outgoing>G3-XORCLOSE24</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G3-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE24</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>PIP1-IM1</incoming>
      <outgoing>IM1-PARCLOSE26</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE22" name="XORCLOSE22">
      <incoming>G1-XORCLOSE22</incoming>
      <incoming>CAI1-XORCLOSE22</incoming>
      <outgoing>XORCLOSE22-PARCLOSE26</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>MDEI1-CEI1</incoming>
      <outgoing>CEI1-PARCLOSE31</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE24" name="XORCLOSE24">
      <incoming>G3-XORCLOSE24</incoming>
      <incoming>CTV1-XORCLOSE24</incoming>
      <outgoing>XORCLOSE24-PARCLOSE30</outgoing>
    </exclusiveGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>Par7-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>IM1-PARCLOSE26</incoming>
      <incoming>XORCLOSE22-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-PARCLOSE32</outgoing>
    </parallelGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>DSE1-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE30</outgoing>
    </task>
    <parallelGateway id="PARCLOSE30" name="PARCLOSE30">
      <incoming>XORCLOSE24-PARCLOSE30</incoming>
      <incoming>FRP1-PARCLOSE30</incoming>
      <outgoing>PARCLOSE30-PARCLOSE31</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE31" name="PARCLOSE31">
      <incoming>CEI1-PARCLOSE31</incoming>
      <incoming>PARCLOSE30-PARCLOSE31</incoming>
      <outgoing>PARCLOSE31-PARCLOSE32</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE32" name="PARCLOSE32">
      <incoming>PARCLOSE26-PARCLOSE32</incoming>
      <incoming>PARCLOSE31-PARCLOSE32</incoming>
      <outgoing>PARCLOSE32-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE32-END</incoming>
    </endEvent>
