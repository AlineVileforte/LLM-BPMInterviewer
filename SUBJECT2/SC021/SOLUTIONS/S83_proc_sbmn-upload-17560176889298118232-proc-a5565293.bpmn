      <incoming>Par1-G0</incoming>
      <outgoing>G0-CAI1</outgoing>
      <outgoing>G0-XORCLOSE9</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G0-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE9</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>PVA1-Par6</incoming>
