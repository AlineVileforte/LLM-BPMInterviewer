<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_fefa4b78-90d0-4740-843d-c586c9b23493" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-IIS1</outgoing>
    </startEvent>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Default_init-IIS1</incoming>
      <outgoing>IIS1-DF1</outgoing>
    </task>
    <task id="DF1" name="Detail Functionalities">
      <incoming>IIS1-DF1</incoming>
      <outgoing>DF1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>DF1-Par2</incoming>
      <outgoing>Par2-APP1</outgoing>
      <outgoing>Par2-PVA1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par2-APP1</incoming>
      <outgoing>APP1-Par5</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>Par2-PVA1</incoming>
      <outgoing>PVA1-IM1</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>APP1-Par5</incoming>
      <outgoing>Par5-PIP1</outgoing>
      <outgoing>Par5-MDEI1</outgoing>
    </parallelGateway>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>Par5-PIP1</incoming>
      <outgoing>PIP1-PPV1</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>PVA1-IM1</incoming>
      <outgoing>IM1-CTV1</outgoing>
    </task>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>PIP1-PPV1</incoming>
      <outgoing>PPV1-G7</outgoing>
    </task>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par5-MDEI1</incoming>
      <outgoing>MDEI1-PARCLOSE22</outgoing>
    </task>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>IM1-CTV1</incoming>
      <outgoing>CTV1-DSE1</outgoing>
    </task>
    <exclusiveGateway id="G7" name="G7">
      <incoming>PPV1-G7</incoming>
      <outgoing>G7-CAI1</outgoing>
      <outgoing>G7-XORCLOSE16</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G7-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE16</outgoing>
    </task>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>CTV1-DSE1</incoming>
      <outgoing>DSE1-FRP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
      <incoming>G7-XORCLOSE16</incoming>
      <incoming>CAI1-XORCLOSE16</incoming>
      <outgoing>XORCLOSE16-G9</outgoing>
    </exclusiveGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>DSE1-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE23</outgoing>
    </task>
    <exclusiveGateway id="G9" name="G9">
      <incoming>XORCLOSE16-G9</incoming>
      <outgoing>G9-CEI1</outgoing>
      <outgoing>G9-XORCLOSE21</outgoing>
    </exclusiveGateway>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>G9-CEI1</incoming>
      <outgoing>CEI1-XORCLOSE21</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE21" name="XORCLOSE21">
      <incoming>G9-XORCLOSE21</incoming>
      <incoming>CEI1-XORCLOSE21</incoming>
      <outgoing>XORCLOSE21-PARCLOSE22</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>MDEI1-PARCLOSE22</incoming>
      <incoming>XORCLOSE21-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-PARCLOSE23</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>FRP1-PARCLOSE23</incoming>
      <incoming>PARCLOSE22-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE23-END</incoming>
    </endEvent>
