  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-DF1</outgoing>
      <outgoing>Par0-IIS1</outgoing>
    </parallelGateway>
    <task id="DF1" name="Detail Functionalities">
      <incoming>Par0-DF1</incoming>
      <outgoing>DF1-Par3</outgoing>
    </task>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par0-IIS1</incoming>
      <outgoing>IIS1-PVA1</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>DF1-Par3</incoming>
      <outgoing>Par3-PPV1</outgoing>
      <outgoing>Par3-G0</outgoing>
    </parallelGateway>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par3-PPV1</incoming>
      <outgoing>PPV1-APP1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par3-G0</incoming>
      <outgoing>G0-CAI1</outgoing>
      <outgoing>G0-XORCLOSE12</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G0-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE12</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>IIS1-PVA1</incoming>
      <outgoing>PVA1-IM1</outgoing>
    </task>
    <task id="APP1" name="Approve Platform Project">
      <incoming>PPV1-APP1</incoming>
      <outgoing>APP1-Par15</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE12" name="XORCLOSE12">
      <incoming>G0-XORCLOSE12</incoming>
      <incoming>CAI1-XORCLOSE12</incoming>
      <outgoing>XORCLOSE12-Par19</outgoing>
    </exclusiveGateway>
    <task id="IM1" name="Integrate Modules">
      <incoming>PVA1-IM1</incoming>
      <outgoing>IM1-PARCLOSE30</outgoing>
    </task>
    <parallelGateway id="Par15" name="PAR">
      <incoming>APP1-Par15</incoming>
      <outgoing>Par15-MDEI1</outgoing>
      <outgoing>Par15-G2</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par15-G2</incoming>
      <outgoing>G2-CTV1</outgoing>
      <outgoing>G2-XORCLOSE24</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G2-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE24</outgoing>
    </task>
    <parallelGateway id="Par19" name="PAR">
      <incoming>XORCLOSE12-Par19</incoming>
      <outgoing>Par19-PIP1</outgoing>
      <outgoing>Par19-CEI1</outgoing>
    </parallelGateway>
    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>Par19-PIP1</incoming>
      <outgoing>PIP1-DSE1</outgoing>
    </task>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>Par19-CEI1</incoming>
      <outgoing>CEI1-PARCLOSE26</outgoing>
    </task>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par15-MDEI1</incoming>
      <outgoing>MDEI1-PARCLOSE27</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE24" name="XORCLOSE24">
      <incoming>G2-XORCLOSE24</incoming>
      <incoming>CTV1-XORCLOSE24</incoming>
      <outgoing>XORCLOSE24-PARCLOSE27</outgoing>
    </exclusiveGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>PIP1-DSE1</incoming>
      <outgoing>DSE1-PARCLOSE26</outgoing>
    </task>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>CEI1-PARCLOSE26</incoming>
      <incoming>DSE1-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-PARCLOSE29</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>MDEI1-PARCLOSE27</incoming>
      <incoming>XORCLOSE24-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-FRP1</outgoing>
    </parallelGateway>
    <task id="FRP1" name="Finalize and Release to Production">
      <incoming>PARCLOSE27-FRP1</incoming>
      <outgoing>FRP1-PARCLOSE29</outgoing>
    </task>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>PARCLOSE26-PARCLOSE29</incoming>
      <incoming>FRP1-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-PARCLOSE30</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE30" name="PARCLOSE30">
      <incoming>IM1-PARCLOSE30</incoming>
      <incoming>PARCLOSE29-PARCLOSE30</incoming>
      <outgoing>PARCLOSE30-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE30-END</incoming>
    </endEvent>
