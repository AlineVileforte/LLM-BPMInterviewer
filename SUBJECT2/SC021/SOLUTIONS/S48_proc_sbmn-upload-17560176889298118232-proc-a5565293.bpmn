    <parallelGateway id="Par18" name="PAR">
      <incoming>XORCLOSE14-Par18</incoming>
      <outgoing>Par18-DSE1</outgoing>
      <outgoing>Par18-FRP1</outgoing>
    </parallelGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>Par18-DSE1</incoming>
      <outgoing>DSE1-G4</outgoing>
    </task>
    <task id="MDEI1" name="Model Database Entities and Indexes">
