    <sequenceFlow id="UCLA1-PARCLOSE21" sourceRef="UCLA1" targetRef="PARCLOSE21"/>
    <sequenceFlow id="FV1-ALSP1" sourceRef="FV1" targetRef="ALSP1"/>
    <sequenceFlow id="ALSP1-PARCLOSE21" sourceRef="ALSP1" targetRef="PARCLOSE21"/>
    <sequenceFlow id="PARCLOSE21-PARCLOSE22" sourceRef="PARCLOSE21" targetRef="PARCLOSE22"/>
    <sequenceFlow id="PARCLOSE22-END" sourceRef="PARCLOSE22" targetRef="END"/>
  </process>
