    <sequenceFlow id="PI1-PARCLOSE26" sourceRef="PI1" targetRef="PARCLOSE26"/>
    <sequenceFlow id="FV1-ALSP1" sourceRef="FV1" targetRef="ALSP1"/>
    <sequenceFlow id="PTM1-PARCLOSE25" sourceRef="PTM1" targetRef="PARCLOSE25"/>
    <sequenceFlow id="ALSP1-PARCLOSE25" sourceRef="ALSP1" targetRef="PARCLOSE25"/>
    <sequenceFlow id="PARCLOSE25-PARCLOSE26" sourceRef="PARCLOSE25" targetRef="PARCLOSE26"/>
    <sequenceFlow id="PARCLOSE26-END" sourceRef="PARCLOSE26" targetRef="END"/>
  </process>
