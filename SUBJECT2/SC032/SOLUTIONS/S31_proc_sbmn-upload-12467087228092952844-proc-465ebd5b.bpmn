<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_0138c515-c4cc-4893-ad9b-17b5562c050a" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DSC1</outgoing>
    </startEvent>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>Default_init-DSC1</incoming>
      <outgoing>DSC1-APC1</outgoing>
    </task>
    <task id="APC1" name="Approve Product Concept">
      <incoming>DSC1-APC1</incoming>
      <outgoing>APC1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>APC1-Par2</incoming>
      <outgoing>Par2-NS1</outgoing>
      <outgoing>Par2-PP1</outgoing>
    </parallelGateway>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>Par2-NS1</incoming>
      <outgoing>NS1-DCS1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>Par2-PP1</incoming>
      <outgoing>PP1-G0</outgoing>
    </task>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>NS1-DCS1</incoming>
      <outgoing>DCS1-UCLA1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>PP1-G0</incoming>
      <outgoing>G0-MTD1</outgoing>
      <outgoing>G0-XORCLOSE11</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G0-MTD1</incoming>
      <outgoing>MTD1-XORCLOSE11</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>DCS1-UCLA1</incoming>
      <outgoing>UCLA1-PARCLOSE24</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE11" name="XORCLOSE11">
      <incoming>G0-XORCLOSE11</incoming>
      <incoming>MTD1-XORCLOSE11</incoming>
      <outgoing>XORCLOSE11-Par12</outgoing>
    </exclusiveGateway>
    <parallelGateway id="Par12" name="PAR">
      <incoming>XORCLOSE11-Par12</incoming>
      <outgoing>Par12-PMT1</outgoing>
      <outgoing>Par12-CTD1</outgoing>
    </parallelGateway>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>Par12-PMT1</incoming>
      <outgoing>PMT1-FV1</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>Par12-CTD1</incoming>
      <outgoing>CTD1-PTM1</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>PMT1-FV1</incoming>
      <outgoing>FV1-Par17</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>CTD1-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE22</outgoing>
    </task>
    <parallelGateway id="Par17" name="PAR">
      <incoming>FV1-Par17</incoming>
      <outgoing>Par17-DVES1</outgoing>
      <outgoing>Par17-ALSP1</outgoing>
    </parallelGateway>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>Par17-DVES1</incoming>
      <outgoing>DVES1-PARCLOSE20</outgoing>
    </task>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>Par17-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE20</outgoing>
    </task>
    <parallelGateway id="PARCLOSE20" name="PARCLOSE20">
      <incoming>DVES1-PARCLOSE20</incoming>
      <incoming>ALSP1-PARCLOSE20</incoming>
      <outgoing>PARCLOSE20-PPL1</outgoing>
    </parallelGateway>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>PARCLOSE20-PPL1</incoming>
      <outgoing>PPL1-PARCLOSE22</outgoing>
    </task>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>PTM1-PARCLOSE22</incoming>
      <incoming>PPL1-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-PI1</outgoing>
    </parallelGateway>
    <task id="PI1" name="Perform Inspections">
      <incoming>PARCLOSE22-PI1</incoming>
      <outgoing>PI1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>UCLA1-PARCLOSE24</incoming>
      <incoming>PI1-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE24-END</incoming>
    </endEvent>
