<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_aeef3359-8fde-449a-8b8b-090b98326d7e" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-APC1</outgoing>
    </startEvent>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Default_init-APC1</incoming>
      <outgoing>APC1-DSC1</outgoing>
    </task>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>APC1-DSC1</incoming>
      <outgoing>DSC1-NS1</outgoing>
    </task>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>DSC1-NS1</incoming>
      <outgoing>NS1-PP1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>NS1-PP1</incoming>
      <outgoing>PP1-Par4</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>PP1-Par4</incoming>
      <outgoing>Par4-DCS1</outgoing>
      <outgoing>Par4-G0</outgoing>
    </parallelGateway>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>Par4-DCS1</incoming>
      <outgoing>DCS1-DVES1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par4-G0</incoming>
      <outgoing>G0-MTD1</outgoing>
      <outgoing>G0-XORCLOSE15</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G0-MTD1</incoming>
      <outgoing>MTD1-XORCLOSE15</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>DCS1-DVES1</incoming>
      <outgoing>DVES1-Par10</outgoing>
    </task>
    <parallelGateway id="Par10" name="PAR">
      <incoming>DVES1-Par10</incoming>
      <outgoing>Par10-UCLA1</outgoing>
      <outgoing>Par10-PPL1</outgoing>
    </parallelGateway>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>Par10-UCLA1</incoming>
      <outgoing>UCLA1-PARCLOSE16</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>Par10-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-PARCLOSE16</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE15" name="XORCLOSE15">
      <incoming>G0-XORCLOSE15</incoming>
      <incoming>MTD1-XORCLOSE15</incoming>
      <outgoing>XORCLOSE15-Par17</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE16" name="PARCLOSE16">
      <incoming>UCLA1-PARCLOSE16</incoming>
      <incoming>PI1-PARCLOSE16</incoming>
      <outgoing>PARCLOSE16-PARCLOSE24</outgoing>
    </parallelGateway>
    <parallelGateway id="Par17" name="PAR">
      <incoming>XORCLOSE15-Par17</incoming>
      <outgoing>Par17-PMT1</outgoing>
      <outgoing>Par17-CTD1</outgoing>
    </parallelGateway>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>Par17-PMT1</incoming>
      <outgoing>PMT1-FV1</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>Par17-CTD1</incoming>
      <outgoing>CTD1-PTM1</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>PMT1-FV1</incoming>
      <outgoing>FV1-ALSP1</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>CTD1-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE23</outgoing>
    </task>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>FV1-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>PTM1-PARCLOSE23</incoming>
      <incoming>ALSP1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-PARCLOSE24</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>PARCLOSE16-PARCLOSE24</incoming>
      <incoming>PARCLOSE23-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE24-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-APC1" sourceRef="Default_init" targetRef="APC1"/>
