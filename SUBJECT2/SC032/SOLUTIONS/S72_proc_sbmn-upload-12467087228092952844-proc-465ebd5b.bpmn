    <sequenceFlow id="XORCLOSE15-Par17" sourceRef="XORCLOSE15" targetRef="Par17"/>
    <sequenceFlow id="PARCLOSE16-PARCLOSE24" sourceRef="PARCLOSE16" targetRef="PARCLOSE24"/>
    <sequenceFlow id="Par17-PMT1" sourceRef="Par17" targetRef="PMT1"/>
