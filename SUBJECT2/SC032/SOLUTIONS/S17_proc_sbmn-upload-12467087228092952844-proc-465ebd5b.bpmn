<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_a7daef1e-d77d-4149-9323-cf2c4b6bc3bb" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DSC1</outgoing>
    </startEvent>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>Default_init-DSC1</incoming>
      <outgoing>DSC1-APC1</outgoing>
    </task>
    <task id="APC1" name="Approve Product Concept">
      <incoming>DSC1-APC1</incoming>
      <outgoing>APC1-PP1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>APC1-PP1</incoming>
      <outgoing>PP1-NS1</outgoing>
    </task>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>PP1-NS1</incoming>
      <outgoing>NS1-Par4</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>NS1-Par4</incoming>
      <outgoing>Par4-UCLA1</outgoing>
      <outgoing>Par4-DVES1</outgoing>
    </parallelGateway>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>Par4-UCLA1</incoming>
      <outgoing>UCLA1-Par7</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>Par4-DVES1</incoming>
      <outgoing>DVES1-PPL1</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>UCLA1-Par7</incoming>
      <outgoing>Par7-DCS1</outgoing>
      <outgoing>Par7-G2</outgoing>
    </parallelGateway>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>Par7-DCS1</incoming>
      <outgoing>DCS1-PARCLOSE19</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par7-G2</incoming>
      <outgoing>G2-MTD1</outgoing>
      <outgoing>G2-XORCLOSE16</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G2-MTD1</incoming>
      <outgoing>MTD1-XORCLOSE16</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>DVES1-PPL1</incoming>
      <outgoing>PPL1-CTD1</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>PPL1-CTD1</incoming>
      <outgoing>CTD1-PTM1</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>CTD1-PTM1</incoming>
      <outgoing>PTM1-PI1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
      <incoming>G2-XORCLOSE16</incoming>
      <incoming>MTD1-XORCLOSE16</incoming>
      <outgoing>XORCLOSE16-PMT1</outgoing>
    </exclusiveGateway>
    <task id="PI1" name="Perform Inspections">
      <incoming>PTM1-PI1</incoming>
      <outgoing>PI1-PARCLOSE22</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>XORCLOSE16-PMT1</incoming>
      <outgoing>PMT1-PARCLOSE19</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>DCS1-PARCLOSE19</incoming>
      <incoming>PMT1-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-FV1</outgoing>
    </parallelGateway>
    <task id="FV1" name="Final Validation">
      <incoming>PARCLOSE19-FV1</incoming>
      <outgoing>FV1-ALSP1</outgoing>
    </task>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>FV1-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE22</outgoing>
    </task>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>PI1-PARCLOSE22</incoming>
      <incoming>ALSP1-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE22-END</incoming>
    </endEvent>
