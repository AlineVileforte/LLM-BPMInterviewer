<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_b8b4e773-e629-4527-99d2-a49289c653e2" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DSC1</outgoing>
    </startEvent>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>Default_init-DSC1</incoming>
      <outgoing>DSC1-APC1</outgoing>
    </task>
    <task id="APC1" name="Approve Product Concept">
      <incoming>DSC1-APC1</incoming>
      <outgoing>APC1-PP1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>APC1-PP1</incoming>
      <outgoing>PP1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>PP1-Par3</incoming>
      <outgoing>Par3-DVES1</outgoing>
      <outgoing>Par3-G2</outgoing>
    </parallelGateway>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>Par3-DVES1</incoming>
      <outgoing>DVES1-Par5</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>DVES1-Par5</incoming>
      <outgoing>Par5-NS1</outgoing>
      <outgoing>Par5-PPL1</outgoing>
    </parallelGateway>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>Par5-NS1</incoming>
      <outgoing>NS1-Par10</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>Par5-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par3-G2</incoming>
      <outgoing>G2-MTD1</outgoing>
      <outgoing>G2-XORCLOSE20</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G2-MTD1</incoming>
      <outgoing>MTD1-XORCLOSE20</outgoing>
    </task>
    <parallelGateway id="Par10" name="PAR">
      <incoming>NS1-Par10</incoming>
      <outgoing>Par10-DCS1</outgoing>
      <outgoing>Par10-UCLA1</outgoing>
    </parallelGateway>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>Par10-DCS1</incoming>
      <outgoing>DCS1-CTD1</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>Par10-UCLA1</incoming>
      <outgoing>UCLA1-PMT1</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-PARCLOSE23</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>DCS1-CTD1</incoming>
      <outgoing>CTD1-PTM1</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>UCLA1-PMT1</incoming>
      <outgoing>PMT1-FV1</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>CTD1-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE22</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>PMT1-FV1</incoming>
      <outgoing>FV1-ALSP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>G2-XORCLOSE20</incoming>
      <incoming>MTD1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-PARCLOSE24</outgoing>
    </exclusiveGateway>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>FV1-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE22</outgoing>
    </task>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>PTM1-PARCLOSE22</incoming>
      <incoming>ALSP1-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-PARCLOSE23</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>PI1-PARCLOSE23</incoming>
      <incoming>PARCLOSE22-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-PARCLOSE24</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>XORCLOSE20-PARCLOSE24</incoming>
      <incoming>PARCLOSE23-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE24-END</incoming>
    </endEvent>
