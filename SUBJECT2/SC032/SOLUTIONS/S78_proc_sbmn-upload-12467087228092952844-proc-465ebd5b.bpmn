    <sequenceFlow id="ALSP1-PARCLOSE25" sourceRef="ALSP1" targetRef="PARCLOSE25"/>
    <sequenceFlow id="PARCLOSE25-PARCLOSE27" sourceRef="PARCLOSE25" targetRef="PARCLOSE27"/>
    <sequenceFlow id="PARCLOSE27-END" sourceRef="PARCLOSE27" targetRef="END"/>
  </process>
