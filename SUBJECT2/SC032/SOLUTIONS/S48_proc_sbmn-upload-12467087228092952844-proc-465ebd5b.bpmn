    <sequenceFlow id="Par24-PTM1" sourceRef="Par24" targetRef="PTM1"/>
    <sequenceFlow id="Par24-ALSP1" sourceRef="Par24" targetRef="ALSP1"/>
    <sequenceFlow id="PTM1-PARCLOSE27" sourceRef="PTM1" targetRef="PARCLOSE27"/>
    <sequenceFlow id="ALSP1-PARCLOSE27" sourceRef="ALSP1" targetRef="PARCLOSE27"/>
    <sequenceFlow id="PARCLOSE27-PARCLOSE28" sourceRef="PARCLOSE27" targetRef="PARCLOSE28"/>
    <sequenceFlow id="PARCLOSE28-END" sourceRef="PARCLOSE28" targetRef="END"/>
  </process>
