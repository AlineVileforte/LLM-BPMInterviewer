  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-APC1</outgoing>
    </startEvent>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Default_init-APC1</incoming>
      <outgoing>APC1-DSC1</outgoing>
    </task>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>APC1-DSC1</incoming>
      <outgoing>DSC1-NS1</outgoing>
    </task>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>DSC1-NS1</incoming>
      <outgoing>NS1-UCLA1</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>NS1-UCLA1</incoming>
      <outgoing>UCLA1-Par4</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>UCLA1-Par4</incoming>
      <outgoing>Par4-PP1</outgoing>
      <outgoing>Par4-DCS1</outgoing>
    </parallelGateway>
    <task id="PP1" name="Produce Prototypes">
      <incoming>Par4-PP1</incoming>
      <outgoing>PP1-G0</outgoing>
    </task>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>Par4-DCS1</incoming>
      <outgoing>DCS1-PARCLOSE28</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>PP1-G0</incoming>
      <outgoing>G0-XORCLOSE12</outgoing>
      <outgoing>G0-MTD1</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G0-MTD1</incoming>
      <outgoing>MTD1-XORCLOSE12</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE12" name="XORCLOSE12">
      <incoming>G0-XORCLOSE12</incoming>
      <incoming>MTD1-XORCLOSE12</incoming>
      <outgoing>XORCLOSE12-Par14</outgoing>
    </exclusiveGateway>
    <parallelGateway id="Par14" name="PAR">
      <incoming>XORCLOSE12-Par14</incoming>
      <outgoing>Par14-CTD1</outgoing>
      <outgoing>Par14-DVES1</outgoing>
    </parallelGateway>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>Par14-CTD1</incoming>
      <outgoing>CTD1-Par16</outgoing>
    </task>
    <parallelGateway id="Par16" name="PAR">
      <incoming>CTD1-Par16</incoming>
      <outgoing>Par16-PMT1</outgoing>
      <outgoing>Par16-PTM1</outgoing>
    </parallelGateway>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>Par16-PMT1</incoming>
      <outgoing>PMT1-PARCLOSE20</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>Par16-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE20</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>Par14-DVES1</incoming>
      <outgoing>DVES1-Par21</outgoing>
    </task>
    <parallelGateway id="PARCLOSE20" name="PARCLOSE20">
      <incoming>PMT1-PARCLOSE20</incoming>
      <incoming>PTM1-PARCLOSE20</incoming>
      <outgoing>PARCLOSE20-PARCLOSE26</outgoing>
    </parallelGateway>
    <parallelGateway id="Par21" name="PAR">
      <incoming>DVES1-Par21</incoming>
      <outgoing>Par21-FV1</outgoing>
      <outgoing>Par21-PPL1</outgoing>
    </parallelGateway>
    <task id="FV1" name="Final Validation">
      <incoming>Par21-FV1</incoming>
      <outgoing>FV1-ALSP1</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>Par21-PPL1</incoming>
      <outgoing>PPL1-PARCLOSE25</outgoing>
    </task>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>FV1-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>PPL1-PARCLOSE25</incoming>
      <incoming>ALSP1-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-PARCLOSE26</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>PARCLOSE20-PARCLOSE26</incoming>
      <incoming>PARCLOSE25-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-PI1</outgoing>
    </parallelGateway>
    <task id="PI1" name="Perform Inspections">
      <incoming>PARCLOSE26-PI1</incoming>
      <outgoing>PI1-PARCLOSE28</outgoing>
    </task>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>DCS1-PARCLOSE28</incoming>
      <incoming>PI1-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE28-END</incoming>
    </endEvent>
