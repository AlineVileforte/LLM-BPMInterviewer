  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-APC1</outgoing>
      <outgoing>Par0-DSC1</outgoing>
    </parallelGateway>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Par0-APC1</incoming>
      <outgoing>APC1-PARCLOSE5</outgoing>
    </task>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>Par0-DSC1</incoming>
      <outgoing>DSC1-PARCLOSE5</outgoing>
    </task>
    <parallelGateway id="PARCLOSE5" name="PARCLOSE5">
      <incoming>APC1-PARCLOSE5</incoming>
      <incoming>DSC1-PARCLOSE5</incoming>
      <outgoing>PARCLOSE5-PP1</outgoing>
    </parallelGateway>
    <task id="PP1" name="Produce Prototypes">
      <incoming>PARCLOSE5-PP1</incoming>
      <outgoing>PP1-Par7</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>PP1-Par7</incoming>
      <outgoing>Par7-NS1</outgoing>
      <outgoing>Par7-MTD1</outgoing>
    </parallelGateway>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>Par7-NS1</incoming>
      <outgoing>NS1-UCLA1</outgoing>
    </task>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>Par7-MTD1</incoming>
      <outgoing>MTD1-PMT1</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>NS1-UCLA1</incoming>
      <outgoing>UCLA1-Par13</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>MTD1-PMT1</incoming>
      <outgoing>PMT1-Par16</outgoing>
    </task>
    <parallelGateway id="Par13" name="PAR">
      <incoming>UCLA1-Par13</incoming>
      <outgoing>Par13-DCS1</outgoing>
      <outgoing>Par13-DVES1</outgoing>
    </parallelGateway>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>Par13-DCS1</incoming>
      <outgoing>DCS1-PARCLOSE19</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>Par13-DVES1</incoming>
      <outgoing>DVES1-PARCLOSE19</outgoing>
    </task>
    <parallelGateway id="Par16" name="PAR">
      <incoming>PMT1-Par16</incoming>
      <outgoing>Par16-CTD1</outgoing>
      <outgoing>Par16-FV1</outgoing>
    </parallelGateway>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>Par16-CTD1</incoming>
      <outgoing>CTD1-Par20</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>Par16-FV1</incoming>
      <outgoing>FV1-ALSP1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>DCS1-PARCLOSE19</incoming>
      <incoming>DVES1-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-PARCLOSE28</outgoing>
    </parallelGateway>
    <parallelGateway id="Par20" name="PAR">
      <incoming>CTD1-Par20</incoming>
      <outgoing>Par20-PPL1</outgoing>
      <outgoing>Par20-PTM1</outgoing>
    </parallelGateway>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>Par20-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>Par20-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE26</outgoing>
    </task>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>FV1-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE27</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-PARCLOSE26</outgoing>
    </task>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>PTM1-PARCLOSE26</incoming>
      <incoming>PI1-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-PARCLOSE27</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>ALSP1-PARCLOSE27</incoming>
      <incoming>PARCLOSE26-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-PARCLOSE28</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>PARCLOSE19-PARCLOSE28</incoming>
      <incoming>PARCLOSE27-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE28-END</incoming>
    </endEvent>
