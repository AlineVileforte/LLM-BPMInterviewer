<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_a2d87122-1701-4a01-a02d-88089ef1cfa9" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-APC1</outgoing>
      <outgoing>Par0-DSC1</outgoing>
    </parallelGateway>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Par0-APC1</incoming>
      <outgoing>APC1-PARCLOSE7</outgoing>
    </task>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>Par0-DSC1</incoming>
      <outgoing>DSC1-PARCLOSE7</outgoing>
    </task>
    <parallelGateway id="PARCLOSE7" name="PARCLOSE7">
      <incoming>APC1-PARCLOSE7</incoming>
      <incoming>DSC1-PARCLOSE7</incoming>
      <outgoing>PARCLOSE7-Par8</outgoing>
    </parallelGateway>
    <parallelGateway id="Par8" name="PAR">
      <incoming>PARCLOSE7-Par8</incoming>
      <outgoing>Par8-NS1</outgoing>
      <outgoing>Par8-PP1</outgoing>
    </parallelGateway>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>Par8-NS1</incoming>
      <outgoing>NS1-UCLA1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>Par8-PP1</incoming>
      <outgoing>PP1-Par12</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>NS1-UCLA1</incoming>
      <outgoing>UCLA1-DCS1</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>PP1-Par12</incoming>
      <outgoing>Par12-DVES1</outgoing>
      <outgoing>Par12-MTD1</outgoing>
    </parallelGateway>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>Par12-DVES1</incoming>
      <outgoing>DVES1-PPL1</outgoing>
    </task>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>Par12-MTD1</incoming>
      <outgoing>MTD1-PMT1</outgoing>
    </task>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>UCLA1-DCS1</incoming>
      <outgoing>DCS1-PARCLOSE23</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>DVES1-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>MTD1-PMT1</incoming>
      <outgoing>PMT1-FV1</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-PARCLOSE21</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>PMT1-FV1</incoming>
      <outgoing>FV1-ALSP1</outgoing>
    </task>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>FV1-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE21</outgoing>
    </task>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>PI1-PARCLOSE21</incoming>
      <incoming>ALSP1-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-CTD1</outgoing>
    </parallelGateway>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>PARCLOSE21-CTD1</incoming>
      <outgoing>CTD1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>DCS1-PARCLOSE23</incoming>
      <incoming>CTD1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-PTM1</outgoing>
    </parallelGateway>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>PARCLOSE23-PTM1</incoming>
      <outgoing>PTM1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PTM1-END</incoming>
    </endEvent>
