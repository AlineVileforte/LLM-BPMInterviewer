    <sequenceFlow id="G2-XORCLOSE16" sourceRef="G2" targetRef="XORCLOSE16"/>
    <sequenceFlow id="MTD1-XORCLOSE16" sourceRef="MTD1" targetRef="XORCLOSE16"/>
    <sequenceFlow id="PI1-DCS1" sourceRef="PI1" targetRef="DCS1"/>
    <sequenceFlow id="UCLA1-PARCLOSE18" sourceRef="UCLA1" targetRef="PARCLOSE18"/>
    <sequenceFlow id="DCS1-CTD1" sourceRef="DCS1" targetRef="CTD1"/>
    <sequenceFlow id="CTD1-PTM1" sourceRef="CTD1" targetRef="PTM1"/>
    <sequenceFlow id="XORCLOSE16-PARCLOSE18" sourceRef="XORCLOSE16" targetRef="PARCLOSE18"/>
    <sequenceFlow id="PTM1-PARCLOSE21" sourceRef="PTM1" targetRef="PARCLOSE21"/>
    <sequenceFlow id="PARCLOSE18-PMT1" sourceRef="PARCLOSE18" targetRef="PMT1"/>
    <sequenceFlow id="PMT1-FV1" sourceRef="PMT1" targetRef="FV1"/>
    <sequenceFlow id="FV1-PARCLOSE21" sourceRef="FV1" targetRef="PARCLOSE21"/>
    <sequenceFlow id="PARCLOSE21-ALSP1" sourceRef="PARCLOSE21" targetRef="ALSP1"/>
    <sequenceFlow id="ALSP1-END" sourceRef="ALSP1" targetRef="END"/>
  </process>
