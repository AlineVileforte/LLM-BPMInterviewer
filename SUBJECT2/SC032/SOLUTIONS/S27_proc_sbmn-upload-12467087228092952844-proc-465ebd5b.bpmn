<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_9743a61b-6e69-4330-b3d0-d5ae1f8278f4" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DSC1</outgoing>
    </startEvent>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>Default_init-DSC1</incoming>
      <outgoing>DSC1-APC1</outgoing>
    </task>
    <task id="APC1" name="Approve Product Concept">
      <incoming>DSC1-APC1</incoming>
      <outgoing>APC1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>APC1-Par2</incoming>
      <outgoing>Par2-NS1</outgoing>
      <outgoing>Par2-PP1</outgoing>
    </parallelGateway>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>Par2-NS1</incoming>
      <outgoing>NS1-UCLA1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>Par2-PP1</incoming>
      <outgoing>PP1-DVES1</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>NS1-UCLA1</incoming>
      <outgoing>UCLA1-DCS1</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>PP1-DVES1</incoming>
      <outgoing>DVES1-MTD1</outgoing>
    </task>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>UCLA1-DCS1</incoming>
      <outgoing>DCS1-PARCLOSE15</outgoing>
    </task>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>DVES1-MTD1</incoming>
      <outgoing>MTD1-PARCLOSE15</outgoing>
    </task>
    <parallelGateway id="PARCLOSE15" name="PARCLOSE15">
      <incoming>DCS1-PARCLOSE15</incoming>
      <incoming>MTD1-PARCLOSE15</incoming>
      <outgoing>PARCLOSE15-Par16</outgoing>
    </parallelGateway>
    <parallelGateway id="Par16" name="PAR">
      <incoming>PARCLOSE15-Par16</incoming>
      <outgoing>Par16-PPL1</outgoing>
      <outgoing>Par16-Par19</outgoing>
    </parallelGateway>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>Par16-PPL1</incoming>
      <outgoing>PPL1-CTD1</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>PPL1-CTD1</incoming>
      <outgoing>CTD1-PTM1</outgoing>
    </task>
    <parallelGateway id="Par19" name="PAR">
      <incoming>Par16-Par19</incoming>
      <outgoing>Par19-PMT1</outgoing>
      <outgoing>Par19-PI1</outgoing>
    </parallelGateway>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>Par19-PMT1</incoming>
      <outgoing>PMT1-FV1</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>Par19-PI1</incoming>
      <outgoing>PI1-PARCLOSE24</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>CTD1-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE26</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>PMT1-FV1</incoming>
      <outgoing>FV1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>PI1-PARCLOSE24</incoming>
      <incoming>FV1-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-ALSP1</outgoing>
    </parallelGateway>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>PARCLOSE24-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE26</outgoing>
    </task>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>PTM1-PARCLOSE26</incoming>
      <incoming>ALSP1-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE26-END</incoming>
    </endEvent>
