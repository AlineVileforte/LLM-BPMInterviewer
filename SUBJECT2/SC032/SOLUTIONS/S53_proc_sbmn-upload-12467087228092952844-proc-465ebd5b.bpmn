<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_c922b49c-e970-40fa-a6a8-2c3616c07670" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DSC1</outgoing>
    </startEvent>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>Default_init-DSC1</incoming>
      <outgoing>DSC1-APC1</outgoing>
    </task>
    <task id="APC1" name="Approve Product Concept">
      <incoming>DSC1-APC1</incoming>
      <outgoing>APC1-NS1</outgoing>
    </task>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>APC1-NS1</incoming>
      <outgoing>NS1-UCLA1</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>NS1-UCLA1</incoming>
      <outgoing>UCLA1-DCS1</outgoing>
    </task>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>UCLA1-DCS1</incoming>
      <outgoing>DCS1-PP1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>DCS1-PP1</incoming>
      <outgoing>PP1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>PP1-G0</incoming>
      <outgoing>G0-MTD1</outgoing>
      <outgoing>G0-XORCLOSE10</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G0-MTD1</incoming>
      <outgoing>MTD1-XORCLOSE10</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE10" name="XORCLOSE10">
      <incoming>G0-XORCLOSE10</incoming>
      <incoming>MTD1-XORCLOSE10</incoming>
      <outgoing>XORCLOSE10-Par11</outgoing>
    </exclusiveGateway>
    <parallelGateway id="Par11" name="PAR">
      <incoming>XORCLOSE10-Par11</incoming>
      <outgoing>Par11-DVES1</outgoing>
      <outgoing>Par11-CTD1</outgoing>
    </parallelGateway>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>Par11-DVES1</incoming>
      <outgoing>DVES1-PMT1</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>Par11-CTD1</incoming>
      <outgoing>CTD1-PTM1</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>DVES1-PMT1</incoming>
      <outgoing>PMT1-FV1</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>CTD1-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE19</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>PMT1-FV1</incoming>
      <outgoing>FV1-PPL1</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>FV1-PPL1</incoming>
      <outgoing>PPL1-ALSP1</outgoing>
    </task>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>PPL1-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE19</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>PTM1-PARCLOSE19</incoming>
      <incoming>ALSP1-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-PI1</outgoing>
    </parallelGateway>
    <task id="PI1" name="Perform Inspections">
      <incoming>PARCLOSE19-PI1</incoming>
      <outgoing>PI1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PI1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DSC1" sourceRef="Default_init" targetRef="DSC1"/>
