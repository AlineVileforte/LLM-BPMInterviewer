    <sequenceFlow id="ALSP1-PARCLOSE19" sourceRef="ALSP1" targetRef="PARCLOSE19"/>
    <sequenceFlow id="PARCLOSE19-PI1" sourceRef="PARCLOSE19" targetRef="PI1"/>
    <sequenceFlow id="PI1-END" sourceRef="PI1" targetRef="END"/>
  </process>
