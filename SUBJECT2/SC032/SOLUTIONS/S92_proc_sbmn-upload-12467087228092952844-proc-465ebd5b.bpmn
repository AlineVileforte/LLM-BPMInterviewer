<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_b6e10f53-f16a-492f-8add-af2a40e8fba9" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DSC1</outgoing>
    </startEvent>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>Default_init-DSC1</incoming>
      <outgoing>DSC1-APC1</outgoing>
    </task>
    <task id="APC1" name="Approve Product Concept">
      <incoming>DSC1-APC1</incoming>
      <outgoing>APC1-PP1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>APC1-PP1</incoming>
      <outgoing>PP1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>PP1-Par3</incoming>
      <outgoing>Par3-DVES1</outgoing>
      <outgoing>Par3-G0</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par3-G0</incoming>
      <outgoing>G0-MTD1</outgoing>
      <outgoing>G0-XORCLOSE16</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G0-MTD1</incoming>
      <outgoing>MTD1-XORCLOSE16</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>Par3-DVES1</incoming>
      <outgoing>DVES1-Par10</outgoing>
    </task>
    <parallelGateway id="Par10" name="PAR">
      <incoming>DVES1-Par10</incoming>
      <outgoing>Par10-NS1</outgoing>
      <outgoing>Par10-PPL1</outgoing>
    </parallelGateway>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>Par10-NS1</incoming>
      <outgoing>NS1-DCS1</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>Par10-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>NS1-DCS1</incoming>
      <outgoing>DCS1-PARCLOSE17</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-PARCLOSE17</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
      <incoming>G0-XORCLOSE16</incoming>
      <incoming>MTD1-XORCLOSE16</incoming>
      <outgoing>XORCLOSE16-Par18</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>DCS1-PARCLOSE17</incoming>
      <incoming>PI1-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-UCLA1</outgoing>
    </parallelGateway>
    <parallelGateway id="Par18" name="PAR">
      <incoming>XORCLOSE16-Par18</incoming>
      <outgoing>Par18-CTD1</outgoing>
      <outgoing>Par18-PMT1</outgoing>
    </parallelGateway>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>Par18-CTD1</incoming>
      <outgoing>CTD1-PTM1</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>PARCLOSE17-UCLA1</incoming>
      <outgoing>UCLA1-PARCLOSE24</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>CTD1-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE23</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>Par18-PMT1</incoming>
      <outgoing>PMT1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>PTM1-PARCLOSE23</incoming>
      <incoming>PMT1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-PARCLOSE24</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>UCLA1-PARCLOSE24</incoming>
      <incoming>PARCLOSE23-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-FV1</outgoing>
    </parallelGateway>
    <task id="FV1" name="Final Validation">
      <incoming>PARCLOSE24-FV1</incoming>
      <outgoing>FV1-ALSP1</outgoing>
    </task>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>FV1-ALSP1</incoming>
      <outgoing>ALSP1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>ALSP1-END</incoming>
    </endEvent>
