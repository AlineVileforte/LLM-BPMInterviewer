<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_ca2264ac-8c91-4321-9685-e085c5693e22" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DSC1</outgoing>
    </startEvent>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>Default_init-DSC1</incoming>
      <outgoing>DSC1-APC1</outgoing>
    </task>
    <task id="APC1" name="Approve Product Concept">
      <incoming>DSC1-APC1</incoming>
      <outgoing>APC1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>APC1-Par2</incoming>
      <outgoing>Par2-NS1</outgoing>
      <outgoing>Par2-PP1</outgoing>
    </parallelGateway>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>Par2-NS1</incoming>
      <outgoing>NS1-UCLA1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>Par2-PP1</incoming>
      <outgoing>PP1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>PP1-G0</incoming>
      <outgoing>G0-MTD1</outgoing>
      <outgoing>G0-XORCLOSE12</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G0-MTD1</incoming>
      <outgoing>MTD1-XORCLOSE12</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>NS1-UCLA1</incoming>
      <outgoing>UCLA1-DCS1</outgoing>
    </task>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>UCLA1-DCS1</incoming>
      <outgoing>DCS1-PARCLOSE13</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE12" name="XORCLOSE12">
      <incoming>G0-XORCLOSE12</incoming>
      <incoming>MTD1-XORCLOSE12</incoming>
      <outgoing>XORCLOSE12-PARCLOSE13</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE13" name="PARCLOSE13">
      <incoming>DCS1-PARCLOSE13</incoming>
      <incoming>XORCLOSE12-PARCLOSE13</incoming>
      <outgoing>PARCLOSE13-Par14</outgoing>
    </parallelGateway>
    <parallelGateway id="Par14" name="PAR">
      <incoming>PARCLOSE13-Par14</incoming>
      <outgoing>Par14-DVES1</outgoing>
      <outgoing>Par14-PPL1</outgoing>
    </parallelGateway>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>Par14-DVES1</incoming>
      <outgoing>DVES1-Par16</outgoing>
    </task>
    <parallelGateway id="Par16" name="PAR">
      <incoming>DVES1-Par16</incoming>
      <outgoing>Par16-CTD1</outgoing>
      <outgoing>Par16-PTM1</outgoing>
    </parallelGateway>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>Par16-CTD1</incoming>
      <outgoing>CTD1-PMT1</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>Par14-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>CTD1-PMT1</incoming>
      <outgoing>PMT1-FV1</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>Par16-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE23</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-PARCLOSE25</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>PMT1-FV1</incoming>
      <outgoing>FV1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>PTM1-PARCLOSE23</incoming>
      <incoming>FV1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-ALSP1</outgoing>
    </parallelGateway>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>PARCLOSE23-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>PI1-PARCLOSE25</incoming>
      <incoming>ALSP1-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE25-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DSC1" sourceRef="Default_init" targetRef="DSC1"/>
