    <sequenceFlow id="PMT1-FV1" sourceRef="PMT1" targetRef="FV1"/>
    <sequenceFlow id="PTM1-PARCLOSE23" sourceRef="PTM1" targetRef="PARCLOSE23"/>
    <sequenceFlow id="PI1-PARCLOSE25" sourceRef="PI1" targetRef="PARCLOSE25"/>
    <sequenceFlow id="FV1-PARCLOSE23" sourceRef="FV1" targetRef="PARCLOSE23"/>
    <sequenceFlow id="PARCLOSE23-ALSP1" sourceRef="PARCLOSE23" targetRef="ALSP1"/>
    <sequenceFlow id="ALSP1-PARCLOSE25" sourceRef="ALSP1" targetRef="PARCLOSE25"/>
    <sequenceFlow id="PARCLOSE25-END" sourceRef="PARCLOSE25" targetRef="END"/>
  </process>
