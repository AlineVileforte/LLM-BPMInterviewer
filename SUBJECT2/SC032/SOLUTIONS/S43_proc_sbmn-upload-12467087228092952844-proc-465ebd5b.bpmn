      <incoming>PTM1-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-ALSP1</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>DCS1-PARCLOSE26</incoming>
      <incoming>FV1-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-PARCLOSE28</outgoing>
    </parallelGateway>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>PARCLOSE25-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE30</outgoing>
    </task>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>PI1-PARCLOSE28</incoming>
      <incoming>PARCLOSE26-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-PARCLOSE30</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE30" name="PARCLOSE30">
      <incoming>ALSP1-PARCLOSE30</incoming>
      <incoming>PARCLOSE28-PARCLOSE30</incoming>
      <outgoing>PARCLOSE30-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE30-END</incoming>
    </endEvent>
