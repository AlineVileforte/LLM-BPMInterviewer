      <outgoing>DVES1-Par16</outgoing>
    </task>
    <parallelGateway id="Par13" name="PAR">
      <incoming>Par9-Par13</incoming>
      <outgoing>Par13-NS1</outgoing>
      <outgoing>Par13-CTD1</outgoing>
    </parallelGateway>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>Par13-NS1</incoming>
      <outgoing>NS1-UCLA1</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>Par13-CTD1</incoming>
      <outgoing>CTD1-PTM1</outgoing>
    </task>
    <parallelGateway id="Par16" name="PAR">
      <incoming>DVES1-Par16</incoming>
      <outgoing>Par16-PMT1</outgoing>
      <outgoing>Par16-PPL1</outgoing>
    </parallelGateway>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>Par16-PMT1</incoming>
      <outgoing>PMT1-Par21</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>Par16-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>NS1-UCLA1</incoming>
      <outgoing>UCLA1-PARCLOSE25</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>CTD1-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="Par21" name="PAR">
      <incoming>PMT1-Par21</incoming>
      <outgoing>Par21-DCS1</outgoing>
      <outgoing>Par21-FV1</outgoing>
    </parallelGateway>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>Par21-DCS1</incoming>
      <outgoing>DCS1-PARCLOSE26</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>Par21-FV1</incoming>
      <outgoing>FV1-PARCLOSE26</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-PARCLOSE28</outgoing>
    </task>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
