<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_88068caa-c7a9-4e75-9d47-e904d8add77e" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-APC1</outgoing>
    </startEvent>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Default_init-APC1</incoming>
      <outgoing>APC1-DSC1</outgoing>
    </task>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>APC1-DSC1</incoming>
      <outgoing>DSC1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>DSC1-Par2</incoming>
      <outgoing>Par2-NS1</outgoing>
      <outgoing>Par2-PP1</outgoing>
    </parallelGateway>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>Par2-NS1</incoming>
      <outgoing>NS1-Par8</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>Par2-PP1</incoming>
      <outgoing>PP1-DVES1</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>PP1-DVES1</incoming>
      <outgoing>DVES1-MTD1</outgoing>
    </task>
    <parallelGateway id="Par8" name="PAR">
      <incoming>NS1-Par8</incoming>
      <outgoing>Par8-DCS1</outgoing>
      <outgoing>Par8-UCLA1</outgoing>
    </parallelGateway>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>Par8-DCS1</incoming>
      <outgoing>DCS1-PARCLOSE13</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>Par8-UCLA1</incoming>
      <outgoing>UCLA1-PARCLOSE13</outgoing>
    </task>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>DVES1-MTD1</incoming>
      <outgoing>MTD1-Par15</outgoing>
    </task>
    <parallelGateway id="PARCLOSE13" name="PARCLOSE13">
      <incoming>DCS1-PARCLOSE13</incoming>
      <incoming>UCLA1-PARCLOSE13</incoming>
      <outgoing>PARCLOSE13-PARCLOSE25</outgoing>
    </parallelGateway>
    <parallelGateway id="Par15" name="PAR">
      <incoming>MTD1-Par15</incoming>
      <outgoing>Par15-CTD1</outgoing>
      <outgoing>Par15-PPL1</outgoing>
    </parallelGateway>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>Par15-CTD1</incoming>
      <outgoing>CTD1-PTM1</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>Par15-PPL1</incoming>
      <outgoing>PPL1-PMT1</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>CTD1-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE20</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>PPL1-PMT1</incoming>
      <outgoing>PMT1-PARCLOSE20</outgoing>
    </task>
    <parallelGateway id="PARCLOSE20" name="PARCLOSE20">
      <incoming>PTM1-PARCLOSE20</incoming>
      <incoming>PMT1-PARCLOSE20</incoming>
      <outgoing>PARCLOSE20-Par21</outgoing>
    </parallelGateway>
    <parallelGateway id="Par21" name="PAR">
      <incoming>PARCLOSE20-Par21</incoming>
      <outgoing>Par21-FV1</outgoing>
      <outgoing>Par21-PI1</outgoing>
    </parallelGateway>
    <task id="FV1" name="Final Validation">
      <incoming>Par21-FV1</incoming>
      <outgoing>FV1-PARCLOSE24</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>Par21-PI1</incoming>
      <outgoing>PI1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>FV1-PARCLOSE24</incoming>
      <incoming>PI1-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-PARCLOSE25</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>PARCLOSE13-PARCLOSE25</incoming>
      <incoming>PARCLOSE24-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-ALSP1</outgoing>
    </parallelGateway>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>PARCLOSE25-ALSP1</incoming>
      <outgoing>ALSP1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>ALSP1-END</incoming>
    </endEvent>
