<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_97222541-c7ee-4c0e-8e73-463067d0c833" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-APC1</outgoing>
    </startEvent>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Default_init-APC1</incoming>
      <outgoing>APC1-DSC1</outgoing>
    </task>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>APC1-DSC1</incoming>
      <outgoing>DSC1-PP1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>DSC1-PP1</incoming>
      <outgoing>PP1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>PP1-G0</incoming>
      <outgoing>G0-MTD1</outgoing>
      <outgoing>G0-XORCLOSE7</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G0-MTD1</incoming>
      <outgoing>MTD1-XORCLOSE7</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE7" name="XORCLOSE7">
      <incoming>G0-XORCLOSE7</incoming>
      <incoming>MTD1-XORCLOSE7</incoming>
      <outgoing>XORCLOSE7-PMT1</outgoing>
    </exclusiveGateway>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>XORCLOSE7-PMT1</incoming>
      <outgoing>PMT1-Par9</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>PMT1-Par9</incoming>
      <outgoing>Par9-DVES1</outgoing>
      <outgoing>Par9-FV1</outgoing>
    </parallelGateway>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>Par9-DVES1</incoming>
      <outgoing>DVES1-Par12</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>Par9-FV1</incoming>
      <outgoing>FV1-NS1</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>DVES1-Par12</incoming>
      <outgoing>Par12-CTD1</outgoing>
      <outgoing>Par12-PTM1</outgoing>
    </parallelGateway>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>Par12-CTD1</incoming>
      <outgoing>CTD1-PPL1</outgoing>
    </task>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>FV1-NS1</incoming>
      <outgoing>NS1-Par17</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>CTD1-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>Par12-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE21</outgoing>
    </task>
    <parallelGateway id="Par17" name="PAR">
      <incoming>NS1-Par17</incoming>
      <outgoing>Par17-DCS1</outgoing>
      <outgoing>Par17-UCLA1</outgoing>
    </parallelGateway>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>Par17-DCS1</incoming>
      <outgoing>DCS1-ALSP1</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>Par17-UCLA1</incoming>
      <outgoing>UCLA1-PARCLOSE23</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-PARCLOSE21</outgoing>
    </task>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>PTM1-PARCLOSE21</incoming>
      <incoming>PI1-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-PARCLOSE24</outgoing>
    </parallelGateway>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>DCS1-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>UCLA1-PARCLOSE23</incoming>
      <incoming>ALSP1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-PARCLOSE24</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>PARCLOSE21-PARCLOSE24</incoming>
      <incoming>PARCLOSE23-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE24-END</incoming>
    </endEvent>
