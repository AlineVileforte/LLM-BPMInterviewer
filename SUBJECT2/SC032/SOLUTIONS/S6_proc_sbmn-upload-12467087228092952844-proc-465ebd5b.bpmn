<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_6856ca79-a24d-4378-99d9-579460e04eac" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-APC1</outgoing>
    </startEvent>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Default_init-APC1</incoming>
      <outgoing>APC1-DSC1</outgoing>
    </task>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>APC1-DSC1</incoming>
      <outgoing>DSC1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>DSC1-Par2</incoming>
      <outgoing>Par2-NS1</outgoing>
      <outgoing>Par2-PP1</outgoing>
    </parallelGateway>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>Par2-NS1</incoming>
      <outgoing>NS1-Par5</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>Par2-PP1</incoming>
      <outgoing>PP1-DVES1</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>NS1-Par5</incoming>
      <outgoing>Par5-DCS1</outgoing>
      <outgoing>Par5-UCLA1</outgoing>
    </parallelGateway>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>Par5-DCS1</incoming>
      <outgoing>DCS1-PARCLOSE12</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>PP1-DVES1</incoming>
      <outgoing>DVES1-MTD1</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>Par5-UCLA1</incoming>
      <outgoing>UCLA1-PARCLOSE12</outgoing>
    </task>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>DVES1-MTD1</incoming>
      <outgoing>MTD1-Par13</outgoing>
    </task>
    <parallelGateway id="PARCLOSE12" name="PARCLOSE12">
      <incoming>DCS1-PARCLOSE12</incoming>
      <incoming>UCLA1-PARCLOSE12</incoming>
      <outgoing>PARCLOSE12-PARCLOSE24</outgoing>
    </parallelGateway>
    <parallelGateway id="Par13" name="PAR">
      <incoming>MTD1-Par13</incoming>
      <outgoing>Par13-CTD1</outgoing>
      <outgoing>Par13-PPL1</outgoing>
    </parallelGateway>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>Par13-CTD1</incoming>
      <outgoing>CTD1-PTM1</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>CTD1-PTM1</incoming>
      <outgoing>PTM1-PMT1</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>Par13-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>PTM1-PMT1</incoming>
      <outgoing>PMT1-PARCLOSE23</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-FV1</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>PI1-FV1</incoming>
      <outgoing>FV1-ALSP1</outgoing>
    </task>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>FV1-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>PMT1-PARCLOSE23</incoming>
      <incoming>ALSP1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-PARCLOSE24</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>PARCLOSE12-PARCLOSE24</incoming>
      <incoming>PARCLOSE23-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE24-END</incoming>
    </endEvent>
