<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_3d18722e-1f41-4f04-b35a-91766e6b688d" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DSC1</outgoing>
    </startEvent>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>Default_init-DSC1</incoming>
      <outgoing>DSC1-APC1</outgoing>
    </task>
    <task id="APC1" name="Approve Product Concept">
      <incoming>DSC1-APC1</incoming>
      <outgoing>APC1-NS1</outgoing>
    </task>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>APC1-NS1</incoming>
      <outgoing>NS1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>NS1-Par3</incoming>
      <outgoing>Par3-UCLA1</outgoing>
      <outgoing>Par3-PP1</outgoing>
    </parallelGateway>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>Par3-UCLA1</incoming>
      <outgoing>UCLA1-DCS1</outgoing>
    </task>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>UCLA1-DCS1</incoming>
      <outgoing>DCS1-PARCLOSE7</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>Par3-PP1</incoming>
      <outgoing>PP1-PARCLOSE7</outgoing>
    </task>
    <parallelGateway id="PARCLOSE7" name="PARCLOSE7">
      <incoming>DCS1-PARCLOSE7</incoming>
      <incoming>PP1-PARCLOSE7</incoming>
      <outgoing>PARCLOSE7-G1</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G1" name="G1">
      <incoming>PARCLOSE7-G1</incoming>
      <outgoing>G1-MTD1</outgoing>
      <outgoing>G1-XORCLOSE14</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G1-MTD1</incoming>
      <outgoing>MTD1-XORCLOSE14</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>G1-XORCLOSE14</incoming>
      <incoming>MTD1-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-CTD1</outgoing>
    </exclusiveGateway>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>XORCLOSE14-CTD1</incoming>
      <outgoing>CTD1-PTM1</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>CTD1-PTM1</incoming>
      <outgoing>PTM1-PMT1</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>PTM1-PMT1</incoming>
      <outgoing>PMT1-DVES1</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>PMT1-DVES1</incoming>
      <outgoing>DVES1-Par19</outgoing>
    </task>
    <parallelGateway id="Par19" name="PAR">
      <incoming>DVES1-Par19</incoming>
      <outgoing>Par19-FV1</outgoing>
      <outgoing>Par19-PPL1</outgoing>
    </parallelGateway>
    <task id="FV1" name="Final Validation">
      <incoming>Par19-FV1</incoming>
      <outgoing>FV1-ALSP1</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>Par19-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>FV1-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE24</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>ALSP1-PARCLOSE24</incoming>
      <incoming>PI1-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE24-END</incoming>
    </endEvent>
