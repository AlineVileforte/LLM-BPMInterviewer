<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_a3b441e8-82d3-45d3-899b-dbb27dabd35b" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-APC1</outgoing>
      <outgoing>Par0-DSC1</outgoing>
    </parallelGateway>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Par0-APC1</incoming>
      <outgoing>APC1-PARCLOSE5</outgoing>
    </task>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>Par0-DSC1</incoming>
      <outgoing>DSC1-PARCLOSE5</outgoing>
    </task>
    <parallelGateway id="PARCLOSE5" name="PARCLOSE5">
      <incoming>APC1-PARCLOSE5</incoming>
      <incoming>DSC1-PARCLOSE5</incoming>
      <outgoing>PARCLOSE5-Par6</outgoing>
    </parallelGateway>
    <parallelGateway id="Par6" name="PAR">
      <incoming>PARCLOSE5-Par6</incoming>
      <outgoing>Par6-NS1</outgoing>
      <outgoing>Par6-PP1</outgoing>
    </parallelGateway>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>Par6-NS1</incoming>
      <outgoing>NS1-DCS1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>Par6-PP1</incoming>
      <outgoing>PP1-MTD1</outgoing>
    </task>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>NS1-DCS1</incoming>
      <outgoing>DCS1-UCLA1</outgoing>
    </task>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>PP1-MTD1</incoming>
      <outgoing>MTD1-PARCLOSE12</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>DCS1-UCLA1</incoming>
      <outgoing>UCLA1-PARCLOSE12</outgoing>
    </task>
    <parallelGateway id="PARCLOSE12" name="PARCLOSE12">
      <incoming>MTD1-PARCLOSE12</incoming>
      <incoming>UCLA1-PARCLOSE12</incoming>
      <outgoing>PARCLOSE12-Par13</outgoing>
    </parallelGateway>
    <parallelGateway id="Par13" name="PAR">
      <incoming>PARCLOSE12-Par13</incoming>
      <outgoing>Par13-DVES1</outgoing>
      <outgoing>Par13-PMT1</outgoing>
    </parallelGateway>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>Par13-DVES1</incoming>
      <outgoing>DVES1-PPL1</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>Par13-PMT1</incoming>
      <outgoing>PMT1-FV1</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>DVES1-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>PMT1-FV1</incoming>
      <outgoing>FV1-CTD1</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-PARCLOSE20</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>FV1-CTD1</incoming>
      <outgoing>CTD1-PARCLOSE20</outgoing>
    </task>
    <parallelGateway id="PARCLOSE20" name="PARCLOSE20">
      <incoming>PI1-PARCLOSE20</incoming>
      <incoming>CTD1-PARCLOSE20</incoming>
      <outgoing>PARCLOSE20-ALSP1</outgoing>
    </parallelGateway>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>PARCLOSE20-ALSP1</incoming>
      <outgoing>ALSP1-PTM1</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>ALSP1-PTM1</incoming>
      <outgoing>PTM1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PTM1-END</incoming>
    </endEvent>
