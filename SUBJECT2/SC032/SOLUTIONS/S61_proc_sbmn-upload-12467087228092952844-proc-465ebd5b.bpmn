<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_3407b852-239d-4169-ba69-c780a60a3e37" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-APC1</outgoing>
    </startEvent>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Default_init-APC1</incoming>
      <outgoing>APC1-DSC1</outgoing>
    </task>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>APC1-DSC1</incoming>
      <outgoing>DSC1-NS1</outgoing>
    </task>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>DSC1-NS1</incoming>
      <outgoing>NS1-PP1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>NS1-PP1</incoming>
      <outgoing>PP1-DVES1</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>PP1-DVES1</incoming>
      <outgoing>DVES1-DCS1</outgoing>
    </task>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>DVES1-DCS1</incoming>
      <outgoing>DCS1-G2</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>DCS1-G2</incoming>
      <outgoing>G2-MTD1</outgoing>
      <outgoing>G2-XORCLOSE10</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G2-MTD1</incoming>
      <outgoing>MTD1-XORCLOSE10</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE10" name="XORCLOSE10">
      <incoming>G2-XORCLOSE10</incoming>
      <incoming>MTD1-XORCLOSE10</incoming>
      <outgoing>XORCLOSE10-Par11</outgoing>
    </exclusiveGateway>
    <parallelGateway id="Par11" name="PAR">
      <incoming>XORCLOSE10-Par11</incoming>
      <outgoing>Par11-UCLA1</outgoing>
      <outgoing>Par11-PPL1</outgoing>
    </parallelGateway>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>Par11-UCLA1</incoming>
      <outgoing>UCLA1-Par13</outgoing>
    </task>
    <parallelGateway id="Par13" name="PAR">
      <incoming>UCLA1-Par13</incoming>
      <outgoing>Par13-PMT1</outgoing>
      <outgoing>Par13-CTD1</outgoing>
    </parallelGateway>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>Par13-PMT1</incoming>
      <outgoing>PMT1-FV1</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>Par13-CTD1</incoming>
      <outgoing>CTD1-PTM1</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>Par11-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>PMT1-FV1</incoming>
      <outgoing>FV1-PARCLOSE20</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>CTD1-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE20</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-ALSP1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE20" name="PARCLOSE20">
      <incoming>FV1-PARCLOSE20</incoming>
      <incoming>PTM1-PARCLOSE20</incoming>
      <outgoing>PARCLOSE20-PARCLOSE22</outgoing>
    </parallelGateway>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>PI1-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE22</outgoing>
    </task>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>PARCLOSE20-PARCLOSE22</incoming>
      <incoming>ALSP1-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE22-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-APC1" sourceRef="Default_init" targetRef="APC1"/>
