    <sequenceFlow id="FV1-PARCLOSE20" sourceRef="FV1" targetRef="PARCLOSE20"/>
    <sequenceFlow id="PTM1-PARCLOSE20" sourceRef="PTM1" targetRef="PARCLOSE20"/>
    <sequenceFlow id="PI1-ALSP1" sourceRef="PI1" targetRef="ALSP1"/>
    <sequenceFlow id="PARCLOSE20-PARCLOSE22" sourceRef="PARCLOSE20" targetRef="PARCLOSE22"/>
    <sequenceFlow id="ALSP1-PARCLOSE22" sourceRef="ALSP1" targetRef="PARCLOSE22"/>
    <sequenceFlow id="PARCLOSE22-END" sourceRef="PARCLOSE22" targetRef="END"/>
  </process>
