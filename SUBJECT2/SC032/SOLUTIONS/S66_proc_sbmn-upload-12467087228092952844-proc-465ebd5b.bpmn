  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DSC1</outgoing>
    </startEvent>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>Default_init-DSC1</incoming>
      <outgoing>DSC1-APC1</outgoing>
    </task>
    <task id="APC1" name="Approve Product Concept">
      <incoming>DSC1-APC1</incoming>
      <outgoing>APC1-NS1</outgoing>
    </task>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>APC1-NS1</incoming>
      <outgoing>NS1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>NS1-Par3</incoming>
      <outgoing>Par3-PP1</outgoing>
      <outgoing>Par3-Par9</outgoing>
    </parallelGateway>
    <task id="PP1" name="Produce Prototypes">
      <incoming>Par3-PP1</incoming>
      <outgoing>PP1-Par5</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>PP1-Par5</incoming>
      <outgoing>Par5-DCS1</outgoing>
      <outgoing>Par5-G0</outgoing>
    </parallelGateway>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>Par5-DCS1</incoming>
      <outgoing>DCS1-PARCLOSE26</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par5-G0</incoming>
      <outgoing>G0-MTD1</outgoing>
      <outgoing>G0-XORCLOSE23</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G0-MTD1</incoming>
      <outgoing>MTD1-XORCLOSE23</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>Par3-Par9</incoming>
      <outgoing>Par9-UCLA1</outgoing>
      <outgoing>Par9-DVES1</outgoing>
    </parallelGateway>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>Par9-UCLA1</incoming>
      <outgoing>UCLA1-Par15</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>Par9-DVES1</incoming>
      <outgoing>DVES1-PPL1</outgoing>
    </task>
    <parallelGateway id="Par15" name="PAR">
      <incoming>UCLA1-Par15</incoming>
      <outgoing>Par15-PMT1</outgoing>
      <outgoing>Par15-CTD1</outgoing>
    </parallelGateway>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>Par15-PMT1</incoming>
      <outgoing>PMT1-FV1</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>Par15-CTD1</incoming>
      <outgoing>CTD1-PTM1</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>DVES1-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>PMT1-FV1</incoming>
      <outgoing>FV1-PARCLOSE24</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>CTD1-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE24</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-ALSP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE23" name="XORCLOSE23">
      <incoming>G0-XORCLOSE23</incoming>
      <incoming>MTD1-XORCLOSE23</incoming>
      <outgoing>XORCLOSE23-PARCLOSE26</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>FV1-PARCLOSE24</incoming>
      <incoming>PTM1-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-PARCLOSE27</outgoing>
    </parallelGateway>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>PI1-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE27</outgoing>
    </task>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>DCS1-PARCLOSE26</incoming>
      <incoming>XORCLOSE23-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-PARCLOSE28</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>PARCLOSE24-PARCLOSE27</incoming>
      <incoming>ALSP1-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-PARCLOSE28</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>PARCLOSE26-PARCLOSE28</incoming>
      <incoming>PARCLOSE27-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE28-END</incoming>
    </endEvent>
