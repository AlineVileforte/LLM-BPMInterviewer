  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-APC1</outgoing>
      <outgoing>Par0-DSC1</outgoing>
    </parallelGateway>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Par0-APC1</incoming>
      <outgoing>APC1-PARCLOSE7</outgoing>
    </task>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>Par0-DSC1</incoming>
      <outgoing>DSC1-PARCLOSE7</outgoing>
    </task>
    <parallelGateway id="PARCLOSE7" name="PARCLOSE7">
      <incoming>APC1-PARCLOSE7</incoming>
      <incoming>DSC1-PARCLOSE7</incoming>
      <outgoing>PARCLOSE7-PP1</outgoing>
    </parallelGateway>
    <task id="PP1" name="Produce Prototypes">
      <incoming>PARCLOSE7-PP1</incoming>
      <outgoing>PP1-Par9</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>PP1-Par9</incoming>
      <outgoing>Par9-NS1</outgoing>
      <outgoing>Par9-DVES1</outgoing>
    </parallelGateway>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>Par9-NS1</incoming>
      <outgoing>NS1-UCLA1</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>Par9-DVES1</incoming>
      <outgoing>DVES1-MTD1</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>NS1-UCLA1</incoming>
      <outgoing>UCLA1-DCS1</outgoing>
    </task>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>DVES1-MTD1</incoming>
      <outgoing>MTD1-Par15</outgoing>
    </task>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>UCLA1-DCS1</incoming>
      <outgoing>DCS1-PMT1</outgoing>
    </task>
    <parallelGateway id="Par15" name="PAR">
      <incoming>MTD1-Par15</incoming>
      <outgoing>Par15-CTD1</outgoing>
      <outgoing>Par15-PTM1</outgoing>
    </parallelGateway>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>Par15-CTD1</incoming>
      <outgoing>CTD1-PPL1</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>DCS1-PMT1</incoming>
      <outgoing>PMT1-FV1</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>CTD1-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>Par15-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE23</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>PMT1-FV1</incoming>
      <outgoing>FV1-ALSP1</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-PARCLOSE23</outgoing>
    </task>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>FV1-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>PTM1-PARCLOSE23</incoming>
      <incoming>PI1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-PARCLOSE24</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>ALSP1-PARCLOSE24</incoming>
      <incoming>PARCLOSE23-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE24-END</incoming>
    </endEvent>
