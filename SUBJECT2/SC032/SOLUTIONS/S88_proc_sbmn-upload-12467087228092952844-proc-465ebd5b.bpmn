<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_c4acb600-a11c-4fe7-b478-ffb1be4f589c" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DSC1</outgoing>
    </startEvent>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>Default_init-DSC1</incoming>
      <outgoing>DSC1-APC1</outgoing>
    </task>
    <task id="APC1" name="Approve Product Concept">
      <incoming>DSC1-APC1</incoming>
      <outgoing>APC1-NS1</outgoing>
    </task>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>APC1-NS1</incoming>
      <outgoing>NS1-DCS1</outgoing>
    </task>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>NS1-DCS1</incoming>
      <outgoing>DCS1-Par5</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>DCS1-Par5</incoming>
      <outgoing>Par5-PP1</outgoing>
      <outgoing>Par5-UCLA1</outgoing>
    </parallelGateway>
    <task id="PP1" name="Produce Prototypes">
      <incoming>Par5-PP1</incoming>
      <outgoing>PP1-DVES1</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>Par5-UCLA1</incoming>
      <outgoing>UCLA1-PARCLOSE29</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>PP1-DVES1</incoming>
      <outgoing>DVES1-Par12</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>DVES1-Par12</incoming>
      <outgoing>Par12-PPL1</outgoing>
      <outgoing>Par12-G1</outgoing>
    </parallelGateway>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>Par12-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par12-G1</incoming>
      <outgoing>G1-MTD1</outgoing>
      <outgoing>G1-XORCLOSE20</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G1-MTD1</incoming>
      <outgoing>MTD1-XORCLOSE20</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-PARCLOSE28</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>G1-XORCLOSE20</incoming>
      <incoming>MTD1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-PMT1</outgoing>
    </exclusiveGateway>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>XORCLOSE20-PMT1</incoming>
      <outgoing>PMT1-Par22</outgoing>
    </task>
    <parallelGateway id="Par22" name="PAR">
      <incoming>PMT1-Par22</incoming>
      <outgoing>Par22-CTD1</outgoing>
      <outgoing>Par22-FV1</outgoing>
    </parallelGateway>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>Par22-CTD1</incoming>
      <outgoing>CTD1-PTM1</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>Par22-FV1</incoming>
      <outgoing>FV1-PARCLOSE26</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>CTD1-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE26</outgoing>
    </task>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>FV1-PARCLOSE26</incoming>
      <incoming>PTM1-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-ALSP1</outgoing>
    </parallelGateway>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>PARCLOSE26-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE28</outgoing>
    </task>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>PI1-PARCLOSE28</incoming>
      <incoming>ALSP1-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-PARCLOSE29</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>UCLA1-PARCLOSE29</incoming>
      <incoming>PARCLOSE28-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE29-END</incoming>
    </endEvent>
