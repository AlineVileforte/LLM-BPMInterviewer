<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_667c0a75-8856-4515-9c1d-1a60d31f2e5a" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-APC1</outgoing>
    </startEvent>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Default_init-APC1</incoming>
      <outgoing>APC1-DSC1</outgoing>
    </task>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>APC1-DSC1</incoming>
      <outgoing>DSC1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>DSC1-Par2</incoming>
      <outgoing>Par2-NS1</outgoing>
      <outgoing>Par2-PP1</outgoing>
    </parallelGateway>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>Par2-NS1</incoming>
      <outgoing>NS1-UCLA1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>Par2-PP1</incoming>
      <outgoing>PP1-DVES1</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>NS1-UCLA1</incoming>
      <outgoing>UCLA1-DCS1</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>PP1-DVES1</incoming>
      <outgoing>DVES1-PPL1</outgoing>
    </task>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>UCLA1-DCS1</incoming>
      <outgoing>DCS1-PARCLOSE18</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>DVES1-PPL1</incoming>
      <outgoing>PPL1-Par13</outgoing>
    </task>
    <parallelGateway id="Par13" name="PAR">
      <incoming>PPL1-Par13</incoming>
      <outgoing>Par13-MTD1</outgoing>
      <outgoing>Par13-PI1</outgoing>
    </parallelGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>Par13-MTD1</incoming>
      <outgoing>MTD1-CTD1</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>Par13-PI1</incoming>
      <outgoing>PI1-PARCLOSE17</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>MTD1-CTD1</incoming>
      <outgoing>CTD1-PARCLOSE17</outgoing>
    </task>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>PI1-PARCLOSE17</incoming>
      <incoming>CTD1-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-PARCLOSE18</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>DCS1-PARCLOSE18</incoming>
      <incoming>PARCLOSE17-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-PMT1</outgoing>
    </parallelGateway>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>PARCLOSE18-PMT1</incoming>
      <outgoing>PMT1-FV1</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>PMT1-FV1</incoming>
      <outgoing>FV1-Par21</outgoing>
    </task>
    <parallelGateway id="Par21" name="PAR">
      <incoming>FV1-Par21</incoming>
      <outgoing>Par21-PTM1</outgoing>
      <outgoing>Par21-ALSP1</outgoing>
    </parallelGateway>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>Par21-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE24</outgoing>
    </task>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>Par21-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>PTM1-PARCLOSE24</incoming>
      <incoming>ALSP1-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE24-END</incoming>
    </endEvent>
