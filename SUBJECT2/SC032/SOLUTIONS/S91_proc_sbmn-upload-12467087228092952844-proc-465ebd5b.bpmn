<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_479f4c10-1bf3-4823-82bd-2f6936446623" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DSC1</outgoing>
    </startEvent>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>Default_init-DSC1</incoming>
      <outgoing>DSC1-APC1</outgoing>
    </task>
    <task id="APC1" name="Approve Product Concept">
      <incoming>DSC1-APC1</incoming>
      <outgoing>APC1-NS1</outgoing>
    </task>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>APC1-NS1</incoming>
      <outgoing>NS1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>NS1-Par3</incoming>
      <outgoing>Par3-PP1</outgoing>
      <outgoing>Par3-UCLA1</outgoing>
    </parallelGateway>
    <task id="PP1" name="Produce Prototypes">
      <incoming>Par3-PP1</incoming>
      <outgoing>PP1-Par6</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>Par3-UCLA1</incoming>
      <outgoing>UCLA1-PARCLOSE19</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>PP1-Par6</incoming>
      <outgoing>Par6-DCS1</outgoing>
      <outgoing>Par6-G0</outgoing>
    </parallelGateway>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>Par6-DCS1</incoming>
      <outgoing>DCS1-DVES1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par6-G0</incoming>
      <outgoing>G0-MTD1</outgoing>
      <outgoing>G0-XORCLOSE14</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G0-MTD1</incoming>
      <outgoing>MTD1-XORCLOSE14</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>DCS1-DVES1</incoming>
      <outgoing>DVES1-PPL1</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>DVES1-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>G0-XORCLOSE14</incoming>
      <incoming>MTD1-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-CTD1</outgoing>
    </exclusiveGateway>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-PARCLOSE18</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>XORCLOSE14-CTD1</incoming>
      <outgoing>CTD1-PTM1</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>CTD1-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE18</outgoing>
    </task>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>PI1-PARCLOSE18</incoming>
      <incoming>PTM1-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-PARCLOSE19</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>UCLA1-PARCLOSE19</incoming>
      <incoming>PARCLOSE18-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-PMT1</outgoing>
    </parallelGateway>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>PARCLOSE19-PMT1</incoming>
      <outgoing>PMT1-FV1</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>PMT1-FV1</incoming>
      <outgoing>FV1-ALSP1</outgoing>
    </task>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>FV1-ALSP1</incoming>
      <outgoing>ALSP1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>ALSP1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DSC1" sourceRef="Default_init" targetRef="DSC1"/>
    <sequenceFlow id="DSC1-APC1" sourceRef="DSC1" targetRef="APC1"/>
