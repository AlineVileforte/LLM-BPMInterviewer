    <sequenceFlow id="DCS1-UCLA1" sourceRef="DCS1" targetRef="UCLA1"/>
    <sequenceFlow id="PI1-PARCLOSE17" sourceRef="PI1" targetRef="PARCLOSE17"/>
    <sequenceFlow id="PMT1-PARCLOSE18" sourceRef="PMT1" targetRef="PARCLOSE18"/>
    <sequenceFlow id="UCLA1-PARCLOSE17" sourceRef="UCLA1" targetRef="PARCLOSE17"/>
    <sequenceFlow id="PARCLOSE17-PARCLOSE18" sourceRef="PARCLOSE17" targetRef="PARCLOSE18"/>
    <sequenceFlow id="PARCLOSE18-CTD1" sourceRef="PARCLOSE18" targetRef="CTD1"/>
    <sequenceFlow id="CTD1-PTM1" sourceRef="CTD1" targetRef="PTM1"/>
    <sequenceFlow id="PTM1-FV1" sourceRef="PTM1" targetRef="FV1"/>
    <sequenceFlow id="FV1-ALSP1" sourceRef="FV1" targetRef="ALSP1"/>
    <sequenceFlow id="ALSP1-END" sourceRef="ALSP1" targetRef="END"/>
  </process>
