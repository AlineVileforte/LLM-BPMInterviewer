<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_eae19036-a4e7-4f14-b5d7-17840fa5d42e" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-APC1</outgoing>
    </startEvent>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Default_init-APC1</incoming>
      <outgoing>APC1-DSC1</outgoing>
    </task>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>APC1-DSC1</incoming>
      <outgoing>DSC1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>DSC1-Par2</incoming>
      <outgoing>Par2-NS1</outgoing>
      <outgoing>Par2-PP1</outgoing>
    </parallelGateway>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>Par2-NS1</incoming>
      <outgoing>NS1-Par5</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>Par2-PP1</incoming>
      <outgoing>PP1-G0</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>NS1-Par5</incoming>
      <outgoing>Par5-DCS1</outgoing>
      <outgoing>Par5-UCLA1</outgoing>
    </parallelGateway>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>Par5-DCS1</incoming>
      <outgoing>DCS1-PARCLOSE15</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>Par5-UCLA1</incoming>
      <outgoing>UCLA1-PARCLOSE15</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>PP1-G0</incoming>
      <outgoing>G0-XORCLOSE13</outgoing>
      <outgoing>G0-MTD1</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G0-MTD1</incoming>
      <outgoing>MTD1-XORCLOSE13</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE13" name="XORCLOSE13">
      <incoming>G0-XORCLOSE13</incoming>
      <incoming>MTD1-XORCLOSE13</incoming>
      <outgoing>XORCLOSE13-Par16</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE15" name="PARCLOSE15">
      <incoming>DCS1-PARCLOSE15</incoming>
      <incoming>UCLA1-PARCLOSE15</incoming>
      <outgoing>PARCLOSE15-PARCLOSE25</outgoing>
    </parallelGateway>
    <parallelGateway id="Par16" name="PAR">
      <incoming>XORCLOSE13-Par16</incoming>
      <outgoing>Par16-DVES1</outgoing>
      <outgoing>Par16-CTD1</outgoing>
    </parallelGateway>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>Par16-DVES1</incoming>
      <outgoing>DVES1-PPL1</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>Par16-CTD1</incoming>
      <outgoing>CTD1-PTM1</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>DVES1-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>CTD1-PTM1</incoming>
      <outgoing>PTM1-PMT1</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-PARCLOSE23</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>PTM1-PMT1</incoming>
      <outgoing>PMT1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>PI1-PARCLOSE23</incoming>
      <incoming>PMT1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-FV1</outgoing>
    </parallelGateway>
    <task id="FV1" name="Final Validation">
      <incoming>PARCLOSE23-FV1</incoming>
      <outgoing>FV1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>PARCLOSE15-PARCLOSE25</incoming>
      <incoming>FV1-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-ALSP1</outgoing>
    </parallelGateway>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>PARCLOSE25-ALSP1</incoming>
      <outgoing>ALSP1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>ALSP1-END</incoming>
    </endEvent>
