<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_d8fd6d12-9811-40ca-bea5-a8f6b57c5228" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DSC1</outgoing>
    </startEvent>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>Default_init-DSC1</incoming>
      <outgoing>DSC1-APC1</outgoing>
    </task>
    <task id="APC1" name="Approve Product Concept">
      <incoming>DSC1-APC1</incoming>
      <outgoing>APC1-NS1</outgoing>
    </task>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>APC1-NS1</incoming>
      <outgoing>NS1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>NS1-Par3</incoming>
      <outgoing>Par3-PP1</outgoing>
      <outgoing>Par3-DVES1</outgoing>
    </parallelGateway>
    <task id="PP1" name="Produce Prototypes">
      <incoming>Par3-PP1</incoming>
      <outgoing>PP1-DCS1</outgoing>
    </task>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>PP1-DCS1</incoming>
      <outgoing>DCS1-UCLA1</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>Par3-DVES1</incoming>
      <outgoing>DVES1-Par8</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>DCS1-UCLA1</incoming>
      <outgoing>UCLA1-PARCLOSE26</outgoing>
    </task>
    <parallelGateway id="Par8" name="PAR">
      <incoming>DVES1-Par8</incoming>
      <outgoing>Par8-PPL1</outgoing>
      <outgoing>Par8-G3</outgoing>
    </parallelGateway>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>Par8-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>Par8-G3</incoming>
      <outgoing>G3-MTD1</outgoing>
      <outgoing>G3-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G3-MTD1</incoming>
      <outgoing>MTD1-XORCLOSE17</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-PARCLOSE25</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE17" name="XORCLOSE17">
      <incoming>G3-XORCLOSE17</incoming>
      <incoming>MTD1-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-PMT1</outgoing>
    </exclusiveGateway>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>XORCLOSE17-PMT1</incoming>
      <outgoing>PMT1-FV1</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>PMT1-FV1</incoming>
      <outgoing>FV1-Par20</outgoing>
    </task>
    <parallelGateway id="Par20" name="PAR">
      <incoming>FV1-Par20</incoming>
      <outgoing>Par20-CTD1</outgoing>
      <outgoing>Par20-ALSP1</outgoing>
    </parallelGateway>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>Par20-CTD1</incoming>
      <outgoing>CTD1-PARCLOSE23</outgoing>
    </task>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>Par20-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>CTD1-PARCLOSE23</incoming>
      <incoming>ALSP1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-PTM1</outgoing>
    </parallelGateway>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>PARCLOSE23-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>PI1-PARCLOSE25</incoming>
      <incoming>PTM1-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-PARCLOSE26</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>UCLA1-PARCLOSE26</incoming>
      <incoming>PARCLOSE25-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE26-END</incoming>
    </endEvent>
