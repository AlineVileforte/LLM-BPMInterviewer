<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_789e46ce-6ea1-43d9-9944-d2cb12514c8e" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-APC1</outgoing>
    </startEvent>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Default_init-APC1</incoming>
      <outgoing>APC1-DSC1</outgoing>
    </task>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>APC1-DSC1</incoming>
      <outgoing>DSC1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>DSC1-Par2</incoming>
      <outgoing>Par2-NS1</outgoing>
      <outgoing>Par2-PP1</outgoing>
    </parallelGateway>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>Par2-NS1</incoming>
      <outgoing>NS1-Par5</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>Par2-PP1</incoming>
      <outgoing>PP1-G0</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>NS1-Par5</incoming>
      <outgoing>Par5-UCLA1</outgoing>
      <outgoing>Par5-DCS1</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G0" name="G0">
      <incoming>PP1-G0</incoming>
      <outgoing>G0-MTD1</outgoing>
      <outgoing>G0-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G0-MTD1</incoming>
      <outgoing>MTD1-XORCLOSE17</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>Par5-UCLA1</incoming>
      <outgoing>UCLA1-PARCLOSE15</outgoing>
    </task>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>Par5-DCS1</incoming>
      <outgoing>DCS1-PARCLOSE15</outgoing>
    </task>
    <parallelGateway id="PARCLOSE15" name="PARCLOSE15">
      <incoming>UCLA1-PARCLOSE15</incoming>
      <incoming>DCS1-PARCLOSE15</incoming>
      <outgoing>PARCLOSE15-PARCLOSE30</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE17" name="XORCLOSE17">
      <incoming>G0-XORCLOSE17</incoming>
      <incoming>MTD1-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-DVES1</outgoing>
    </exclusiveGateway>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>XORCLOSE17-DVES1</incoming>
      <outgoing>DVES1-PMT1</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>DVES1-PMT1</incoming>
      <outgoing>PMT1-Par20</outgoing>
    </task>
    <parallelGateway id="Par20" name="PAR">
      <incoming>PMT1-Par20</incoming>
      <outgoing>Par20-FV1</outgoing>
      <outgoing>Par20-PPL1</outgoing>
    </parallelGateway>
    <task id="FV1" name="Final Validation">
      <incoming>Par20-FV1</incoming>
      <outgoing>FV1-ALSP1</outgoing>
    </task>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>FV1-ALSP1</incoming>
      <outgoing>ALSP1-CTD1</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>Par20-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>ALSP1-CTD1</incoming>
      <outgoing>CTD1-PTM1</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-PARCLOSE29</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>CTD1-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE29</outgoing>
    </task>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>PI1-PARCLOSE29</incoming>
      <incoming>PTM1-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-PARCLOSE30</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE30" name="PARCLOSE30">
      <incoming>PARCLOSE15-PARCLOSE30</incoming>
      <incoming>PARCLOSE29-PARCLOSE30</incoming>
      <outgoing>PARCLOSE30-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE30-END</incoming>
    </endEvent>
