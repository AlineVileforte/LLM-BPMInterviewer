    <sequenceFlow id="DCS1-UCLA1" sourceRef="DCS1" targetRef="UCLA1"/>
    <sequenceFlow id="UCLA1-PARCLOSE16" sourceRef="UCLA1" targetRef="PARCLOSE16"/>
    <sequenceFlow id="PPL1-PI1" sourceRef="PPL1" targetRef="PI1"/>
    <sequenceFlow id="PI1-PARCLOSE16" sourceRef="PI1" targetRef="PARCLOSE16"/>
    <sequenceFlow id="XORCLOSE15-PMT1" sourceRef="XORCLOSE15" targetRef="PMT1"/>
    <sequenceFlow id="PARCLOSE16-PARCLOSE19" sourceRef="PARCLOSE16" targetRef="PARCLOSE19"/>
    <sequenceFlow id="PMT1-FV1" sourceRef="PMT1" targetRef="FV1"/>
    <sequenceFlow id="FV1-PARCLOSE19" sourceRef="FV1" targetRef="PARCLOSE19"/>
    <sequenceFlow id="PARCLOSE19-ALSP1" sourceRef="PARCLOSE19" targetRef="ALSP1"/>
    <sequenceFlow id="ALSP1-CTD1" sourceRef="ALSP1" targetRef="CTD1"/>
    <sequenceFlow id="CTD1-PTM1" sourceRef="CTD1" targetRef="PTM1"/>
    <sequenceFlow id="PTM1-END" sourceRef="PTM1" targetRef="END"/>
  </process>
