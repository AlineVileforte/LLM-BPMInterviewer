<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_98444488-672f-455a-9aad-34a057407619" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-APC1</outgoing>
    </startEvent>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Default_init-APC1</incoming>
      <outgoing>APC1-DSC1</outgoing>
    </task>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>APC1-DSC1</incoming>
      <outgoing>DSC1-PP1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>DSC1-PP1</incoming>
      <outgoing>PP1-DVES1</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>PP1-DVES1</incoming>
      <outgoing>DVES1-Par4</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>DVES1-Par4</incoming>
      <outgoing>Par4-NS1</outgoing>
      <outgoing>Par4-G1</outgoing>
    </parallelGateway>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>Par4-NS1</incoming>
      <outgoing>NS1-Par8</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par4-G1</incoming>
      <outgoing>G1-MTD1</outgoing>
      <outgoing>G1-XORCLOSE15</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G1-MTD1</incoming>
      <outgoing>MTD1-XORCLOSE15</outgoing>
    </task>
    <parallelGateway id="Par8" name="PAR">
      <incoming>NS1-Par8</incoming>
      <outgoing>Par8-DCS1</outgoing>
      <outgoing>Par8-PPL1</outgoing>
    </parallelGateway>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>Par8-DCS1</incoming>
      <outgoing>DCS1-UCLA1</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>DCS1-UCLA1</incoming>
      <outgoing>UCLA1-PARCLOSE16</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>Par8-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-PARCLOSE16</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE15" name="XORCLOSE15">
      <incoming>G1-XORCLOSE15</incoming>
      <incoming>MTD1-XORCLOSE15</incoming>
      <outgoing>XORCLOSE15-PMT1</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE16" name="PARCLOSE16">
      <incoming>UCLA1-PARCLOSE16</incoming>
      <incoming>PI1-PARCLOSE16</incoming>
      <outgoing>PARCLOSE16-PARCLOSE19</outgoing>
    </parallelGateway>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>XORCLOSE15-PMT1</incoming>
      <outgoing>PMT1-FV1</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>PMT1-FV1</incoming>
      <outgoing>FV1-PARCLOSE19</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>PARCLOSE16-PARCLOSE19</incoming>
      <incoming>FV1-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-ALSP1</outgoing>
    </parallelGateway>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>PARCLOSE19-ALSP1</incoming>
      <outgoing>ALSP1-CTD1</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>ALSP1-CTD1</incoming>
      <outgoing>CTD1-PTM1</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>CTD1-PTM1</incoming>
      <outgoing>PTM1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PTM1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-APC1" sourceRef="Default_init" targetRef="APC1"/>
    <sequenceFlow id="APC1-DSC1" sourceRef="APC1" targetRef="DSC1"/>
