<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_5a670d37-96ef-4fc2-9a6c-83f129dbc965" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DSC1</outgoing>
    </startEvent>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>Default_init-DSC1</incoming>
      <outgoing>DSC1-APC1</outgoing>
    </task>
    <task id="APC1" name="Approve Product Concept">
      <incoming>DSC1-APC1</incoming>
      <outgoing>APC1-PP1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>APC1-PP1</incoming>
      <outgoing>PP1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>PP1-Par3</incoming>
      <outgoing>Par3-NS1</outgoing>
      <outgoing>Par3-G0</outgoing>
    </parallelGateway>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>Par3-NS1</incoming>
      <outgoing>NS1-UCLA1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par3-G0</incoming>
      <outgoing>G0-MTD1</outgoing>
      <outgoing>G0-XORCLOSE16</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G0-MTD1</incoming>
      <outgoing>MTD1-XORCLOSE16</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>NS1-UCLA1</incoming>
      <outgoing>UCLA1-DVES1</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>UCLA1-DVES1</incoming>
      <outgoing>DVES1-Par13</outgoing>
    </task>
    <parallelGateway id="Par13" name="PAR">
      <incoming>DVES1-Par13</incoming>
      <outgoing>Par13-DCS1</outgoing>
      <outgoing>Par13-PPL1</outgoing>
    </parallelGateway>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>Par13-DCS1</incoming>
      <outgoing>DCS1-PARCLOSE17</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>Par13-PPL1</incoming>
      <outgoing>PPL1-PARCLOSE17</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
      <incoming>G0-XORCLOSE16</incoming>
      <incoming>MTD1-XORCLOSE16</incoming>
      <outgoing>XORCLOSE16-Par18</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>DCS1-PARCLOSE17</incoming>
      <incoming>PPL1-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-PI1</outgoing>
    </parallelGateway>
    <parallelGateway id="Par18" name="PAR">
      <incoming>XORCLOSE16-Par18</incoming>
      <outgoing>Par18-PMT1</outgoing>
      <outgoing>Par18-FV1</outgoing>
    </parallelGateway>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>Par18-PMT1</incoming>
      <outgoing>PMT1-CTD1</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>PARCLOSE17-PI1</incoming>
      <outgoing>PI1-PARCLOSE26</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>PMT1-CTD1</incoming>
      <outgoing>CTD1-PTM1</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>Par18-FV1</incoming>
      <outgoing>FV1-ALSP1</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>CTD1-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE25</outgoing>
    </task>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>FV1-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>PTM1-PARCLOSE25</incoming>
      <incoming>ALSP1-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-PARCLOSE26</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>PI1-PARCLOSE26</incoming>
      <incoming>PARCLOSE25-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE26-END</incoming>
    </endEvent>
