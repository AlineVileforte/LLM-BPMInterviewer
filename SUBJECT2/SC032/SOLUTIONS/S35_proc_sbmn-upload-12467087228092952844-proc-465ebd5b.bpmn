    <sequenceFlow id="Par16-PPL1" sourceRef="Par16" targetRef="PPL1"/>
    <sequenceFlow id="DVES1-ALSP1" sourceRef="DVES1" targetRef="ALSP1"/>
    <sequenceFlow id="ALSP1-CTD1" sourceRef="ALSP1" targetRef="CTD1"/>
    <sequenceFlow id="PPL1-PI1" sourceRef="PPL1" targetRef="PI1"/>
    <sequenceFlow id="CTD1-PTM1" sourceRef="CTD1" targetRef="PTM1"/>
    <sequenceFlow id="PI1-PARCLOSE23" sourceRef="PI1" targetRef="PARCLOSE23"/>
    <sequenceFlow id="PTM1-PARCLOSE23" sourceRef="PTM1" targetRef="PARCLOSE23"/>
    <sequenceFlow id="PARCLOSE23-END" sourceRef="PARCLOSE23" targetRef="END"/>
  </process>
