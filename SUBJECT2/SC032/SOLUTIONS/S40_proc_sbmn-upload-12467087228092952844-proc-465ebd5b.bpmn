    <sequenceFlow id="XORCLOSE16-PI1" sourceRef="XORCLOSE16" targetRef="PI1"/>
    <sequenceFlow id="PMT1-PARCLOSE19" sourceRef="PMT1" targetRef="PARCLOSE19"/>
    <sequenceFlow id="PI1-FV1" sourceRef="PI1" targetRef="FV1"/>
    <sequenceFlow id="PARCLOSE19-PARCLOSE21" sourceRef="PARCLOSE19" targetRef="PARCLOSE21"/>
    <sequenceFlow id="FV1-PARCLOSE21" sourceRef="FV1" targetRef="PARCLOSE21"/>
    <sequenceFlow id="PARCLOSE21-ALSP1" sourceRef="PARCLOSE21" targetRef="ALSP1"/>
    <sequenceFlow id="ALSP1-END" sourceRef="ALSP1" targetRef="END"/>
  </process>
