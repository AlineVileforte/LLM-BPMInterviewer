<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_34813bc1-33b1-4e21-8b9e-a8b53a003b0d" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-APC1</outgoing>
    </startEvent>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Default_init-APC1</incoming>
      <outgoing>APC1-DSC1</outgoing>
    </task>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>APC1-DSC1</incoming>
      <outgoing>DSC1-NS1</outgoing>
    </task>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>DSC1-NS1</incoming>
      <outgoing>NS1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>NS1-Par3</incoming>
      <outgoing>Par3-DCS1</outgoing>
      <outgoing>Par3-UCLA1</outgoing>
    </parallelGateway>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>Par3-DCS1</incoming>
      <outgoing>DCS1-PP1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>DCS1-PP1</incoming>
      <outgoing>PP1-G0</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>Par3-UCLA1</incoming>
      <outgoing>UCLA1-DVES1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>PP1-G0</incoming>
      <outgoing>G0-MTD1</outgoing>
      <outgoing>G0-XORCLOSE16</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G0-MTD1</incoming>
      <outgoing>MTD1-XORCLOSE16</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>UCLA1-DVES1</incoming>
      <outgoing>DVES1-CTD1</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>DVES1-CTD1</incoming>
      <outgoing>CTD1-Par13</outgoing>
    </task>
    <parallelGateway id="Par13" name="PAR">
      <incoming>CTD1-Par13</incoming>
      <outgoing>Par13-PPL1</outgoing>
      <outgoing>Par13-PTM1</outgoing>
    </parallelGateway>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>Par13-PPL1</incoming>
      <outgoing>PPL1-PMT1</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>Par13-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE19</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
      <incoming>G0-XORCLOSE16</incoming>
      <incoming>MTD1-XORCLOSE16</incoming>
      <outgoing>XORCLOSE16-PI1</outgoing>
    </exclusiveGateway>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>PPL1-PMT1</incoming>
      <outgoing>PMT1-PARCLOSE19</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>XORCLOSE16-PI1</incoming>
      <outgoing>PI1-FV1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>PTM1-PARCLOSE19</incoming>
      <incoming>PMT1-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-PARCLOSE21</outgoing>
    </parallelGateway>
    <task id="FV1" name="Final Validation">
      <incoming>PI1-FV1</incoming>
      <outgoing>FV1-PARCLOSE21</outgoing>
    </task>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>PARCLOSE19-PARCLOSE21</incoming>
      <incoming>FV1-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-ALSP1</outgoing>
    </parallelGateway>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>PARCLOSE21-ALSP1</incoming>
      <outgoing>ALSP1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>ALSP1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-APC1" sourceRef="Default_init" targetRef="APC1"/>
