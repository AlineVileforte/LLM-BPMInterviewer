<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_9d23814a-67f8-4eb5-99ce-2645b70d9400" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-APC1</outgoing>
      <outgoing>Par0-DSC1</outgoing>
    </parallelGateway>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Par0-APC1</incoming>
      <outgoing>APC1-PARCLOSE5</outgoing>
    </task>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>Par0-DSC1</incoming>
      <outgoing>DSC1-PARCLOSE5</outgoing>
    </task>
    <parallelGateway id="PARCLOSE5" name="PARCLOSE5">
      <incoming>APC1-PARCLOSE5</incoming>
      <incoming>DSC1-PARCLOSE5</incoming>
      <outgoing>PARCLOSE5-PP1</outgoing>
    </parallelGateway>
    <task id="PP1" name="Produce Prototypes">
      <incoming>PARCLOSE5-PP1</incoming>
      <outgoing>PP1-NS1</outgoing>
    </task>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>PP1-NS1</incoming>
      <outgoing>NS1-Par8</outgoing>
    </task>
    <parallelGateway id="Par8" name="PAR">
      <incoming>NS1-Par8</incoming>
      <outgoing>Par8-DCS1</outgoing>
      <outgoing>Par8-MTD1</outgoing>
    </parallelGateway>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>Par8-DCS1</incoming>
      <outgoing>DCS1-UCLA1</outgoing>
    </task>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>Par8-MTD1</incoming>
      <outgoing>MTD1-CTD1</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>DCS1-UCLA1</incoming>
      <outgoing>UCLA1-DVES1</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>MTD1-CTD1</incoming>
      <outgoing>CTD1-Par14</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>UCLA1-DVES1</incoming>
      <outgoing>DVES1-PPL1</outgoing>
    </task>
    <parallelGateway id="Par14" name="PAR">
      <incoming>CTD1-Par14</incoming>
      <outgoing>Par14-PMT1</outgoing>
      <outgoing>Par14-PTM1</outgoing>
    </parallelGateway>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>Par14-PMT1</incoming>
      <outgoing>PMT1-PARCLOSE18</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>Par14-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE18</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>DVES1-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>PMT1-PARCLOSE18</incoming>
      <incoming>PTM1-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-FV1</outgoing>
    </parallelGateway>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-PARCLOSE21</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>PARCLOSE18-FV1</incoming>
      <outgoing>FV1-PARCLOSE21</outgoing>
    </task>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>PI1-PARCLOSE21</incoming>
      <incoming>FV1-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-ALSP1</outgoing>
    </parallelGateway>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>PARCLOSE21-ALSP1</incoming>
      <outgoing>ALSP1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>ALSP1-END</incoming>
    </endEvent>
