<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_e05c0ec7-27e1-4f84-bae2-58ba794ada32" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-APC1</outgoing>
    </startEvent>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Default_init-APC1</incoming>
      <outgoing>APC1-DSC1</outgoing>
    </task>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>APC1-DSC1</incoming>
      <outgoing>DSC1-NS1</outgoing>
    </task>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>DSC1-NS1</incoming>
      <outgoing>NS1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>NS1-Par3</incoming>
      <outgoing>Par3-PP1</outgoing>
      <outgoing>Par3-DCS1</outgoing>
    </parallelGateway>
    <task id="PP1" name="Produce Prototypes">
      <incoming>Par3-PP1</incoming>
      <outgoing>PP1-DVES1</outgoing>
    </task>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>Par3-DCS1</incoming>
      <outgoing>DCS1-PARCLOSE24</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>PP1-DVES1</incoming>
      <outgoing>DVES1-Par9</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>DVES1-Par9</incoming>
      <outgoing>Par9-UCLA1</outgoing>
      <outgoing>Par9-PPL1</outgoing>
    </parallelGateway>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>Par9-UCLA1</incoming>
      <outgoing>UCLA1-MTD1</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>Par9-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>UCLA1-MTD1</incoming>
      <outgoing>MTD1-Par16</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="Par16" name="PAR">
      <incoming>MTD1-Par16</incoming>
      <outgoing>Par16-PMT1</outgoing>
      <outgoing>Par16-CTD1</outgoing>
    </parallelGateway>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>Par16-PMT1</incoming>
      <outgoing>PMT1-FV1</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>Par16-CTD1</incoming>
      <outgoing>CTD1-PTM1</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>PMT1-FV1</incoming>
      <outgoing>FV1-PARCLOSE21</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>CTD1-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE21</outgoing>
    </task>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>FV1-PARCLOSE21</incoming>
      <incoming>PTM1-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-ALSP1</outgoing>
    </parallelGateway>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>PARCLOSE21-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>PI1-PARCLOSE23</incoming>
      <incoming>ALSP1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-PARCLOSE24</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>DCS1-PARCLOSE24</incoming>
      <incoming>PARCLOSE23-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE24-END</incoming>
    </endEvent>
