<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_328115b7-9d55-4785-966e-add91ac1704b" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-APC1</outgoing>
    </startEvent>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Default_init-APC1</incoming>
      <outgoing>APC1-DSC1</outgoing>
    </task>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>APC1-DSC1</incoming>
      <outgoing>DSC1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>DSC1-Par2</incoming>
      <outgoing>Par2-NS1</outgoing>
      <outgoing>Par2-PP1</outgoing>
    </parallelGateway>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>Par2-NS1</incoming>
      <outgoing>NS1-Par9</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>Par2-PP1</incoming>
      <outgoing>PP1-DVES1</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>PP1-DVES1</incoming>
      <outgoing>DVES1-PPL1</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>NS1-Par9</incoming>
      <outgoing>Par9-DCS1</outgoing>
      <outgoing>Par9-UCLA1</outgoing>
    </parallelGateway>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>Par9-DCS1</incoming>
      <outgoing>DCS1-PARCLOSE13</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>Par9-UCLA1</incoming>
      <outgoing>UCLA1-PARCLOSE13</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>DVES1-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE13" name="PARCLOSE13">
      <incoming>DCS1-PARCLOSE13</incoming>
      <incoming>UCLA1-PARCLOSE13</incoming>
      <outgoing>PARCLOSE13-PARCLOSE18</outgoing>
    </parallelGateway>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-MTD1</outgoing>
    </task>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>PI1-MTD1</incoming>
      <outgoing>MTD1-PMT1</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>MTD1-PMT1</incoming>
      <outgoing>PMT1-PARCLOSE18</outgoing>
    </task>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>PARCLOSE13-PARCLOSE18</incoming>
      <incoming>PMT1-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-FV1</outgoing>
    </parallelGateway>
    <task id="FV1" name="Final Validation">
      <incoming>PARCLOSE18-FV1</incoming>
      <outgoing>FV1-Par20</outgoing>
    </task>
    <parallelGateway id="Par20" name="PAR">
      <incoming>FV1-Par20</incoming>
      <outgoing>Par20-CTD1</outgoing>
      <outgoing>Par20-ALSP1</outgoing>
    </parallelGateway>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>Par20-CTD1</incoming>
      <outgoing>CTD1-PTM1</outgoing>
    </task>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>Par20-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE24</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>CTD1-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>ALSP1-PARCLOSE24</incoming>
      <incoming>PTM1-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE24-END</incoming>
    </endEvent>
