    <parallelGateway id="Par9" name="PAR">
      <incoming>NS1-Par9</incoming>
      <outgoing>Par9-DCS1</outgoing>
      <outgoing>Par9-UCLA1</outgoing>
    </parallelGateway>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>Par9-DCS1</incoming>
      <outgoing>DCS1-PARCLOSE15</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>Par9-UCLA1</incoming>
      <outgoing>UCLA1-PARCLOSE15</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>PP1-Par12</incoming>
      <outgoing>Par12-DVES1</outgoing>
      <outgoing>Par12-MTD1</outgoing>
    </parallelGateway>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>Par12-DVES1</incoming>
      <outgoing>DVES1-PPL1</outgoing>
    </task>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>Par12-MTD1</incoming>
      <outgoing>MTD1-PMT1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE15" name="PARCLOSE15">
      <incoming>DCS1-PARCLOSE15</incoming>
      <incoming>UCLA1-PARCLOSE15</incoming>
      <outgoing>PARCLOSE15-PARCLOSE26</outgoing>
    </parallelGateway>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>DVES1-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>MTD1-PMT1</incoming>
      <outgoing>PMT1-CTD1</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-PARCLOSE24</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>PMT1-CTD1</incoming>
      <outgoing>CTD1-Par20</outgoing>
    </task>
    <parallelGateway id="Par20" name="PAR">
      <incoming>CTD1-Par20</incoming>
      <outgoing>Par20-FV1</outgoing>
      <outgoing>Par20-PTM1</outgoing>
    </parallelGateway>
    <task id="FV1" name="Final Validation">
      <incoming>Par20-FV1</incoming>
      <outgoing>FV1-PARCLOSE23</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>Par20-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>FV1-PARCLOSE23</incoming>
      <incoming>PTM1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-PARCLOSE24</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>PI1-PARCLOSE24</incoming>
      <incoming>PARCLOSE23-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-ALSP1</outgoing>
    </parallelGateway>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>PARCLOSE24-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE26</outgoing>
    </task>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>PARCLOSE15-PARCLOSE26</incoming>
      <incoming>ALSP1-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE26-END</incoming>
    </endEvent>
