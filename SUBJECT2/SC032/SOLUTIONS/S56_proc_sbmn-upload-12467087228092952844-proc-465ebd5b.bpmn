<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_715abefd-984d-4fcb-9924-ba0a879f095f" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-APC1</outgoing>
      <outgoing>Par0-DSC1</outgoing>
    </parallelGateway>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Par0-APC1</incoming>
      <outgoing>APC1-PARCLOSE5</outgoing>
    </task>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>Par0-DSC1</incoming>
      <outgoing>DSC1-PARCLOSE5</outgoing>
    </task>
    <parallelGateway id="PARCLOSE5" name="PARCLOSE5">
      <incoming>APC1-PARCLOSE5</incoming>
      <incoming>DSC1-PARCLOSE5</incoming>
      <outgoing>PARCLOSE5-Par6</outgoing>
    </parallelGateway>
    <parallelGateway id="Par6" name="PAR">
      <incoming>PARCLOSE5-Par6</incoming>
      <outgoing>Par6-NS1</outgoing>
      <outgoing>Par6-PP1</outgoing>
    </parallelGateway>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>Par6-NS1</incoming>
      <outgoing>NS1-UCLA1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>Par6-PP1</incoming>
      <outgoing>PP1-DVES1</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>NS1-UCLA1</incoming>
      <outgoing>UCLA1-DCS1</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>PP1-DVES1</incoming>
      <outgoing>DVES1-PARCLOSE12</outgoing>
    </task>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>UCLA1-DCS1</incoming>
      <outgoing>DCS1-PARCLOSE12</outgoing>
    </task>
    <parallelGateway id="PARCLOSE12" name="PARCLOSE12">
      <incoming>DVES1-PARCLOSE12</incoming>
      <incoming>DCS1-PARCLOSE12</incoming>
      <outgoing>PARCLOSE12-PPL1</outgoing>
    </parallelGateway>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>PARCLOSE12-PPL1</incoming>
      <outgoing>PPL1-Par14</outgoing>
    </task>
    <parallelGateway id="Par14" name="PAR">
      <incoming>PPL1-Par14</incoming>
      <outgoing>Par14-MTD1</outgoing>
      <outgoing>Par14-PI1</outgoing>
    </parallelGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>Par14-MTD1</incoming>
      <outgoing>MTD1-PMT1</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>Par14-PI1</incoming>
      <outgoing>PI1-PARCLOSE19</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>MTD1-PMT1</incoming>
      <outgoing>PMT1-FV1</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>PMT1-FV1</incoming>
      <outgoing>FV1-PARCLOSE19</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>PI1-PARCLOSE19</incoming>
      <incoming>FV1-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-Par20</outgoing>
    </parallelGateway>
    <parallelGateway id="Par20" name="PAR">
      <incoming>PARCLOSE19-Par20</incoming>
      <outgoing>Par20-CTD1</outgoing>
      <outgoing>Par20-ALSP1</outgoing>
    </parallelGateway>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>Par20-CTD1</incoming>
      <outgoing>CTD1-PARCLOSE23</outgoing>
    </task>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>Par20-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>CTD1-PARCLOSE23</incoming>
      <incoming>ALSP1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-PTM1</outgoing>
    </parallelGateway>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>PARCLOSE23-PTM1</incoming>
      <outgoing>PTM1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PTM1-END</incoming>
    </endEvent>
