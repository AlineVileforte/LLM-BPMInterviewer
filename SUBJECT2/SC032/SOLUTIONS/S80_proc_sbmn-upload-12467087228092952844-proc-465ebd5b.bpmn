  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DSC1</outgoing>
    </startEvent>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>Default_init-DSC1</incoming>
      <outgoing>DSC1-APC1</outgoing>
    </task>
    <task id="APC1" name="Approve Product Concept">
      <incoming>DSC1-APC1</incoming>
      <outgoing>APC1-PP1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>APC1-PP1</incoming>
      <outgoing>PP1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>PP1-Par3</incoming>
      <outgoing>Par3-NS1</outgoing>
      <outgoing>Par3-DVES1</outgoing>
    </parallelGateway>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>Par3-NS1</incoming>
      <outgoing>NS1-Par6</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>Par3-DVES1</incoming>
      <outgoing>DVES1-Par9</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>NS1-Par6</incoming>
      <outgoing>Par6-DCS1</outgoing>
      <outgoing>Par6-UCLA1</outgoing>
    </parallelGateway>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>Par6-DCS1</incoming>
      <outgoing>DCS1-PARCLOSE13</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>Par6-UCLA1</incoming>
      <outgoing>UCLA1-PARCLOSE13</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>DVES1-Par9</incoming>
      <outgoing>Par9-PPL1</outgoing>
      <outgoing>Par9-G2</outgoing>
    </parallelGateway>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>Par9-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par9-G2</incoming>
      <outgoing>G2-MTD1</outgoing>
      <outgoing>G2-XORCLOSE22</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G2-MTD1</incoming>
      <outgoing>MTD1-XORCLOSE22</outgoing>
    </task>
    <parallelGateway id="PARCLOSE13" name="PARCLOSE13">
      <incoming>DCS1-PARCLOSE13</incoming>
      <incoming>UCLA1-PARCLOSE13</incoming>
      <outgoing>PARCLOSE13-Par16</outgoing>
    </parallelGateway>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="Par16" name="PAR">
      <incoming>PARCLOSE13-Par16</incoming>
      <outgoing>Par16-PMT1</outgoing>
      <outgoing>Par16-CTD1</outgoing>
    </parallelGateway>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>Par16-PMT1</incoming>
      <outgoing>PMT1-FV1</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>Par16-CTD1</incoming>
      <outgoing>CTD1-PTM1</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>PMT1-FV1</incoming>
      <outgoing>FV1-PARCLOSE23</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>CTD1-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE23</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE22" name="XORCLOSE22">
      <incoming>G2-XORCLOSE22</incoming>
      <incoming>MTD1-XORCLOSE22</incoming>
      <outgoing>XORCLOSE22-ALSP1</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>FV1-PARCLOSE23</incoming>
      <incoming>PTM1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-PARCLOSE26</outgoing>
    </parallelGateway>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>XORCLOSE22-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>PI1-PARCLOSE25</incoming>
      <incoming>ALSP1-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-PARCLOSE26</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>PARCLOSE23-PARCLOSE26</incoming>
      <incoming>PARCLOSE25-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE26-END</incoming>
    </endEvent>
