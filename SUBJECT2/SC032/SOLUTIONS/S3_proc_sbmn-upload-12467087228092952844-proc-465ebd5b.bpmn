<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_c92e78d7-0aa4-4518-8564-a75357cceaa0" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-APC1</outgoing>
    </startEvent>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Default_init-APC1</incoming>
      <outgoing>APC1-DSC1</outgoing>
    </task>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>APC1-DSC1</incoming>
      <outgoing>DSC1-NS1</outgoing>
    </task>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>DSC1-NS1</incoming>
      <outgoing>NS1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>NS1-Par3</incoming>
      <outgoing>Par3-PP1</outgoing>
      <outgoing>Par3-UCLA1</outgoing>
    </parallelGateway>
    <task id="PP1" name="Produce Prototypes">
      <incoming>Par3-PP1</incoming>
      <outgoing>PP1-DVES1</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>Par3-UCLA1</incoming>
      <outgoing>UCLA1-DCS1</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>PP1-DVES1</incoming>
      <outgoing>DVES1-G1</outgoing>
    </task>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>UCLA1-DCS1</incoming>
      <outgoing>DCS1-PARCLOSE29</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>DVES1-G1</incoming>
      <outgoing>G1-MTD1</outgoing>
      <outgoing>G1-XORCLOSE15</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G1-MTD1</incoming>
      <outgoing>MTD1-XORCLOSE15</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE15" name="XORCLOSE15">
      <incoming>G1-XORCLOSE15</incoming>
      <incoming>MTD1-XORCLOSE15</incoming>
      <outgoing>XORCLOSE15-Par16</outgoing>
    </exclusiveGateway>
    <parallelGateway id="Par16" name="PAR">
      <incoming>XORCLOSE15-Par16</incoming>
      <outgoing>Par16-PPL1</outgoing>
      <outgoing>Par16-PI1</outgoing>
    </parallelGateway>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>Par16-PPL1</incoming>
      <outgoing>PPL1-CTD1</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>PPL1-CTD1</incoming>
      <outgoing>CTD1-Par21</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>Par16-PI1</incoming>
      <outgoing>PI1-PARCLOSE28</outgoing>
    </task>
    <parallelGateway id="Par21" name="PAR">
      <incoming>CTD1-Par21</incoming>
      <outgoing>Par21-PMT1</outgoing>
      <outgoing>Par21-PTM1</outgoing>
    </parallelGateway>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>Par21-PMT1</incoming>
      <outgoing>PMT1-PARCLOSE24</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>Par21-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>PMT1-PARCLOSE24</incoming>
      <incoming>PTM1-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-FV1</outgoing>
    </parallelGateway>
    <task id="FV1" name="Final Validation">
      <incoming>PARCLOSE24-FV1</incoming>
      <outgoing>FV1-ALSP1</outgoing>
    </task>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>FV1-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE28</outgoing>
    </task>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>PI1-PARCLOSE28</incoming>
      <incoming>ALSP1-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-PARCLOSE29</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>DCS1-PARCLOSE29</incoming>
      <incoming>PARCLOSE28-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE29-END</incoming>
    </endEvent>
