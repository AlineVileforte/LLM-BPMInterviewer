<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_7a1b77ee-23cb-43a3-9e48-8f428cf13309" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-APC1</outgoing>
      <outgoing>Par0-DSC1</outgoing>
    </parallelGateway>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Par0-APC1</incoming>
      <outgoing>APC1-PARCLOSE7</outgoing>
    </task>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>Par0-DSC1</incoming>
      <outgoing>DSC1-PARCLOSE7</outgoing>
    </task>
    <parallelGateway id="PARCLOSE7" name="PARCLOSE7">
      <incoming>APC1-PARCLOSE7</incoming>
      <incoming>DSC1-PARCLOSE7</incoming>
      <outgoing>PARCLOSE7-NS1</outgoing>
    </parallelGateway>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>PARCLOSE7-NS1</incoming>
      <outgoing>NS1-Par9</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>NS1-Par9</incoming>
      <outgoing>Par9-UCLA1</outgoing>
      <outgoing>Par9-DCS1</outgoing>
    </parallelGateway>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>Par9-UCLA1</incoming>
      <outgoing>UCLA1-PP1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>UCLA1-PP1</incoming>
      <outgoing>PP1-MTD1</outgoing>
    </task>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>Par9-DCS1</incoming>
      <outgoing>DCS1-DVES1</outgoing>
    </task>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>PP1-MTD1</incoming>
      <outgoing>MTD1-CTD1</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>DCS1-DVES1</incoming>
      <outgoing>DVES1-PPL1</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>MTD1-CTD1</incoming>
      <outgoing>CTD1-PMT1</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>DVES1-PPL1</incoming>
      <outgoing>PPL1-Par18</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>CTD1-PMT1</incoming>
      <outgoing>PMT1-FV1</outgoing>
    </task>
    <parallelGateway id="Par18" name="PAR">
      <incoming>PPL1-Par18</incoming>
      <outgoing>Par18-PI1</outgoing>
      <outgoing>Par18-PTM1</outgoing>
    </parallelGateway>
    <task id="PI1" name="Perform Inspections">
      <incoming>Par18-PI1</incoming>
      <outgoing>PI1-PARCLOSE22</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>Par18-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE22</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>PMT1-FV1</incoming>
      <outgoing>FV1-ALSP1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>PI1-PARCLOSE22</incoming>
      <incoming>PTM1-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-PARCLOSE24</outgoing>
    </parallelGateway>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>FV1-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>PARCLOSE22-PARCLOSE24</incoming>
      <incoming>ALSP1-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE24-END</incoming>
    </endEvent>
