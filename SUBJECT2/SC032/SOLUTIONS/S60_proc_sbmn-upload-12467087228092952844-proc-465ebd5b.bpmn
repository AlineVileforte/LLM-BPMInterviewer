<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_cb3833f8-5974-4e85-a02a-516f455924bf" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-APC1</outgoing>
    </startEvent>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Default_init-APC1</incoming>
      <outgoing>APC1-DSC1</outgoing>
    </task>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>APC1-DSC1</incoming>
      <outgoing>DSC1-NS1</outgoing>
    </task>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>DSC1-NS1</incoming>
      <outgoing>NS1-DCS1</outgoing>
    </task>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>NS1-DCS1</incoming>
      <outgoing>DCS1-UCLA1</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>DCS1-UCLA1</incoming>
      <outgoing>UCLA1-PP1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>UCLA1-PP1</incoming>
      <outgoing>PP1-Par6</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>PP1-Par6</incoming>
      <outgoing>Par6-DVES1</outgoing>
      <outgoing>Par6-G0</outgoing>
    </parallelGateway>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>Par6-DVES1</incoming>
      <outgoing>DVES1-PPL1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par6-G0</incoming>
      <outgoing>G0-MTD1</outgoing>
      <outgoing>G0-XORCLOSE14</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G0-MTD1</incoming>
      <outgoing>MTD1-XORCLOSE14</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>DVES1-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-PARCLOSE22</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>G0-XORCLOSE14</incoming>
      <incoming>MTD1-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-CTD1</outgoing>
    </exclusiveGateway>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>XORCLOSE14-CTD1</incoming>
      <outgoing>CTD1-PMT1</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>CTD1-PMT1</incoming>
      <outgoing>PMT1-FV1</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>PMT1-FV1</incoming>
      <outgoing>FV1-Par18</outgoing>
    </task>
    <parallelGateway id="Par18" name="PAR">
      <incoming>FV1-Par18</incoming>
      <outgoing>Par18-PTM1</outgoing>
      <outgoing>Par18-ALSP1</outgoing>
    </parallelGateway>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>Par18-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE21</outgoing>
    </task>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>Par18-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE21</outgoing>
    </task>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>PTM1-PARCLOSE21</incoming>
      <incoming>ALSP1-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-PARCLOSE22</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>PI1-PARCLOSE22</incoming>
      <incoming>PARCLOSE21-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE22-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-APC1" sourceRef="Default_init" targetRef="APC1"/>
