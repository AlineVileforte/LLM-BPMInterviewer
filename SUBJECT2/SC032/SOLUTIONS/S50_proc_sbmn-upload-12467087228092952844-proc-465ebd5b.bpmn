  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-APC1</outgoing>
      <outgoing>Par0-DSC1</outgoing>
    </parallelGateway>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Par0-APC1</incoming>
      <outgoing>APC1-PARCLOSE7</outgoing>
    </task>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>Par0-DSC1</incoming>
      <outgoing>DSC1-PARCLOSE7</outgoing>
    </task>
    <parallelGateway id="PARCLOSE7" name="PARCLOSE7">
      <incoming>APC1-PARCLOSE7</incoming>
      <incoming>DSC1-PARCLOSE7</incoming>
      <outgoing>PARCLOSE7-NS1</outgoing>
    </parallelGateway>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>PARCLOSE7-NS1</incoming>
      <outgoing>NS1-Par9</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>NS1-Par9</incoming>
      <outgoing>Par9-PP1</outgoing>
      <outgoing>Par9-MTD1</outgoing>
    </parallelGateway>
    <task id="PP1" name="Produce Prototypes">
      <incoming>Par9-PP1</incoming>
      <outgoing>PP1-DVES1</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>PP1-DVES1</incoming>
      <outgoing>DVES1-Par13</outgoing>
    </task>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>Par9-MTD1</incoming>
      <outgoing>MTD1-CTD1</outgoing>
    </task>
    <parallelGateway id="Par13" name="PAR">
      <incoming>DVES1-Par13</incoming>
      <outgoing>Par13-DCS1</outgoing>
      <outgoing>Par13-PMT1</outgoing>
    </parallelGateway>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>Par13-DCS1</incoming>
      <outgoing>DCS1-Par17</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>MTD1-CTD1</incoming>
      <outgoing>CTD1-PTM1</outgoing>
    </task>
    <parallelGateway id="Par17" name="PAR">
      <incoming>DCS1-Par17</incoming>
      <outgoing>Par17-UCLA1</outgoing>
      <outgoing>Par17-PPL1</outgoing>
    </parallelGateway>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>Par17-UCLA1</incoming>
      <outgoing>UCLA1-PARCLOSE25</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>Par17-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>Par13-PMT1</incoming>
      <outgoing>PMT1-FV1</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>CTD1-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE28</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-PARCLOSE25</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>PMT1-FV1</incoming>
      <outgoing>FV1-ALSP1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>UCLA1-PARCLOSE25</incoming>
      <incoming>PI1-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-PARCLOSE27</outgoing>
    </parallelGateway>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>FV1-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE27</outgoing>
    </task>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>PARCLOSE25-PARCLOSE27</incoming>
      <incoming>ALSP1-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-PARCLOSE28</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>PTM1-PARCLOSE28</incoming>
      <incoming>PARCLOSE27-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE28-END</incoming>
    </endEvent>
