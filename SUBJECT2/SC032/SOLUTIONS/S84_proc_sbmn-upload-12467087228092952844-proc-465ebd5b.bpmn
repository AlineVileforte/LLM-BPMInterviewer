<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_33113ecb-5cd0-4ff0-a8b8-d80f1abc618e" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DSC1</outgoing>
    </startEvent>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>Default_init-DSC1</incoming>
      <outgoing>DSC1-APC1</outgoing>
    </task>
    <task id="APC1" name="Approve Product Concept">
      <incoming>DSC1-APC1</incoming>
      <outgoing>APC1-NS1</outgoing>
    </task>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>APC1-NS1</incoming>
      <outgoing>NS1-PP1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>NS1-PP1</incoming>
      <outgoing>PP1-Par4</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>PP1-Par4</incoming>
      <outgoing>Par4-DCS1</outgoing>
      <outgoing>Par4-UCLA1</outgoing>
    </parallelGateway>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>Par4-DCS1</incoming>
      <outgoing>DCS1-DVES1</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>Par4-UCLA1</incoming>
      <outgoing>UCLA1-G2</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>DCS1-DVES1</incoming>
      <outgoing>DVES1-PPL1</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>UCLA1-G2</incoming>
      <outgoing>G2-MTD1</outgoing>
      <outgoing>G2-XORCLOSE15</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G2-MTD1</incoming>
      <outgoing>MTD1-XORCLOSE15</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>DVES1-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-CTD1</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>PI1-CTD1</incoming>
      <outgoing>CTD1-PTM1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE15" name="XORCLOSE15">
      <incoming>G2-XORCLOSE15</incoming>
      <incoming>MTD1-XORCLOSE15</incoming>
      <outgoing>XORCLOSE15-PMT1</outgoing>
    </exclusiveGateway>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>CTD1-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE19</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>XORCLOSE15-PMT1</incoming>
      <outgoing>PMT1-FV1</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>PMT1-FV1</incoming>
      <outgoing>FV1-PARCLOSE19</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>PTM1-PARCLOSE19</incoming>
      <incoming>FV1-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-ALSP1</outgoing>
    </parallelGateway>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>PARCLOSE19-ALSP1</incoming>
      <outgoing>ALSP1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>ALSP1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-DSC1" sourceRef="Default_init" targetRef="DSC1"/>
