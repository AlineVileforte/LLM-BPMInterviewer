<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_a9df4f9b-0266-4f63-b12c-25eb1d543a68" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-DSC1</outgoing>
    </startEvent>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>Default_init-DSC1</incoming>
      <outgoing>DSC1-APC1</outgoing>
    </task>
    <task id="APC1" name="Approve Product Concept">
      <incoming>DSC1-APC1</incoming>
      <outgoing>APC1-PP1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>APC1-PP1</incoming>
      <outgoing>PP1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>PP1-Par3</incoming>
      <outgoing>Par3-Par6</outgoing>
      <outgoing>Par3-G0</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par3-G0</incoming>
      <outgoing>G0-MTD1</outgoing>
      <outgoing>G0-XORCLOSE19</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G0-MTD1</incoming>
      <outgoing>MTD1-XORCLOSE19</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>Par3-Par6</incoming>
      <outgoing>Par6-NS1</outgoing>
      <outgoing>Par6-DVES1</outgoing>
    </parallelGateway>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>Par6-NS1</incoming>
      <outgoing>NS1-Par12</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>Par6-DVES1</incoming>
      <outgoing>DVES1-PPL1</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>NS1-Par12</incoming>
      <outgoing>Par12-DCS1</outgoing>
      <outgoing>Par12-UCLA1</outgoing>
    </parallelGateway>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>Par12-DCS1</incoming>
      <outgoing>DCS1-PARCLOSE17</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>Par12-UCLA1</incoming>
      <outgoing>UCLA1-PARCLOSE17</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>DVES1-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>DCS1-PARCLOSE17</incoming>
      <incoming>UCLA1-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-PARCLOSE20</outgoing>
    </parallelGateway>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-PARCLOSE20</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE19" name="XORCLOSE19">
      <incoming>G0-XORCLOSE19</incoming>
      <incoming>MTD1-XORCLOSE19</incoming>
      <outgoing>XORCLOSE19-PARCLOSE21</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE20" name="PARCLOSE20">
      <incoming>PARCLOSE17-PARCLOSE20</incoming>
      <incoming>PI1-PARCLOSE20</incoming>
      <outgoing>PARCLOSE20-PARCLOSE21</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>XORCLOSE19-PARCLOSE21</incoming>
      <incoming>PARCLOSE20-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-CTD1</outgoing>
    </parallelGateway>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>PARCLOSE21-CTD1</incoming>
      <outgoing>CTD1-PMT1</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>CTD1-PMT1</incoming>
      <outgoing>PMT1-Par24</outgoing>
    </task>
    <parallelGateway id="Par24" name="PAR">
      <incoming>PMT1-Par24</incoming>
      <outgoing>Par24-FV1</outgoing>
      <outgoing>Par24-PTM1</outgoing>
    </parallelGateway>
    <task id="FV1" name="Final Validation">
      <incoming>Par24-FV1</incoming>
      <outgoing>FV1-ALSP1</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>Par24-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE28</outgoing>
    </task>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>FV1-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE28</outgoing>
    </task>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>PTM1-PARCLOSE28</incoming>
      <incoming>ALSP1-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE28-END</incoming>
    </endEvent>
