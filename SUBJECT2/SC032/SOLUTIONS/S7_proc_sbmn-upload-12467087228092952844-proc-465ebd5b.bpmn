    <sequenceFlow id="Par8-G1" sourceRef="Par8" targetRef="G1"/>
    <sequenceFlow id="DVES1-PPL1" sourceRef="DVES1" targetRef="PPL1"/>
    <sequenceFlow id="G1-MTD1" sourceRef="G1" targetRef="MTD1"/>
    <sequenceFlow id="G1-XORCLOSE16" sourceRef="G1" targetRef="XORCLOSE16"/>
    <sequenceFlow id="MTD1-XORCLOSE16" sourceRef="MTD1" targetRef="XORCLOSE16"/>
    <sequenceFlow id="PPL1-PI1" sourceRef="PPL1" targetRef="PI1"/>
    <sequenceFlow id="PI1-PARCLOSE19" sourceRef="PI1" targetRef="PARCLOSE19"/>
    <sequenceFlow id="XORCLOSE16-PMT1" sourceRef="XORCLOSE16" targetRef="PMT1"/>
    <sequenceFlow id="PMT1-CTD1" sourceRef="PMT1" targetRef="CTD1"/>
    <sequenceFlow id="CTD1-PARCLOSE19" sourceRef="CTD1" targetRef="PARCLOSE19"/>
    <sequenceFlow id="PARCLOSE19-FV1" sourceRef="PARCLOSE19" targetRef="FV1"/>
    <sequenceFlow id="FV1-ALSP1" sourceRef="FV1" targetRef="ALSP1"/>
    <sequenceFlow id="ALSP1-PTM1" sourceRef="ALSP1" targetRef="PTM1"/>
    <sequenceFlow id="PTM1-END" sourceRef="PTM1" targetRef="END"/>
  </process>
