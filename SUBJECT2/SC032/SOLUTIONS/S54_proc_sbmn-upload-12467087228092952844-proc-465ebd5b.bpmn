<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_ea26344d-7894-4240-b1e2-20295e737e04" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-APC1</outgoing>
    </startEvent>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Default_init-APC1</incoming>
      <outgoing>APC1-DSC1</outgoing>
    </task>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>APC1-DSC1</incoming>
      <outgoing>DSC1-PP1</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>DSC1-PP1</incoming>
      <outgoing>PP1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>PP1-Par3</incoming>
      <outgoing>Par3-NS1</outgoing>
      <outgoing>Par3-G0</outgoing>
    </parallelGateway>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>Par3-NS1</incoming>
      <outgoing>NS1-DVES1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par3-G0</incoming>
      <outgoing>G0-MTD1</outgoing>
      <outgoing>G0-XORCLOSE14</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G0-MTD1</incoming>
      <outgoing>MTD1-XORCLOSE14</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>NS1-DVES1</incoming>
      <outgoing>DVES1-PPL1</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>DVES1-PPL1</incoming>
      <outgoing>PPL1-Par11</outgoing>
    </task>
    <parallelGateway id="Par11" name="PAR">
      <incoming>PPL1-Par11</incoming>
      <outgoing>Par11-DCS1</outgoing>
      <outgoing>Par11-PI1</outgoing>
    </parallelGateway>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>Par11-DCS1</incoming>
      <outgoing>DCS1-UCLA1</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>Par11-PI1</incoming>
      <outgoing>PI1-PARCLOSE16</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>G0-XORCLOSE14</incoming>
      <incoming>MTD1-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-CTD1</outgoing>
    </exclusiveGateway>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>DCS1-UCLA1</incoming>
      <outgoing>UCLA1-PARCLOSE16</outgoing>
    </task>
    <parallelGateway id="PARCLOSE16" name="PARCLOSE16">
      <incoming>PI1-PARCLOSE16</incoming>
      <incoming>UCLA1-PARCLOSE16</incoming>
      <outgoing>PARCLOSE16-PARCLOSE19</outgoing>
    </parallelGateway>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>XORCLOSE14-CTD1</incoming>
      <outgoing>CTD1-PMT1</outgoing>
    </task>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>CTD1-PMT1</incoming>
      <outgoing>PMT1-PARCLOSE19</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>PARCLOSE16-PARCLOSE19</incoming>
      <incoming>PMT1-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-FV1</outgoing>
    </parallelGateway>
    <task id="FV1" name="Final Validation">
      <incoming>PARCLOSE19-FV1</incoming>
      <outgoing>FV1-PTM1</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>FV1-PTM1</incoming>
      <outgoing>PTM1-ALSP1</outgoing>
    </task>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>PTM1-ALSP1</incoming>
      <outgoing>ALSP1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>ALSP1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-APC1" sourceRef="Default_init" targetRef="APC1"/>
