    <sequenceFlow id="PMT1-FV1" sourceRef="PMT1" targetRef="FV1"/>
    <sequenceFlow id="CTD1-PTM1" sourceRef="CTD1" targetRef="PTM1"/>
    <sequenceFlow id="FV1-ALSP1" sourceRef="FV1" targetRef="ALSP1"/>
    <sequenceFlow id="PTM1-PARCLOSE24" sourceRef="PTM1" targetRef="PARCLOSE24"/>
    <sequenceFlow id="ALSP1-PARCLOSE24" sourceRef="ALSP1" targetRef="PARCLOSE24"/>
    <sequenceFlow id="PARCLOSE24-END" sourceRef="PARCLOSE24" targetRef="END"/>
  </process>
