    <sequenceFlow id="ALSP1-DVES1" sourceRef="ALSP1" targetRef="DVES1"/>
    <sequenceFlow id="DVES1-PPL1" sourceRef="DVES1" targetRef="PPL1"/>
    <sequenceFlow id="CTD1-PTM1" sourceRef="CTD1" targetRef="PTM1"/>
    <sequenceFlow id="PPL1-PI1" sourceRef="PPL1" targetRef="PI1"/>
    <sequenceFlow id="PTM1-PARCLOSE22" sourceRef="PTM1" targetRef="PARCLOSE22"/>
    <sequenceFlow id="PI1-PARCLOSE22" sourceRef="PI1" targetRef="PARCLOSE22"/>
    <sequenceFlow id="PARCLOSE22-END" sourceRef="PARCLOSE22" targetRef="END"/>
  </process>
