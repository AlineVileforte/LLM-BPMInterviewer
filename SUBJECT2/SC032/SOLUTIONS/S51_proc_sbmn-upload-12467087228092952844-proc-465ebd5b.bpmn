<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_47b9682c-10a3-4ab7-9bcb-06eca3b582d4" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-APC1</outgoing>
    </startEvent>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Default_init-APC1</incoming>
      <outgoing>APC1-DSC1</outgoing>
    </task>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>APC1-DSC1</incoming>
      <outgoing>DSC1-NS1</outgoing>
    </task>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>DSC1-NS1</incoming>
      <outgoing>NS1-DCS1</outgoing>
    </task>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>NS1-DCS1</incoming>
      <outgoing>DCS1-Par4</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>DCS1-Par4</incoming>
      <outgoing>Par4-PP1</outgoing>
      <outgoing>Par4-UCLA1</outgoing>
    </parallelGateway>
    <task id="PP1" name="Produce Prototypes">
      <incoming>Par4-PP1</incoming>
      <outgoing>PP1-G0</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>Par4-UCLA1</incoming>
      <outgoing>UCLA1-PARCLOSE14</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>PP1-G0</incoming>
      <outgoing>G0-MTD1</outgoing>
      <outgoing>G0-XORCLOSE11</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G0-MTD1</incoming>
      <outgoing>MTD1-XORCLOSE11</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE11" name="XORCLOSE11">
      <incoming>G0-XORCLOSE11</incoming>
      <incoming>MTD1-XORCLOSE11</incoming>
      <outgoing>XORCLOSE11-PMT1</outgoing>
    </exclusiveGateway>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>XORCLOSE11-PMT1</incoming>
      <outgoing>PMT1-FV1</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>PMT1-FV1</incoming>
      <outgoing>FV1-PARCLOSE14</outgoing>
    </task>
    <parallelGateway id="PARCLOSE14" name="PARCLOSE14">
      <incoming>UCLA1-PARCLOSE14</incoming>
      <incoming>FV1-PARCLOSE14</incoming>
      <outgoing>PARCLOSE14-Par15</outgoing>
    </parallelGateway>
    <parallelGateway id="Par15" name="PAR">
      <incoming>PARCLOSE14-Par15</incoming>
      <outgoing>Par15-ALSP1</outgoing>
      <outgoing>Par15-CTD1</outgoing>
    </parallelGateway>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>Par15-ALSP1</incoming>
      <outgoing>ALSP1-DVES1</outgoing>
    </task>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>ALSP1-DVES1</incoming>
      <outgoing>DVES1-PPL1</outgoing>
    </task>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>Par15-CTD1</incoming>
      <outgoing>CTD1-PTM1</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>DVES1-PPL1</incoming>
      <outgoing>PPL1-PI1</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>CTD1-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE22</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>PPL1-PI1</incoming>
      <outgoing>PI1-PARCLOSE22</outgoing>
    </task>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>PTM1-PARCLOSE22</incoming>
      <incoming>PI1-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE22-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-APC1" sourceRef="Default_init" targetRef="APC1"/>
