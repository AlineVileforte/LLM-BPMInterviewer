<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_bced5a15-9970-4adb-ad0d-d622f89517b3" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-APC1</outgoing>
    </startEvent>
    <task id="APC1" name="Approve Product Concept">
      <incoming>Default_init-APC1</incoming>
      <outgoing>APC1-DSC1</outgoing>
    </task>
    <task id="DSC1" name="Develop Structural Components">
      <incoming>APC1-DSC1</incoming>
      <outgoing>DSC1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>DSC1-Par2</incoming>
      <outgoing>Par2-NS1</outgoing>
      <outgoing>Par2-PP1</outgoing>
    </parallelGateway>
    <task id="NS1" name="Negotiate with Suppliers">
      <incoming>Par2-NS1</incoming>
      <outgoing>NS1-Par5</outgoing>
    </task>
    <task id="PP1" name="Produce Prototypes">
      <incoming>Par2-PP1</incoming>
      <outgoing>PP1-G0</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>NS1-Par5</incoming>
      <outgoing>Par5-DCS1</outgoing>
      <outgoing>Par5-UCLA1</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G0" name="G0">
      <incoming>PP1-G0</incoming>
      <outgoing>G0-MTD1</outgoing>
      <outgoing>G0-XORCLOSE15</outgoing>
    </exclusiveGateway>
    <task id="MTD1" name="Modify Technical Drawings">
      <incoming>G0-MTD1</incoming>
      <outgoing>MTD1-XORCLOSE15</outgoing>
    </task>
    <task id="DCS1" name="Design Circuits and Sensors">
      <incoming>Par5-DCS1</incoming>
      <outgoing>DCS1-PARCLOSE16</outgoing>
    </task>
    <task id="UCLA1" name="Update Cost and Logistics Analysis">
      <incoming>Par5-UCLA1</incoming>
      <outgoing>UCLA1-PARCLOSE16</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE15" name="XORCLOSE15">
      <incoming>G0-XORCLOSE15</incoming>
      <incoming>MTD1-XORCLOSE15</incoming>
      <outgoing>XORCLOSE15-DVES1</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE16" name="PARCLOSE16">
      <incoming>DCS1-PARCLOSE16</incoming>
      <incoming>UCLA1-PARCLOSE16</incoming>
      <outgoing>PARCLOSE16-PARCLOSE19</outgoing>
    </parallelGateway>
    <task id="DVES1" name="Develop and Validate Embedded Software">
      <incoming>XORCLOSE15-DVES1</incoming>
      <outgoing>DVES1-PPL1</outgoing>
    </task>
    <task id="PPL1" name="Prepare Production Line">
      <incoming>DVES1-PPL1</incoming>
      <outgoing>PPL1-PARCLOSE19</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>PARCLOSE16-PARCLOSE19</incoming>
      <incoming>PPL1-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-Par20</outgoing>
    </parallelGateway>
    <parallelGateway id="Par20" name="PAR">
      <incoming>PARCLOSE19-Par20</incoming>
      <outgoing>Par20-PMT1</outgoing>
      <outgoing>Par20-PI1</outgoing>
    </parallelGateway>
    <task id="PMT1" name="Perform Mechanical Tests">
      <incoming>Par20-PMT1</incoming>
      <outgoing>PMT1-Par22</outgoing>
    </task>
    <parallelGateway id="Par22" name="PAR">
      <incoming>PMT1-Par22</incoming>
      <outgoing>Par22-CTD1</outgoing>
      <outgoing>Par22-FV1</outgoing>
    </parallelGateway>
    <task id="CTD1" name="Consolidate Technical Documentation">
      <incoming>Par22-CTD1</incoming>
      <outgoing>CTD1-PTM1</outgoing>
    </task>
    <task id="FV1" name="Final Validation">
      <incoming>Par22-FV1</incoming>
      <outgoing>FV1-ALSP1</outgoing>
    </task>
    <task id="PI1" name="Perform Inspections">
      <incoming>Par20-PI1</incoming>
      <outgoing>PI1-PARCLOSE29</outgoing>
    </task>
    <task id="PTM1" name="Prepare Training Materials">
      <incoming>CTD1-PTM1</incoming>
      <outgoing>PTM1-PARCLOSE28</outgoing>
    </task>
    <task id="ALSP1" name="Authorize Large-Scale Production">
      <incoming>FV1-ALSP1</incoming>
      <outgoing>ALSP1-PARCLOSE28</outgoing>
    </task>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>PTM1-PARCLOSE28</incoming>
      <incoming>ALSP1-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-PARCLOSE29</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>PI1-PARCLOSE29</incoming>
      <incoming>PARCLOSE28-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE29-END</incoming>
    </endEvent>
