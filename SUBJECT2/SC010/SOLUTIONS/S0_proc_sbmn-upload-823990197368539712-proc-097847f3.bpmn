  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-AIA1</outgoing>
    </startEvent>
    <task id="AIA1" name="Analyze Insurance Agreement">
      <incoming>Default_init-AIA1</incoming>
      <outgoing>AIA1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>AIA1-G0</incoming>
      <outgoing>G0-G1</outgoing>
      <outgoing>G0-OIH1</outgoing>
    </exclusiveGateway>
    <task id="OIH1" name="Offer Immediate Help">
      <incoming>G0-OIH1</incoming>
      <outgoing>OIH1-G2</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>G0-G1</incoming>
      <outgoing>G1-SOEH1</outgoing>
      <outgoing>G1-XORCLOSE8</outgoing>
    </exclusiveGateway>
    <task id="SOEH1" name="Send Out Offer for Emergency Help">
      <incoming>G1-SOEH1</incoming>
      <outgoing>SOEH1-XORCLOSE8</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>OIH1-G2</incoming>
      <outgoing>G2-ARN1</outgoing>
      <outgoing>G2-G3</outgoing>
    </exclusiveGateway>
    <task id="ARN1" name="Ask for Rejection Notification">
      <incoming>G2-ARN1</incoming>
      <outgoing>ARN1-XORCLOSE13</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE8" name="XORCLOSE8">
      <incoming>G1-XORCLOSE8</incoming>
      <incoming>SOEH1-XORCLOSE8</incoming>
      <outgoing>XORCLOSE8-XORCLOSE14</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G3" name="G3">
      <incoming>G2-G3</incoming>
      <outgoing>G3-DIA1</outgoing>
      <outgoing>G3-XORCLOSE12</outgoing>
    </exclusiveGateway>
    <task id="DIA1" name="Do Internal Accounting">
      <incoming>G3-DIA1</incoming>
      <outgoing>DIA1-XORCLOSE12</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE12" name="XORCLOSE12">
      <incoming>G3-XORCLOSE12</incoming>
      <incoming>DIA1-XORCLOSE12</incoming>
      <outgoing>XORCLOSE12-XORCLOSE13</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE13" name="XORCLOSE13">
      <incoming>ARN1-XORCLOSE13</incoming>
      <incoming>XORCLOSE12-XORCLOSE13</incoming>
      <outgoing>XORCLOSE13-XORCLOSE14</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>XORCLOSE8-XORCLOSE14</incoming>
      <incoming>XORCLOSE13-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE14-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-AIA1" sourceRef="Default_init" targetRef="AIA1"/>
