<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_50e60273-06d9-41c5-a5ee-f3bf3a420027" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-CST1</outgoing>
      <outgoing>Par0-SR1</outgoing>
    </parallelGateway>
    <task id="CST1" name="Customer searches for ticket">
      <incoming>Par0-CST1</incoming>
      <outgoing>CST1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>CST1-Par2</incoming>
      <outgoing>Par2-SDT1</outgoing>
      <outgoing>Par2-PPD1</outgoing>
    </parallelGateway>
    <task id="SDT1" name="Select date and time">
      <incoming>Par2-SDT1</incoming>
      <outgoing>SDT1-PARCLOSE9</outgoing>
    </task>
    <task id="PPD1" name="Provide payment details">
      <incoming>Par2-PPD1</incoming>
      <outgoing>PPD1-PARCLOSE9</outgoing>
    </task>
    <task id="SR1" name="Select route">
      <incoming>Par0-SR1</incoming>
      <outgoing>SR1-PPI1</outgoing>
    </task>
    <task id="PPI1" name="Provide personal information">
      <incoming>SR1-PPI1</incoming>
      <outgoing>PPI1-GT1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE9" name="PARCLOSE9">
      <incoming>SDT1-PARCLOSE9</incoming>
      <incoming>PPD1-PARCLOSE9</incoming>
      <outgoing>PARCLOSE9-PARCLOSE20</outgoing>
    </parallelGateway>
    <task id="GT1" name="Generate ticket">
      <incoming>PPI1-GT1</incoming>
      <outgoing>GT1-Par11</outgoing>
    </task>
    <parallelGateway id="Par11" name="PAR">
      <incoming>GT1-Par11</incoming>
      <outgoing>Par11-USI1</outgoing>
      <outgoing>Par11-G0</outgoing>
    </parallelGateway>
    <task id="USI1" name="Update seat inventory">
      <incoming>Par11-USI1</incoming>
      <outgoing>USI1-SIN1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par11-G0</incoming>
      <outgoing>G0-STE1</outgoing>
      <outgoing>G0-STS1</outgoing>
    </exclusiveGateway>
    <task id="STE1" name="Send ticket via email">
      <incoming>G0-STE1</incoming>
      <outgoing>STE1-XORCLOSE17</outgoing>
    </task>
    <task id="STS1" name="Send ticket via SMS">
      <incoming>G0-STS1</incoming>
      <outgoing>STS1-XORCLOSE17</outgoing>
    </task>
    <task id="SIN1" name="Send instructions">
      <incoming>USI1-SIN1</incoming>
      <outgoing>SIN1-PARCLOSE18</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE17" name="XORCLOSE17">
      <incoming>STE1-XORCLOSE17</incoming>
      <incoming>STS1-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-PARCLOSE18</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>SIN1-PARCLOSE18</incoming>
      <incoming>XORCLOSE17-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-SRM1</outgoing>
    </parallelGateway>
    <task id="SRM1" name="Send reminder">
      <incoming>PARCLOSE18-SRM1</incoming>
      <outgoing>SRM1-PARCLOSE20</outgoing>
    </task>
    <parallelGateway id="PARCLOSE20" name="PARCLOSE20">
      <incoming>PARCLOSE9-PARCLOSE20</incoming>
      <incoming>SRM1-PARCLOSE20</incoming>
      <outgoing>PARCLOSE20-CCJ1</outgoing>
    </parallelGateway>
    <task id="CCJ1" name="Customer completes journey">
      <incoming>PARCLOSE20-CCJ1</incoming>
      <outgoing>CCJ1-PTF1</outgoing>
    </task>
    <task id="PTF1" name="Post-travel feedback or services">
      <incoming>CCJ1-PTF1</incoming>
      <outgoing>PTF1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PTF1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
    <sequenceFlow id="Par0-CST1" sourceRef="Par0" targetRef="CST1"/>
    <sequenceFlow id="Par0-SR1" sourceRef="Par0" targetRef="SR1"/>
