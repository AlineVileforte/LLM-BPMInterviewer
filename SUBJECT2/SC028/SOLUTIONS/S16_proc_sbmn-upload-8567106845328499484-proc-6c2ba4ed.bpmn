<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_0c0f5fdc-3162-42fd-92f9-104448a1e968" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-SDT1</outgoing>
      <outgoing>Par0-CST1</outgoing>
    </parallelGateway>
    <task id="SDT1" name="Select date and time">
      <incoming>Par0-SDT1</incoming>
      <outgoing>SDT1-PPD1</outgoing>
    </task>
    <task id="PPD1" name="Provide payment details">
      <incoming>SDT1-PPD1</incoming>
      <outgoing>PPD1-PARCLOSE24</outgoing>
    </task>
    <task id="CST1" name="Customer searches for ticket">
      <incoming>Par0-CST1</incoming>
      <outgoing>CST1-SR1</outgoing>
    </task>
    <task id="SR1" name="Select route">
      <incoming>CST1-SR1</incoming>
      <outgoing>SR1-PPI1</outgoing>
    </task>
    <task id="PPI1" name="Provide personal information">
      <incoming>SR1-PPI1</incoming>
      <outgoing>PPI1-GT1</outgoing>
    </task>
    <task id="GT1" name="Generate ticket">
      <incoming>PPI1-GT1</incoming>
      <outgoing>GT1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>GT1-G0</incoming>
      <outgoing>G0-STE1</outgoing>
      <outgoing>G0-STS1</outgoing>
    </exclusiveGateway>
    <task id="STE1" name="Send ticket via email">
      <incoming>G0-STE1</incoming>
      <outgoing>STE1-XORCLOSE10</outgoing>
    </task>
    <task id="STS1" name="Send ticket via SMS">
      <incoming>G0-STS1</incoming>
      <outgoing>STS1-XORCLOSE10</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE10" name="XORCLOSE10">
      <incoming>STE1-XORCLOSE10</incoming>
      <incoming>STS1-XORCLOSE10</incoming>
      <outgoing>XORCLOSE10-USI1</outgoing>
    </exclusiveGateway>
    <task id="USI1" name="Update seat inventory">
      <incoming>XORCLOSE10-USI1</incoming>
      <outgoing>USI1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>USI1-G1</incoming>
      <outgoing>G1-SRM1</outgoing>
      <outgoing>G1-SIN1</outgoing>
    </exclusiveGateway>
    <task id="SRM1" name="Send reminder">
      <incoming>G1-SRM1</incoming>
      <outgoing>SRM1-XORCLOSE21</outgoing>
    </task>
    <task id="SIN1" name="Send instructions">
      <incoming>G1-SIN1</incoming>
      <outgoing>SIN1-XORCLOSE21</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE21" name="XORCLOSE21">
      <incoming>SRM1-XORCLOSE21</incoming>
      <incoming>SIN1-XORCLOSE21</incoming>
      <outgoing>XORCLOSE21-CCJ1</outgoing>
    </exclusiveGateway>
    <task id="CCJ1" name="Customer completes journey">
      <incoming>XORCLOSE21-CCJ1</incoming>
      <outgoing>CCJ1-PTF1</outgoing>
    </task>
    <task id="PTF1" name="Post-travel feedback or services">
      <incoming>CCJ1-PTF1</incoming>
      <outgoing>PTF1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>PPD1-PARCLOSE24</incoming>
      <incoming>PTF1-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE24-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
    <sequenceFlow id="Par0-SDT1" sourceRef="Par0" targetRef="SDT1"/>
    <sequenceFlow id="Par0-CST1" sourceRef="Par0" targetRef="CST1"/>
    <sequenceFlow id="SDT1-PPD1" sourceRef="SDT1" targetRef="PPD1"/>
    <sequenceFlow id="PPD1-PARCLOSE24" sourceRef="PPD1" targetRef="PARCLOSE24"/>
    <sequenceFlow id="CST1-SR1" sourceRef="CST1" targetRef="SR1"/>
    <sequenceFlow id="SR1-PPI1" sourceRef="SR1" targetRef="PPI1"/>
    <sequenceFlow id="PPI1-GT1" sourceRef="PPI1" targetRef="GT1"/>
    <sequenceFlow id="GT1-G0" sourceRef="GT1" targetRef="G0"/>
    <sequenceFlow id="G0-STE1" sourceRef="G0" targetRef="STE1"/>
    <sequenceFlow id="G0-STS1" sourceRef="G0" targetRef="STS1"/>
    <sequenceFlow id="STE1-XORCLOSE10" sourceRef="STE1" targetRef="XORCLOSE10"/>
    <sequenceFlow id="STS1-XORCLOSE10" sourceRef="STS1" targetRef="XORCLOSE10"/>
    <sequenceFlow id="XORCLOSE10-USI1" sourceRef="XORCLOSE10" targetRef="USI1"/>
    <sequenceFlow id="USI1-G1" sourceRef="USI1" targetRef="G1"/>
    <sequenceFlow id="G1-SRM1" sourceRef="G1" targetRef="SRM1"/>
    <sequenceFlow id="G1-SIN1" sourceRef="G1" targetRef="SIN1"/>
    <sequenceFlow id="SRM1-XORCLOSE21" sourceRef="SRM1" targetRef="XORCLOSE21"/>
    <sequenceFlow id="SIN1-XORCLOSE21" sourceRef="SIN1" targetRef="XORCLOSE21"/>
    <sequenceFlow id="XORCLOSE21-CCJ1" sourceRef="XORCLOSE21" targetRef="CCJ1"/>
    <sequenceFlow id="CCJ1-PTF1" sourceRef="CCJ1" targetRef="PTF1"/>
    <sequenceFlow id="PTF1-PARCLOSE24" sourceRef="PTF1" targetRef="PARCLOSE24"/>
    <sequenceFlow id="PARCLOSE24-END" sourceRef="PARCLOSE24" targetRef="END"/>
  </process>
