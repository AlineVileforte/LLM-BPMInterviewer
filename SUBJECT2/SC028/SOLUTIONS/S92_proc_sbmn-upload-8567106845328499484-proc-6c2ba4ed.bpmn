<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_420970ad-7c20-479e-a9af-c773b4e14cc5" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-SDT1</outgoing>
    </startEvent>
    <task id="SDT1" name="Select date and time">
      <incoming>Default_init-SDT1</incoming>
      <outgoing>SDT1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>SDT1-Par1</incoming>
      <outgoing>Par1-CST1</outgoing>
      <outgoing>Par1-PPD1</outgoing>
    </parallelGateway>
    <task id="CST1" name="Customer searches for ticket">
      <incoming>Par1-CST1</incoming>
      <outgoing>CST1-SR1</outgoing>
    </task>
    <task id="PPD1" name="Provide payment details">
      <incoming>Par1-PPD1</incoming>
      <outgoing>PPD1-PARCLOSE10</outgoing>
    </task>
    <task id="SR1" name="Select route">
      <incoming>CST1-SR1</incoming>
      <outgoing>SR1-PPI1</outgoing>
    </task>
    <task id="PPI1" name="Provide personal information">
      <incoming>SR1-PPI1</incoming>
      <outgoing>PPI1-PARCLOSE10</outgoing>
    </task>
    <parallelGateway id="PARCLOSE10" name="PARCLOSE10">
      <incoming>PPD1-PARCLOSE10</incoming>
      <incoming>PPI1-PARCLOSE10</incoming>
      <outgoing>PARCLOSE10-GT1</outgoing>
    </parallelGateway>
    <task id="GT1" name="Generate ticket">
      <incoming>PARCLOSE10-GT1</incoming>
      <outgoing>GT1-USI1</outgoing>
    </task>
    <task id="USI1" name="Update seat inventory">
      <incoming>GT1-USI1</incoming>
      <outgoing>USI1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>USI1-G1</incoming>
      <outgoing>G1-STE1</outgoing>
      <outgoing>G1-STS1</outgoing>
    </exclusiveGateway>
    <task id="STE1" name="Send ticket via email">
      <incoming>G1-STE1</incoming>
      <outgoing>STE1-XORCLOSE16</outgoing>
    </task>
    <task id="STS1" name="Send ticket via SMS">
      <incoming>G1-STS1</incoming>
      <outgoing>STS1-XORCLOSE16</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
      <incoming>STE1-XORCLOSE16</incoming>
      <incoming>STS1-XORCLOSE16</incoming>
      <outgoing>XORCLOSE16-G2</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G2" name="G2">
      <incoming>XORCLOSE16-G2</incoming>
      <outgoing>G2-SRM1</outgoing>
      <outgoing>G2-SIN1</outgoing>
    </exclusiveGateway>
    <task id="SRM1" name="Send reminder">
      <incoming>G2-SRM1</incoming>
      <outgoing>SRM1-XORCLOSE20</outgoing>
    </task>
    <task id="SIN1" name="Send instructions">
      <incoming>G2-SIN1</incoming>
      <outgoing>SIN1-XORCLOSE20</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>SRM1-XORCLOSE20</incoming>
      <incoming>SIN1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-CCJ1</outgoing>
    </exclusiveGateway>
    <task id="CCJ1" name="Customer completes journey">
      <incoming>XORCLOSE20-CCJ1</incoming>
      <outgoing>CCJ1-PTF1</outgoing>
    </task>
    <task id="PTF1" name="Post-travel feedback or services">
      <incoming>CCJ1-PTF1</incoming>
      <outgoing>PTF1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PTF1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-SDT1" sourceRef="Default_init" targetRef="SDT1"/>
    <sequenceFlow id="SDT1-Par1" sourceRef="SDT1" targetRef="Par1"/>
    <sequenceFlow id="Par1-CST1" sourceRef="Par1" targetRef="CST1"/>
    <sequenceFlow id="Par1-PPD1" sourceRef="Par1" targetRef="PPD1"/>
    <sequenceFlow id="CST1-SR1" sourceRef="CST1" targetRef="SR1"/>
    <sequenceFlow id="PPD1-PARCLOSE10" sourceRef="PPD1" targetRef="PARCLOSE10"/>
    <sequenceFlow id="SR1-PPI1" sourceRef="SR1" targetRef="PPI1"/>
    <sequenceFlow id="PPI1-PARCLOSE10" sourceRef="PPI1" targetRef="PARCLOSE10"/>
    <sequenceFlow id="PARCLOSE10-GT1" sourceRef="PARCLOSE10" targetRef="GT1"/>
    <sequenceFlow id="GT1-USI1" sourceRef="GT1" targetRef="USI1"/>
    <sequenceFlow id="USI1-G1" sourceRef="USI1" targetRef="G1"/>
    <sequenceFlow id="G1-STE1" sourceRef="G1" targetRef="STE1"/>
    <sequenceFlow id="G1-STS1" sourceRef="G1" targetRef="STS1"/>
    <sequenceFlow id="STE1-XORCLOSE16" sourceRef="STE1" targetRef="XORCLOSE16"/>
    <sequenceFlow id="STS1-XORCLOSE16" sourceRef="STS1" targetRef="XORCLOSE16"/>
    <sequenceFlow id="XORCLOSE16-G2" sourceRef="XORCLOSE16" targetRef="G2"/>
    <sequenceFlow id="G2-SRM1" sourceRef="G2" targetRef="SRM1"/>
    <sequenceFlow id="G2-SIN1" sourceRef="G2" targetRef="SIN1"/>
    <sequenceFlow id="SRM1-XORCLOSE20" sourceRef="SRM1" targetRef="XORCLOSE20"/>
    <sequenceFlow id="SIN1-XORCLOSE20" sourceRef="SIN1" targetRef="XORCLOSE20"/>
    <sequenceFlow id="XORCLOSE20-CCJ1" sourceRef="XORCLOSE20" targetRef="CCJ1"/>
    <sequenceFlow id="CCJ1-PTF1" sourceRef="CCJ1" targetRef="PTF1"/>
    <sequenceFlow id="PTF1-END" sourceRef="PTF1" targetRef="END"/>
  </process>
