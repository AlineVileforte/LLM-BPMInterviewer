<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_b2d7be24-5851-4ab8-b3c7-589cbb3ef3c0" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-PPD1</outgoing>
    </startEvent>
    <task id="PPD1" name="Provide payment details">
      <incoming>Default_init-PPD1</incoming>
      <outgoing>PPD1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>PPD1-Par2</incoming>
      <outgoing>Par2-CST1</outgoing>
      <outgoing>Par2-SDT1</outgoing>
    </parallelGateway>
    <task id="CST1" name="Customer searches for ticket">
      <incoming>Par2-CST1</incoming>
      <outgoing>CST1-SR1</outgoing>
    </task>
    <task id="SDT1" name="Select date and time">
      <incoming>Par2-SDT1</incoming>
      <outgoing>SDT1-PARCLOSE10</outgoing>
    </task>
    <task id="SR1" name="Select route">
      <incoming>CST1-SR1</incoming>
      <outgoing>SR1-PARCLOSE10</outgoing>
    </task>
    <parallelGateway id="PARCLOSE10" name="PARCLOSE10">
      <incoming>SDT1-PARCLOSE10</incoming>
      <incoming>SR1-PARCLOSE10</incoming>
      <outgoing>PARCLOSE10-PPI1</outgoing>
    </parallelGateway>
    <task id="PPI1" name="Provide personal information">
      <incoming>PARCLOSE10-PPI1</incoming>
      <outgoing>PPI1-GT1</outgoing>
    </task>
    <task id="GT1" name="Generate ticket">
      <incoming>PPI1-GT1</incoming>
      <outgoing>GT1-USI1</outgoing>
    </task>
    <task id="USI1" name="Update seat inventory">
      <incoming>GT1-USI1</incoming>
      <outgoing>USI1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>USI1-G1</incoming>
      <outgoing>G1-STE1</outgoing>
      <outgoing>G1-STS1</outgoing>
    </exclusiveGateway>
    <task id="STE1" name="Send ticket via email">
      <incoming>G1-STE1</incoming>
      <outgoing>STE1-XORCLOSE18</outgoing>
    </task>
    <task id="STS1" name="Send ticket via SMS">
      <incoming>G1-STS1</incoming>
      <outgoing>STS1-XORCLOSE18</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>STE1-XORCLOSE18</incoming>
      <incoming>STS1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-G2</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G2" name="G2">
      <incoming>XORCLOSE18-G2</incoming>
      <outgoing>G2-SRM1</outgoing>
      <outgoing>G2-SIN1</outgoing>
    </exclusiveGateway>
    <task id="SRM1" name="Send reminder">
      <incoming>G2-SRM1</incoming>
      <outgoing>SRM1-XORCLOSE22</outgoing>
    </task>
    <task id="SIN1" name="Send instructions">
      <incoming>G2-SIN1</incoming>
      <outgoing>SIN1-XORCLOSE22</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE22" name="XORCLOSE22">
      <incoming>SRM1-XORCLOSE22</incoming>
      <incoming>SIN1-XORCLOSE22</incoming>
      <outgoing>XORCLOSE22-CCJ1</outgoing>
    </exclusiveGateway>
    <task id="CCJ1" name="Customer completes journey">
      <incoming>XORCLOSE22-CCJ1</incoming>
      <outgoing>CCJ1-PTF1</outgoing>
    </task>
    <task id="PTF1" name="Post-travel feedback or services">
      <incoming>CCJ1-PTF1</incoming>
      <outgoing>PTF1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PTF1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-PPD1" sourceRef="Default_init" targetRef="PPD1"/>
    <sequenceFlow id="PPD1-Par2" sourceRef="PPD1" targetRef="Par2"/>
    <sequenceFlow id="Par2-CST1" sourceRef="Par2" targetRef="CST1"/>
    <sequenceFlow id="Par2-SDT1" sourceRef="Par2" targetRef="SDT1"/>
    <sequenceFlow id="CST1-SR1" sourceRef="CST1" targetRef="SR1"/>
    <sequenceFlow id="SDT1-PARCLOSE10" sourceRef="SDT1" targetRef="PARCLOSE10"/>
    <sequenceFlow id="SR1-PARCLOSE10" sourceRef="SR1" targetRef="PARCLOSE10"/>
    <sequenceFlow id="PARCLOSE10-PPI1" sourceRef="PARCLOSE10" targetRef="PPI1"/>
    <sequenceFlow id="PPI1-GT1" sourceRef="PPI1" targetRef="GT1"/>
    <sequenceFlow id="GT1-USI1" sourceRef="GT1" targetRef="USI1"/>
    <sequenceFlow id="USI1-G1" sourceRef="USI1" targetRef="G1"/>
    <sequenceFlow id="G1-STE1" sourceRef="G1" targetRef="STE1"/>
    <sequenceFlow id="G1-STS1" sourceRef="G1" targetRef="STS1"/>
    <sequenceFlow id="STE1-XORCLOSE18" sourceRef="STE1" targetRef="XORCLOSE18"/>
    <sequenceFlow id="STS1-XORCLOSE18" sourceRef="STS1" targetRef="XORCLOSE18"/>
    <sequenceFlow id="XORCLOSE18-G2" sourceRef="XORCLOSE18" targetRef="G2"/>
    <sequenceFlow id="G2-SRM1" sourceRef="G2" targetRef="SRM1"/>
    <sequenceFlow id="G2-SIN1" sourceRef="G2" targetRef="SIN1"/>
    <sequenceFlow id="SRM1-XORCLOSE22" sourceRef="SRM1" targetRef="XORCLOSE22"/>
    <sequenceFlow id="SIN1-XORCLOSE22" sourceRef="SIN1" targetRef="XORCLOSE22"/>
    <sequenceFlow id="XORCLOSE22-CCJ1" sourceRef="XORCLOSE22" targetRef="CCJ1"/>
    <sequenceFlow id="CCJ1-PTF1" sourceRef="CCJ1" targetRef="PTF1"/>
    <sequenceFlow id="PTF1-END" sourceRef="PTF1" targetRef="END"/>
  </process>
