<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_93d1b8fb-c6f9-4461-b7aa-4c5765466e9a" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-SDT1</outgoing>
    </startEvent>
    <task id="SDT1" name="Select date and time">
      <incoming>Default_init-SDT1</incoming>
      <outgoing>SDT1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>SDT1-Par1</incoming>
      <outgoing>Par1-CST1</outgoing>
      <outgoing>Par1-PPD1</outgoing>
    </parallelGateway>
    <task id="CST1" name="Customer searches for ticket">
      <incoming>Par1-CST1</incoming>
      <outgoing>CST1-PARCLOSE6</outgoing>
    </task>
    <task id="PPD1" name="Provide payment details">
      <incoming>Par1-PPD1</incoming>
      <outgoing>PPD1-PARCLOSE6</outgoing>
    </task>
    <parallelGateway id="PARCLOSE6" name="PARCLOSE6">
      <incoming>CST1-PARCLOSE6</incoming>
      <incoming>PPD1-PARCLOSE6</incoming>
      <outgoing>PARCLOSE6-SR1</outgoing>
    </parallelGateway>
    <task id="SR1" name="Select route">
      <incoming>PARCLOSE6-SR1</incoming>
      <outgoing>SR1-PPI1</outgoing>
    </task>
    <task id="PPI1" name="Provide personal information">
      <incoming>SR1-PPI1</incoming>
      <outgoing>PPI1-GT1</outgoing>
    </task>
    <task id="GT1" name="Generate ticket">
      <incoming>PPI1-GT1</incoming>
      <outgoing>GT1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>GT1-G0</incoming>
      <outgoing>G0-STE1</outgoing>
      <outgoing>G0-STS1</outgoing>
    </exclusiveGateway>
    <task id="STE1" name="Send ticket via email">
      <incoming>G0-STE1</incoming>
      <outgoing>STE1-XORCLOSE13</outgoing>
    </task>
    <task id="STS1" name="Send ticket via SMS">
      <incoming>G0-STS1</incoming>
      <outgoing>STS1-XORCLOSE13</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE13" name="XORCLOSE13">
      <incoming>STE1-XORCLOSE13</incoming>
      <incoming>STS1-XORCLOSE13</incoming>
      <outgoing>XORCLOSE13-USI1</outgoing>
    </exclusiveGateway>
    <task id="USI1" name="Update seat inventory">
      <incoming>XORCLOSE13-USI1</incoming>
      <outgoing>USI1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>USI1-G1</incoming>
      <outgoing>G1-SRM1</outgoing>
      <outgoing>G1-SIN1</outgoing>
    </exclusiveGateway>
    <task id="SRM1" name="Send reminder">
      <incoming>G1-SRM1</incoming>
      <outgoing>SRM1-XORCLOSE18</outgoing>
    </task>
    <task id="SIN1" name="Send instructions">
      <incoming>G1-SIN1</incoming>
      <outgoing>SIN1-XORCLOSE18</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>SRM1-XORCLOSE18</incoming>
      <incoming>SIN1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-CCJ1</outgoing>
    </exclusiveGateway>
    <task id="CCJ1" name="Customer completes journey">
      <incoming>XORCLOSE18-CCJ1</incoming>
      <outgoing>CCJ1-PTF1</outgoing>
    </task>
    <task id="PTF1" name="Post-travel feedback or services">
      <incoming>CCJ1-PTF1</incoming>
      <outgoing>PTF1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PTF1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-SDT1" sourceRef="Default_init" targetRef="SDT1"/>
    <sequenceFlow id="SDT1-Par1" sourceRef="SDT1" targetRef="Par1"/>
    <sequenceFlow id="Par1-CST1" sourceRef="Par1" targetRef="CST1"/>
    <sequenceFlow id="Par1-PPD1" sourceRef="Par1" targetRef="PPD1"/>
    <sequenceFlow id="CST1-PARCLOSE6" sourceRef="CST1" targetRef="PARCLOSE6"/>
    <sequenceFlow id="PPD1-PARCLOSE6" sourceRef="PPD1" targetRef="PARCLOSE6"/>
    <sequenceFlow id="PARCLOSE6-SR1" sourceRef="PARCLOSE6" targetRef="SR1"/>
    <sequenceFlow id="SR1-PPI1" sourceRef="SR1" targetRef="PPI1"/>
    <sequenceFlow id="PPI1-GT1" sourceRef="PPI1" targetRef="GT1"/>
    <sequenceFlow id="GT1-G0" sourceRef="GT1" targetRef="G0"/>
    <sequenceFlow id="G0-STE1" sourceRef="G0" targetRef="STE1"/>
    <sequenceFlow id="G0-STS1" sourceRef="G0" targetRef="STS1"/>
    <sequenceFlow id="STE1-XORCLOSE13" sourceRef="STE1" targetRef="XORCLOSE13"/>
    <sequenceFlow id="STS1-XORCLOSE13" sourceRef="STS1" targetRef="XORCLOSE13"/>
    <sequenceFlow id="XORCLOSE13-USI1" sourceRef="XORCLOSE13" targetRef="USI1"/>
    <sequenceFlow id="USI1-G1" sourceRef="USI1" targetRef="G1"/>
    <sequenceFlow id="G1-SRM1" sourceRef="G1" targetRef="SRM1"/>
    <sequenceFlow id="G1-SIN1" sourceRef="G1" targetRef="SIN1"/>
    <sequenceFlow id="SRM1-XORCLOSE18" sourceRef="SRM1" targetRef="XORCLOSE18"/>
    <sequenceFlow id="SIN1-XORCLOSE18" sourceRef="SIN1" targetRef="XORCLOSE18"/>
    <sequenceFlow id="XORCLOSE18-CCJ1" sourceRef="XORCLOSE18" targetRef="CCJ1"/>
    <sequenceFlow id="CCJ1-PTF1" sourceRef="CCJ1" targetRef="PTF1"/>
    <sequenceFlow id="PTF1-END" sourceRef="PTF1" targetRef="END"/>
  </process>
