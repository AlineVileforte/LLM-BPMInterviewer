<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_7e067f63-5428-403f-a38a-696df3e3cfff" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-SDT1</outgoing>
      <outgoing>Par0-CST1</outgoing>
    </parallelGateway>
    <task id="SDT1" name="Select date and time">
      <incoming>Par0-SDT1</incoming>
      <outgoing>SDT1-PPD1</outgoing>
    </task>
    <task id="PPD1" name="Provide payment details">
      <incoming>SDT1-PPD1</incoming>
      <outgoing>PPD1-PARCLOSE8</outgoing>
    </task>
    <task id="CST1" name="Customer searches for ticket">
      <incoming>Par0-CST1</incoming>
      <outgoing>CST1-SR1</outgoing>
    </task>
    <task id="SR1" name="Select route">
      <incoming>CST1-SR1</incoming>
      <outgoing>SR1-PPI1</outgoing>
    </task>
    <task id="PPI1" name="Provide personal information">
      <incoming>SR1-PPI1</incoming>
      <outgoing>PPI1-GT1</outgoing>
    </task>
    <task id="GT1" name="Generate ticket">
      <incoming>PPI1-GT1</incoming>
      <outgoing>GT1-USI1</outgoing>
    </task>
    <task id="USI1" name="Update seat inventory">
      <incoming>GT1-USI1</incoming>
      <outgoing>USI1-PARCLOSE8</outgoing>
    </task>
    <parallelGateway id="PARCLOSE8" name="PARCLOSE8">
      <incoming>PPD1-PARCLOSE8</incoming>
      <incoming>USI1-PARCLOSE8</incoming>
      <outgoing>PARCLOSE8-G2</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G2" name="G2">
      <incoming>PARCLOSE8-G2</incoming>
      <outgoing>G2-STE1</outgoing>
      <outgoing>G2-STS1</outgoing>
    </exclusiveGateway>
    <task id="STE1" name="Send ticket via email">
      <incoming>G2-STE1</incoming>
      <outgoing>STE1-XORCLOSE12</outgoing>
    </task>
    <task id="STS1" name="Send ticket via SMS">
      <incoming>G2-STS1</incoming>
      <outgoing>STS1-XORCLOSE12</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE12" name="XORCLOSE12">
      <incoming>STE1-XORCLOSE12</incoming>
      <incoming>STS1-XORCLOSE12</incoming>
      <outgoing>XORCLOSE12-G3</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G3" name="G3">
      <incoming>XORCLOSE12-G3</incoming>
      <outgoing>G3-SRM1</outgoing>
      <outgoing>G3-SIN1</outgoing>
    </exclusiveGateway>
    <task id="SRM1" name="Send reminder">
      <incoming>G3-SRM1</incoming>
      <outgoing>SRM1-XORCLOSE20</outgoing>
    </task>
    <task id="SIN1" name="Send instructions">
      <incoming>G3-SIN1</incoming>
      <outgoing>SIN1-XORCLOSE20</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>SRM1-XORCLOSE20</incoming>
      <incoming>SIN1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-CCJ1</outgoing>
    </exclusiveGateway>
    <task id="CCJ1" name="Customer completes journey">
      <incoming>XORCLOSE20-CCJ1</incoming>
      <outgoing>CCJ1-PTF1</outgoing>
    </task>
    <task id="PTF1" name="Post-travel feedback or services">
      <incoming>CCJ1-PTF1</incoming>
      <outgoing>PTF1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PTF1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
    <sequenceFlow id="Par0-SDT1" sourceRef="Par0" targetRef="SDT1"/>
    <sequenceFlow id="Par0-CST1" sourceRef="Par0" targetRef="CST1"/>
    <sequenceFlow id="SDT1-PPD1" sourceRef="SDT1" targetRef="PPD1"/>
    <sequenceFlow id="PPD1-PARCLOSE8" sourceRef="PPD1" targetRef="PARCLOSE8"/>
    <sequenceFlow id="CST1-SR1" sourceRef="CST1" targetRef="SR1"/>
    <sequenceFlow id="SR1-PPI1" sourceRef="SR1" targetRef="PPI1"/>
    <sequenceFlow id="PPI1-GT1" sourceRef="PPI1" targetRef="GT1"/>
    <sequenceFlow id="GT1-USI1" sourceRef="GT1" targetRef="USI1"/>
    <sequenceFlow id="USI1-PARCLOSE8" sourceRef="USI1" targetRef="PARCLOSE8"/>
    <sequenceFlow id="PARCLOSE8-G2" sourceRef="PARCLOSE8" targetRef="G2"/>
    <sequenceFlow id="G2-STE1" sourceRef="G2" targetRef="STE1"/>
    <sequenceFlow id="G2-STS1" sourceRef="G2" targetRef="STS1"/>
    <sequenceFlow id="STE1-XORCLOSE12" sourceRef="STE1" targetRef="XORCLOSE12"/>
    <sequenceFlow id="STS1-XORCLOSE12" sourceRef="STS1" targetRef="XORCLOSE12"/>
    <sequenceFlow id="XORCLOSE12-G3" sourceRef="XORCLOSE12" targetRef="G3"/>
    <sequenceFlow id="G3-SRM1" sourceRef="G3" targetRef="SRM1"/>
    <sequenceFlow id="G3-SIN1" sourceRef="G3" targetRef="SIN1"/>
    <sequenceFlow id="SRM1-XORCLOSE20" sourceRef="SRM1" targetRef="XORCLOSE20"/>
    <sequenceFlow id="SIN1-XORCLOSE20" sourceRef="SIN1" targetRef="XORCLOSE20"/>
    <sequenceFlow id="XORCLOSE20-CCJ1" sourceRef="XORCLOSE20" targetRef="CCJ1"/>
    <sequenceFlow id="CCJ1-PTF1" sourceRef="CCJ1" targetRef="PTF1"/>
    <sequenceFlow id="PTF1-END" sourceRef="PTF1" targetRef="END"/>
  </process>
