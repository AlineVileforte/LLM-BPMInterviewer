<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_b8918688-122c-485d-8eb2-36adcd4f8aa6" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-CST1</outgoing>
      <outgoing>Par0-Par3</outgoing>
    </parallelGateway>
    <task id="CST1" name="Customer searches for ticket">
      <incoming>Par0-CST1</incoming>
      <outgoing>CST1-PPD1</outgoing>
    </task>
    <task id="PPD1" name="Provide payment details">
      <incoming>CST1-PPD1</incoming>
      <outgoing>PPD1-PARCLOSE9</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>Par0-Par3</incoming>
      <outgoing>Par3-SR1</outgoing>
      <outgoing>Par3-SDT1</outgoing>
    </parallelGateway>
    <task id="SR1" name="Select route">
      <incoming>Par3-SR1</incoming>
      <outgoing>SR1-PARCLOSE8</outgoing>
    </task>
    <task id="SDT1" name="Select date and time">
      <incoming>Par3-SDT1</incoming>
      <outgoing>SDT1-PARCLOSE8</outgoing>
    </task>
    <parallelGateway id="PARCLOSE8" name="PARCLOSE8">
      <incoming>SR1-PARCLOSE8</incoming>
      <incoming>SDT1-PARCLOSE8</incoming>
      <outgoing>PARCLOSE8-PARCLOSE9</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE9" name="PARCLOSE9">
      <incoming>PPD1-PARCLOSE9</incoming>
      <incoming>PARCLOSE8-PARCLOSE9</incoming>
      <outgoing>PARCLOSE9-PPI1</outgoing>
    </parallelGateway>
    <task id="PPI1" name="Provide personal information">
      <incoming>PARCLOSE9-PPI1</incoming>
      <outgoing>PPI1-GT1</outgoing>
    </task>
    <task id="GT1" name="Generate ticket">
      <incoming>PPI1-GT1</incoming>
      <outgoing>GT1-USI1</outgoing>
    </task>
    <task id="USI1" name="Update seat inventory">
      <incoming>GT1-USI1</incoming>
      <outgoing>USI1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>USI1-G1</incoming>
      <outgoing>G1-STE1</outgoing>
      <outgoing>G1-STS1</outgoing>
    </exclusiveGateway>
    <task id="STE1" name="Send ticket via email">
      <incoming>G1-STE1</incoming>
      <outgoing>STE1-XORCLOSE16</outgoing>
    </task>
    <task id="STS1" name="Send ticket via SMS">
      <incoming>G1-STS1</incoming>
      <outgoing>STS1-XORCLOSE16</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
      <incoming>STE1-XORCLOSE16</incoming>
      <incoming>STS1-XORCLOSE16</incoming>
      <outgoing>XORCLOSE16-G2</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G2" name="G2">
      <incoming>XORCLOSE16-G2</incoming>
      <outgoing>G2-SRM1</outgoing>
      <outgoing>G2-SIN1</outgoing>
    </exclusiveGateway>
    <task id="SRM1" name="Send reminder">
      <incoming>G2-SRM1</incoming>
      <outgoing>SRM1-XORCLOSE20</outgoing>
    </task>
    <task id="SIN1" name="Send instructions">
      <incoming>G2-SIN1</incoming>
      <outgoing>SIN1-XORCLOSE20</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>SRM1-XORCLOSE20</incoming>
      <incoming>SIN1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-CCJ1</outgoing>
    </exclusiveGateway>
    <task id="CCJ1" name="Customer completes journey">
      <incoming>XORCLOSE20-CCJ1</incoming>
      <outgoing>CCJ1-PTF1</outgoing>
    </task>
    <task id="PTF1" name="Post-travel feedback or services">
      <incoming>CCJ1-PTF1</incoming>
      <outgoing>PTF1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PTF1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
    <sequenceFlow id="Par0-CST1" sourceRef="Par0" targetRef="CST1"/>
    <sequenceFlow id="Par0-Par3" sourceRef="Par0" targetRef="Par3"/>
