<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_2d79857f-c544-40a7-9360-c130b1ec5369" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-PPD1</outgoing>
      <outgoing>Par0-CST1</outgoing>
    </parallelGateway>
    <task id="PPD1" name="Provide payment details">
      <incoming>Par0-PPD1</incoming>
      <outgoing>PPD1-SDT1</outgoing>
    </task>
    <task id="SDT1" name="Select date and time">
      <incoming>PPD1-SDT1</incoming>
      <outgoing>SDT1-PARCLOSE4</outgoing>
    </task>
    <task id="CST1" name="Customer searches for ticket">
      <incoming>Par0-CST1</incoming>
      <outgoing>CST1-PARCLOSE4</outgoing>
    </task>
    <parallelGateway id="PARCLOSE4" name="PARCLOSE4">
      <incoming>SDT1-PARCLOSE4</incoming>
      <incoming>CST1-PARCLOSE4</incoming>
      <outgoing>PARCLOSE4-SR1</outgoing>
    </parallelGateway>
    <task id="SR1" name="Select route">
      <incoming>PARCLOSE4-SR1</incoming>
      <outgoing>SR1-PPI1</outgoing>
    </task>
    <task id="PPI1" name="Provide personal information">
      <incoming>SR1-PPI1</incoming>
      <outgoing>PPI1-GT1</outgoing>
    </task>
    <task id="GT1" name="Generate ticket">
      <incoming>PPI1-GT1</incoming>
      <outgoing>GT1-Par8</outgoing>
    </task>
    <parallelGateway id="Par8" name="PAR">
      <incoming>GT1-Par8</incoming>
      <outgoing>Par8-USI1</outgoing>
      <outgoing>Par8-G0</outgoing>
    </parallelGateway>
    <task id="USI1" name="Update seat inventory">
      <incoming>Par8-USI1</incoming>
      <outgoing>USI1-PARCLOSE14</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par8-G0</incoming>
      <outgoing>G0-STE1</outgoing>
      <outgoing>G0-STS1</outgoing>
    </exclusiveGateway>
    <task id="STE1" name="Send ticket via email">
      <incoming>G0-STE1</incoming>
      <outgoing>STE1-XORCLOSE13</outgoing>
    </task>
    <task id="STS1" name="Send ticket via SMS">
      <incoming>G0-STS1</incoming>
      <outgoing>STS1-XORCLOSE13</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE13" name="XORCLOSE13">
      <incoming>STE1-XORCLOSE13</incoming>
      <incoming>STS1-XORCLOSE13</incoming>
      <outgoing>XORCLOSE13-PARCLOSE14</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE14" name="PARCLOSE14">
      <incoming>USI1-PARCLOSE14</incoming>
      <incoming>XORCLOSE13-PARCLOSE14</incoming>
      <outgoing>PARCLOSE14-G1</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G1" name="G1">
      <incoming>PARCLOSE14-G1</incoming>
      <outgoing>G1-SRM1</outgoing>
      <outgoing>G1-SIN1</outgoing>
    </exclusiveGateway>
    <task id="SRM1" name="Send reminder">
      <incoming>G1-SRM1</incoming>
      <outgoing>SRM1-XORCLOSE24</outgoing>
    </task>
    <task id="SIN1" name="Send instructions">
      <incoming>G1-SIN1</incoming>
      <outgoing>SIN1-XORCLOSE24</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE24" name="XORCLOSE24">
      <incoming>SRM1-XORCLOSE24</incoming>
      <incoming>SIN1-XORCLOSE24</incoming>
      <outgoing>XORCLOSE24-CCJ1</outgoing>
    </exclusiveGateway>
    <task id="CCJ1" name="Customer completes journey">
      <incoming>XORCLOSE24-CCJ1</incoming>
      <outgoing>CCJ1-PTF1</outgoing>
    </task>
    <task id="PTF1" name="Post-travel feedback or services">
      <incoming>CCJ1-PTF1</incoming>
      <outgoing>PTF1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PTF1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
    <sequenceFlow id="Par0-PPD1" sourceRef="Par0" targetRef="PPD1"/>
    <sequenceFlow id="Par0-CST1" sourceRef="Par0" targetRef="CST1"/>
