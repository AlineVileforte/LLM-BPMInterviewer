<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_3988a50d-7f7f-4024-934f-fa929dff1d49" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-SDT1</outgoing>
    </startEvent>
    <task id="SDT1" name="Select date and time">
      <incoming>Default_init-SDT1</incoming>
      <outgoing>SDT1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>SDT1-Par2</incoming>
      <outgoing>Par2-CST1</outgoing>
      <outgoing>Par2-PPD1</outgoing>
    </parallelGateway>
    <task id="CST1" name="Customer searches for ticket">
      <incoming>Par2-CST1</incoming>
      <outgoing>CST1-SR1</outgoing>
    </task>
    <task id="PPD1" name="Provide payment details">
      <incoming>Par2-PPD1</incoming>
      <outgoing>PPD1-PARCLOSE10</outgoing>
    </task>
    <task id="SR1" name="Select route">
      <incoming>CST1-SR1</incoming>
      <outgoing>SR1-PARCLOSE10</outgoing>
    </task>
    <parallelGateway id="PARCLOSE10" name="PARCLOSE10">
      <incoming>PPD1-PARCLOSE10</incoming>
      <incoming>SR1-PARCLOSE10</incoming>
      <outgoing>PARCLOSE10-PPI1</outgoing>
    </parallelGateway>
    <task id="PPI1" name="Provide personal information">
      <incoming>PARCLOSE10-PPI1</incoming>
      <outgoing>PPI1-GT1</outgoing>
    </task>
    <task id="GT1" name="Generate ticket">
      <incoming>PPI1-GT1</incoming>
      <outgoing>GT1-Par13</outgoing>
    </task>
    <parallelGateway id="Par13" name="PAR">
      <incoming>GT1-Par13</incoming>
      <outgoing>Par13-USI1</outgoing>
      <outgoing>Par13-G0</outgoing>
    </parallelGateway>
    <task id="USI1" name="Update seat inventory">
      <incoming>Par13-USI1</incoming>
      <outgoing>USI1-PARCLOSE19</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par13-G0</incoming>
      <outgoing>G0-STE1</outgoing>
      <outgoing>G0-STS1</outgoing>
    </exclusiveGateway>
    <task id="STE1" name="Send ticket via email">
      <incoming>G0-STE1</incoming>
      <outgoing>STE1-XORCLOSE18</outgoing>
    </task>
    <task id="STS1" name="Send ticket via SMS">
      <incoming>G0-STS1</incoming>
      <outgoing>STS1-XORCLOSE18</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>STE1-XORCLOSE18</incoming>
      <incoming>STS1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-PARCLOSE19</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>USI1-PARCLOSE19</incoming>
      <incoming>XORCLOSE18-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-G2</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G2" name="G2">
      <incoming>PARCLOSE19-G2</incoming>
      <outgoing>G2-SRM1</outgoing>
      <outgoing>G2-SIN1</outgoing>
    </exclusiveGateway>
    <task id="SRM1" name="Send reminder">
      <incoming>G2-SRM1</incoming>
      <outgoing>SRM1-XORCLOSE24</outgoing>
    </task>
    <task id="SIN1" name="Send instructions">
      <incoming>G2-SIN1</incoming>
      <outgoing>SIN1-XORCLOSE24</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE24" name="XORCLOSE24">
      <incoming>SRM1-XORCLOSE24</incoming>
      <incoming>SIN1-XORCLOSE24</incoming>
      <outgoing>XORCLOSE24-CCJ1</outgoing>
    </exclusiveGateway>
    <task id="CCJ1" name="Customer completes journey">
      <incoming>XORCLOSE24-CCJ1</incoming>
      <outgoing>CCJ1-PTF1</outgoing>
    </task>
    <task id="PTF1" name="Post-travel feedback or services">
      <incoming>CCJ1-PTF1</incoming>
      <outgoing>PTF1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PTF1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-SDT1" sourceRef="Default_init" targetRef="SDT1"/>
    <sequenceFlow id="SDT1-Par2" sourceRef="SDT1" targetRef="Par2"/>
    <sequenceFlow id="Par2-CST1" sourceRef="Par2" targetRef="CST1"/>
    <sequenceFlow id="Par2-PPD1" sourceRef="Par2" targetRef="PPD1"/>
