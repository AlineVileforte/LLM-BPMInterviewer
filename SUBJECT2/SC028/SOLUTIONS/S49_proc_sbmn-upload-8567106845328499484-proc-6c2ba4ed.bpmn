<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_b6fbd87f-a6c0-4e41-a76b-1f763e4b8587" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-CST1</outgoing>
      <outgoing>Par0-SR1</outgoing>
    </parallelGateway>
    <task id="CST1" name="Customer searches for ticket">
      <incoming>Par0-CST1</incoming>
      <outgoing>CST1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>CST1-Par2</incoming>
      <outgoing>Par2-SDT1</outgoing>
      <outgoing>Par2-PPD1</outgoing>
    </parallelGateway>
    <task id="SDT1" name="Select date and time">
      <incoming>Par2-SDT1</incoming>
      <outgoing>SDT1-PARCLOSE9</outgoing>
    </task>
    <task id="PPD1" name="Provide payment details">
      <incoming>Par2-PPD1</incoming>
      <outgoing>PPD1-PARCLOSE9</outgoing>
    </task>
    <task id="SR1" name="Select route">
      <incoming>Par0-SR1</incoming>
      <outgoing>SR1-PPI1</outgoing>
    </task>
    <task id="PPI1" name="Provide personal information">
      <incoming>SR1-PPI1</incoming>
      <outgoing>PPI1-GT1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE9" name="PARCLOSE9">
      <incoming>SDT1-PARCLOSE9</incoming>
      <incoming>PPD1-PARCLOSE9</incoming>
      <outgoing>PARCLOSE9-PARCLOSE15</outgoing>
    </parallelGateway>
    <task id="GT1" name="Generate ticket">
      <incoming>PPI1-GT1</incoming>
      <outgoing>GT1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>GT1-G0</incoming>
      <outgoing>G0-STE1</outgoing>
      <outgoing>G0-STS1</outgoing>
    </exclusiveGateway>
    <task id="STE1" name="Send ticket via email">
      <incoming>G0-STE1</incoming>
      <outgoing>STE1-XORCLOSE14</outgoing>
    </task>
    <task id="STS1" name="Send ticket via SMS">
      <incoming>G0-STS1</incoming>
      <outgoing>STS1-XORCLOSE14</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>STE1-XORCLOSE14</incoming>
      <incoming>STS1-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-PARCLOSE15</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE15" name="PARCLOSE15">
      <incoming>PARCLOSE9-PARCLOSE15</incoming>
      <incoming>XORCLOSE14-PARCLOSE15</incoming>
      <outgoing>PARCLOSE15-USI1</outgoing>
    </parallelGateway>
    <task id="USI1" name="Update seat inventory">
      <incoming>PARCLOSE15-USI1</incoming>
      <outgoing>USI1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>USI1-G1</incoming>
      <outgoing>G1-SRM1</outgoing>
      <outgoing>G1-SIN1</outgoing>
    </exclusiveGateway>
    <task id="SRM1" name="Send reminder">
      <incoming>G1-SRM1</incoming>
      <outgoing>SRM1-XORCLOSE20</outgoing>
    </task>
    <task id="SIN1" name="Send instructions">
      <incoming>G1-SIN1</incoming>
      <outgoing>SIN1-XORCLOSE20</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>SRM1-XORCLOSE20</incoming>
      <incoming>SIN1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-CCJ1</outgoing>
    </exclusiveGateway>
    <task id="CCJ1" name="Customer completes journey">
      <incoming>XORCLOSE20-CCJ1</incoming>
      <outgoing>CCJ1-PTF1</outgoing>
    </task>
    <task id="PTF1" name="Post-travel feedback or services">
      <incoming>CCJ1-PTF1</incoming>
      <outgoing>PTF1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PTF1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
    <sequenceFlow id="Par0-CST1" sourceRef="Par0" targetRef="CST1"/>
    <sequenceFlow id="Par0-SR1" sourceRef="Par0" targetRef="SR1"/>
    <sequenceFlow id="CST1-Par2" sourceRef="CST1" targetRef="Par2"/>
