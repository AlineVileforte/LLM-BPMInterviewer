    <sequenceFlow id="G0-STS1" sourceRef="G0" targetRef="STS1"/>
    <sequenceFlow id="STE1-XORCLOSE18" sourceRef="STE1" targetRef="XORCLOSE18"/>
    <sequenceFlow id="STS1-XORCLOSE18" sourceRef="STS1" targetRef="XORCLOSE18"/>
    <sequenceFlow id="XORCLOSE18-PARCLOSE19" sourceRef="XORCLOSE18" targetRef="PARCLOSE19"/>
    <sequenceFlow id="PARCLOSE19-USI1" sourceRef="PARCLOSE19" targetRef="USI1"/>
    <sequenceFlow id="USI1-G1" sourceRef="USI1" targetRef="G1"/>
    <sequenceFlow id="G1-SRM1" sourceRef="G1" targetRef="SRM1"/>
    <sequenceFlow id="G1-SIN1" sourceRef="G1" targetRef="SIN1"/>
    <sequenceFlow id="SRM1-XORCLOSE24" sourceRef="SRM1" targetRef="XORCLOSE24"/>
    <sequenceFlow id="SIN1-XORCLOSE24" sourceRef="SIN1" targetRef="XORCLOSE24"/>
    <sequenceFlow id="XORCLOSE24-CCJ1" sourceRef="XORCLOSE24" targetRef="CCJ1"/>
    <sequenceFlow id="CCJ1-PTF1" sourceRef="CCJ1" targetRef="PTF1"/>
    <sequenceFlow id="PTF1-END" sourceRef="PTF1" targetRef="END"/>
  </process>
