<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_c9fd0b45-fde7-47e3-85e7-e3c7c78705d9" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-CST1</outgoing>
      <outgoing>Par0-Par4</outgoing>
    </parallelGateway>
    <task id="CST1" name="Customer searches for ticket">
      <incoming>Par0-CST1</incoming>
      <outgoing>CST1-SDT1</outgoing>
    </task>
    <task id="SDT1" name="Select date and time">
      <incoming>CST1-SDT1</incoming>
      <outgoing>SDT1-PARCLOSE19</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>Par0-Par4</incoming>
      <outgoing>Par4-SR1</outgoing>
      <outgoing>Par4-PPD1</outgoing>
    </parallelGateway>
    <task id="SR1" name="Select route">
      <incoming>Par4-SR1</incoming>
      <outgoing>SR1-PPI1</outgoing>
    </task>
    <task id="PPD1" name="Provide payment details">
      <incoming>Par4-PPD1</incoming>
      <outgoing>PPD1-PARCLOSE13</outgoing>
    </task>
    <task id="PPI1" name="Provide personal information">
      <incoming>SR1-PPI1</incoming>
      <outgoing>PPI1-PARCLOSE13</outgoing>
    </task>
    <parallelGateway id="PARCLOSE13" name="PARCLOSE13">
      <incoming>PPD1-PARCLOSE13</incoming>
      <incoming>PPI1-PARCLOSE13</incoming>
      <outgoing>PARCLOSE13-GT1</outgoing>
    </parallelGateway>
    <task id="GT1" name="Generate ticket">
      <incoming>PARCLOSE13-GT1</incoming>
      <outgoing>GT1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>GT1-G0</incoming>
      <outgoing>G0-STE1</outgoing>
      <outgoing>G0-STS1</outgoing>
    </exclusiveGateway>
    <task id="STE1" name="Send ticket via email">
      <incoming>G0-STE1</incoming>
      <outgoing>STE1-XORCLOSE18</outgoing>
    </task>
    <task id="STS1" name="Send ticket via SMS">
      <incoming>G0-STS1</incoming>
      <outgoing>STS1-XORCLOSE18</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>STE1-XORCLOSE18</incoming>
      <incoming>STS1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-PARCLOSE19</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>SDT1-PARCLOSE19</incoming>
      <incoming>XORCLOSE18-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-USI1</outgoing>
    </parallelGateway>
    <task id="USI1" name="Update seat inventory">
      <incoming>PARCLOSE19-USI1</incoming>
      <outgoing>USI1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>USI1-G1</incoming>
      <outgoing>G1-SRM1</outgoing>
      <outgoing>G1-SIN1</outgoing>
    </exclusiveGateway>
    <task id="SRM1" name="Send reminder">
      <incoming>G1-SRM1</incoming>
      <outgoing>SRM1-XORCLOSE24</outgoing>
    </task>
    <task id="SIN1" name="Send instructions">
      <incoming>G1-SIN1</incoming>
      <outgoing>SIN1-XORCLOSE24</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE24" name="XORCLOSE24">
      <incoming>SRM1-XORCLOSE24</incoming>
      <incoming>SIN1-XORCLOSE24</incoming>
      <outgoing>XORCLOSE24-CCJ1</outgoing>
    </exclusiveGateway>
    <task id="CCJ1" name="Customer completes journey">
      <incoming>XORCLOSE24-CCJ1</incoming>
      <outgoing>CCJ1-PTF1</outgoing>
    </task>
    <task id="PTF1" name="Post-travel feedback or services">
      <incoming>CCJ1-PTF1</incoming>
      <outgoing>PTF1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PTF1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
    <sequenceFlow id="Par0-CST1" sourceRef="Par0" targetRef="CST1"/>
    <sequenceFlow id="Par0-Par4" sourceRef="Par0" targetRef="Par4"/>
