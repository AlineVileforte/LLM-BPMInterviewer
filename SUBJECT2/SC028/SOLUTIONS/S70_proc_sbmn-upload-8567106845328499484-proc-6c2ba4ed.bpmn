<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_8a977b0e-3db3-4fcb-bb81-fd28682117a1" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-SDT1</outgoing>
    </startEvent>
    <task id="SDT1" name="Select date and time">
      <incoming>Default_init-SDT1</incoming>
      <outgoing>SDT1-CST1</outgoing>
    </task>
    <task id="CST1" name="Customer searches for ticket">
      <incoming>SDT1-CST1</incoming>
      <outgoing>CST1-SR1</outgoing>
    </task>
    <task id="SR1" name="Select route">
      <incoming>CST1-SR1</incoming>
      <outgoing>SR1-PPI1</outgoing>
    </task>
    <task id="PPI1" name="Provide personal information">
      <incoming>SR1-PPI1</incoming>
      <outgoing>PPI1-PPD1</outgoing>
    </task>
    <task id="PPD1" name="Provide payment details">
      <incoming>PPI1-PPD1</incoming>
      <outgoing>PPD1-GT1</outgoing>
    </task>
    <task id="GT1" name="Generate ticket">
      <incoming>PPD1-GT1</incoming>
      <outgoing>GT1-Par6</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>GT1-Par6</incoming>
      <outgoing>Par6-USI1</outgoing>
      <outgoing>Par6-G0</outgoing>
    </parallelGateway>
    <task id="USI1" name="Update seat inventory">
      <incoming>Par6-USI1</incoming>
      <outgoing>USI1-PARCLOSE12</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par6-G0</incoming>
      <outgoing>G0-STE1</outgoing>
      <outgoing>G0-STS1</outgoing>
    </exclusiveGateway>
    <task id="STE1" name="Send ticket via email">
      <incoming>G0-STE1</incoming>
      <outgoing>STE1-XORCLOSE11</outgoing>
    </task>
    <task id="STS1" name="Send ticket via SMS">
      <incoming>G0-STS1</incoming>
      <outgoing>STS1-XORCLOSE11</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE11" name="XORCLOSE11">
      <incoming>STE1-XORCLOSE11</incoming>
      <incoming>STS1-XORCLOSE11</incoming>
      <outgoing>XORCLOSE11-PARCLOSE12</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE12" name="PARCLOSE12">
      <incoming>USI1-PARCLOSE12</incoming>
      <incoming>XORCLOSE11-PARCLOSE12</incoming>
      <outgoing>PARCLOSE12-G1</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G1" name="G1">
      <incoming>PARCLOSE12-G1</incoming>
      <outgoing>G1-SRM1</outgoing>
      <outgoing>G1-SIN1</outgoing>
    </exclusiveGateway>
    <task id="SRM1" name="Send reminder">
      <incoming>G1-SRM1</incoming>
      <outgoing>SRM1-XORCLOSE20</outgoing>
    </task>
    <task id="SIN1" name="Send instructions">
      <incoming>G1-SIN1</incoming>
      <outgoing>SIN1-XORCLOSE20</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>SRM1-XORCLOSE20</incoming>
      <incoming>SIN1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-CCJ1</outgoing>
    </exclusiveGateway>
    <task id="CCJ1" name="Customer completes journey">
      <incoming>XORCLOSE20-CCJ1</incoming>
      <outgoing>CCJ1-PTF1</outgoing>
    </task>
    <task id="PTF1" name="Post-travel feedback or services">
      <incoming>CCJ1-PTF1</incoming>
      <outgoing>PTF1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PTF1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-SDT1" sourceRef="Default_init" targetRef="SDT1"/>
    <sequenceFlow id="SDT1-CST1" sourceRef="SDT1" targetRef="CST1"/>
    <sequenceFlow id="CST1-SR1" sourceRef="CST1" targetRef="SR1"/>
    <sequenceFlow id="SR1-PPI1" sourceRef="SR1" targetRef="PPI1"/>
    <sequenceFlow id="PPI1-PPD1" sourceRef="PPI1" targetRef="PPD1"/>
    <sequenceFlow id="PPD1-GT1" sourceRef="PPD1" targetRef="GT1"/>
    <sequenceFlow id="GT1-Par6" sourceRef="GT1" targetRef="Par6"/>
    <sequenceFlow id="Par6-USI1" sourceRef="Par6" targetRef="USI1"/>
    <sequenceFlow id="Par6-G0" sourceRef="Par6" targetRef="G0"/>
    <sequenceFlow id="USI1-PARCLOSE12" sourceRef="USI1" targetRef="PARCLOSE12"/>
    <sequenceFlow id="G0-STE1" sourceRef="G0" targetRef="STE1"/>
    <sequenceFlow id="G0-STS1" sourceRef="G0" targetRef="STS1"/>
    <sequenceFlow id="STE1-XORCLOSE11" sourceRef="STE1" targetRef="XORCLOSE11"/>
    <sequenceFlow id="STS1-XORCLOSE11" sourceRef="STS1" targetRef="XORCLOSE11"/>
    <sequenceFlow id="XORCLOSE11-PARCLOSE12" sourceRef="XORCLOSE11" targetRef="PARCLOSE12"/>
    <sequenceFlow id="PARCLOSE12-G1" sourceRef="PARCLOSE12" targetRef="G1"/>
    <sequenceFlow id="G1-SRM1" sourceRef="G1" targetRef="SRM1"/>
    <sequenceFlow id="G1-SIN1" sourceRef="G1" targetRef="SIN1"/>
    <sequenceFlow id="SRM1-XORCLOSE20" sourceRef="SRM1" targetRef="XORCLOSE20"/>
    <sequenceFlow id="SIN1-XORCLOSE20" sourceRef="SIN1" targetRef="XORCLOSE20"/>
    <sequenceFlow id="XORCLOSE20-CCJ1" sourceRef="XORCLOSE20" targetRef="CCJ1"/>
    <sequenceFlow id="CCJ1-PTF1" sourceRef="CCJ1" targetRef="PTF1"/>
    <sequenceFlow id="PTF1-END" sourceRef="PTF1" targetRef="END"/>
  </process>
