<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_b62f358d-f925-454f-a712-534a516cc634" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CST1</outgoing>
    </startEvent>
    <task id="CST1" name="Customer searches for ticket">
      <incoming>Default_init-CST1</incoming>
      <outgoing>CST1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>CST1-Par1</incoming>
      <outgoing>Par1-SDT1</outgoing>
      <outgoing>Par1-PPD1</outgoing>
    </parallelGateway>
    <task id="SDT1" name="Select date and time">
      <incoming>Par1-SDT1</incoming>
      <outgoing>SDT1-PPI1</outgoing>
    </task>
    <task id="PPD1" name="Provide payment details">
      <incoming>Par1-PPD1</incoming>
      <outgoing>PPD1-SR1</outgoing>
    </task>
    <task id="SR1" name="Select route">
      <incoming>PPD1-SR1</incoming>
      <outgoing>SR1-PARCLOSE8</outgoing>
    </task>
    <task id="PPI1" name="Provide personal information">
      <incoming>SDT1-PPI1</incoming>
      <outgoing>PPI1-PARCLOSE8</outgoing>
    </task>
    <parallelGateway id="PARCLOSE8" name="PARCLOSE8">
      <incoming>SR1-PARCLOSE8</incoming>
      <incoming>PPI1-PARCLOSE8</incoming>
      <outgoing>PARCLOSE8-GT1</outgoing>
    </parallelGateway>
    <task id="GT1" name="Generate ticket">
      <incoming>PARCLOSE8-GT1</incoming>
      <outgoing>GT1-Par10</outgoing>
    </task>
    <parallelGateway id="Par10" name="PAR">
      <incoming>GT1-Par10</incoming>
      <outgoing>Par10-USI1</outgoing>
      <outgoing>Par10-G0</outgoing>
    </parallelGateway>
    <task id="USI1" name="Update seat inventory">
      <incoming>Par10-USI1</incoming>
      <outgoing>USI1-PARCLOSE16</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par10-G0</incoming>
      <outgoing>G0-STE1</outgoing>
      <outgoing>G0-STS1</outgoing>
    </exclusiveGateway>
    <task id="STE1" name="Send ticket via email">
      <incoming>G0-STE1</incoming>
      <outgoing>STE1-XORCLOSE15</outgoing>
    </task>
    <task id="STS1" name="Send ticket via SMS">
      <incoming>G0-STS1</incoming>
      <outgoing>STS1-XORCLOSE15</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE15" name="XORCLOSE15">
      <incoming>STE1-XORCLOSE15</incoming>
      <incoming>STS1-XORCLOSE15</incoming>
      <outgoing>XORCLOSE15-PARCLOSE16</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE16" name="PARCLOSE16">
      <incoming>USI1-PARCLOSE16</incoming>
      <incoming>XORCLOSE15-PARCLOSE16</incoming>
      <outgoing>PARCLOSE16-G1</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G1" name="G1">
      <incoming>PARCLOSE16-G1</incoming>
      <outgoing>G1-SRM1</outgoing>
      <outgoing>G1-SIN1</outgoing>
    </exclusiveGateway>
    <task id="SRM1" name="Send reminder">
      <incoming>G1-SRM1</incoming>
      <outgoing>SRM1-XORCLOSE20</outgoing>
    </task>
    <task id="SIN1" name="Send instructions">
      <incoming>G1-SIN1</incoming>
      <outgoing>SIN1-XORCLOSE20</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>SRM1-XORCLOSE20</incoming>
      <incoming>SIN1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-CCJ1</outgoing>
    </exclusiveGateway>
    <task id="CCJ1" name="Customer completes journey">
      <incoming>XORCLOSE20-CCJ1</incoming>
      <outgoing>CCJ1-PTF1</outgoing>
    </task>
    <task id="PTF1" name="Post-travel feedback or services">
      <incoming>CCJ1-PTF1</incoming>
      <outgoing>PTF1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PTF1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-CST1" sourceRef="Default_init" targetRef="CST1"/>
    <sequenceFlow id="CST1-Par1" sourceRef="CST1" targetRef="Par1"/>
    <sequenceFlow id="Par1-SDT1" sourceRef="Par1" targetRef="SDT1"/>
    <sequenceFlow id="Par1-PPD1" sourceRef="Par1" targetRef="PPD1"/>
