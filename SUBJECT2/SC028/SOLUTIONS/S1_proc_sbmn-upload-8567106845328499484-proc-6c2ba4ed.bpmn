<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_08df58fa-57a1-4bcc-8237-0902f56ff140" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-SDT1</outgoing>
      <outgoing>Par0-PPD1</outgoing>
    </parallelGateway>
    <task id="SDT1" name="Select date and time">
      <incoming>Par0-SDT1</incoming>
      <outgoing>SDT1-PPI1</outgoing>
    </task>
    <task id="PPD1" name="Provide payment details">
      <incoming>Par0-PPD1</incoming>
      <outgoing>PPD1-CST1</outgoing>
    </task>
    <task id="CST1" name="Customer searches for ticket">
      <incoming>PPD1-CST1</incoming>
      <outgoing>CST1-SR1</outgoing>
    </task>
    <task id="SR1" name="Select route">
      <incoming>CST1-SR1</incoming>
      <outgoing>SR1-PARCLOSE10</outgoing>
    </task>
    <task id="PPI1" name="Provide personal information">
      <incoming>SDT1-PPI1</incoming>
      <outgoing>PPI1-PARCLOSE10</outgoing>
    </task>
    <parallelGateway id="PARCLOSE10" name="PARCLOSE10">
      <incoming>SR1-PARCLOSE10</incoming>
      <incoming>PPI1-PARCLOSE10</incoming>
      <outgoing>PARCLOSE10-GT1</outgoing>
    </parallelGateway>
    <task id="GT1" name="Generate ticket">
      <incoming>PARCLOSE10-GT1</incoming>
      <outgoing>GT1-Par12</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>GT1-Par12</incoming>
      <outgoing>Par12-USI1</outgoing>
      <outgoing>Par12-G0</outgoing>
    </parallelGateway>
    <task id="USI1" name="Update seat inventory">
      <incoming>Par12-USI1</incoming>
      <outgoing>USI1-PARCLOSE18</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par12-G0</incoming>
      <outgoing>G0-STE1</outgoing>
      <outgoing>G0-STS1</outgoing>
    </exclusiveGateway>
    <task id="STE1" name="Send ticket via email">
      <incoming>G0-STE1</incoming>
      <outgoing>STE1-XORCLOSE17</outgoing>
    </task>
    <task id="STS1" name="Send ticket via SMS">
      <incoming>G0-STS1</incoming>
      <outgoing>STS1-XORCLOSE17</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE17" name="XORCLOSE17">
      <incoming>STE1-XORCLOSE17</incoming>
      <incoming>STS1-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-PARCLOSE18</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>USI1-PARCLOSE18</incoming>
      <incoming>XORCLOSE17-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-G1</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G1" name="G1">
      <incoming>PARCLOSE18-G1</incoming>
      <outgoing>G1-SRM1</outgoing>
      <outgoing>G1-SIN1</outgoing>
    </exclusiveGateway>
    <task id="SRM1" name="Send reminder">
      <incoming>G1-SRM1</incoming>
      <outgoing>SRM1-XORCLOSE22</outgoing>
    </task>
    <task id="SIN1" name="Send instructions">
      <incoming>G1-SIN1</incoming>
      <outgoing>SIN1-XORCLOSE22</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE22" name="XORCLOSE22">
      <incoming>SRM1-XORCLOSE22</incoming>
      <incoming>SIN1-XORCLOSE22</incoming>
      <outgoing>XORCLOSE22-CCJ1</outgoing>
    </exclusiveGateway>
    <task id="CCJ1" name="Customer completes journey">
      <incoming>XORCLOSE22-CCJ1</incoming>
      <outgoing>CCJ1-PTF1</outgoing>
    </task>
    <task id="PTF1" name="Post-travel feedback or services">
      <incoming>CCJ1-PTF1</incoming>
      <outgoing>PTF1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PTF1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
    <sequenceFlow id="Par0-SDT1" sourceRef="Par0" targetRef="SDT1"/>
    <sequenceFlow id="Par0-PPD1" sourceRef="Par0" targetRef="PPD1"/>
