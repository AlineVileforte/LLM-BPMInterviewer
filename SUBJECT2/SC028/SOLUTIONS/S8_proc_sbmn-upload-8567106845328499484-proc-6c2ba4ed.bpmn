<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_5bd0af28-c34d-46ba-bec3-2544bbbe0a24" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-CST1</outgoing>
      <outgoing>Par0-SR1</outgoing>
    </parallelGateway>
    <task id="CST1" name="Customer searches for ticket">
      <incoming>Par0-CST1</incoming>
      <outgoing>CST1-SDT1</outgoing>
    </task>
    <task id="SDT1" name="Select date and time">
      <incoming>CST1-SDT1</incoming>
      <outgoing>SDT1-PPD1</outgoing>
    </task>
    <task id="SR1" name="Select route">
      <incoming>Par0-SR1</incoming>
      <outgoing>SR1-PPI1</outgoing>
    </task>
    <task id="PPD1" name="Provide payment details">
      <incoming>SDT1-PPD1</incoming>
      <outgoing>PPD1-PARCLOSE9</outgoing>
    </task>
    <task id="PPI1" name="Provide personal information">
      <incoming>SR1-PPI1</incoming>
      <outgoing>PPI1-GT1</outgoing>
    </task>
    <task id="GT1" name="Generate ticket">
      <incoming>PPI1-GT1</incoming>
      <outgoing>GT1-PARCLOSE9</outgoing>
    </task>
    <parallelGateway id="PARCLOSE9" name="PARCLOSE9">
      <incoming>PPD1-PARCLOSE9</incoming>
      <incoming>GT1-PARCLOSE9</incoming>
      <outgoing>PARCLOSE9-Par10</outgoing>
    </parallelGateway>
    <parallelGateway id="Par10" name="PAR">
      <incoming>PARCLOSE9-Par10</incoming>
      <outgoing>Par10-USI1</outgoing>
      <outgoing>Par10-G1</outgoing>
    </parallelGateway>
    <task id="USI1" name="Update seat inventory">
      <incoming>Par10-USI1</incoming>
      <outgoing>USI1-PARCLOSE16</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par10-G1</incoming>
      <outgoing>G1-STE1</outgoing>
      <outgoing>G1-STS1</outgoing>
    </exclusiveGateway>
    <task id="STE1" name="Send ticket via email">
      <incoming>G1-STE1</incoming>
      <outgoing>STE1-XORCLOSE15</outgoing>
    </task>
    <task id="STS1" name="Send ticket via SMS">
      <incoming>G1-STS1</incoming>
      <outgoing>STS1-XORCLOSE15</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE15" name="XORCLOSE15">
      <incoming>STE1-XORCLOSE15</incoming>
      <incoming>STS1-XORCLOSE15</incoming>
      <outgoing>XORCLOSE15-PARCLOSE16</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE16" name="PARCLOSE16">
      <incoming>USI1-PARCLOSE16</incoming>
      <incoming>XORCLOSE15-PARCLOSE16</incoming>
      <outgoing>PARCLOSE16-G2</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G2" name="G2">
      <incoming>PARCLOSE16-G2</incoming>
      <outgoing>G2-SRM1</outgoing>
      <outgoing>G2-SIN1</outgoing>
    </exclusiveGateway>
    <task id="SRM1" name="Send reminder">
      <incoming>G2-SRM1</incoming>
      <outgoing>SRM1-XORCLOSE24</outgoing>
    </task>
    <task id="SIN1" name="Send instructions">
      <incoming>G2-SIN1</incoming>
      <outgoing>SIN1-XORCLOSE24</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE24" name="XORCLOSE24">
      <incoming>SRM1-XORCLOSE24</incoming>
      <incoming>SIN1-XORCLOSE24</incoming>
      <outgoing>XORCLOSE24-CCJ1</outgoing>
    </exclusiveGateway>
    <task id="CCJ1" name="Customer completes journey">
      <incoming>XORCLOSE24-CCJ1</incoming>
      <outgoing>CCJ1-PTF1</outgoing>
    </task>
    <task id="PTF1" name="Post-travel feedback or services">
      <incoming>CCJ1-PTF1</incoming>
      <outgoing>PTF1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PTF1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
    <sequenceFlow id="Par0-CST1" sourceRef="Par0" targetRef="CST1"/>
    <sequenceFlow id="Par0-SR1" sourceRef="Par0" targetRef="SR1"/>
