    <sequenceFlow id="Par10-XOR_JMPBB_RP1_TS1" sourceRef="Par10" targetRef="XOR_JMPBB_RP1_TS1"/>
    <sequenceFlow id="TF1-PARCLOSE13" sourceRef="TF1" targetRef="PARCLOSE13"/>
    <sequenceFlow id="TS1-PARCLOSE13" sourceRef="TS1" targetRef="PARCLOSE13"/>
    <sequenceFlow id="PARCLOSE13-CFTP1" sourceRef="PARCLOSE13" targetRef="CFTP1"/>
    <sequenceFlow id="CFTP1-G0" sourceRef="CFTP1" targetRef="G0"/>
