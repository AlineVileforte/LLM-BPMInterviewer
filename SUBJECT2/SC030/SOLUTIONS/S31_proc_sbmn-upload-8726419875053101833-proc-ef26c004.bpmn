<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_b45608fd-72b0-4365-8b0f-2fb49121265e" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-IINP1</outgoing>
    </startEvent>
    <task id="IINP1" name="Identify idea for new product or improvement">
      <incoming>Default_init-IINP1</incoming>
      <outgoing>IINP1-CFS1</outgoing>
    </task>
    <task id="CFS1" name="Conduct feasibility studies">
      <incoming>IINP1-CFS1</incoming>
      <outgoing>CFS1-CIR1</outgoing>
    </task>
    <task id="CIR1" name="Conduct initial research">
      <incoming>CFS1-CIR1</incoming>
      <outgoing>CIR1-DDC1</outgoing>
    </task>
    <task id="DDC1" name="Draft design concepts">
      <incoming>CIR1-DDC1</incoming>
      <outgoing>DDC1-SPD1</outgoing>
    </task>
    <task id="SPD1" name="Select promising design">
      <incoming>DDC1-SPD1</incoming>
      <outgoing>SPD1-BP1</outgoing>
    </task>
    <task id="BP1" name="Build prototype">
      <incoming>SPD1-BP1</incoming>
      <outgoing>BP1-XOR_JMPBB_RP1_TS1</outgoing>
    </task>
    <task id="TS1" name="Test safety">
      <incoming>XOR_JMPBB_RP1_TS1-TS1</incoming>
      <outgoing>TS1-Par8</outgoing>
    </task>
    <parallelGateway id="Par8" name="PAR">
      <incoming>TS1-Par8</incoming>
      <outgoing>Par8-XOR_JMPBB_RP1_TF1</outgoing>
      <outgoing>Par8-XOR_JMPBB_RP1_TMP1</outgoing>
    </parallelGateway>
    <task id="TF1" name="Test functionality">
      <incoming>XOR_JMPBB_RP1_TF1-TF1</incoming>
      <outgoing>TF1-PARCLOSE11</outgoing>
    </task>
    <task id="TMP1" name="Test market potential">
      <incoming>XOR_JMPBB_RP1_TMP1-TMP1</incoming>
      <outgoing>TMP1-PARCLOSE11</outgoing>
    </task>
    <parallelGateway id="PARCLOSE11" name="PARCLOSE11">
      <incoming>TF1-PARCLOSE11</incoming>
      <incoming>TMP1-PARCLOSE11</incoming>
      <outgoing>PARCLOSE11-CFTP1</outgoing>
    </parallelGateway>
    <task id="CFTP1" name="Collect feedback from testing phase">
      <incoming>PARCLOSE11-CFTP1</incoming>
      <outgoing>CFTP1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CFTP1-G0</incoming>
      <outgoing>G0-RP1</outgoing>
      <outgoing>G0-G1</outgoing>
    </exclusiveGateway>
    <task id="RP1" name="Refine prototype">
      <incoming>G0-RP1</incoming>
      <outgoing>RP1-XOR_JMPAA_RP1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>G0-G1</incoming>
      <outgoing>G1-APFD1</outgoing>
      <outgoing>G1-DP1</outgoing>
    </exclusiveGateway>
    <task id="APFD1" name="Approve prototype for further development">
      <incoming>G1-APFD1</incoming>
      <outgoing>APFD1-XORCLOSE19</outgoing>
    </task>
    <task id="DP1" name="Discard prototype">
      <incoming>G1-DP1</incoming>
      <outgoing>DP1-XORCLOSE19</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE19" name="XORCLOSE19">
      <incoming>APFD1-XORCLOSE19</incoming>
      <incoming>DP1-XORCLOSE19</incoming>
      <outgoing>XORCLOSE19-XORCLOSE20</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>XORCLOSE19-XORCLOSE20</incoming>
      <incoming>XOR_JMPAA_RP1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE20-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_RP1" name="XOR_JMPAA_Refine prototype">
      <incoming>RP1-XOR_JMPAA_RP1</incoming>
      <outgoing>XOR_JMPAA_RP1-XORCLOSE20</outgoing>
      <outgoing>XOR_JMPAA_RP1-XOR_JMPBB_RP1_TF1</outgoing>
      <outgoing>XOR_JMPAA_RP1-XOR_JMPBB_RP1_TS1</outgoing>
      <outgoing>XOR_JMPAA_RP1-XOR_JMPBB_RP1_TMP1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_RP1_TF1" name="XOR_JMPBB_Test functionality">
      <incoming>Par8-XOR_JMPBB_RP1_TF1</incoming>
      <incoming>XOR_JMPAA_RP1-XOR_JMPBB_RP1_TF1</incoming>
      <outgoing>XOR_JMPBB_RP1_TF1-TF1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_RP1_TS1" name="XOR_JMPBB_Test safety">
      <incoming>BP1-XOR_JMPBB_RP1_TS1</incoming>
      <incoming>XOR_JMPAA_RP1-XOR_JMPBB_RP1_TS1</incoming>
      <outgoing>XOR_JMPBB_RP1_TS1-TS1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_RP1_TMP1" name="XOR_JMPBB_Test market potential">
      <incoming>Par8-XOR_JMPBB_RP1_TMP1</incoming>
      <incoming>XOR_JMPAA_RP1-XOR_JMPBB_RP1_TMP1</incoming>
      <outgoing>XOR_JMPBB_RP1_TMP1-TMP1</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Default_init-IINP1" sourceRef="Default_init" targetRef="IINP1"/>
    <sequenceFlow id="IINP1-CFS1" sourceRef="IINP1" targetRef="CFS1"/>
    <sequenceFlow id="CFS1-CIR1" sourceRef="CFS1" targetRef="CIR1"/>
    <sequenceFlow id="CIR1-DDC1" sourceRef="CIR1" targetRef="DDC1"/>
    <sequenceFlow id="DDC1-SPD1" sourceRef="DDC1" targetRef="SPD1"/>
    <sequenceFlow id="SPD1-BP1" sourceRef="SPD1" targetRef="BP1"/>
    <sequenceFlow id="BP1-XOR_JMPBB_RP1_TS1" sourceRef="BP1" targetRef="XOR_JMPBB_RP1_TS1"/>
    <sequenceFlow id="TS1-Par8" sourceRef="TS1" targetRef="Par8"/>
    <sequenceFlow id="Par8-XOR_JMPBB_RP1_TF1" sourceRef="Par8" targetRef="XOR_JMPBB_RP1_TF1"/>
    <sequenceFlow id="Par8-XOR_JMPBB_RP1_TMP1" sourceRef="Par8" targetRef="XOR_JMPBB_RP1_TMP1"/>
    <sequenceFlow id="TF1-PARCLOSE11" sourceRef="TF1" targetRef="PARCLOSE11"/>
    <sequenceFlow id="TMP1-PARCLOSE11" sourceRef="TMP1" targetRef="PARCLOSE11"/>
    <sequenceFlow id="PARCLOSE11-CFTP1" sourceRef="PARCLOSE11" targetRef="CFTP1"/>
    <sequenceFlow id="CFTP1-G0" sourceRef="CFTP1" targetRef="G0"/>
    <sequenceFlow id="G0-RP1" sourceRef="G0" targetRef="RP1"/>
    <sequenceFlow id="G0-G1" sourceRef="G0" targetRef="G1"/>
    <sequenceFlow id="RP1-XOR_JMPAA_RP1" sourceRef="RP1" targetRef="XOR_JMPAA_RP1"/>
    <sequenceFlow id="G1-APFD1" sourceRef="G1" targetRef="APFD1"/>
    <sequenceFlow id="G1-DP1" sourceRef="G1" targetRef="DP1"/>
    <sequenceFlow id="APFD1-XORCLOSE19" sourceRef="APFD1" targetRef="XORCLOSE19"/>
    <sequenceFlow id="DP1-XORCLOSE19" sourceRef="DP1" targetRef="XORCLOSE19"/>
    <sequenceFlow id="XORCLOSE19-XORCLOSE20" sourceRef="XORCLOSE19" targetRef="XORCLOSE20"/>
    <sequenceFlow id="XORCLOSE20-END" sourceRef="XORCLOSE20" targetRef="END"/>
    <sequenceFlow id="XOR_JMPAA_RP1-XORCLOSE20" sourceRef="XOR_JMPAA_RP1" targetRef="XORCLOSE20"/>
    <sequenceFlow id="XOR_JMPAA_RP1-XOR_JMPBB_RP1_TF1" sourceRef="XOR_JMPAA_RP1" targetRef="XOR_JMPBB_RP1_TF1"/>
    <sequenceFlow id="XOR_JMPAA_RP1-XOR_JMPBB_RP1_TS1" sourceRef="XOR_JMPAA_RP1" targetRef="XOR_JMPBB_RP1_TS1"/>
    <sequenceFlow id="XOR_JMPAA_RP1-XOR_JMPBB_RP1_TMP1" sourceRef="XOR_JMPAA_RP1" targetRef="XOR_JMPBB_RP1_TMP1"/>
    <sequenceFlow id="XOR_JMPBB_RP1_TF1-TF1" sourceRef="XOR_JMPBB_RP1_TF1" targetRef="TF1"/>
    <sequenceFlow id="XOR_JMPBB_RP1_TS1-TS1" sourceRef="XOR_JMPBB_RP1_TS1" targetRef="TS1"/>
    <sequenceFlow id="XOR_JMPBB_RP1_TMP1-TMP1" sourceRef="XOR_JMPBB_RP1_TMP1" targetRef="TMP1"/>
  </process>
