    <sequenceFlow id="Par8-XOR_JMPBB_RP1_TS1" sourceRef="Par8" targetRef="XOR_JMPBB_RP1_TS1"/>
    <sequenceFlow id="TF1-XOR_JMPBB_RP1_TMP1" sourceRef="TF1" targetRef="XOR_JMPBB_RP1_TMP1"/>
    <sequenceFlow id="TS1-PARCLOSE12" sourceRef="TS1" targetRef="PARCLOSE12"/>
    <sequenceFlow id="TMP1-PARCLOSE12" sourceRef="TMP1" targetRef="PARCLOSE12"/>
    <sequenceFlow id="PARCLOSE12-CFTP1" sourceRef="PARCLOSE12" targetRef="CFTP1"/>
    <sequenceFlow id="CFTP1-G0" sourceRef="CFTP1" targetRef="G0"/>
    <sequenceFlow id="G0-RP1" sourceRef="G0" targetRef="RP1"/>
    <sequenceFlow id="G0-G1" sourceRef="G0" targetRef="G1"/>
    <sequenceFlow id="RP1-XOR_JMPAA_RP1" sourceRef="RP1" targetRef="XOR_JMPAA_RP1"/>
    <sequenceFlow id="G1-APFD1" sourceRef="G1" targetRef="APFD1"/>
    <sequenceFlow id="G1-DP1" sourceRef="G1" targetRef="DP1"/>
