  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-AS1</outgoing>
    </startEvent>
    <task id="AS1" name="Approve Script">
      <incoming>Default_init-AS1</incoming>
      <outgoing>AS1-BC1</outgoing>
    </task>
    <task id="BC1" name="Begin Casting">
      <incoming>AS1-BC1</incoming>
      <outgoing>BC1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>BC1-Par2</incoming>
      <outgoing>Par2-DSS1</outgoing>
      <outgoing>Par2-SL1</outgoing>
    </parallelGateway>
    <task id="DSS1" name="Detail Script Scenes">
      <incoming>Par2-DSS1</incoming>
      <outgoing>DSS1-RS1</outgoing>
    </task>
    <task id="RS1" name="Rehearse Scenes">
      <incoming>DSS1-RS1</incoming>
      <outgoing>RS1-AJ1</outgoing>
    </task>
    <task id="SL1" name="Search Locations">
      <incoming>Par2-SL1</incoming>
      <outgoing>SL1-HS1</outgoing>
    </task>
    <task id="AJ1" name="Adjust Script">
      <incoming>RS1-AJ1</incoming>
      <outgoing>AJ1-Par8</outgoing>
    </task>
    <task id="HS1" name="Hire Suppliers">
      <incoming>SL1-HS1</incoming>
      <outgoing>HS1-PC1</outgoing>
    </task>
    <parallelGateway id="Par8" name="PAR">
      <incoming>AJ1-Par8</incoming>
      <outgoing>Par8-AF1</outgoing>
      <outgoing>Par8-CS1</outgoing>
    </parallelGateway>
    <task id="AF1" name="Additional Filming">
      <incoming>Par8-AF1</incoming>
      <outgoing>AF1-CSG1</outgoing>
    </task>
    <task id="CS1" name="Compose Soundtrack">
      <incoming>Par8-CS1</incoming>
      <outgoing>CS1-PARCLOSE18</outgoing>
    </task>
    <task id="PC1" name="Produce Costumes">
      <incoming>HS1-PC1</incoming>
      <outgoing>PC1-Par14</outgoing>
    </task>
    <task id="CSG1" name="Construct Stage">
      <incoming>AF1-CSG1</incoming>
      <outgoing>CSG1-PARCLOSE18</outgoing>
    </task>
    <parallelGateway id="Par14" name="PAR">
      <incoming>PC1-Par14</incoming>
      <outgoing>Par14-PFE1</outgoing>
      <outgoing>Par14-G1</outgoing>
    </parallelGateway>
    <task id="PFE1" name="Prepare Filming Equipment">
      <incoming>Par14-PFE1</incoming>
      <outgoing>PFE1-PARCLOSE33</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par14-G1</incoming>
      <outgoing>G1-FS1</outgoing>
      <outgoing>G1-NWF1</outgoing>
    </exclusiveGateway>
    <task id="FS1" name="Film Scenes">
      <incoming>G1-FS1</incoming>
      <outgoing>FS1-PVE1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>CS1-PARCLOSE18</incoming>
      <incoming>CSG1-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-PPM1</outgoing>
    </parallelGateway>
    <task id="PVE1" name="Produce Visual Effects">
      <incoming>FS1-PVE1</incoming>
      <outgoing>PVE1-PE1</outgoing>
    </task>
    <task id="PPM1" name="Produce Promotional Material">
      <incoming>PARCLOSE18-PPM1</incoming>
      <outgoing>PPM1-DM1</outgoing>
    </task>
    <task id="PE1" name="Preliminary Editing">
      <incoming>PVE1-PE1</incoming>
      <outgoing>PE1-APP1</outgoing>
    </task>
    <task id="NWF1" name="Negotiate with Festivals">
      <incoming>G1-NWF1</incoming>
      <outgoing>NWF1-XORCLOSE32</outgoing>
    </task>
    <task id="DM1" name="Distribute Movie">
      <incoming>PPM1-DM1</incoming>
      <outgoing>DM1-PARCLOSE34</outgoing>
    </task>
    <task id="APP1" name="Advance Post-Production">
      <incoming>PE1-APP1</incoming>
      <outgoing>APP1-RMC1</outgoing>
    </task>
    <task id="RMC1" name="Run Marketing Campaign">
      <incoming>APP1-RMC1</incoming>
      <outgoing>RMC1-FSE1</outgoing>
    </task>
    <task id="FSE1" name="Final Sound Editing">
      <incoming>RMC1-FSE1</incoming>
      <outgoing>FSE1-AFV1</outgoing>
    </task>
    <task id="AFV1" name="Approve Final Version">
      <incoming>FSE1-AFV1</incoming>
      <outgoing>AFV1-XORCLOSE32</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE32" name="XORCLOSE32">
      <incoming>NWF1-XORCLOSE32</incoming>
      <incoming>AFV1-XORCLOSE32</incoming>
      <outgoing>XORCLOSE32-PARCLOSE33</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE33" name="PARCLOSE33">
      <incoming>PFE1-PARCLOSE33</incoming>
      <incoming>XORCLOSE32-PARCLOSE33</incoming>
      <outgoing>PARCLOSE33-PARCLOSE34</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE34" name="PARCLOSE34">
      <incoming>DM1-PARCLOSE34</incoming>
      <incoming>PARCLOSE33-PARCLOSE34</incoming>
      <outgoing>PARCLOSE34-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE34-END</incoming>
    </endEvent>
