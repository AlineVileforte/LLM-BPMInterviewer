  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-AS1</outgoing>
    </startEvent>
    <task id="AS1" name="Approve Script">
      <incoming>Default_init-AS1</incoming>
      <outgoing>AS1-BC1</outgoing>
    </task>
    <task id="BC1" name="Begin Casting">
      <incoming>AS1-BC1</incoming>
      <outgoing>BC1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>BC1-Par2</incoming>
      <outgoing>Par2-RS1</outgoing>
      <outgoing>Par2-DSS1</outgoing>
    </parallelGateway>
    <task id="RS1" name="Rehearse Scenes">
      <incoming>Par2-RS1</incoming>
      <outgoing>RS1-SL1</outgoing>
    </task>
    <task id="SL1" name="Search Locations">
      <incoming>RS1-SL1</incoming>
      <outgoing>SL1-HS1</outgoing>
    </task>
    <task id="DSS1" name="Detail Script Scenes">
      <incoming>Par2-DSS1</incoming>
      <outgoing>DSS1-AJ1</outgoing>
    </task>
    <task id="HS1" name="Hire Suppliers">
      <incoming>SL1-HS1</incoming>
      <outgoing>HS1-CS1</outgoing>
    </task>
    <task id="AJ1" name="Adjust Script">
      <incoming>DSS1-AJ1</incoming>
      <outgoing>AJ1-Par9</outgoing>
    </task>
    <task id="CS1" name="Compose Soundtrack">
      <incoming>HS1-CS1</incoming>
      <outgoing>CS1-AF1</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>AJ1-Par9</incoming>
      <outgoing>Par9-PC1</outgoing>
      <outgoing>Par9-PFE1</outgoing>
    </parallelGateway>
    <task id="PC1" name="Produce Costumes">
      <incoming>Par9-PC1</incoming>
      <outgoing>PC1-CSG1</outgoing>
    </task>
    <task id="AF1" name="Additional Filming">
      <incoming>CS1-AF1</incoming>
      <outgoing>AF1-G0</outgoing>
    </task>
    <task id="CSG1" name="Construct Stage">
      <incoming>PC1-CSG1</incoming>
      <outgoing>CSG1-PARCLOSE16</outgoing>
    </task>
    <task id="PFE1" name="Prepare Filming Equipment">
      <incoming>Par9-PFE1</incoming>
      <outgoing>PFE1-PARCLOSE16</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>AF1-G0</incoming>
      <outgoing>G0-FS1</outgoing>
      <outgoing>G0-NWF1</outgoing>
    </exclusiveGateway>
    <task id="FS1" name="Film Scenes">
      <incoming>G0-FS1</incoming>
      <outgoing>FS1-PVE1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE16" name="PARCLOSE16">
      <incoming>CSG1-PARCLOSE16</incoming>
      <incoming>PFE1-PARCLOSE16</incoming>
      <outgoing>PARCLOSE16-PPM1</outgoing>
    </parallelGateway>
    <task id="PVE1" name="Produce Visual Effects">
      <incoming>FS1-PVE1</incoming>
      <outgoing>PVE1-PE1</outgoing>
    </task>
    <task id="PPM1" name="Produce Promotional Material">
      <incoming>PARCLOSE16-PPM1</incoming>
      <outgoing>PPM1-DM1</outgoing>
    </task>
    <task id="PE1" name="Preliminary Editing">
      <incoming>PVE1-PE1</incoming>
      <outgoing>PE1-APP1</outgoing>
    </task>
    <task id="NWF1" name="Negotiate with Festivals">
      <incoming>G0-NWF1</incoming>
      <outgoing>NWF1-XORCLOSE32</outgoing>
    </task>
    <task id="DM1" name="Distribute Movie">
      <incoming>PPM1-DM1</incoming>
      <outgoing>DM1-PARCLOSE33</outgoing>
    </task>
    <task id="APP1" name="Advance Post-Production">
      <incoming>PE1-APP1</incoming>
      <outgoing>APP1-FSE1</outgoing>
    </task>
    <task id="FSE1" name="Final Sound Editing">
      <incoming>APP1-FSE1</incoming>
      <outgoing>FSE1-Par28</outgoing>
    </task>
    <parallelGateway id="Par28" name="PAR">
      <incoming>FSE1-Par28</incoming>
      <outgoing>Par28-RMC1</outgoing>
      <outgoing>Par28-AFV1</outgoing>
    </parallelGateway>
    <task id="RMC1" name="Run Marketing Campaign">
      <incoming>Par28-RMC1</incoming>
      <outgoing>RMC1-PARCLOSE31</outgoing>
    </task>
    <task id="AFV1" name="Approve Final Version">
      <incoming>Par28-AFV1</incoming>
      <outgoing>AFV1-PARCLOSE31</outgoing>
    </task>
    <parallelGateway id="PARCLOSE31" name="PARCLOSE31">
      <incoming>RMC1-PARCLOSE31</incoming>
      <incoming>AFV1-PARCLOSE31</incoming>
      <outgoing>PARCLOSE31-XORCLOSE32</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE32" name="XORCLOSE32">
      <incoming>NWF1-XORCLOSE32</incoming>
      <incoming>PARCLOSE31-XORCLOSE32</incoming>
      <outgoing>XORCLOSE32-PARCLOSE33</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE33" name="PARCLOSE33">
      <incoming>DM1-PARCLOSE33</incoming>
      <incoming>XORCLOSE32-PARCLOSE33</incoming>
      <outgoing>PARCLOSE33-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE33-END</incoming>
    </endEvent>
