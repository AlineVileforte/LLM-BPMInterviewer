  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-AS1</outgoing>
    </startEvent>
    <task id="AS1" name="Approve Script">
      <incoming>Default_init-AS1</incoming>
      <outgoing>AS1-BC1</outgoing>
    </task>
    <task id="BC1" name="Begin Casting">
      <incoming>AS1-BC1</incoming>
      <outgoing>BC1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>BC1-Par2</incoming>
      <outgoing>Par2-SL1</outgoing>
      <outgoing>Par2-Par6</outgoing>
    </parallelGateway>
    <task id="SL1" name="Search Locations">
      <incoming>Par2-SL1</incoming>
      <outgoing>SL1-Par4</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>SL1-Par4</incoming>
      <outgoing>Par4-HS1</outgoing>
      <outgoing>Par4-PC1</outgoing>
    </parallelGateway>
    <task id="HS1" name="Hire Suppliers">
      <incoming>Par4-HS1</incoming>
      <outgoing>HS1-RS1</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>Par2-Par6</incoming>
      <outgoing>Par6-DSS1</outgoing>
      <outgoing>Par6-AJ1</outgoing>
    </parallelGateway>
    <task id="DSS1" name="Detail Script Scenes">
      <incoming>Par6-DSS1</incoming>
      <outgoing>DSS1-Par12</outgoing>
    </task>
    <task id="RS1" name="Rehearse Scenes">
      <incoming>HS1-RS1</incoming>
      <outgoing>RS1-PARCLOSE23</outgoing>
    </task>
    <task id="PC1" name="Produce Costumes">
      <incoming>Par4-PC1</incoming>
      <outgoing>PC1-PFE1</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>DSS1-Par12</incoming>
      <outgoing>Par12-CS1</outgoing>
      <outgoing>Par12-CSG1</outgoing>
    </parallelGateway>
    <task id="CS1" name="Compose Soundtrack">
      <incoming>Par12-CS1</incoming>
      <outgoing>CS1-PARCLOSE18</outgoing>
    </task>
    <task id="CSG1" name="Construct Stage">
      <incoming>Par12-CSG1</incoming>
      <outgoing>CSG1-PARCLOSE18</outgoing>
    </task>
    <task id="AJ1" name="Adjust Script">
      <incoming>Par6-AJ1</incoming>
      <outgoing>AJ1-AF1</outgoing>
    </task>
    <task id="PFE1" name="Prepare Filming Equipment">
      <incoming>PC1-PFE1</incoming>
      <outgoing>PFE1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>CS1-PARCLOSE18</incoming>
      <incoming>CSG1-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-PARCLOSE36</outgoing>
    </parallelGateway>
    <task id="AF1" name="Additional Filming">
      <incoming>AJ1-AF1</incoming>
      <outgoing>AF1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>AF1-G0</incoming>
      <outgoing>G0-FS1</outgoing>
      <outgoing>G0-NWF1</outgoing>
    </exclusiveGateway>
    <task id="FS1" name="Film Scenes">
      <incoming>G0-FS1</incoming>
      <outgoing>FS1-PVE1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>RS1-PARCLOSE23</incoming>
      <incoming>PFE1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-PPM1</outgoing>
    </parallelGateway>
    <task id="PVE1" name="Produce Visual Effects">
      <incoming>FS1-PVE1</incoming>
      <outgoing>PVE1-PE1</outgoing>
    </task>
    <task id="PPM1" name="Produce Promotional Material">
      <incoming>PARCLOSE23-PPM1</incoming>
      <outgoing>PPM1-DM1</outgoing>
    </task>
    <task id="PE1" name="Preliminary Editing">
      <incoming>PVE1-PE1</incoming>
      <outgoing>PE1-APP1</outgoing>
    </task>
    <task id="NWF1" name="Negotiate with Festivals">
      <incoming>G0-NWF1</incoming>
      <outgoing>NWF1-XORCLOSE35</outgoing>
    </task>
    <task id="DM1" name="Distribute Movie">
      <incoming>PPM1-DM1</incoming>
      <outgoing>DM1-PARCLOSE37</outgoing>
    </task>
    <task id="APP1" name="Advance Post-Production">
      <incoming>PE1-APP1</incoming>
      <outgoing>APP1-FSE1</outgoing>
    </task>
    <task id="FSE1" name="Final Sound Editing">
      <incoming>APP1-FSE1</incoming>
      <outgoing>FSE1-AFV1</outgoing>
    </task>
    <task id="AFV1" name="Approve Final Version">
      <incoming>FSE1-AFV1</incoming>
      <outgoing>AFV1-RMC1</outgoing>
    </task>
    <task id="RMC1" name="Run Marketing Campaign">
      <incoming>AFV1-RMC1</incoming>
      <outgoing>RMC1-XORCLOSE35</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE35" name="XORCLOSE35">
      <incoming>NWF1-XORCLOSE35</incoming>
      <incoming>RMC1-XORCLOSE35</incoming>
      <outgoing>XORCLOSE35-PARCLOSE36</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE36" name="PARCLOSE36">
      <incoming>PARCLOSE18-PARCLOSE36</incoming>
      <incoming>XORCLOSE35-PARCLOSE36</incoming>
      <outgoing>PARCLOSE36-PARCLOSE37</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE37" name="PARCLOSE37">
      <incoming>DM1-PARCLOSE37</incoming>
      <incoming>PARCLOSE36-PARCLOSE37</incoming>
      <outgoing>PARCLOSE37-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE37-END</incoming>
    </endEvent>
