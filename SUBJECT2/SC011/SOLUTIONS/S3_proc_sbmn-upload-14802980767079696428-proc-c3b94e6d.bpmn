  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-AS1</outgoing>
    </startEvent>
    <task id="AS1" name="Approve Script">
      <incoming>Default_init-AS1</incoming>
      <outgoing>AS1-SL1</outgoing>
    </task>
    <task id="SL1" name="Search Locations">
      <incoming>AS1-SL1</incoming>
      <outgoing>SL1-BC1</outgoing>
    </task>
    <task id="BC1" name="Begin Casting">
      <incoming>SL1-BC1</incoming>
      <outgoing>BC1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>BC1-Par3</incoming>
      <outgoing>Par3-RS1</outgoing>
      <outgoing>Par3-HS1</outgoing>
    </parallelGateway>
    <task id="RS1" name="Rehearse Scenes">
      <incoming>Par3-RS1</incoming>
      <outgoing>RS1-Par6</outgoing>
    </task>
    <task id="HS1" name="Hire Suppliers">
      <incoming>Par3-HS1</incoming>
      <outgoing>HS1-CSG1</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>RS1-Par6</incoming>
      <outgoing>Par6-DSS1</outgoing>
      <outgoing>Par6-CS1</outgoing>
    </parallelGateway>
    <task id="DSS1" name="Detail Script Scenes">
      <incoming>Par6-DSS1</incoming>
      <outgoing>DSS1-AJ1</outgoing>
    </task>
    <task id="CS1" name="Compose Soundtrack">
      <incoming>Par6-CS1</incoming>
      <outgoing>CS1-PARCLOSE27</outgoing>
    </task>
    <task id="CSG1" name="Construct Stage">
      <incoming>HS1-CSG1</incoming>
      <outgoing>CSG1-PC1</outgoing>
    </task>
    <task id="AJ1" name="Adjust Script">
      <incoming>DSS1-AJ1</incoming>
      <outgoing>AJ1-AF1</outgoing>
    </task>
    <task id="PC1" name="Produce Costumes">
      <incoming>CSG1-PC1</incoming>
      <outgoing>PC1-PFE1</outgoing>
    </task>
    <task id="AF1" name="Additional Filming">
      <incoming>AJ1-AF1</incoming>
      <outgoing>AF1-Par17</outgoing>
    </task>
    <parallelGateway id="Par17" name="PAR">
      <incoming>AF1-Par17</incoming>
      <outgoing>Par17-FS1</outgoing>
      <outgoing>Par17-NWF1</outgoing>
    </parallelGateway>
    <task id="FS1" name="Film Scenes">
      <incoming>Par17-FS1</incoming>
      <outgoing>FS1-PVE1</outgoing>
    </task>
    <task id="NWF1" name="Negotiate with Festivals">
      <incoming>Par17-NWF1</incoming>
      <outgoing>NWF1-PPM1</outgoing>
    </task>
    <task id="PFE1" name="Prepare Filming Equipment">
      <incoming>PC1-PFE1</incoming>
      <outgoing>PFE1-PARCLOSE33</outgoing>
    </task>
    <task id="PVE1" name="Produce Visual Effects">
      <incoming>FS1-PVE1</incoming>
      <outgoing>PVE1-PE1</outgoing>
    </task>
    <task id="PPM1" name="Produce Promotional Material">
      <incoming>NWF1-PPM1</incoming>
      <outgoing>PPM1-DM1</outgoing>
    </task>
    <task id="PE1" name="Preliminary Editing">
      <incoming>PVE1-PE1</incoming>
      <outgoing>PE1-PARCLOSE25</outgoing>
    </task>
    <task id="DM1" name="Distribute Movie">
      <incoming>PPM1-DM1</incoming>
      <outgoing>DM1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>PE1-PARCLOSE25</incoming>
      <incoming>DM1-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-APP1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Advance Post-Production">
      <incoming>PARCLOSE25-APP1</incoming>
      <outgoing>APP1-PARCLOSE27</outgoing>
    </task>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>CS1-PARCLOSE27</incoming>
      <incoming>APP1-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-FSE1</outgoing>
    </parallelGateway>
    <task id="FSE1" name="Final Sound Editing">
      <incoming>PARCLOSE27-FSE1</incoming>
      <outgoing>FSE1-Par29</outgoing>
    </task>
    <parallelGateway id="Par29" name="PAR">
      <incoming>FSE1-Par29</incoming>
      <outgoing>Par29-RMC1</outgoing>
      <outgoing>Par29-AFV1</outgoing>
    </parallelGateway>
    <task id="RMC1" name="Run Marketing Campaign">
      <incoming>Par29-RMC1</incoming>
      <outgoing>RMC1-PARCLOSE32</outgoing>
    </task>
    <task id="AFV1" name="Approve Final Version">
      <incoming>Par29-AFV1</incoming>
      <outgoing>AFV1-PARCLOSE32</outgoing>
    </task>
    <parallelGateway id="PARCLOSE32" name="PARCLOSE32">
      <incoming>RMC1-PARCLOSE32</incoming>
      <incoming>AFV1-PARCLOSE32</incoming>
      <outgoing>PARCLOSE32-PARCLOSE33</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE33" name="PARCLOSE33">
      <incoming>PFE1-PARCLOSE33</incoming>
      <incoming>PARCLOSE32-PARCLOSE33</incoming>
      <outgoing>PARCLOSE33-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE33-END</incoming>
    </endEvent>
