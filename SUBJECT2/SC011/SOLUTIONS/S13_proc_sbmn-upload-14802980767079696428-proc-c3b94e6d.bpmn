  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-AS1</outgoing>
    </startEvent>
    <task id="AS1" name="Approve Script">
      <incoming>Default_init-AS1</incoming>
      <outgoing>AS1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>AS1-Par1</incoming>
      <outgoing>Par1-SL1</outgoing>
      <outgoing>Par1-BC1</outgoing>
    </parallelGateway>
    <task id="SL1" name="Search Locations">
      <incoming>Par1-SL1</incoming>
      <outgoing>SL1-Par4</outgoing>
    </task>
    <task id="BC1" name="Begin Casting">
      <incoming>Par1-BC1</incoming>
      <outgoing>BC1-RS1</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>SL1-Par4</incoming>
      <outgoing>Par4-CS1</outgoing>
      <outgoing>Par4-HS1</outgoing>
    </parallelGateway>
    <task id="RS1" name="Rehearse Scenes">
      <incoming>BC1-RS1</incoming>
      <outgoing>RS1-DSS1</outgoing>
    </task>
    <task id="HS1" name="Hire Suppliers">
      <incoming>Par4-HS1</incoming>
      <outgoing>HS1-PARCLOSE20</outgoing>
    </task>
    <task id="CS1" name="Compose Soundtrack">
      <incoming>Par4-CS1</incoming>
      <outgoing>CS1-Par13</outgoing>
    </task>
    <task id="DSS1" name="Detail Script Scenes">
      <incoming>RS1-DSS1</incoming>
      <outgoing>DSS1-AJ1</outgoing>
    </task>
    <parallelGateway id="Par13" name="PAR">
      <incoming>CS1-Par13</incoming>
      <outgoing>Par13-PC1</outgoing>
      <outgoing>Par13-CSG1</outgoing>
    </parallelGateway>
    <task id="PC1" name="Produce Costumes">
      <incoming>Par13-PC1</incoming>
      <outgoing>PC1-PFE1</outgoing>
    </task>
    <task id="CSG1" name="Construct Stage">
      <incoming>Par13-CSG1</incoming>
      <outgoing>CSG1-PARCLOSE18</outgoing>
    </task>
    <task id="AJ1" name="Adjust Script">
      <incoming>DSS1-AJ1</incoming>
      <outgoing>AJ1-AF1</outgoing>
    </task>
    <task id="PFE1" name="Prepare Filming Equipment">
      <incoming>PC1-PFE1</incoming>
      <outgoing>PFE1-PARCLOSE18</outgoing>
    </task>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>CSG1-PARCLOSE18</incoming>
      <incoming>PFE1-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-PARCLOSE20</outgoing>
    </parallelGateway>
    <task id="AF1" name="Additional Filming">
      <incoming>AJ1-AF1</incoming>
      <outgoing>AF1-Par21</outgoing>
    </task>
    <parallelGateway id="PARCLOSE20" name="PARCLOSE20">
      <incoming>HS1-PARCLOSE20</incoming>
      <incoming>PARCLOSE18-PARCLOSE20</incoming>
      <outgoing>PARCLOSE20-PARCLOSE29</outgoing>
    </parallelGateway>
    <parallelGateway id="Par21" name="PAR">
      <incoming>AF1-Par21</incoming>
      <outgoing>Par21-FS1</outgoing>
      <outgoing>Par21-NWF1</outgoing>
    </parallelGateway>
    <task id="FS1" name="Film Scenes">
      <incoming>Par21-FS1</incoming>
      <outgoing>FS1-PVE1</outgoing>
    </task>
    <task id="NWF1" name="Negotiate with Festivals">
      <incoming>Par21-NWF1</incoming>
      <outgoing>NWF1-PPM1</outgoing>
    </task>
    <task id="PVE1" name="Produce Visual Effects">
      <incoming>FS1-PVE1</incoming>
      <outgoing>PVE1-PE1</outgoing>
    </task>
    <task id="PPM1" name="Produce Promotional Material">
      <incoming>NWF1-PPM1</incoming>
      <outgoing>PPM1-DM1</outgoing>
    </task>
    <task id="PE1" name="Preliminary Editing">
      <incoming>PVE1-PE1</incoming>
      <outgoing>PE1-PARCLOSE28</outgoing>
    </task>
    <task id="DM1" name="Distribute Movie">
      <incoming>PPM1-DM1</incoming>
      <outgoing>DM1-PARCLOSE28</outgoing>
    </task>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>PE1-PARCLOSE28</incoming>
      <incoming>DM1-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-PARCLOSE29</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>PARCLOSE20-PARCLOSE29</incoming>
      <incoming>PARCLOSE28-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-APP1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Advance Post-Production">
      <incoming>PARCLOSE29-APP1</incoming>
      <outgoing>APP1-RMC1</outgoing>
    </task>
    <task id="RMC1" name="Run Marketing Campaign">
      <incoming>APP1-RMC1</incoming>
      <outgoing>RMC1-FSE1</outgoing>
    </task>
    <task id="FSE1" name="Final Sound Editing">
      <incoming>RMC1-FSE1</incoming>
      <outgoing>FSE1-AFV1</outgoing>
    </task>
    <task id="AFV1" name="Approve Final Version">
      <incoming>FSE1-AFV1</incoming>
      <outgoing>AFV1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>AFV1-END</incoming>
    </endEvent>
