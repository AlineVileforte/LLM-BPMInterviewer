<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_180ab1ea-29c5-46ca-82ef-7d1318c69f1a" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-AS1</outgoing>
    </startEvent>
    <task id="AS1" name="Approve Script">
      <incoming>Default_init-AS1</incoming>
      <outgoing>AS1-SL1</outgoing>
    </task>
    <task id="SL1" name="Search Locations">
      <incoming>AS1-SL1</incoming>
      <outgoing>SL1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>SL1-Par2</incoming>
      <outgoing>Par2-BC1</outgoing>
      <outgoing>Par2-CS1</outgoing>
    </parallelGateway>
    <task id="BC1" name="Begin Casting">
      <incoming>Par2-BC1</incoming>
      <outgoing>BC1-DSS1</outgoing>
    </task>
    <task id="CS1" name="Compose Soundtrack">
      <incoming>Par2-CS1</incoming>
      <outgoing>CS1-HS1</outgoing>
    </task>
    <task id="DSS1" name="Detail Script Scenes">
      <incoming>BC1-DSS1</incoming>
      <outgoing>DSS1-RS1</outgoing>
    </task>
    <task id="HS1" name="Hire Suppliers">
      <incoming>CS1-HS1</incoming>
      <outgoing>HS1-Par10</outgoing>
    </task>
    <task id="RS1" name="Rehearse Scenes">
      <incoming>DSS1-RS1</incoming>
      <outgoing>RS1-AJ1</outgoing>
    </task>
    <parallelGateway id="Par10" name="PAR">
      <incoming>HS1-Par10</incoming>
      <outgoing>Par10-PC1</outgoing>
      <outgoing>Par10-CSG1</outgoing>
    </parallelGateway>
    <task id="PC1" name="Produce Costumes">
      <incoming>Par10-PC1</incoming>
      <outgoing>PC1-PFE1</outgoing>
    </task>
    <task id="CSG1" name="Construct Stage">
      <incoming>Par10-CSG1</incoming>
      <outgoing>CSG1-PARCLOSE16</outgoing>
    </task>
    <task id="AJ1" name="Adjust Script">
      <incoming>RS1-AJ1</incoming>
      <outgoing>AJ1-PARCLOSE18</outgoing>
    </task>
    <task id="PFE1" name="Prepare Filming Equipment">
      <incoming>PC1-PFE1</incoming>
      <outgoing>PFE1-PARCLOSE16</outgoing>
    </task>
    <parallelGateway id="PARCLOSE16" name="PARCLOSE16">
      <incoming>CSG1-PARCLOSE16</incoming>
      <incoming>PFE1-PARCLOSE16</incoming>
      <outgoing>PARCLOSE16-PARCLOSE18</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>AJ1-PARCLOSE18</incoming>
      <incoming>PARCLOSE16-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-AF1</outgoing>
    </parallelGateway>
    <task id="AF1" name="Additional Filming">
      <incoming>PARCLOSE18-AF1</incoming>
      <outgoing>AF1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>AF1-G0</incoming>
      <outgoing>G0-FS1</outgoing>
      <outgoing>G0-NWF1</outgoing>
    </exclusiveGateway>
    <task id="FS1" name="Film Scenes">
      <incoming>G0-FS1</incoming>
      <outgoing>FS1-PVE1</outgoing>
    </task>
    <task id="NWF1" name="Negotiate with Festivals">
      <incoming>G0-NWF1</incoming>
      <outgoing>NWF1-PPM1</outgoing>
    </task>
    <task id="PVE1" name="Produce Visual Effects">
      <incoming>FS1-PVE1</incoming>
      <outgoing>PVE1-PE1</outgoing>
    </task>
    <task id="PPM1" name="Produce Promotional Material">
      <incoming>NWF1-PPM1</incoming>
      <outgoing>PPM1-DM1</outgoing>
    </task>
    <task id="PE1" name="Preliminary Editing">
      <incoming>PVE1-PE1</incoming>
      <outgoing>PE1-APP1</outgoing>
    </task>
    <task id="DM1" name="Distribute Movie">
      <incoming>PPM1-DM1</incoming>
      <outgoing>DM1-XORCLOSE31</outgoing>
    </task>
    <task id="APP1" name="Advance Post-Production">
      <incoming>PE1-APP1</incoming>
      <outgoing>APP1-FSE1</outgoing>
    </task>
    <task id="FSE1" name="Final Sound Editing">
      <incoming>APP1-FSE1</incoming>
      <outgoing>FSE1-AFV1</outgoing>
    </task>
    <task id="AFV1" name="Approve Final Version">
      <incoming>FSE1-AFV1</incoming>
      <outgoing>AFV1-RMC1</outgoing>
    </task>
    <task id="RMC1" name="Run Marketing Campaign">
      <incoming>AFV1-RMC1</incoming>
      <outgoing>RMC1-XORCLOSE31</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE31" name="XORCLOSE31">
      <incoming>DM1-XORCLOSE31</incoming>
      <incoming>RMC1-XORCLOSE31</incoming>
      <outgoing>XORCLOSE31-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE31-END</incoming>
    </endEvent>
