  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-AS1</outgoing>
    </startEvent>
    <task id="AS1" name="Approve Script">
      <incoming>Default_init-AS1</incoming>
      <outgoing>AS1-BC1</outgoing>
    </task>
    <task id="BC1" name="Begin Casting">
      <incoming>AS1-BC1</incoming>
      <outgoing>BC1-DSS1</outgoing>
    </task>
    <task id="DSS1" name="Detail Script Scenes">
      <incoming>BC1-DSS1</incoming>
      <outgoing>DSS1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>DSS1-Par3</incoming>
      <outgoing>Par3-RS1</outgoing>
      <outgoing>Par3-AJ1</outgoing>
    </parallelGateway>
    <task id="RS1" name="Rehearse Scenes">
      <incoming>Par3-RS1</incoming>
      <outgoing>RS1-HS1</outgoing>
    </task>
    <task id="AJ1" name="Adjust Script">
      <incoming>Par3-AJ1</incoming>
      <outgoing>AJ1-SL1</outgoing>
    </task>
    <task id="SL1" name="Search Locations">
      <incoming>AJ1-SL1</incoming>
      <outgoing>SL1-AF1</outgoing>
    </task>
    <task id="AF1" name="Additional Filming">
      <incoming>SL1-AF1</incoming>
      <outgoing>AF1-Par12</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>AF1-Par12</incoming>
      <outgoing>Par12-CS1</outgoing>
      <outgoing>Par12-NWF1</outgoing>
    </parallelGateway>
    <task id="CS1" name="Compose Soundtrack">
      <incoming>Par12-CS1</incoming>
      <outgoing>CS1-PARCLOSE16</outgoing>
    </task>
    <task id="NWF1" name="Negotiate with Festivals">
      <incoming>Par12-NWF1</incoming>
      <outgoing>NWF1-PARCLOSE16</outgoing>
    </task>
    <task id="HS1" name="Hire Suppliers">
      <incoming>RS1-HS1</incoming>
      <outgoing>HS1-CSG1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE16" name="PARCLOSE16">
      <incoming>CS1-PARCLOSE16</incoming>
      <incoming>NWF1-PARCLOSE16</incoming>
      <outgoing>PARCLOSE16-Par18</outgoing>
    </parallelGateway>
    <task id="CSG1" name="Construct Stage">
      <incoming>HS1-CSG1</incoming>
      <outgoing>CSG1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="Par18" name="PAR">
      <incoming>PARCLOSE16-Par18</incoming>
      <outgoing>Par18-PC1</outgoing>
      <outgoing>Par18-PPM1</outgoing>
    </parallelGateway>
    <task id="PC1" name="Produce Costumes">
      <incoming>Par18-PC1</incoming>
      <outgoing>PC1-PFE1</outgoing>
    </task>
    <task id="PPM1" name="Produce Promotional Material">
      <incoming>Par18-PPM1</incoming>
      <outgoing>PPM1-PARCLOSE22</outgoing>
    </task>
    <task id="PFE1" name="Prepare Filming Equipment">
      <incoming>PC1-PFE1</incoming>
      <outgoing>PFE1-PARCLOSE22</outgoing>
    </task>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>PPM1-PARCLOSE22</incoming>
      <incoming>PFE1-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-PARCLOSE23</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>CSG1-PARCLOSE23</incoming>
      <incoming>PARCLOSE22-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-DM1</outgoing>
    </parallelGateway>
    <task id="DM1" name="Distribute Movie">
      <incoming>PARCLOSE23-DM1</incoming>
      <outgoing>DM1-FS1</outgoing>
    </task>
    <task id="FS1" name="Film Scenes">
      <incoming>DM1-FS1</incoming>
      <outgoing>FS1-PVE1</outgoing>
    </task>
    <task id="PVE1" name="Produce Visual Effects">
      <incoming>FS1-PVE1</incoming>
      <outgoing>PVE1-PE1</outgoing>
    </task>
    <task id="PE1" name="Preliminary Editing">
      <incoming>PVE1-PE1</incoming>
      <outgoing>PE1-APP1</outgoing>
    </task>
    <task id="APP1" name="Advance Post-Production">
      <incoming>PE1-APP1</incoming>
      <outgoing>APP1-Par29</outgoing>
    </task>
    <parallelGateway id="Par29" name="PAR">
      <incoming>APP1-Par29</incoming>
      <outgoing>Par29-RMC1</outgoing>
      <outgoing>Par29-FSE1</outgoing>
    </parallelGateway>
    <task id="RMC1" name="Run Marketing Campaign">
      <incoming>Par29-RMC1</incoming>
      <outgoing>RMC1-PARCLOSE33</outgoing>
    </task>
    <task id="FSE1" name="Final Sound Editing">
      <incoming>Par29-FSE1</incoming>
      <outgoing>FSE1-AFV1</outgoing>
    </task>
    <task id="AFV1" name="Approve Final Version">
      <incoming>FSE1-AFV1</incoming>
      <outgoing>AFV1-PARCLOSE33</outgoing>
    </task>
    <parallelGateway id="PARCLOSE33" name="PARCLOSE33">
      <incoming>RMC1-PARCLOSE33</incoming>
      <incoming>AFV1-PARCLOSE33</incoming>
      <outgoing>PARCLOSE33-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE33-END</incoming>
    </endEvent>
