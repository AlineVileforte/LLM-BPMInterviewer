  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-AS1</outgoing>
    </startEvent>
    <task id="AS1" name="Approve Script">
      <incoming>Default_init-AS1</incoming>
      <outgoing>AS1-SL1</outgoing>
    </task>
    <task id="SL1" name="Search Locations">
      <incoming>AS1-SL1</incoming>
      <outgoing>SL1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>SL1-Par2</incoming>
      <outgoing>Par2-BC1</outgoing>
      <outgoing>Par2-HS1</outgoing>
    </parallelGateway>
    <task id="BC1" name="Begin Casting">
      <incoming>Par2-BC1</incoming>
      <outgoing>BC1-Par5</outgoing>
    </task>
    <task id="HS1" name="Hire Suppliers">
      <incoming>Par2-HS1</incoming>
      <outgoing>HS1-Par8</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>BC1-Par5</incoming>
      <outgoing>Par5-DSS1</outgoing>
      <outgoing>Par5-CS1</outgoing>
    </parallelGateway>
    <task id="DSS1" name="Detail Script Scenes">
      <incoming>Par5-DSS1</incoming>
      <outgoing>DSS1-Par10</outgoing>
    </task>
    <task id="CS1" name="Compose Soundtrack">
