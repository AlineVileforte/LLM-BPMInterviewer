      <outgoing>PARCLOSE18-PARCLOSE33</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>RS1-PARCLOSE19</incoming>
      <incoming>AF1-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-NWF1</outgoing>
    </parallelGateway>
    <task id="NWF1" name="Negotiate with Festivals">
      <incoming>PARCLOSE19-NWF1</incoming>
      <outgoing>NWF1-FS1</outgoing>
    </task>
    <task id="FS1" name="Film Scenes">
      <incoming>NWF1-FS1</incoming>
      <outgoing>FS1-Par22</outgoing>
    </task>
    <parallelGateway id="Par22" name="PAR">
      <incoming>FS1-Par22</incoming>
      <outgoing>Par22-PVE1</outgoing>
      <outgoing>Par22-PPM1</outgoing>
    </parallelGateway>
    <task id="PVE1" name="Produce Visual Effects">
      <incoming>Par22-PVE1</incoming>
      <outgoing>PVE1-PE1</outgoing>
    </task>
    <task id="PPM1" name="Produce Promotional Material">
      <incoming>Par22-PPM1</incoming>
      <outgoing>PPM1-DM1</outgoing>
    </task>
    <task id="PE1" name="Preliminary Editing">
      <incoming>PVE1-PE1</incoming>
