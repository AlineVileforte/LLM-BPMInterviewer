    <parallelGateway id="Par10" name="PAR">
      <incoming>DSS1-Par10</incoming>
      <outgoing>Par10-RS1</outgoing>
      <outgoing>Par10-AJ1</outgoing>
    </parallelGateway>
    <task id="RS1" name="Rehearse Scenes">
      <incoming>Par10-RS1</incoming>
      <outgoing>RS1-PARCLOSE19</outgoing>
    </task>
    <task id="AJ1" name="Adjust Script">
      <incoming>Par10-AJ1</incoming>
      <outgoing>AJ1-AF1</outgoing>
    </task>
    <task id="PC1" name="Produce Costumes">
      <incoming>Par8-PC1</incoming>
      <outgoing>PC1-PFE1</outgoing>
    </task>
    <task id="CSG1" name="Construct Stage">
      <incoming>Par8-CSG1</incoming>
      <outgoing>CSG1-PARCLOSE18</outgoing>
    </task>
    <task id="AF1" name="Additional Filming">
      <incoming>AJ1-AF1</incoming>
      <outgoing>AF1-PARCLOSE19</outgoing>
    </task>
    <task id="PFE1" name="Prepare Filming Equipment">
