  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-AS1</outgoing>
    </startEvent>
    <task id="AS1" name="Approve Script">
      <incoming>Default_init-AS1</incoming>
      <outgoing>AS1-SL1</outgoing>
    </task>
    <task id="SL1" name="Search Locations">
      <incoming>AS1-SL1</incoming>
      <outgoing>SL1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>SL1-Par2</incoming>
      <outgoing>Par2-BC1</outgoing>
      <outgoing>Par2-RS1</outgoing>
    </parallelGateway>
    <task id="BC1" name="Begin Casting">
      <incoming>Par2-BC1</incoming>
      <outgoing>BC1-Par4</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>BC1-Par4</incoming>
      <outgoing>Par4-DSS1</outgoing>
      <outgoing>Par4-HS1</outgoing>
    </parallelGateway>
    <task id="DSS1" name="Detail Script Scenes">
      <incoming>Par4-DSS1</incoming>
      <outgoing>DSS1-AJ1</outgoing>
    </task>
    <task id="HS1" name="Hire Suppliers">
      <incoming>Par4-HS1</incoming>
      <outgoing>HS1-CSG1</outgoing>
    </task>
    <task id="RS1" name="Rehearse Scenes">
      <incoming>Par2-RS1</incoming>
      <outgoing>RS1-Par12</outgoing>
    </task>
    <task id="AJ1" name="Adjust Script">
      <incoming>DSS1-AJ1</incoming>
      <outgoing>AJ1-AF1</outgoing>
    </task>
    <task id="CSG1" name="Construct Stage">
      <incoming>HS1-CSG1</incoming>
      <outgoing>CSG1-PARCLOSE28</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>RS1-Par12</incoming>
      <outgoing>Par12-CS1</outgoing>
      <outgoing>Par12-PC1</outgoing>
    </parallelGateway>
    <task id="CS1" name="Compose Soundtrack">
      <incoming>Par12-CS1</incoming>
      <outgoing>CS1-PARCLOSE17</outgoing>
    </task>
    <task id="PC1" name="Produce Costumes">
      <incoming>Par12-PC1</incoming>
      <outgoing>PC1-PARCLOSE17</outgoing>
    </task>
    <task id="AF1" name="Additional Filming">
      <incoming>AJ1-AF1</incoming>
      <outgoing>AF1-Par18</outgoing>
    </task>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>CS1-PARCLOSE17</incoming>
      <incoming>PC1-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-PFE1</outgoing>
    </parallelGateway>
    <parallelGateway id="Par18" name="PAR">
      <incoming>AF1-Par18</incoming>
      <outgoing>Par18-FS1</outgoing>
      <outgoing>Par18-NWF1</outgoing>
    </parallelGateway>
    <task id="FS1" name="Film Scenes">
      <incoming>Par18-FS1</incoming>
      <outgoing>FS1-PVE1</outgoing>
    </task>
    <task id="NWF1" name="Negotiate with Festivals">
      <incoming>Par18-NWF1</incoming>
      <outgoing>NWF1-PPM1</outgoing>
    </task>
    <task id="PFE1" name="Prepare Filming Equipment">
      <incoming>PARCLOSE17-PFE1</incoming>
      <outgoing>PFE1-PARCLOSE29</outgoing>
    </task>
    <task id="PVE1" name="Produce Visual Effects">
      <incoming>FS1-PVE1</incoming>
      <outgoing>PVE1-PE1</outgoing>
    </task>
    <task id="PPM1" name="Produce Promotional Material">
      <incoming>NWF1-PPM1</incoming>
      <outgoing>PPM1-DM1</outgoing>
    </task>
    <task id="PE1" name="Preliminary Editing">
      <incoming>PVE1-PE1</incoming>
      <outgoing>PE1-PARCLOSE27</outgoing>
    </task>
    <task id="DM1" name="Distribute Movie">
      <incoming>PPM1-DM1</incoming>
      <outgoing>DM1-PARCLOSE27</outgoing>
    </task>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>PE1-PARCLOSE27</incoming>
      <incoming>DM1-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-PARCLOSE28</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>CSG1-PARCLOSE28</incoming>
      <incoming>PARCLOSE27-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-PARCLOSE29</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>PFE1-PARCLOSE29</incoming>
      <incoming>PARCLOSE28-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-APP1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Advance Post-Production">
      <incoming>PARCLOSE29-APP1</incoming>
      <outgoing>APP1-RMC1</outgoing>
    </task>
    <task id="RMC1" name="Run Marketing Campaign">
      <incoming>APP1-RMC1</incoming>
      <outgoing>RMC1-FSE1</outgoing>
    </task>
    <task id="FSE1" name="Final Sound Editing">
      <incoming>RMC1-FSE1</incoming>
      <outgoing>FSE1-AFV1</outgoing>
    </task>
    <task id="AFV1" name="Approve Final Version">
      <incoming>FSE1-AFV1</incoming>
      <outgoing>AFV1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>AFV1-END</incoming>
    </endEvent>
