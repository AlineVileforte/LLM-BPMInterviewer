  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-AS1</outgoing>
    </startEvent>
    <task id="AS1" name="Approve Script">
      <incoming>Default_init-AS1</incoming>
      <outgoing>AS1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>AS1-Par1</incoming>
      <outgoing>Par1-SL1</outgoing>
      <outgoing>Par1-BC1</outgoing>
    </parallelGateway>
    <task id="SL1" name="Search Locations">
      <incoming>Par1-SL1</incoming>
      <outgoing>SL1-CS1</outgoing>
    </task>
    <task id="BC1" name="Begin Casting">
      <incoming>Par1-BC1</incoming>
      <outgoing>BC1-Par7</outgoing>
    </task>
    <task id="CS1" name="Compose Soundtrack">
      <incoming>SL1-CS1</incoming>
      <outgoing>CS1-HS1</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>BC1-Par7</incoming>
      <outgoing>Par7-RS1</outgoing>
      <outgoing>Par7-DSS1</outgoing>
    </parallelGateway>
    <task id="RS1" name="Rehearse Scenes">
      <incoming>Par7-RS1</incoming>
      <outgoing>RS1-PARCLOSE13</outgoing>
    </task>
    <task id="DSS1" name="Detail Script Scenes">
      <incoming>Par7-DSS1</incoming>
      <outgoing>DSS1-PARCLOSE13</outgoing>
    </task>
    <task id="HS1" name="Hire Suppliers">
      <incoming>CS1-HS1</incoming>
      <outgoing>HS1-PC1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE13" name="PARCLOSE13">
      <incoming>RS1-PARCLOSE13</incoming>
      <incoming>DSS1-PARCLOSE13</incoming>
      <outgoing>PARCLOSE13-AJ1</outgoing>
    </parallelGateway>
    <task id="PC1" name="Produce Costumes">
      <incoming>HS1-PC1</incoming>
      <outgoing>PC1-Par16</outgoing>
    </task>
    <task id="AJ1" name="Adjust Script">
      <incoming>PARCLOSE13-AJ1</incoming>
      <outgoing>AJ1-AF1</outgoing>
    </task>
    <parallelGateway id="Par16" name="PAR">
      <incoming>PC1-Par16</incoming>
      <outgoing>Par16-PFE1</outgoing>
      <outgoing>Par16-CSG1</outgoing>
    </parallelGateway>
    <task id="PFE1" name="Prepare Filming Equipment">
      <incoming>Par16-PFE1</incoming>
      <outgoing>PFE1-PARCLOSE20</outgoing>
    </task>
    <task id="CSG1" name="Construct Stage">
      <incoming>Par16-CSG1</incoming>
      <outgoing>CSG1-PARCLOSE20</outgoing>
    </task>
    <task id="AF1" name="Additional Filming">
      <incoming>AJ1-AF1</incoming>
      <outgoing>AF1-NWF1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE20" name="PARCLOSE20">
      <incoming>PFE1-PARCLOSE20</incoming>
      <incoming>CSG1-PARCLOSE20</incoming>
      <outgoing>PARCLOSE20-PARCLOSE33</outgoing>
    </parallelGateway>
    <task id="NWF1" name="Negotiate with Festivals">
      <incoming>AF1-NWF1</incoming>
      <outgoing>NWF1-Par24</outgoing>
    </task>
    <parallelGateway id="Par24" name="PAR">
      <incoming>NWF1-Par24</incoming>
      <outgoing>Par24-FS1</outgoing>
      <outgoing>Par24-PPM1</outgoing>
    </parallelGateway>
    <task id="FS1" name="Film Scenes">
      <incoming>Par24-FS1</incoming>
      <outgoing>FS1-PVE1</outgoing>
    </task>
    <task id="PPM1" name="Produce Promotional Material">
      <incoming>Par24-PPM1</incoming>
      <outgoing>PPM1-DM1</outgoing>
    </task>
    <task id="PVE1" name="Produce Visual Effects">
      <incoming>FS1-PVE1</incoming>
      <outgoing>PVE1-PARCLOSE29</outgoing>
    </task>
    <task id="DM1" name="Distribute Movie">
      <incoming>PPM1-DM1</incoming>
      <outgoing>DM1-PARCLOSE29</outgoing>
    </task>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>PVE1-PARCLOSE29</incoming>
      <incoming>DM1-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-PE1</outgoing>
    </parallelGateway>
    <task id="PE1" name="Preliminary Editing">
      <incoming>PARCLOSE29-PE1</incoming>
      <outgoing>PE1-APP1</outgoing>
    </task>
    <task id="APP1" name="Advance Post-Production">
      <incoming>PE1-APP1</incoming>
      <outgoing>APP1-FSE1</outgoing>
    </task>
    <task id="FSE1" name="Final Sound Editing">
      <incoming>APP1-FSE1</incoming>
      <outgoing>FSE1-PARCLOSE33</outgoing>
    </task>
    <parallelGateway id="PARCLOSE33" name="PARCLOSE33">
      <incoming>PARCLOSE20-PARCLOSE33</incoming>
      <incoming>FSE1-PARCLOSE33</incoming>
      <outgoing>PARCLOSE33-RMC1</outgoing>
    </parallelGateway>
    <task id="RMC1" name="Run Marketing Campaign">
      <incoming>PARCLOSE33-RMC1</incoming>
      <outgoing>RMC1-AFV1</outgoing>
    </task>
    <task id="AFV1" name="Approve Final Version">
      <incoming>RMC1-AFV1</incoming>
      <outgoing>AFV1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>AFV1-END</incoming>
    </endEvent>
