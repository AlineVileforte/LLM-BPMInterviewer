<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_91ef974e-ad62-4965-9b30-e55195b4892a" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-AS1</outgoing>
    </startEvent>
    <task id="AS1" name="Approve Script">
      <incoming>Default_init-AS1</incoming>
      <outgoing>AS1-SL1</outgoing>
    </task>
    <task id="SL1" name="Search Locations">
      <incoming>AS1-SL1</incoming>
      <outgoing>SL1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>SL1-Par2</incoming>
      <outgoing>Par2-HS1</outgoing>
      <outgoing>Par2-CSG1</outgoing>
    </parallelGateway>
    <task id="HS1" name="Hire Suppliers">
      <incoming>Par2-HS1</incoming>
      <outgoing>HS1-Par4</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>HS1-Par4</incoming>
      <outgoing>Par4-PC1</outgoing>
      <outgoing>Par4-CS1</outgoing>
    </parallelGateway>
    <task id="PC1" name="Produce Costumes">
      <incoming>Par4-PC1</incoming>
      <outgoing>PC1-BC1</outgoing>
    </task>
    <task id="CSG1" name="Construct Stage">
      <incoming>Par2-CSG1</incoming>
      <outgoing>CSG1-PFE1</outgoing>
    </task>
    <task id="BC1" name="Begin Casting">
      <incoming>PC1-BC1</incoming>
      <outgoing>BC1-Par10</outgoing>
    </task>
    <task id="CS1" name="Compose Soundtrack">
      <incoming>Par4-CS1</incoming>
      <outgoing>CS1-PARCLOSE23</outgoing>
    </task>
    <task id="PFE1" name="Prepare Filming Equipment">
      <incoming>CSG1-PFE1</incoming>
      <outgoing>PFE1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="Par10" name="PAR">
      <incoming>BC1-Par10</incoming>
      <outgoing>Par10-RS1</outgoing>
      <outgoing>Par10-DSS1</outgoing>
    </parallelGateway>
    <task id="RS1" name="Rehearse Scenes">
      <incoming>Par10-RS1</incoming>
      <outgoing>RS1-PARCLOSE22</outgoing>
    </task>
    <task id="DSS1" name="Detail Script Scenes">
      <incoming>Par10-DSS1</incoming>
      <outgoing>DSS1-AJ1</outgoing>
    </task>
    <task id="AJ1" name="Adjust Script">
      <incoming>DSS1-AJ1</incoming>
      <outgoing>AJ1-AF1</outgoing>
    </task>
    <task id="AF1" name="Additional Filming">
      <incoming>AJ1-AF1</incoming>
      <outgoing>AF1-NWF1</outgoing>
    </task>
    <task id="NWF1" name="Negotiate with Festivals">
      <incoming>AF1-NWF1</incoming>
      <outgoing>NWF1-PPM1</outgoing>
    </task>
    <task id="PPM1" name="Produce Promotional Material">
      <incoming>NWF1-PPM1</incoming>
      <outgoing>PPM1-DM1</outgoing>
    </task>
    <task id="DM1" name="Distribute Movie">
      <incoming>PPM1-DM1</incoming>
      <outgoing>DM1-PARCLOSE22</outgoing>
    </task>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>RS1-PARCLOSE22</incoming>
      <incoming>DM1-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-PARCLOSE23</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>CS1-PARCLOSE23</incoming>
      <incoming>PARCLOSE22-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-FS1</outgoing>
    </parallelGateway>
    <task id="FS1" name="Film Scenes">
      <incoming>PARCLOSE23-FS1</incoming>
      <outgoing>FS1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>PFE1-PARCLOSE25</incoming>
      <incoming>FS1-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-PVE1</outgoing>
    </parallelGateway>
    <task id="PVE1" name="Produce Visual Effects">
      <incoming>PARCLOSE25-PVE1</incoming>
      <outgoing>PVE1-PE1</outgoing>
    </task>
    <task id="PE1" name="Preliminary Editing">
      <incoming>PVE1-PE1</incoming>
      <outgoing>PE1-APP1</outgoing>
    </task>
    <task id="APP1" name="Advance Post-Production">
      <incoming>PE1-APP1</incoming>
      <outgoing>APP1-RMC1</outgoing>
    </task>
    <task id="RMC1" name="Run Marketing Campaign">
      <incoming>APP1-RMC1</incoming>
      <outgoing>RMC1-FSE1</outgoing>
    </task>
    <task id="FSE1" name="Final Sound Editing">
      <incoming>RMC1-FSE1</incoming>
      <outgoing>FSE1-AFV1</outgoing>
    </task>
    <task id="AFV1" name="Approve Final Version">
      <incoming>FSE1-AFV1</incoming>
      <outgoing>AFV1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>AFV1-END</incoming>
    </endEvent>
