  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-AS1</outgoing>
    </startEvent>
    <task id="AS1" name="Approve Script">
      <incoming>Default_init-AS1</incoming>
      <outgoing>AS1-BC1</outgoing>
    </task>
    <task id="BC1" name="Begin Casting">
      <incoming>AS1-BC1</incoming>
      <outgoing>BC1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>BC1-Par2</incoming>
      <outgoing>Par2-SL1</outgoing>
      <outgoing>Par2-DSS1</outgoing>
    </parallelGateway>
    <task id="SL1" name="Search Locations">
      <incoming>Par2-SL1</incoming>
      <outgoing>SL1-Par8</outgoing>
    </task>
    <task id="DSS1" name="Detail Script Scenes">
      <incoming>Par2-DSS1</incoming>
      <outgoing>DSS1-RS1</outgoing>
    </task>
    <task id="RS1" name="Rehearse Scenes">
      <incoming>DSS1-RS1</incoming>
      <outgoing>RS1-AJ1</outgoing>
    </task>
    <parallelGateway id="Par8" name="PAR">
      <incoming>SL1-Par8</incoming>
      <outgoing>Par8-CS1</outgoing>
      <outgoing>Par8-HS1</outgoing>
    </parallelGateway>
    <task id="CS1" name="Compose Soundtrack">
      <incoming>Par8-CS1</incoming>
      <outgoing>CS1-PARCLOSE19</outgoing>
    </task>
    <task id="HS1" name="Hire Suppliers">
      <incoming>Par8-HS1</incoming>
      <outgoing>HS1-Par13</outgoing>
    </task>
    <task id="AJ1" name="Adjust Script">
      <incoming>RS1-AJ1</incoming>
      <outgoing>AJ1-AF1</outgoing>
    </task>
    <parallelGateway id="Par13" name="PAR">
      <incoming>HS1-Par13</incoming>
      <outgoing>Par13-PC1</outgoing>
      <outgoing>Par13-CSG1</outgoing>
    </parallelGateway>
    <task id="PC1" name="Produce Costumes">
      <incoming>Par13-PC1</incoming>
      <outgoing>PC1-PARCLOSE17</outgoing>
    </task>
    <task id="CSG1" name="Construct Stage">
      <incoming>Par13-CSG1</incoming>
      <outgoing>CSG1-PARCLOSE17</outgoing>
    </task>
    <task id="AF1" name="Additional Filming">
      <incoming>AJ1-AF1</incoming>
      <outgoing>AF1-NWF1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>PC1-PARCLOSE17</incoming>
      <incoming>CSG1-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-PARCLOSE19</outgoing>
    </parallelGateway>
    <task id="NWF1" name="Negotiate with Festivals">
      <incoming>AF1-NWF1</incoming>
      <outgoing>NWF1-Par20</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>CS1-PARCLOSE19</incoming>
      <incoming>PARCLOSE17-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-PFE1</outgoing>
    </parallelGateway>
    <parallelGateway id="Par20" name="PAR">
      <incoming>NWF1-Par20</incoming>
      <outgoing>Par20-FS1</outgoing>
      <outgoing>Par20-PPM1</outgoing>
    </parallelGateway>
    <task id="FS1" name="Film Scenes">
      <incoming>Par20-FS1</incoming>
      <outgoing>FS1-PVE1</outgoing>
    </task>
    <task id="PPM1" name="Produce Promotional Material">
      <incoming>Par20-PPM1</incoming>
      <outgoing>PPM1-DM1</outgoing>
    </task>
    <task id="PVE1" name="Produce Visual Effects">
      <incoming>FS1-PVE1</incoming>
      <outgoing>PVE1-PE1</outgoing>
    </task>
    <task id="DM1" name="Distribute Movie">
      <incoming>PPM1-DM1</incoming>
      <outgoing>DM1-PARCLOSE28</outgoing>
    </task>
    <task id="PFE1" name="Prepare Filming Equipment">
      <incoming>PARCLOSE19-PFE1</incoming>
      <outgoing>PFE1-PARCLOSE30</outgoing>
    </task>
    <task id="PE1" name="Preliminary Editing">
      <incoming>PVE1-PE1</incoming>
      <outgoing>PE1-PARCLOSE28</outgoing>
    </task>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>DM1-PARCLOSE28</incoming>
      <incoming>PE1-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-APP1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Advance Post-Production">
      <incoming>PARCLOSE28-APP1</incoming>
      <outgoing>APP1-PARCLOSE30</outgoing>
    </task>
    <parallelGateway id="PARCLOSE30" name="PARCLOSE30">
      <incoming>PFE1-PARCLOSE30</incoming>
      <incoming>APP1-PARCLOSE30</incoming>
      <outgoing>PARCLOSE30-Par31</outgoing>
    </parallelGateway>
    <parallelGateway id="Par31" name="PAR">
      <incoming>PARCLOSE30-Par31</incoming>
      <outgoing>Par31-RMC1</outgoing>
      <outgoing>Par31-FSE1</outgoing>
    </parallelGateway>
    <task id="RMC1" name="Run Marketing Campaign">
      <incoming>Par31-RMC1</incoming>
      <outgoing>RMC1-PARCLOSE34</outgoing>
    </task>
    <task id="FSE1" name="Final Sound Editing">
      <incoming>Par31-FSE1</incoming>
      <outgoing>FSE1-PARCLOSE34</outgoing>
    </task>
    <parallelGateway id="PARCLOSE34" name="PARCLOSE34">
      <incoming>RMC1-PARCLOSE34</incoming>
      <incoming>FSE1-PARCLOSE34</incoming>
      <outgoing>PARCLOSE34-AFV1</outgoing>
    </parallelGateway>
    <task id="AFV1" name="Approve Final Version">
      <incoming>PARCLOSE34-AFV1</incoming>
      <outgoing>AFV1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>AFV1-END</incoming>
    </endEvent>
