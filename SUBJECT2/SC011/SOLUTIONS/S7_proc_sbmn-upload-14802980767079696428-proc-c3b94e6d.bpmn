  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-AS1</outgoing>
    </startEvent>
    <task id="AS1" name="Approve Script">
      <incoming>Default_init-AS1</incoming>
      <outgoing>AS1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>AS1-Par1</incoming>
      <outgoing>Par1-SL1</outgoing>
      <outgoing>Par1-BC1</outgoing>
    </parallelGateway>
    <task id="SL1" name="Search Locations">
      <incoming>Par1-SL1</incoming>
      <outgoing>SL1-Par4</outgoing>
    </task>
    <task id="BC1" name="Begin Casting">
      <incoming>Par1-BC1</incoming>
      <outgoing>BC1-RS1</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>SL1-Par4</incoming>
      <outgoing>Par4-Par7</outgoing>
      <outgoing>Par4-PC1</outgoing>
    </parallelGateway>
    <task id="RS1" name="Rehearse Scenes">
      <incoming>BC1-RS1</incoming>
      <outgoing>RS1-DSS1</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>Par4-Par7</incoming>
      <outgoing>Par7-HS1</outgoing>
      <outgoing>Par7-CS1</outgoing>
    </parallelGateway>
    <task id="HS1" name="Hire Suppliers">
      <incoming>Par7-HS1</incoming>
      <outgoing>HS1-CSG1</outgoing>
    </task>
    <task id="DSS1" name="Detail Script Scenes">
      <incoming>RS1-DSS1</incoming>
      <outgoing>DSS1-AJ1</outgoing>
    </task>
    <task id="CSG1" name="Construct Stage">
      <incoming>HS1-CSG1</incoming>
      <outgoing>CSG1-PARCLOSE19</outgoing>
    </task>
    <task id="CS1" name="Compose Soundtrack">
      <incoming>Par7-CS1</incoming>
      <outgoing>CS1-PARCLOSE19</outgoing>
    </task>
    <task id="PC1" name="Produce Costumes">
      <incoming>Par4-PC1</incoming>
      <outgoing>PC1-PFE1</outgoing>
    </task>
    <task id="AJ1" name="Adjust Script">
      <incoming>DSS1-AJ1</incoming>
      <outgoing>AJ1-AF1</outgoing>
    </task>
    <task id="PFE1" name="Prepare Filming Equipment">
      <incoming>PC1-PFE1</incoming>
      <outgoing>PFE1-PARCLOSE20</outgoing>
    </task>
    <task id="AF1" name="Additional Filming">
      <incoming>AJ1-AF1</incoming>
      <outgoing>AF1-FS1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>CSG1-PARCLOSE19</incoming>
      <incoming>CS1-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-PARCLOSE20</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE20" name="PARCLOSE20">
      <incoming>PFE1-PARCLOSE20</incoming>
      <incoming>PARCLOSE19-PARCLOSE20</incoming>
      <outgoing>PARCLOSE20-PARCLOSE32</outgoing>
    </parallelGateway>
    <task id="FS1" name="Film Scenes">
      <incoming>AF1-FS1</incoming>
      <outgoing>FS1-PVE1</outgoing>
    </task>
    <task id="PVE1" name="Produce Visual Effects">
      <incoming>FS1-PVE1</incoming>
      <outgoing>PVE1-NWF1</outgoing>
    </task>
    <task id="NWF1" name="Negotiate with Festivals">
      <incoming>PVE1-NWF1</incoming>
      <outgoing>NWF1-Par24</outgoing>
    </task>
    <parallelGateway id="Par24" name="PAR">
      <incoming>NWF1-Par24</incoming>
      <outgoing>Par24-PE1</outgoing>
      <outgoing>Par24-PPM1</outgoing>
    </parallelGateway>
    <task id="PE1" name="Preliminary Editing">
      <incoming>Par24-PE1</incoming>
      <outgoing>PE1-APP1</outgoing>
    </task>
    <task id="PPM1" name="Produce Promotional Material">
      <incoming>Par24-PPM1</incoming>
      <outgoing>PPM1-DM1</outgoing>
    </task>
    <task id="APP1" name="Advance Post-Production">
      <incoming>PE1-APP1</incoming>
      <outgoing>APP1-RMC1</outgoing>
    </task>
    <task id="DM1" name="Distribute Movie">
      <incoming>PPM1-DM1</incoming>
      <outgoing>DM1-PARCLOSE30</outgoing>
    </task>
    <task id="RMC1" name="Run Marketing Campaign">
      <incoming>APP1-RMC1</incoming>
      <outgoing>RMC1-PARCLOSE30</outgoing>
    </task>
    <parallelGateway id="PARCLOSE30" name="PARCLOSE30">
      <incoming>DM1-PARCLOSE30</incoming>
      <incoming>RMC1-PARCLOSE30</incoming>
      <outgoing>PARCLOSE30-FSE1</outgoing>
    </parallelGateway>
    <task id="FSE1" name="Final Sound Editing">
      <incoming>PARCLOSE30-FSE1</incoming>
      <outgoing>FSE1-PARCLOSE32</outgoing>
    </task>
    <parallelGateway id="PARCLOSE32" name="PARCLOSE32">
      <incoming>PARCLOSE20-PARCLOSE32</incoming>
      <incoming>FSE1-PARCLOSE32</incoming>
      <outgoing>PARCLOSE32-AFV1</outgoing>
    </parallelGateway>
    <task id="AFV1" name="Approve Final Version">
      <incoming>PARCLOSE32-AFV1</incoming>
      <outgoing>AFV1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>AFV1-END</incoming>
    </endEvent>
