  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-AS1</outgoing>
    </startEvent>
    <task id="AS1" name="Approve Script">
      <incoming>Default_init-AS1</incoming>
      <outgoing>AS1-SL1</outgoing>
    </task>
    <task id="SL1" name="Search Locations">
      <incoming>AS1-SL1</incoming>
      <outgoing>SL1-CS1</outgoing>
    </task>
    <task id="CS1" name="Compose Soundtrack">
      <incoming>SL1-CS1</incoming>
      <outgoing>CS1-HS1</outgoing>
    </task>
    <task id="HS1" name="Hire Suppliers">
      <incoming>CS1-HS1</incoming>
      <outgoing>HS1-Par4</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>HS1-Par4</incoming>
      <outgoing>Par4-CSG1</outgoing>
      <outgoing>Par4-PC1</outgoing>
    </parallelGateway>
    <task id="CSG1" name="Construct Stage">
      <incoming>Par4-CSG1</incoming>
      <outgoing>CSG1-BC1</outgoing>
    </task>
    <task id="BC1" name="Begin Casting">
      <incoming>CSG1-BC1</incoming>
      <outgoing>BC1-RS1</outgoing>
    </task>
    <task id="PC1" name="Produce Costumes">
      <incoming>Par4-PC1</incoming>
      <outgoing>PC1-Par9</outgoing>
    </task>
    <task id="RS1" name="Rehearse Scenes">
      <incoming>BC1-RS1</incoming>
      <outgoing>RS1-PARCLOSE31</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>PC1-Par9</incoming>
      <outgoing>Par9-DSS1</outgoing>
      <outgoing>Par9-PFE1</outgoing>
    </parallelGateway>
    <task id="DSS1" name="Detail Script Scenes">
      <incoming>Par9-DSS1</incoming>
      <outgoing>DSS1-AJ1</outgoing>
    </task>
    <task id="PFE1" name="Prepare Filming Equipment">
      <incoming>Par9-PFE1</incoming>
      <outgoing>PFE1-PARCLOSE19</outgoing>
    </task>
    <task id="AJ1" name="Adjust Script">
      <incoming>DSS1-AJ1</incoming>
      <outgoing>AJ1-AF1</outgoing>
    </task>
    <task id="AF1" name="Additional Filming">
      <incoming>AJ1-AF1</incoming>
      <outgoing>AF1-NWF1</outgoing>
    </task>
    <task id="NWF1" name="Negotiate with Festivals">
      <incoming>AF1-NWF1</incoming>
      <outgoing>NWF1-PARCLOSE19</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>PFE1-PARCLOSE19</incoming>
      <incoming>NWF1-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-Par20</outgoing>
    </parallelGateway>
    <parallelGateway id="Par20" name="PAR">
      <incoming>PARCLOSE19-Par20</incoming>
      <outgoing>Par20-FS1</outgoing>
      <outgoing>Par20-PPM1</outgoing>
    </parallelGateway>
    <task id="FS1" name="Film Scenes">
      <incoming>Par20-FS1</incoming>
      <outgoing>FS1-PVE1</outgoing>
    </task>
    <task id="PPM1" name="Produce Promotional Material">
      <incoming>Par20-PPM1</incoming>
      <outgoing>PPM1-DM1</outgoing>
    </task>
    <task id="PVE1" name="Produce Visual Effects">
      <incoming>FS1-PVE1</incoming>
      <outgoing>PVE1-PE1</outgoing>
    </task>
    <task id="DM1" name="Distribute Movie">
      <incoming>PPM1-DM1</incoming>
      <outgoing>DM1-PARCLOSE29</outgoing>
    </task>
    <task id="PE1" name="Preliminary Editing">
      <incoming>PVE1-PE1</incoming>
      <outgoing>PE1-APP1</outgoing>
    </task>
    <task id="APP1" name="Advance Post-Production">
      <incoming>PE1-APP1</incoming>
      <outgoing>APP1-RMC1</outgoing>
    </task>
    <task id="RMC1" name="Run Marketing Campaign">
      <incoming>APP1-RMC1</incoming>
      <outgoing>RMC1-FSE1</outgoing>
    </task>
    <task id="FSE1" name="Final Sound Editing">
      <incoming>RMC1-FSE1</incoming>
      <outgoing>FSE1-PARCLOSE29</outgoing>
    </task>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>DM1-PARCLOSE29</incoming>
      <incoming>FSE1-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-AFV1</outgoing>
    </parallelGateway>
    <task id="AFV1" name="Approve Final Version">
      <incoming>PARCLOSE29-AFV1</incoming>
      <outgoing>AFV1-PARCLOSE31</outgoing>
    </task>
    <parallelGateway id="PARCLOSE31" name="PARCLOSE31">
      <incoming>RS1-PARCLOSE31</incoming>
      <incoming>AFV1-PARCLOSE31</incoming>
      <outgoing>PARCLOSE31-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE31-END</incoming>
    </endEvent>
