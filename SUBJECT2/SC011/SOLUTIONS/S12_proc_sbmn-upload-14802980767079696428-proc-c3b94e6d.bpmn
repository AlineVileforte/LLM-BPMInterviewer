  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-AS1</outgoing>
    </startEvent>
    <task id="AS1" name="Approve Script">
      <incoming>Default_init-AS1</incoming>
      <outgoing>AS1-SL1</outgoing>
    </task>
    <task id="SL1" name="Search Locations">
      <incoming>AS1-SL1</incoming>
      <outgoing>SL1-BC1</outgoing>
    </task>
    <task id="BC1" name="Begin Casting">
      <incoming>SL1-BC1</incoming>
      <outgoing>BC1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>BC1-Par3</incoming>
      <outgoing>Par3-DSS1</outgoing>
      <outgoing>Par3-HS1</outgoing>
    </parallelGateway>
    <task id="DSS1" name="Detail Script Scenes">
      <incoming>Par3-DSS1</incoming>
      <outgoing>DSS1-Par6</outgoing>
    </task>
    <task id="HS1" name="Hire Suppliers">
      <incoming>Par3-HS1</incoming>
      <outgoing>HS1-Par9</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>DSS1-Par6</incoming>
      <outgoing>Par6-AJ1</outgoing>
      <outgoing>Par6-CS1</outgoing>
    </parallelGateway>
    <task id="AJ1" name="Adjust Script">
      <incoming>Par6-AJ1</incoming>
      <outgoing>AJ1-AF1</outgoing>
    </task>
    <task id="CS1" name="Compose Soundtrack">
      <incoming>Par6-CS1</incoming>
      <outgoing>CS1-RS1</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>HS1-Par9</incoming>
      <outgoing>Par9-PC1</outgoing>
      <outgoing>Par9-CSG1</outgoing>
    </parallelGateway>
    <task id="AF1" name="Additional Filming">
      <incoming>AJ1-AF1</incoming>
      <outgoing>AF1-NWF1</outgoing>
    </task>
    <task id="RS1" name="Rehearse Scenes">
      <incoming>CS1-RS1</incoming>
      <outgoing>RS1-PARCLOSE26</outgoing>
    </task>
    <task id="PC1" name="Produce Costumes">
      <incoming>Par9-PC1</incoming>
      <outgoing>PC1-PFE1</outgoing>
    </task>
    <task id="CSG1" name="Construct Stage">
      <incoming>Par9-CSG1</incoming>
      <outgoing>CSG1-PARCLOSE21</outgoing>
    </task>
    <task id="NWF1" name="Negotiate with Festivals">
      <incoming>AF1-NWF1</incoming>
      <outgoing>NWF1-PPM1</outgoing>
    </task>
    <task id="PFE1" name="Prepare Filming Equipment">
      <incoming>PC1-PFE1</incoming>
      <outgoing>PFE1-PARCLOSE21</outgoing>
    </task>
    <task id="PPM1" name="Produce Promotional Material">
      <incoming>NWF1-PPM1</incoming>
      <outgoing>PPM1-Par22</outgoing>
    </task>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>CSG1-PARCLOSE21</incoming>
      <incoming>PFE1-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-PARCLOSE29</outgoing>
    </parallelGateway>
    <parallelGateway id="Par22" name="PAR">
      <incoming>PPM1-Par22</incoming>
      <outgoing>Par22-FS1</outgoing>
      <outgoing>Par22-DM1</outgoing>
    </parallelGateway>
    <task id="FS1" name="Film Scenes">
      <incoming>Par22-FS1</incoming>
      <outgoing>FS1-PARCLOSE25</outgoing>
    </task>
    <task id="DM1" name="Distribute Movie">
      <incoming>Par22-DM1</incoming>
      <outgoing>DM1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>FS1-PARCLOSE25</incoming>
      <incoming>DM1-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-PARCLOSE26</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>RS1-PARCLOSE26</incoming>
      <incoming>PARCLOSE25-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-PVE1</outgoing>
    </parallelGateway>
    <task id="PVE1" name="Produce Visual Effects">
      <incoming>PARCLOSE26-PVE1</incoming>
      <outgoing>PVE1-PE1</outgoing>
    </task>
    <task id="PE1" name="Preliminary Editing">
      <incoming>PVE1-PE1</incoming>
      <outgoing>PE1-PARCLOSE29</outgoing>
    </task>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>PARCLOSE21-PARCLOSE29</incoming>
      <incoming>PE1-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-APP1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Advance Post-Production">
      <incoming>PARCLOSE29-APP1</incoming>
      <outgoing>APP1-Par31</outgoing>
    </task>
    <parallelGateway id="Par31" name="PAR">
      <incoming>APP1-Par31</incoming>
      <outgoing>Par31-RMC1</outgoing>
      <outgoing>Par31-FSE1</outgoing>
    </parallelGateway>
    <task id="RMC1" name="Run Marketing Campaign">
      <incoming>Par31-RMC1</incoming>
      <outgoing>RMC1-PARCLOSE34</outgoing>
    </task>
    <task id="FSE1" name="Final Sound Editing">
      <incoming>Par31-FSE1</incoming>
      <outgoing>FSE1-PARCLOSE34</outgoing>
    </task>
    <parallelGateway id="PARCLOSE34" name="PARCLOSE34">
      <incoming>RMC1-PARCLOSE34</incoming>
      <incoming>FSE1-PARCLOSE34</incoming>
      <outgoing>PARCLOSE34-AFV1</outgoing>
    </parallelGateway>
    <task id="AFV1" name="Approve Final Version">
      <incoming>PARCLOSE34-AFV1</incoming>
      <outgoing>AFV1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>AFV1-END</incoming>
    </endEvent>
