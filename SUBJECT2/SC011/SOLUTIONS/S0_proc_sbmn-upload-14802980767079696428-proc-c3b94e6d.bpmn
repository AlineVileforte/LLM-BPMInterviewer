  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-AS1</outgoing>
    </startEvent>
    <task id="AS1" name="Approve Script">
      <incoming>Default_init-AS1</incoming>
      <outgoing>AS1-SL1</outgoing>
    </task>
    <task id="SL1" name="Search Locations">
      <incoming>AS1-SL1</incoming>
      <outgoing>SL1-CS1</outgoing>
    </task>
    <task id="CS1" name="Compose Soundtrack">
      <incoming>SL1-CS1</incoming>
      <outgoing>CS1-Par4</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>CS1-Par4</incoming>
      <outgoing>Par4-BC1</outgoing>
      <outgoing>Par4-HS1</outgoing>
    </parallelGateway>
    <task id="BC1" name="Begin Casting">
      <incoming>Par4-BC1</incoming>
      <outgoing>BC1-Par7</outgoing>
    </task>
    <task id="HS1" name="Hire Suppliers">
      <incoming>Par4-HS1</incoming>
      <outgoing>HS1-Par10</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>BC1-Par7</incoming>
      <outgoing>Par7-RS1</outgoing>
      <outgoing>Par7-DSS1</outgoing>
    </parallelGateway>
    <task id="RS1" name="Rehearse Scenes">
      <incoming>Par7-RS1</incoming>
      <outgoing>RS1-PARCLOSE13</outgoing>
    </task>
    <task id="DSS1" name="Detail Script Scenes">
      <incoming>Par7-DSS1</incoming>
      <outgoing>DSS1-PARCLOSE13</outgoing>
    </task>
    <parallelGateway id="Par10" name="PAR">
      <incoming>HS1-Par10</incoming>
      <outgoing>Par10-PC1</outgoing>
      <outgoing>Par10-CSG1</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE13" name="PARCLOSE13">
      <incoming>RS1-PARCLOSE13</incoming>
      <incoming>DSS1-PARCLOSE13</incoming>
      <outgoing>PARCLOSE13-AJ1</outgoing>
    </parallelGateway>
    <task id="CSG1" name="Construct Stage">
      <incoming>Par10-CSG1</incoming>
      <outgoing>CSG1-PARCLOSE19</outgoing>
    </task>
    <task id="PC1" name="Produce Costumes">
      <incoming>Par10-PC1</incoming>
      <outgoing>PC1-PFE1</outgoing>
    </task>
    <task id="AJ1" name="Adjust Script">
      <incoming>PARCLOSE13-AJ1</incoming>
      <outgoing>AJ1-AF1</outgoing>
    </task>
    <task id="PFE1" name="Prepare Filming Equipment">
      <incoming>PC1-PFE1</incoming>
      <outgoing>PFE1-PARCLOSE19</outgoing>
    </task>
    <task id="AF1" name="Additional Filming">
      <incoming>AJ1-AF1</incoming>
      <outgoing>AF1-G0</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>CSG1-PARCLOSE19</incoming>
      <incoming>PFE1-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-PARCLOSE34</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G0" name="G0">
      <incoming>AF1-G0</incoming>
      <outgoing>G0-FS1</outgoing>
      <outgoing>G0-NWF1</outgoing>
    </exclusiveGateway>
    <task id="FS1" name="Film Scenes">
      <incoming>G0-FS1</incoming>
      <outgoing>FS1-PVE1</outgoing>
    </task>
    <task id="NWF1" name="Negotiate with Festivals">
      <incoming>G0-NWF1</incoming>
      <outgoing>NWF1-PPM1</outgoing>
    </task>
    <task id="PVE1" name="Produce Visual Effects">
      <incoming>FS1-PVE1</incoming>
      <outgoing>PVE1-PE1</outgoing>
    </task>
    <task id="PPM1" name="Produce Promotional Material">
      <incoming>NWF1-PPM1</incoming>
      <outgoing>PPM1-DM1</outgoing>
    </task>
    <task id="PE1" name="Preliminary Editing">
      <incoming>PVE1-PE1</incoming>
      <outgoing>PE1-APP1</outgoing>
    </task>
    <task id="DM1" name="Distribute Movie">
      <incoming>PPM1-DM1</incoming>
      <outgoing>DM1-XORCLOSE33</outgoing>
    </task>
    <task id="APP1" name="Advance Post-Production">
      <incoming>PE1-APP1</incoming>
      <outgoing>APP1-Par28</outgoing>
    </task>
    <parallelGateway id="Par28" name="PAR">
      <incoming>APP1-Par28</incoming>
      <outgoing>Par28-FSE1</outgoing>
      <outgoing>Par28-RMC1</outgoing>
    </parallelGateway>
    <task id="FSE1" name="Final Sound Editing">
      <incoming>Par28-FSE1</incoming>
      <outgoing>FSE1-AFV1</outgoing>
    </task>
    <task id="RMC1" name="Run Marketing Campaign">
      <incoming>Par28-RMC1</incoming>
      <outgoing>RMC1-PARCLOSE32</outgoing>
    </task>
    <task id="AFV1" name="Approve Final Version">
      <incoming>FSE1-AFV1</incoming>
      <outgoing>AFV1-PARCLOSE32</outgoing>
    </task>
    <parallelGateway id="PARCLOSE32" name="PARCLOSE32">
      <incoming>RMC1-PARCLOSE32</incoming>
      <incoming>AFV1-PARCLOSE32</incoming>
      <outgoing>PARCLOSE32-XORCLOSE33</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE33" name="XORCLOSE33">
      <incoming>DM1-XORCLOSE33</incoming>
      <incoming>PARCLOSE32-XORCLOSE33</incoming>
      <outgoing>XORCLOSE33-PARCLOSE34</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE34" name="PARCLOSE34">
      <incoming>PARCLOSE19-PARCLOSE34</incoming>
      <incoming>XORCLOSE33-PARCLOSE34</incoming>
      <outgoing>PARCLOSE34-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE34-END</incoming>
    </endEvent>
