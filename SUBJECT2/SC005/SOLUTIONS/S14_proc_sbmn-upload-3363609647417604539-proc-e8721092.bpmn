<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_a4be1890-9703-4ce0-affa-541af175a580" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CCIL1</outgoing>
    </startEvent>
    <task id="CCIL1" name="Check Current Inventory Level">
      <incoming>Default_init-CCIL1</incoming>
      <outgoing>CCIL1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CCIL1-G0</incoming>
      <outgoing>G0-CPO1</outgoing>
      <outgoing>G0-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="CPO1" name="Create Purchase Order">
      <incoming>G0-CPO1</incoming>
      <outgoing>CPO1-XOR_JMPBB_RWPO1_RPO1</outgoing>
    </task>
    <task id="RPO1" name="Review Purchase Order">
      <incoming>XOR_JMPBB_RWPO1_RPO1-RPO1</incoming>
      <outgoing>RPO1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>RPO1-G1</incoming>
      <outgoing>G1-APO1</outgoing>
      <outgoing>G1-RWPO1</outgoing>
    </exclusiveGateway>
    <task id="RWPO1" name="Rework Purchase Order">
      <incoming>G1-RWPO1</incoming>
      <outgoing>RWPO1-XOR_JMPAA_RWPO1_RPO1</outgoing>
    </task>
    <task id="APO1" name="Accept Purchase Order">
      <incoming>G1-APO1</incoming>
      <outgoing>APO1-RPF1</outgoing>
    </task>
    <task id="RPF1" name="Reserve Purchase Funds">
      <incoming>APO1-RPF1</incoming>
      <outgoing>RPF1-SPOS1</outgoing>
    </task>
    <task id="SPOS1" name="Send Purchase Order to Supplier">
      <incoming>RPF1-SPOS1</incoming>
      <outgoing>SPOS1-ROPS1</outgoing>
    </task>
    <task id="ROPS1" name="Receive Order Packing Slip">
      <incoming>SPOS1-ROPS1</incoming>
      <outgoing>ROPS1-ROI1</outgoing>
    </task>
    <task id="ROI1" name="Receive Order Invoice">
      <incoming>ROPS1-ROI1</incoming>
      <outgoing>ROI1-ROPS_REC1</outgoing>
    </task>
    <task id="ROPS_REC1" name="Record Order Packing Slip">
      <incoming>ROI1-ROPS_REC1</incoming>
      <outgoing>ROPS_REC1-ROI_REC1</outgoing>
    </task>
    <task id="ROI_REC1" name="Record Order Invoice">
      <incoming>ROPS_REC1-ROI_REC1</incoming>
      <outgoing>ROI_REC1-RF1</outgoing>
    </task>
    <task id="RF1" name="Release Funds">
      <incoming>ROI_REC1-RF1</incoming>
      <outgoing>RF1-IPTS1</outgoing>
    </task>
    <task id="IPTS1" name="Issue Payment to Supplier">
      <incoming>RF1-IPTS1</incoming>
      <outgoing>IPTS1-XORCLOSE16</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
      <incoming>IPTS1-XORCLOSE16</incoming>
      <incoming>XOR_JMPAA_RWPO1_RPO1-XORCLOSE16</incoming>
      <outgoing>XORCLOSE16-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE17" name="XORCLOSE17">
      <incoming>G0-XORCLOSE17</incoming>
      <incoming>XORCLOSE16-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE17-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_RWPO1_RPO1" name="XOR_JMPAA_Rework Purchase Order">
      <incoming>RWPO1-XOR_JMPAA_RWPO1_RPO1</incoming>
      <outgoing>XOR_JMPAA_RWPO1_RPO1-XORCLOSE16</outgoing>
      <outgoing>XOR_JMPAA_RWPO1_RPO1-XOR_JMPBB_RWPO1_RPO1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_RWPO1_RPO1" name="XOR_JMPBB_Review Purchase Order">
      <incoming>CPO1-XOR_JMPBB_RWPO1_RPO1</incoming>
      <incoming>XOR_JMPAA_RWPO1_RPO1-XOR_JMPBB_RWPO1_RPO1</incoming>
      <outgoing>XOR_JMPBB_RWPO1_RPO1-RPO1</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Default_init-CCIL1" sourceRef="Default_init" targetRef="CCIL1"/>
    <sequenceFlow id="CCIL1-G0" sourceRef="CCIL1" targetRef="G0"/>
    <sequenceFlow id="G0-CPO1" sourceRef="G0" targetRef="CPO1"/>
    <sequenceFlow id="G0-XORCLOSE17" sourceRef="G0" targetRef="XORCLOSE17"/>
    <sequenceFlow id="CPO1-XOR_JMPBB_RWPO1_RPO1" sourceRef="CPO1" targetRef="XOR_JMPBB_RWPO1_RPO1"/>
    <sequenceFlow id="RPO1-G1" sourceRef="RPO1" targetRef="G1"/>
    <sequenceFlow id="G1-APO1" sourceRef="G1" targetRef="APO1"/>
    <sequenceFlow id="G1-RWPO1" sourceRef="G1" targetRef="RWPO1"/>
    <sequenceFlow id="RWPO1-XOR_JMPAA_RWPO1_RPO1" sourceRef="RWPO1" targetRef="XOR_JMPAA_RWPO1_RPO1"/>
    <sequenceFlow id="APO1-RPF1" sourceRef="APO1" targetRef="RPF1"/>
    <sequenceFlow id="RPF1-SPOS1" sourceRef="RPF1" targetRef="SPOS1"/>
    <sequenceFlow id="SPOS1-ROPS1" sourceRef="SPOS1" targetRef="ROPS1"/>
    <sequenceFlow id="ROPS1-ROI1" sourceRef="ROPS1" targetRef="ROI1"/>
    <sequenceFlow id="ROI1-ROPS_REC1" sourceRef="ROI1" targetRef="ROPS_REC1"/>
    <sequenceFlow id="ROPS_REC1-ROI_REC1" sourceRef="ROPS_REC1" targetRef="ROI_REC1"/>
    <sequenceFlow id="ROI_REC1-RF1" sourceRef="ROI_REC1" targetRef="RF1"/>
    <sequenceFlow id="RF1-IPTS1" sourceRef="RF1" targetRef="IPTS1"/>
    <sequenceFlow id="IPTS1-XORCLOSE16" sourceRef="IPTS1" targetRef="XORCLOSE16"/>
    <sequenceFlow id="XORCLOSE16-XORCLOSE17" sourceRef="XORCLOSE16" targetRef="XORCLOSE17"/>
    <sequenceFlow id="XORCLOSE17-END" sourceRef="XORCLOSE17" targetRef="END"/>
    <sequenceFlow id="XOR_JMPAA_RWPO1_RPO1-XORCLOSE16" sourceRef="XOR_JMPAA_RWPO1_RPO1" targetRef="XORCLOSE16"/>
    <sequenceFlow id="XOR_JMPAA_RWPO1_RPO1-XOR_JMPBB_RWPO1_RPO1" sourceRef="XOR_JMPAA_RWPO1_RPO1" targetRef="XOR_JMPBB_RWPO1_RPO1"/>
    <sequenceFlow id="XOR_JMPBB_RWPO1_RPO1-RPO1" sourceRef="XOR_JMPBB_RWPO1_RPO1" targetRef="RPO1"/>
  </process>
