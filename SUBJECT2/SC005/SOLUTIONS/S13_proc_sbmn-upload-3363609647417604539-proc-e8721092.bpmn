<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_8503e519-4461-4d7a-bc28-5bcc59267281" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CCIL1</outgoing>
    </startEvent>
    <task id="CCIL1" name="Check Current Inventory Level">
      <incoming>Default_init-CCIL1</incoming>
      <outgoing>CCIL1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CCIL1-G0</incoming>
      <outgoing>G0-CPO1</outgoing>
      <outgoing>G0-XORCLOSE19</outgoing>
    </exclusiveGateway>
    <task id="CPO1" name="Create Purchase Order">
      <incoming>G0-CPO1</incoming>
      <outgoing>CPO1-XOR_JMPBB_RWPO1_RPO1</outgoing>
    </task>
    <task id="RPO1" name="Review Purchase Order">
      <incoming>XOR_JMPBB_RWPO1_RPO1-RPO1</incoming>
      <outgoing>RPO1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>RPO1-G1</incoming>
      <outgoing>G1-APO1</outgoing>
      <outgoing>G1-RWPO1</outgoing>
    </exclusiveGateway>
    <task id="RWPO1" name="Rework Purchase Order">
      <incoming>G1-RWPO1</incoming>
      <outgoing>RWPO1-XOR_JMPAA_RWPO1_RPO1</outgoing>
    </task>
    <task id="APO1" name="Accept Purchase Order">
      <incoming>G1-APO1</incoming>
      <outgoing>APO1-Par8</outgoing>
    </task>
    <parallelGateway id="Par8" name="PAR">
      <incoming>APO1-Par8</incoming>
      <outgoing>Par8-RPF1</outgoing>
      <outgoing>Par8-SPOS1</outgoing>
    </parallelGateway>
    <task id="RPF1" name="Reserve Purchase Funds">
      <incoming>Par8-RPF1</incoming>
      <outgoing>RPF1-PARCLOSE12</outgoing>
    </task>
    <task id="SPOS1" name="Send Purchase Order to Supplier">
      <incoming>Par8-SPOS1</incoming>
      <outgoing>SPOS1-ROPS1</outgoing>
    </task>
    <task id="ROPS1" name="Receive Order Packing Slip">
      <incoming>SPOS1-ROPS1</incoming>
      <outgoing>ROPS1-PARCLOSE12</outgoing>
    </task>
    <parallelGateway id="PARCLOSE12" name="PARCLOSE12">
      <incoming>RPF1-PARCLOSE12</incoming>
      <incoming>ROPS1-PARCLOSE12</incoming>
      <outgoing>PARCLOSE12-ROI1</outgoing>
    </parallelGateway>
    <task id="ROI1" name="Receive Order Invoice">
      <incoming>PARCLOSE12-ROI1</incoming>
      <outgoing>ROI1-ROI_REC1</outgoing>
    </task>
    <task id="ROI_REC1" name="Record Order Invoice">
      <incoming>ROI1-ROI_REC1</incoming>
      <outgoing>ROI_REC1-ROPS_REC1</outgoing>
    </task>
    <task id="ROPS_REC1" name="Record Order Packing Slip">
      <incoming>ROI_REC1-ROPS_REC1</incoming>
      <outgoing>ROPS_REC1-RF1</outgoing>
    </task>
    <task id="RF1" name="Release Funds">
      <incoming>ROPS_REC1-RF1</incoming>
      <outgoing>RF1-IPTS1</outgoing>
    </task>
    <task id="IPTS1" name="Issue Payment to Supplier">
      <incoming>RF1-IPTS1</incoming>
      <outgoing>IPTS1-XORCLOSE18</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>IPTS1-XORCLOSE18</incoming>
      <incoming>XOR_JMPAA_RWPO1_RPO1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-XORCLOSE19</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE19" name="XORCLOSE19">
      <incoming>G0-XORCLOSE19</incoming>
      <incoming>XORCLOSE18-XORCLOSE19</incoming>
      <outgoing>XORCLOSE19-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE19-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_RWPO1_RPO1" name="XOR_JMPAA_Rework Purchase Order">
      <incoming>RWPO1-XOR_JMPAA_RWPO1_RPO1</incoming>
      <outgoing>XOR_JMPAA_RWPO1_RPO1-XORCLOSE18</outgoing>
      <outgoing>XOR_JMPAA_RWPO1_RPO1-XOR_JMPBB_RWPO1_RPO1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_RWPO1_RPO1" name="XOR_JMPBB_Review Purchase Order">
      <incoming>CPO1-XOR_JMPBB_RWPO1_RPO1</incoming>
      <incoming>XOR_JMPAA_RWPO1_RPO1-XOR_JMPBB_RWPO1_RPO1</incoming>
      <outgoing>XOR_JMPBB_RWPO1_RPO1-RPO1</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Default_init-CCIL1" sourceRef="Default_init" targetRef="CCIL1"/>
    <sequenceFlow id="CCIL1-G0" sourceRef="CCIL1" targetRef="G0"/>
    <sequenceFlow id="G0-CPO1" sourceRef="G0" targetRef="CPO1"/>
    <sequenceFlow id="G0-XORCLOSE19" sourceRef="G0" targetRef="XORCLOSE19"/>
    <sequenceFlow id="CPO1-XOR_JMPBB_RWPO1_RPO1" sourceRef="CPO1" targetRef="XOR_JMPBB_RWPO1_RPO1"/>
    <sequenceFlow id="RPO1-G1" sourceRef="RPO1" targetRef="G1"/>
    <sequenceFlow id="G1-APO1" sourceRef="G1" targetRef="APO1"/>
    <sequenceFlow id="G1-RWPO1" sourceRef="G1" targetRef="RWPO1"/>
    <sequenceFlow id="RWPO1-XOR_JMPAA_RWPO1_RPO1" sourceRef="RWPO1" targetRef="XOR_JMPAA_RWPO1_RPO1"/>
    <sequenceFlow id="APO1-Par8" sourceRef="APO1" targetRef="Par8"/>
    <sequenceFlow id="Par8-RPF1" sourceRef="Par8" targetRef="RPF1"/>
    <sequenceFlow id="Par8-SPOS1" sourceRef="Par8" targetRef="SPOS1"/>
    <sequenceFlow id="RPF1-PARCLOSE12" sourceRef="RPF1" targetRef="PARCLOSE12"/>
    <sequenceFlow id="SPOS1-ROPS1" sourceRef="SPOS1" targetRef="ROPS1"/>
    <sequenceFlow id="ROPS1-PARCLOSE12" sourceRef="ROPS1" targetRef="PARCLOSE12"/>
    <sequenceFlow id="PARCLOSE12-ROI1" sourceRef="PARCLOSE12" targetRef="ROI1"/>
    <sequenceFlow id="ROI1-ROI_REC1" sourceRef="ROI1" targetRef="ROI_REC1"/>
    <sequenceFlow id="ROI_REC1-ROPS_REC1" sourceRef="ROI_REC1" targetRef="ROPS_REC1"/>
    <sequenceFlow id="ROPS_REC1-RF1" sourceRef="ROPS_REC1" targetRef="RF1"/>
    <sequenceFlow id="RF1-IPTS1" sourceRef="RF1" targetRef="IPTS1"/>
    <sequenceFlow id="IPTS1-XORCLOSE18" sourceRef="IPTS1" targetRef="XORCLOSE18"/>
    <sequenceFlow id="XORCLOSE18-XORCLOSE19" sourceRef="XORCLOSE18" targetRef="XORCLOSE19"/>
    <sequenceFlow id="XORCLOSE19-END" sourceRef="XORCLOSE19" targetRef="END"/>
    <sequenceFlow id="XOR_JMPAA_RWPO1_RPO1-XORCLOSE18" sourceRef="XOR_JMPAA_RWPO1_RPO1" targetRef="XORCLOSE18"/>
    <sequenceFlow id="XOR_JMPAA_RWPO1_RPO1-XOR_JMPBB_RWPO1_RPO1" sourceRef="XOR_JMPAA_RWPO1_RPO1" targetRef="XOR_JMPBB_RWPO1_RPO1"/>
    <sequenceFlow id="XOR_JMPBB_RWPO1_RPO1-RPO1" sourceRef="XOR_JMPBB_RWPO1_RPO1" targetRef="RPO1"/>
  </process>
