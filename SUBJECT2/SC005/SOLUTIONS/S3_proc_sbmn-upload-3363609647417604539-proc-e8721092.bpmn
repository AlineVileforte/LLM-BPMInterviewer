<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_3402e263-1f78-4f1e-ba72-4aafb2f7fb81" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CCIL1</outgoing>
    </startEvent>
    <task id="CCIL1" name="Check Current Inventory Level">
      <incoming>Default_init-CCIL1</incoming>
      <outgoing>CCIL1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CCIL1-G0</incoming>
      <outgoing>G0-CPO1</outgoing>
      <outgoing>G0-XORCLOSE21</outgoing>
    </exclusiveGateway>
    <task id="CPO1" name="Create Purchase Order">
      <incoming>G0-CPO1</incoming>
      <outgoing>CPO1-XOR_JMPBB_RWPO1_RPO1</outgoing>
    </task>
    <task id="RPO1" name="Review Purchase Order">
      <incoming>XOR_JMPBB_RWPO1_RPO1-RPO1</incoming>
      <outgoing>RPO1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>RPO1-G1</incoming>
      <outgoing>G1-APO1</outgoing>
      <outgoing>G1-RWPO1</outgoing>
    </exclusiveGateway>
    <task id="RWPO1" name="Rework Purchase Order">
      <incoming>G1-RWPO1</incoming>
      <outgoing>RWPO1-XOR_JMPAA_RWPO1_RPO1</outgoing>
    </task>
    <task id="APO1" name="Accept Purchase Order">
      <incoming>G1-APO1</incoming>
      <outgoing>APO1-SPOS1</outgoing>
    </task>
    <task id="SPOS1" name="Send Purchase Order to Supplier">
      <incoming>APO1-SPOS1</incoming>
      <outgoing>SPOS1-Par9</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>SPOS1-Par9</incoming>
      <outgoing>Par9-ROI1</outgoing>
      <outgoing>Par9-Par12</outgoing>
    </parallelGateway>
    <task id="ROI1" name="Receive Order Invoice">
      <incoming>Par9-ROI1</incoming>
      <outgoing>ROI1-ROPS1</outgoing>
    </task>
    <task id="ROPS1" name="Receive Order Packing Slip">
      <incoming>ROI1-ROPS1</incoming>
      <outgoing>ROPS1-ROPS_REC1</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>Par9-Par12</incoming>
      <outgoing>Par12-RPF1</outgoing>
      <outgoing>Par12-ROI_REC1</outgoing>
    </parallelGateway>
    <task id="RPF1" name="Reserve Purchase Funds">
      <incoming>Par12-RPF1</incoming>
      <outgoing>RPF1-PARCLOSE16</outgoing>
    </task>
    <task id="ROI_REC1" name="Record Order Invoice">
      <incoming>Par12-ROI_REC1</incoming>
      <outgoing>ROI_REC1-PARCLOSE16</outgoing>
    </task>
    <task id="ROPS_REC1" name="Record Order Packing Slip">
      <incoming>ROPS1-ROPS_REC1</incoming>
      <outgoing>ROPS_REC1-RF1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE16" name="PARCLOSE16">
      <incoming>RPF1-PARCLOSE16</incoming>
      <incoming>ROI_REC1-PARCLOSE16</incoming>
      <outgoing>PARCLOSE16-PARCLOSE18</outgoing>
    </parallelGateway>
    <task id="RF1" name="Release Funds">
      <incoming>ROPS_REC1-RF1</incoming>
      <outgoing>RF1-PARCLOSE18</outgoing>
    </task>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>PARCLOSE16-PARCLOSE18</incoming>
      <incoming>RF1-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-IPTS1</outgoing>
    </parallelGateway>
    <task id="IPTS1" name="Issue Payment to Supplier">
      <incoming>PARCLOSE18-IPTS1</incoming>
      <outgoing>IPTS1-XORCLOSE20</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>IPTS1-XORCLOSE20</incoming>
      <incoming>XOR_JMPAA_RWPO1_RPO1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-XORCLOSE21</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE21" name="XORCLOSE21">
      <incoming>G0-XORCLOSE21</incoming>
      <incoming>XORCLOSE20-XORCLOSE21</incoming>
      <outgoing>XORCLOSE21-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE21-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_RWPO1_RPO1" name="XOR_JMPAA_Rework Purchase Order">
      <incoming>RWPO1-XOR_JMPAA_RWPO1_RPO1</incoming>
      <outgoing>XOR_JMPAA_RWPO1_RPO1-XORCLOSE20</outgoing>
      <outgoing>XOR_JMPAA_RWPO1_RPO1-XOR_JMPBB_RWPO1_RPO1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_RWPO1_RPO1" name="XOR_JMPBB_Review Purchase Order">
      <incoming>CPO1-XOR_JMPBB_RWPO1_RPO1</incoming>
      <incoming>XOR_JMPAA_RWPO1_RPO1-XOR_JMPBB_RWPO1_RPO1</incoming>
      <outgoing>XOR_JMPBB_RWPO1_RPO1-RPO1</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Default_init-CCIL1" sourceRef="Default_init" targetRef="CCIL1"/>
    <sequenceFlow id="CCIL1-G0" sourceRef="CCIL1" targetRef="G0"/>
    <sequenceFlow id="G0-CPO1" sourceRef="G0" targetRef="CPO1"/>
    <sequenceFlow id="G0-XORCLOSE21" sourceRef="G0" targetRef="XORCLOSE21"/>
    <sequenceFlow id="CPO1-XOR_JMPBB_RWPO1_RPO1" sourceRef="CPO1" targetRef="XOR_JMPBB_RWPO1_RPO1"/>
    <sequenceFlow id="RPO1-G1" sourceRef="RPO1" targetRef="G1"/>
    <sequenceFlow id="G1-APO1" sourceRef="G1" targetRef="APO1"/>
    <sequenceFlow id="G1-RWPO1" sourceRef="G1" targetRef="RWPO1"/>
    <sequenceFlow id="RWPO1-XOR_JMPAA_RWPO1_RPO1" sourceRef="RWPO1" targetRef="XOR_JMPAA_RWPO1_RPO1"/>
    <sequenceFlow id="APO1-SPOS1" sourceRef="APO1" targetRef="SPOS1"/>
    <sequenceFlow id="SPOS1-Par9" sourceRef="SPOS1" targetRef="Par9"/>
    <sequenceFlow id="Par9-ROI1" sourceRef="Par9" targetRef="ROI1"/>
    <sequenceFlow id="Par9-Par12" sourceRef="Par9" targetRef="Par12"/>
    <sequenceFlow id="ROI1-ROPS1" sourceRef="ROI1" targetRef="ROPS1"/>
    <sequenceFlow id="ROPS1-ROPS_REC1" sourceRef="ROPS1" targetRef="ROPS_REC1"/>
    <sequenceFlow id="Par12-RPF1" sourceRef="Par12" targetRef="RPF1"/>
    <sequenceFlow id="Par12-ROI_REC1" sourceRef="Par12" targetRef="ROI_REC1"/>
    <sequenceFlow id="RPF1-PARCLOSE16" sourceRef="RPF1" targetRef="PARCLOSE16"/>
    <sequenceFlow id="ROI_REC1-PARCLOSE16" sourceRef="ROI_REC1" targetRef="PARCLOSE16"/>
    <sequenceFlow id="ROPS_REC1-RF1" sourceRef="ROPS_REC1" targetRef="RF1"/>
    <sequenceFlow id="PARCLOSE16-PARCLOSE18" sourceRef="PARCLOSE16" targetRef="PARCLOSE18"/>
    <sequenceFlow id="RF1-PARCLOSE18" sourceRef="RF1" targetRef="PARCLOSE18"/>
    <sequenceFlow id="PARCLOSE18-IPTS1" sourceRef="PARCLOSE18" targetRef="IPTS1"/>
    <sequenceFlow id="IPTS1-XORCLOSE20" sourceRef="IPTS1" targetRef="XORCLOSE20"/>
    <sequenceFlow id="XORCLOSE20-XORCLOSE21" sourceRef="XORCLOSE20" targetRef="XORCLOSE21"/>
    <sequenceFlow id="XORCLOSE21-END" sourceRef="XORCLOSE21" targetRef="END"/>
    <sequenceFlow id="XOR_JMPAA_RWPO1_RPO1-XORCLOSE20" sourceRef="XOR_JMPAA_RWPO1_RPO1" targetRef="XORCLOSE20"/>
    <sequenceFlow id="XOR_JMPAA_RWPO1_RPO1-XOR_JMPBB_RWPO1_RPO1" sourceRef="XOR_JMPAA_RWPO1_RPO1" targetRef="XOR_JMPBB_RWPO1_RPO1"/>
    <sequenceFlow id="XOR_JMPBB_RWPO1_RPO1-RPO1" sourceRef="XOR_JMPBB_RWPO1_RPO1" targetRef="RPO1"/>
  </process>
