  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CI1</outgoing>
    </startEvent>
    <task id="CI1" name="Check Inventory">
      <incoming>Default_init-CI1</incoming>
      <outgoing>CI1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CI1-G0</incoming>
      <outgoing>G0-XORCLOSE18</outgoing>
      <outgoing>G0-XOR_JMPBB_RPO1_CPO1</outgoing>
    </exclusiveGateway>
    <task id="CPO1" name="Construct Purchase Order">
      <incoming>XOR_JMPBB_RPO1_CPO1-CPO1</incoming>
      <outgoing>CPO1-RPO1</outgoing>
    </task>
    <task id="RPO1" name="Review PurchaseOrder">
      <incoming>CPO1-RPO1</incoming>
      <outgoing>RPO1-XOR_JMPAA_RPO1_CPO1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>XOR_JMPAA_RPO1_CPO1-G1</incoming>
      <outgoing>G1-SPT1</outgoing>
      <outgoing>G1-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="SPT1" name="Send PurchaseOrder toSupplier">
      <incoming>G1-SPT1</incoming>
      <outgoing>SPT1-RF1</outgoing>
    </task>
    <task id="RF1" name="Reserve Fund">
      <incoming>SPT1-RF1</incoming>
      <outgoing>RF1-MO1</outgoing>
    </task>
    <task id="MO1" name="Match Order">
      <incoming>RF1-MO1</incoming>
      <outgoing>MO1-G3</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>MO1-G3</incoming>
      <outgoing>G3-SPK1</outgoing>
      <outgoing>G3-SI1</outgoing>
    </exclusiveGateway>
    <task id="SPK1" name="Send packingslip">
      <incoming>G3-SPK1</incoming>
      <outgoing>SPK1-RC1__1</outgoing>
    </task>
    <task id="SI1" name="Send Invoice">
      <incoming>G3-SI1</incoming>
      <outgoing>SI1-RC1__2</outgoing>
    </task>
    <task id="RC1__1" name="Receive Confirmation">
      <incoming>SPK1-RC1__1</incoming>
      <outgoing>RC1__1-RLF1</outgoing>
    </task>
    <task id="RC1__2" name="Receive Confirmation">
      <incoming>SI1-RC1__2</incoming>
      <outgoing>RC1__2-XORCLOSE16</outgoing>
    </task>
    <task id="RLF1" name="Release Funds">
      <incoming>RC1__1-RLF1</incoming>
      <outgoing>RLF1-XORCLOSE16</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
      <incoming>RC1__2-XORCLOSE16</incoming>
      <incoming>RLF1-XORCLOSE16</incoming>
      <outgoing>XORCLOSE16-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE17" name="XORCLOSE17">
      <incoming>G1-XORCLOSE17</incoming>
      <incoming>XORCLOSE16-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>G0-XORCLOSE18</incoming>
      <incoming>XORCLOSE17-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE18-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_RPO1_CPO1" name="XOR_JMPAA_Review PurchaseOrder">
