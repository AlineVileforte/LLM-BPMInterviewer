  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CI1</outgoing>
    </startEvent>
    <task id="CI1" name="Check Inventory">
      <incoming>Default_init-CI1</incoming>
      <outgoing>CI1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CI1-G0</incoming>
      <outgoing>G0-XORCLOSE19</outgoing>
      <outgoing>G0-XOR_JMPBB_RPO1_CPO1</outgoing>
    </exclusiveGateway>
    <task id="CPO1" name="Construct Purchase Order">
      <incoming>XOR_JMPBB_RPO1_CPO1-CPO1</incoming>
      <outgoing>CPO1-RPO1</outgoing>
    </task>
    <task id="RPO1" name="Review PurchaseOrder">
      <incoming>CPO1-RPO1</incoming>
      <outgoing>RPO1-XOR_JMPAA_RPO1_CPO1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>XOR_JMPAA_RPO1_CPO1-G1</incoming>
      <outgoing>G1-SPT1</outgoing>
      <outgoing>G1-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="SPT1" name="Send PurchaseOrder toSupplier">
      <incoming>G1-SPT1</incoming>
      <outgoing>SPT1-Par8</outgoing>
    </task>
    <parallelGateway id="Par8" name="PAR">
      <incoming>SPT1-Par8</incoming>
      <outgoing>Par8-MO1</outgoing>
      <outgoing>Par8-RF1</outgoing>
    </parallelGateway>
    <task id="MO1" name="Match Order">
      <incoming>Par8-MO1</incoming>
      <outgoing>MO1-G2</outgoing>
    </task>
    <task id="RF1" name="Reserve Fund">
      <incoming>Par8-RF1</incoming>
      <outgoing>RF1-PARCLOSE15</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>MO1-G2</incoming>
      <outgoing>G2-SPK1</outgoing>
      <outgoing>G2-SI1</outgoing>
    </exclusiveGateway>
    <task id="SPK1" name="Send packingslip">
      <incoming>G2-SPK1</incoming>
      <outgoing>SPK1-XORCLOSE14</outgoing>
    </task>
    <task id="SI1" name="Send Invoice">
      <incoming>G2-SI1</incoming>
      <outgoing>SI1-XORCLOSE14</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>SPK1-XORCLOSE14</incoming>
      <incoming>SI1-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-PARCLOSE15</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE15" name="PARCLOSE15">
      <incoming>RF1-PARCLOSE15</incoming>
      <incoming>XORCLOSE14-PARCLOSE15</incoming>
      <outgoing>PARCLOSE15-RC1</outgoing>
    </parallelGateway>
    <task id="RC1" name="Receive Confirmation">
      <incoming>PARCLOSE15-RC1</incoming>
      <outgoing>RC1-RLF1</outgoing>
    </task>
    <task id="RLF1" name="Release Funds">
      <incoming>RC1-RLF1</incoming>
      <outgoing>RLF1-XORCLOSE18</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>G1-XORCLOSE18</incoming>
      <incoming>RLF1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-XORCLOSE19</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE19" name="XORCLOSE19">
      <incoming>G0-XORCLOSE19</incoming>
      <incoming>XORCLOSE18-XORCLOSE19</incoming>
      <outgoing>XORCLOSE19-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE19-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_RPO1_CPO1" name="XOR_JMPAA_Review PurchaseOrder">
      <incoming>RPO1-XOR_JMPAA_RPO1_CPO1</incoming>
      <outgoing>XOR_JMPAA_RPO1_CPO1-G1</outgoing>
      <outgoing>XOR_JMPAA_RPO1_CPO1-XOR_JMPBB_RPO1_CPO1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_RPO1_CPO1" name="XOR_JMPBB_Construct Purchase Order">
