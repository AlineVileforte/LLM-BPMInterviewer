<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_bd65ca44-d913-424a-9dd6-e61845837866" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-G0</outgoing>
    </startEvent>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Default_init-G0</incoming>
      <outgoing>G0-COO1</outgoing>
      <outgoing>G0-CPT1</outgoing>
    </exclusiveGateway>
    <task id="COO1" name="Customer places order online">
      <incoming>G0-COO1</incoming>
      <outgoing>COO1-XORCLOSE3</outgoing>
    </task>
    <task id="CPT1" name="Customer places order over the phone">
      <incoming>G0-CPT1</incoming>
      <outgoing>CPT1-XORCLOSE3</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE3" name="XORCLOSE3">
      <incoming>COO1-XORCLOSE3</incoming>
      <incoming>CPT1-XORCLOSE3</incoming>
      <outgoing>XORCLOSE3-GSC1</outgoing>
    </exclusiveGateway>
    <task id="GSC1" name="Generate and send order confirmation">
      <incoming>XORCLOSE3-GSC1</incoming>
      <outgoing>GSC1-Par5</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>GSC1-Par5</incoming>
      <outgoing>Par5-PPI1</outgoing>
      <outgoing>Par5-GSL1</outgoing>
    </parallelGateway>
    <task id="PPI1" name="Pick and pack items">
      <incoming>Par5-PPI1</incoming>
      <outgoing>PPI1-PARCLOSE8</outgoing>
    </task>
    <task id="GSL1" name="Generate shipping label">
      <incoming>Par5-GSL1</incoming>
      <outgoing>GSL1-PARCLOSE8</outgoing>
    </task>
    <parallelGateway id="PARCLOSE8" name="PARCLOSE8">
      <incoming>PPI1-PARCLOSE8</incoming>
      <incoming>GSL1-PARCLOSE8</incoming>
      <outgoing>PARCLOSE8-HOL1</outgoing>
    </parallelGateway>
    <task id="HOL1" name="Hand over order to logistics provider">
      <incoming>PARCLOSE8-HOL1</incoming>
      <outgoing>HOL1-STC1</outgoing>
    </task>
    <task id="STC1" name="Send tracking information to customer">
      <incoming>HOL1-STC1</incoming>
      <outgoing>STC1-XOR_JMPBB_MSH1_MSH1</outgoing>
    </task>
    <task id="MSH1" name="Monitor shipment">
      <incoming>XOR_JMPBB_MSH1_MSH1-MSH1</incoming>
      <outgoing>MSH1-XOR_JMPAA_MSH1_MSH1</outgoing>
    </task>
    <task id="SDL1" name="Successful delivery">
      <incoming>XOR_JMPAA_MSH1_MSH1-SDL1</incoming>
      <outgoing>SDL1-PCF1</outgoing>
    </task>
    <task id="PCF1" name="Process customer feedback or returns">
      <incoming>SDL1-PCF1</incoming>
      <outgoing>PCF1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PCF1-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_MSH1_MSH1" name="XOR_JMPAA_Monitor shipment">
      <incoming>MSH1-XOR_JMPAA_MSH1_MSH1</incoming>
      <outgoing>XOR_JMPAA_MSH1_MSH1-SDL1</outgoing>
      <outgoing>XOR_JMPAA_MSH1_MSH1-XOR_JMPBB_MSH1_MSH1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_MSH1_MSH1" name="XOR_JMPBB_Monitor shipment">
      <incoming>STC1-XOR_JMPBB_MSH1_MSH1</incoming>
      <incoming>XOR_JMPAA_MSH1_MSH1-XOR_JMPBB_MSH1_MSH1</incoming>
      <outgoing>XOR_JMPBB_MSH1_MSH1-MSH1</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Default_init-G0" sourceRef="Default_init" targetRef="G0"/>
    <sequenceFlow id="G0-COO1" sourceRef="G0" targetRef="COO1"/>
    <sequenceFlow id="G0-CPT1" sourceRef="G0" targetRef="CPT1"/>
    <sequenceFlow id="COO1-XORCLOSE3" sourceRef="COO1" targetRef="XORCLOSE3"/>
    <sequenceFlow id="CPT1-XORCLOSE3" sourceRef="CPT1" targetRef="XORCLOSE3"/>
    <sequenceFlow id="XORCLOSE3-GSC1" sourceRef="XORCLOSE3" targetRef="GSC1"/>
    <sequenceFlow id="GSC1-Par5" sourceRef="GSC1" targetRef="Par5"/>
    <sequenceFlow id="Par5-PPI1" sourceRef="Par5" targetRef="PPI1"/>
    <sequenceFlow id="Par5-GSL1" sourceRef="Par5" targetRef="GSL1"/>
    <sequenceFlow id="PPI1-PARCLOSE8" sourceRef="PPI1" targetRef="PARCLOSE8"/>
    <sequenceFlow id="GSL1-PARCLOSE8" sourceRef="GSL1" targetRef="PARCLOSE8"/>
    <sequenceFlow id="PARCLOSE8-HOL1" sourceRef="PARCLOSE8" targetRef="HOL1"/>
    <sequenceFlow id="HOL1-STC1" sourceRef="HOL1" targetRef="STC1"/>
    <sequenceFlow id="STC1-XOR_JMPBB_MSH1_MSH1" sourceRef="STC1" targetRef="XOR_JMPBB_MSH1_MSH1"/>
    <sequenceFlow id="MSH1-XOR_JMPAA_MSH1_MSH1" sourceRef="MSH1" targetRef="XOR_JMPAA_MSH1_MSH1"/>
    <sequenceFlow id="SDL1-PCF1" sourceRef="SDL1" targetRef="PCF1"/>
    <sequenceFlow id="PCF1-END" sourceRef="PCF1" targetRef="END"/>
    <sequenceFlow id="XOR_JMPAA_MSH1_MSH1-SDL1" sourceRef="XOR_JMPAA_MSH1_MSH1" targetRef="SDL1"/>
    <sequenceFlow id="XOR_JMPAA_MSH1_MSH1-XOR_JMPBB_MSH1_MSH1" sourceRef="XOR_JMPAA_MSH1_MSH1" targetRef="XOR_JMPBB_MSH1_MSH1"/>
    <sequenceFlow id="XOR_JMPBB_MSH1_MSH1-MSH1" sourceRef="XOR_JMPBB_MSH1_MSH1" targetRef="MSH1"/>
  </process>
