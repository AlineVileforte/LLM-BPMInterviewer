      <outgoing>LV1-G2</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>LV1-G2</incoming>
      <outgoing>G2-ER1</outgoing>
      <outgoing>G2-G4</outgoing>
    </exclusiveGateway>
    <task id="ER1" name="Enter reservation">
      <incoming>G2-ER1</incoming>
      <outgoing>ER1-XOR_JMPAA_ER1_OAC1</outgoing>
    </task>
