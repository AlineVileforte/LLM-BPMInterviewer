  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-LV1</outgoing>
    </startEvent>
    <task id="LV1" name="Login verification">
      <incoming>Default_init-LV1</incoming>
      <outgoing>LV1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>LV1-Par1</incoming>
      <outgoing>Par1-MR1</outgoing>
      <outgoing>Par1-G1</outgoing>
    </parallelGateway>
    <task id="MR1" name="Modify requirements">
      <incoming>Par1-MR1</incoming>
      <outgoing>MR1-G3</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par1-G1</incoming>
      <outgoing>G1-ER1</outgoing>
      <outgoing>G1-G4</outgoing>
    </exclusiveGateway>
    <task id="ER1" name="Enter reservation">
      <incoming>G1-ER1</incoming>
      <outgoing>ER1-XOR_JMPAA_ER1_OAC1</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>MR1-G3</incoming>
      <outgoing>G3-SE2</outgoing>
      <outgoing>G3-XORCLOSE11</outgoing>
    </exclusiveGateway>
    <task id="SE2" name="Send email about 2...">
      <incoming>G3-SE2</incoming>
      <outgoing>SE2-XORCLOSE11</outgoing>
    </task>
    <exclusiveGateway id="G4" name="G4">
      <incoming>G1-G4</incoming>
      <outgoing>G4-CA1</outgoing>
      <outgoing>G4-XORCLOSE12</outgoing>
    </exclusiveGateway>
    <task id="CA1" name="Check availability">
      <incoming>G4-CA1</incoming>
      <outgoing>CA1-XORCLOSE12</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE11" name="XORCLOSE11">
      <incoming>G3-XORCLOSE11</incoming>
      <incoming>SE2-XORCLOSE11</incoming>
      <outgoing>XORCLOSE11-PARCLOSE15</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE12" name="XORCLOSE12">
      <incoming>G4-XORCLOSE12</incoming>
      <incoming>CA1-XORCLOSE12</incoming>
