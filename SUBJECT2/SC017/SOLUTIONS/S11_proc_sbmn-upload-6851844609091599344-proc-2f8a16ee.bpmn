    <task id="MR1" name="Modify requirements">
      <incoming>Par8-MR1</incoming>
      <outgoing>MR1-G5</outgoing>
    </task>
    <exclusiveGateway id="G5" name="G5">
      <incoming>MR1-G5</incoming>
