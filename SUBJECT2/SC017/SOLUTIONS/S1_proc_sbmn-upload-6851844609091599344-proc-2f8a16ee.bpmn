      <outgoing>G3-CA1</outgoing>
      <outgoing>G3-XORCLOSE12</outgoing>
    </exclusiveGateway>
    <task id="CA1" name="Check availability">
      <incoming>G3-CA1</incoming>
      <outgoing>CA1-XORCLOSE12</outgoing>
