  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-LV1</outgoing>
      <outgoing>Par0-G0</outgoing>
    </parallelGateway>
    <task id="LV1" name="Login verification">
      <incoming>Par0-LV1</incoming>
      <outgoing>LV1-MR1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par0-G0</incoming>
      <outgoing>G0-SE2</outgoing>
      <outgoing>G0-XORCLOSE6</outgoing>
    </exclusiveGateway>
    <task id="SE2" name="Send email about 2...">
      <incoming>G0-SE2</incoming>
      <outgoing>SE2-XORCLOSE6</outgoing>
    </task>
    <task id="MR1" name="Modify requirements">
      <incoming>LV1-MR1</incoming>
      <outgoing>MR1-G2</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE6" name="XORCLOSE6">
