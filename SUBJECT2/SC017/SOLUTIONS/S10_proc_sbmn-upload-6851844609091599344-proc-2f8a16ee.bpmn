  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-LV1</outgoing>
      <outgoing>Par0-MR1</outgoing>
    </parallelGateway>
    <task id="LV1" name="Login verification">
      <incoming>Par0-LV1</incoming>
      <outgoing>LV1-G2</outgoing>
    </task>
    <task id="MR1" name="Modify requirements">
      <incoming>Par0-MR1</incoming>
      <outgoing>MR1-PARCLOSE24</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>LV1-G2</incoming>
      <outgoing>G2-SE2</outgoing>
      <outgoing>G2-XORCLOSE16</outgoing>
    </exclusiveGateway>
    <task id="SE2" name="Send email about 2...">
      <incoming>G2-SE2</incoming>
      <outgoing>SE2-SD1</outgoing>
    </task>
    <task id="SD1" name="Save to database">
      <incoming>SE2-SD1</incoming>
      <outgoing>SD1-SCE1</outgoing>
    </task>
    <task id="SCE1" name="Send confirmation email">
      <incoming>SD1-SCE1</incoming>
      <outgoing>SCE1-DG1</outgoing>
    </task>
    <task id="DG1" name="Deliver the Goods">
      <incoming>SCE1-DG1</incoming>
      <outgoing>DG1-PI1</outgoing>
    </task>
    <task id="PI1" name="Preparing Invoice">
      <incoming>DG1-PI1</incoming>
      <outgoing>PI1-SIC1</outgoing>
    </task>
    <task id="SIC1" name="Send the Invoice to Customer">
      <incoming>PI1-SIC1</incoming>
      <outgoing>SIC1-XOR_JMPBB_CTR1_CFP1</outgoing>
    </task>
    <task id="CFP1" name="Check for Payment">
      <incoming>XOR_JMPBB_CTR1_CFP1-CFP1</incoming>
      <outgoing>CFP1-CO1</outgoing>
    </task>
    <task id="CO1" name="closing order">
      <incoming>CFP1-CO1</incoming>
      <outgoing>CO1-CTR1</outgoing>
    </task>
    <task id="CTR1" name="Checking the reminders">
      <incoming>CO1-CTR1</incoming>
      <outgoing>CTR1-XOR_JMPAA_CTR1_CFP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
      <incoming>G2-XORCLOSE16</incoming>
      <incoming>XOR_JMPAA_CTR1_CFP1-XORCLOSE16</incoming>
      <outgoing>XORCLOSE16-G3</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G3" name="G3">
      <incoming>XORCLOSE16-G3</incoming>
      <outgoing>G3-ER1</outgoing>
      <outgoing>G3-CA1</outgoing>
    </exclusiveGateway>
    <task id="ER1" name="Enter reservation">
      <incoming>G3-ER1</incoming>
      <outgoing>ER1-XOR_JMPAA_ER1_OAC1</outgoing>
    </task>
    <task id="CA1" name="Check availability">
      <incoming>G3-CA1</incoming>
      <outgoing>CA1-RRM1</outgoing>
    </task>
    <task id="RRM1" name="Request requirement modification">
      <incoming>CA1-RRM1</incoming>
      <outgoing>RRM1-XOR_JMPBB_ER1_OAC1</outgoing>
    </task>
    <task id="OAC1" name="Order acceptance confirmation">
      <incoming>XOR_JMPBB_ER1_OAC1-OAC1</incoming>
      <outgoing>OAC1-SE1</outgoing>
    </task>
    <task id="SE1" name="Send email about 1...">
      <incoming>OAC1-SE1</incoming>
      <outgoing>SE1-XORCLOSE23</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE23" name="XORCLOSE23">
      <incoming>SE1-XORCLOSE23</incoming>
      <incoming>XOR_JMPAA_ER1_OAC1-XORCLOSE23</incoming>
      <outgoing>XORCLOSE23-PARCLOSE24</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>MR1-PARCLOSE24</incoming>
      <incoming>XORCLOSE23-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE24-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_ER1_OAC1" name="XOR_JMPAA_Enter reservation">
      <incoming>ER1-XOR_JMPAA_ER1_OAC1</incoming>
      <outgoing>XOR_JMPAA_ER1_OAC1-XORCLOSE23</outgoing>
      <outgoing>XOR_JMPAA_ER1_OAC1-XOR_JMPBB_ER1_OAC1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_ER1_OAC1" name="XOR_JMPBB_Order acceptance confirmation">
      <incoming>RRM1-XOR_JMPBB_ER1_OAC1</incoming>
      <incoming>XOR_JMPAA_ER1_OAC1-XOR_JMPBB_ER1_OAC1</incoming>
      <outgoing>XOR_JMPBB_ER1_OAC1-OAC1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPAA_CTR1_CFP1" name="XOR_JMPAA_Checking the reminders">
      <incoming>CTR1-XOR_JMPAA_CTR1_CFP1</incoming>
      <outgoing>XOR_JMPAA_CTR1_CFP1-XORCLOSE16</outgoing>
      <outgoing>XOR_JMPAA_CTR1_CFP1-XOR_JMPBB_CTR1_CFP1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_CTR1_CFP1" name="XOR_JMPBB_Check for Payment">
      <incoming>SIC1-XOR_JMPBB_CTR1_CFP1</incoming>
      <incoming>XOR_JMPAA_CTR1_CFP1-XOR_JMPBB_CTR1_CFP1</incoming>
      <outgoing>XOR_JMPBB_CTR1_CFP1-CFP1</outgoing>
    </exclusiveGateway>
