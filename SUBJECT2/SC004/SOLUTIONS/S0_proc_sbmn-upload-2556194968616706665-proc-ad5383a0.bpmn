    <sequenceFlow id="CIR1__2-PARCLOSE18" sourceRef="CIR1__2" targetRef="PARCLOSE18"/>
    <sequenceFlow id="XORCLOSE15-XORCLOSE21" sourceRef="XORCLOSE15" targetRef="XORCLOSE21"/>
    <sequenceFlow id="PARCLOSE16-PIR1__2" sourceRef="PARCLOSE16" targetRef="PIR1__2"/>
    <sequenceFlow id="PIR1__1-PARCLOSE18" sourceRef="PIR1__1" targetRef="PARCLOSE18"/>
    <sequenceFlow id="PARCLOSE18-XORCLOSE20" sourceRef="PARCLOSE18" targetRef="XORCLOSE20"/>
    <sequenceFlow id="PIR1__2-XORCLOSE20" sourceRef="PIR1__2" targetRef="XORCLOSE20"/>
    <sequenceFlow id="XORCLOSE20-XORCLOSE21" sourceRef="XORCLOSE20" targetRef="XORCLOSE21"/>
    <sequenceFlow id="XORCLOSE21-END" sourceRef="XORCLOSE21" targetRef="END"/>
  </process>
