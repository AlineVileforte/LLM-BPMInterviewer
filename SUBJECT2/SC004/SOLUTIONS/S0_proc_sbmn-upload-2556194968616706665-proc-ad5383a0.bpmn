<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_ddd90318-a464-4b53-a8db-c676118bef17" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CPO1</outgoing>
    </startEvent>
    <task id="CPO1" name="Customer Places Order">
      <incoming>Default_init-CPO1</incoming>
      <outgoing>CPO1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CPO1-G0</incoming>
      <outgoing>G0-OLU1</outgoing>
      <outgoing>G0-G2</outgoing>
    </exclusiveGateway>
    <task id="OLU1" name="Order License Upgrade">
      <incoming>G0-OLU1</incoming>
      <outgoing>OLU1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>OLU1-G1</incoming>
      <outgoing>G1-CVG1</outgoing>
      <outgoing>G1-RCI1</outgoing>
    </exclusiveGateway>
    <task id="CVG1" name="Check Which Version of the Game the Customer Has">
      <incoming>G1-CVG1</incoming>
      <outgoing>CVG1-Par9</outgoing>
    </task>
    <task id="RCI1" name="Register Customer Information">
      <incoming>G1-RCI1</incoming>
      <outgoing>RCI1-Par12</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>G0-G2</incoming>
      <outgoing>G2-ONL1</outgoing>
      <outgoing>G2-XORCLOSE15</outgoing>
    </exclusiveGateway>
    <task id="ONL1" name="Order New License">
      <incoming>G2-ONL1</incoming>
      <outgoing>ONL1-XORCLOSE15</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>CVG1-Par9</incoming>
      <outgoing>Par9-RIS1__1</outgoing>
      <outgoing>Par9-CIR1__1</outgoing>
    </parallelGateway>
    <task id="RIS1__1" name="Requested Item plus Invoice is Sent to Customer by Post">
      <incoming>Par9-RIS1__1</incoming>
      <outgoing>RIS1__1-PARCLOSE16</outgoing>
    </task>
    <task id="CIR1__1" name="Copy of Customer Invoice is Received">
      <incoming>Par9-CIR1__1</incoming>
      <outgoing>CIR1__1-PARCLOSE16</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>RCI1-Par12</incoming>
      <outgoing>Par12-RIS1__2</outgoing>
      <outgoing>Par12-CIR1__2</outgoing>
    </parallelGateway>
    <task id="RIS1__2" name="Requested Item plus Invoice is Sent to Customer by Post">
      <incoming>Par12-RIS1__2</incoming>
      <outgoing>RIS1__2-PIR1__1</outgoing>
    </task>
    <task id="CIR1__2" name="Copy of Customer Invoice is Received">
      <incoming>Par12-CIR1__2</incoming>
      <outgoing>CIR1__2-PARCLOSE18</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE15" name="XORCLOSE15">
      <incoming>G2-XORCLOSE15</incoming>
      <incoming>ONL1-XORCLOSE15</incoming>
      <outgoing>XORCLOSE15-XORCLOSE21</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE16" name="PARCLOSE16">
      <incoming>RIS1__1-PARCLOSE16</incoming>
      <incoming>CIR1__1-PARCLOSE16</incoming>
      <outgoing>PARCLOSE16-PIR1__2</outgoing>
    </parallelGateway>
    <task id="PIR1__1" name="Payment is Received">
      <incoming>RIS1__2-PIR1__1</incoming>
      <outgoing>PIR1__1-PARCLOSE18</outgoing>
    </task>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>CIR1__2-PARCLOSE18</incoming>
      <incoming>PIR1__1-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-XORCLOSE20</outgoing>
    </parallelGateway>
    <task id="PIR1__2" name="Payment is Received">
      <incoming>PARCLOSE16-PIR1__2</incoming>
      <outgoing>PIR1__2-XORCLOSE20</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>PARCLOSE18-XORCLOSE20</incoming>
      <incoming>PIR1__2-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-XORCLOSE21</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE21" name="XORCLOSE21">
      <incoming>XORCLOSE15-XORCLOSE21</incoming>
      <incoming>XORCLOSE20-XORCLOSE21</incoming>
      <outgoing>XORCLOSE21-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE21-END</incoming>
    </endEvent>
