<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_64da6b9c-3073-48c3-81f5-48dcfea4e22b" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CPO1</outgoing>
    </startEvent>
    <task id="CPO1" name="Customer Places Order">
      <incoming>Default_init-CPO1</incoming>
      <outgoing>CPO1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CPO1-G0</incoming>
      <outgoing>G0-OLU1</outgoing>
      <outgoing>G0-G2</outgoing>
    </exclusiveGateway>
    <task id="OLU1" name="Order License Upgrade">
      <incoming>G0-OLU1</incoming>
      <outgoing>OLU1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>OLU1-G1</incoming>
      <outgoing>G1-CVG1</outgoing>
      <outgoing>G1-RCI1</outgoing>
    </exclusiveGateway>
    <task id="CVG1" name="Check Which Version of the Game the Customer Has">
      <incoming>G1-CVG1</incoming>
      <outgoing>CVG1-CIR1__1</outgoing>
    </task>
    <task id="RCI1" name="Register Customer Information">
      <incoming>G1-RCI1</incoming>
      <outgoing>RCI1-Par10</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>G0-G2</incoming>
      <outgoing>G2-ONL1</outgoing>
      <outgoing>G2-XORCLOSE13</outgoing>
    </exclusiveGateway>
    <task id="ONL1" name="Order New License">
      <incoming>G2-ONL1</incoming>
      <outgoing>ONL1-XORCLOSE13</outgoing>
    </task>
    <task id="CIR1__1" name="Copy of Customer Invoice is Received">
      <incoming>CVG1-CIR1__1</incoming>
      <outgoing>CIR1__1-RIS1__2</outgoing>
    </task>
    <parallelGateway id="Par10" name="PAR">
      <incoming>RCI1-Par10</incoming>
      <outgoing>Par10-RIS1__1</outgoing>
      <outgoing>Par10-CIR1__2</outgoing>
    </parallelGateway>
    <task id="RIS1__1" name="Requested Item plus Invoice is Sent to Customer by Post">
      <incoming>Par10-RIS1__1</incoming>
      <outgoing>RIS1__1-PIR1__1</outgoing>
    </task>
    <task id="CIR1__2" name="Copy of Customer Invoice is Received">
      <incoming>Par10-CIR1__2</incoming>
      <outgoing>CIR1__2-PARCLOSE16</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE13" name="XORCLOSE13">
      <incoming>G2-XORCLOSE13</incoming>
      <incoming>ONL1-XORCLOSE13</incoming>
      <outgoing>XORCLOSE13-XORCLOSE19</outgoing>
    </exclusiveGateway>
    <task id="RIS1__2" name="Requested Item plus Invoice is Sent to Customer by Post">
      <incoming>CIR1__1-RIS1__2</incoming>
      <outgoing>RIS1__2-PIR1__2</outgoing>
    </task>
    <task id="PIR1__1" name="Payment is Received">
      <incoming>RIS1__1-PIR1__1</incoming>
      <outgoing>PIR1__1-PARCLOSE16</outgoing>
    </task>
    <parallelGateway id="PARCLOSE16" name="PARCLOSE16">
      <incoming>CIR1__2-PARCLOSE16</incoming>
      <incoming>PIR1__1-PARCLOSE16</incoming>
      <outgoing>PARCLOSE16-XORCLOSE18</outgoing>
    </parallelGateway>
    <task id="PIR1__2" name="Payment is Received">
      <incoming>RIS1__2-PIR1__2</incoming>
      <outgoing>PIR1__2-XORCLOSE18</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>PARCLOSE16-XORCLOSE18</incoming>
      <incoming>PIR1__2-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-XORCLOSE19</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE19" name="XORCLOSE19">
      <incoming>XORCLOSE13-XORCLOSE19</incoming>
      <incoming>XORCLOSE18-XORCLOSE19</incoming>
      <outgoing>XORCLOSE19-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE19-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-CPO1" sourceRef="Default_init" targetRef="CPO1"/>
    <sequenceFlow id="CPO1-G0" sourceRef="CPO1" targetRef="G0"/>
    <sequenceFlow id="G0-OLU1" sourceRef="G0" targetRef="OLU1"/>
