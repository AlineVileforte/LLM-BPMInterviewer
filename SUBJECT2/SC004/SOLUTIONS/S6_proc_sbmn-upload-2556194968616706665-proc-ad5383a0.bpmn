    <sequenceFlow id="Par10-RIS1__1" sourceRef="Par10" targetRef="RIS1__1"/>
    <sequenceFlow id="Par10-CIR1__2" sourceRef="Par10" targetRef="CIR1__2"/>
    <sequenceFlow id="RIS1__1-PIR1__1" sourceRef="RIS1__1" targetRef="PIR1__1"/>
    <sequenceFlow id="CIR1__2-PARCLOSE16" sourceRef="CIR1__2" targetRef="PARCLOSE16"/>
    <sequenceFlow id="XORCLOSE13-XORCLOSE19" sourceRef="XORCLOSE13" targetRef="XORCLOSE19"/>
    <sequenceFlow id="RIS1__2-PIR1__2" sourceRef="RIS1__2" targetRef="PIR1__2"/>
    <sequenceFlow id="PIR1__1-PARCLOSE16" sourceRef="PIR1__1" targetRef="PARCLOSE16"/>
    <sequenceFlow id="PARCLOSE16-XORCLOSE18" sourceRef="PARCLOSE16" targetRef="XORCLOSE18"/>
    <sequenceFlow id="PIR1__2-XORCLOSE18" sourceRef="PIR1__2" targetRef="XORCLOSE18"/>
    <sequenceFlow id="XORCLOSE18-XORCLOSE19" sourceRef="XORCLOSE18" targetRef="XORCLOSE19"/>
    <sequenceFlow id="XORCLOSE19-END" sourceRef="XORCLOSE19" targetRef="END"/>
  </process>
