    <sequenceFlow id="RCI1-CIR1__2" sourceRef="RCI1" targetRef="CIR1__2"/>
    <sequenceFlow id="G2-ONL1" sourceRef="G2" targetRef="ONL1"/>
    <sequenceFlow id="G2-XORCLOSE13" sourceRef="G2" targetRef="XORCLOSE13"/>
    <sequenceFlow id="ONL1-XORCLOSE13" sourceRef="ONL1" targetRef="XORCLOSE13"/>
    <sequenceFlow id="Par9-RIS1" sourceRef="Par9" targetRef="RIS1"/>
    <sequenceFlow id="Par9-CIR1__1" sourceRef="Par9" targetRef="CIR1__1"/>
    <sequenceFlow id="RIS1-PARCLOSE14" sourceRef="RIS1" targetRef="PARCLOSE14"/>
    <sequenceFlow id="CIR1__1-PARCLOSE14" sourceRef="CIR1__1" targetRef="PARCLOSE14"/>
    <sequenceFlow id="CIR1__2-XORCLOSE16" sourceRef="CIR1__2" targetRef="XORCLOSE16"/>
    <sequenceFlow id="XORCLOSE13-XORCLOSE17" sourceRef="XORCLOSE13" targetRef="XORCLOSE17"/>
    <sequenceFlow id="PARCLOSE14-PIR1" sourceRef="PARCLOSE14" targetRef="PIR1"/>
    <sequenceFlow id="PIR1-XORCLOSE16" sourceRef="PIR1" targetRef="XORCLOSE16"/>
    <sequenceFlow id="XORCLOSE16-XORCLOSE17" sourceRef="XORCLOSE16" targetRef="XORCLOSE17"/>
    <sequenceFlow id="XORCLOSE17-END" sourceRef="XORCLOSE17" targetRef="END"/>
  </process>
