<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_a013fd12-e840-41db-890a-3734000dbca8" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CPO1</outgoing>
    </startEvent>
    <task id="CPO1" name="Customer Places Order">
      <incoming>Default_init-CPO1</incoming>
      <outgoing>CPO1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CPO1-G0</incoming>
      <outgoing>G0-OLU1</outgoing>
      <outgoing>G0-G2</outgoing>
    </exclusiveGateway>
    <task id="OLU1" name="Order License Upgrade">
      <incoming>G0-OLU1</incoming>
      <outgoing>OLU1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>OLU1-G1</incoming>
      <outgoing>G1-CVG1</outgoing>
      <outgoing>G1-RCI1</outgoing>
    </exclusiveGateway>
    <task id="CVG1" name="Check Which Version of the Game the Customer Has">
      <incoming>G1-CVG1</incoming>
      <outgoing>CVG1-Par9</outgoing>
    </task>
    <task id="RCI1" name="Register Customer Information">
      <incoming>G1-RCI1</incoming>
      <outgoing>RCI1-CIR1__2</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>G0-G2</incoming>
      <outgoing>G2-ONL1</outgoing>
      <outgoing>G2-XORCLOSE13</outgoing>
    </exclusiveGateway>
    <task id="ONL1" name="Order New License">
      <incoming>G2-ONL1</incoming>
      <outgoing>ONL1-XORCLOSE13</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>CVG1-Par9</incoming>
      <outgoing>Par9-RIS1</outgoing>
      <outgoing>Par9-CIR1__1</outgoing>
    </parallelGateway>
    <task id="RIS1" name="Requested Item plus Invoice is Sent to Customer by Post">
      <incoming>Par9-RIS1</incoming>
      <outgoing>RIS1-PARCLOSE14</outgoing>
    </task>
    <task id="CIR1__1" name="Copy of Customer Invoice is Received">
      <incoming>Par9-CIR1__1</incoming>
      <outgoing>CIR1__1-PARCLOSE14</outgoing>
    </task>
    <task id="CIR1__2" name="Copy of Customer Invoice is Received">
      <incoming>RCI1-CIR1__2</incoming>
      <outgoing>CIR1__2-XORCLOSE16</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE13" name="XORCLOSE13">
      <incoming>G2-XORCLOSE13</incoming>
      <incoming>ONL1-XORCLOSE13</incoming>
      <outgoing>XORCLOSE13-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE14" name="PARCLOSE14">
      <incoming>RIS1-PARCLOSE14</incoming>
      <incoming>CIR1__1-PARCLOSE14</incoming>
      <outgoing>PARCLOSE14-PIR1</outgoing>
    </parallelGateway>
    <task id="PIR1" name="Payment is Received">
      <incoming>PARCLOSE14-PIR1</incoming>
      <outgoing>PIR1-XORCLOSE16</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
      <incoming>CIR1__2-XORCLOSE16</incoming>
      <incoming>PIR1-XORCLOSE16</incoming>
      <outgoing>XORCLOSE16-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE17" name="XORCLOSE17">
      <incoming>XORCLOSE13-XORCLOSE17</incoming>
      <incoming>XORCLOSE16-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE17-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-CPO1" sourceRef="Default_init" targetRef="CPO1"/>
    <sequenceFlow id="CPO1-G0" sourceRef="CPO1" targetRef="G0"/>
    <sequenceFlow id="G0-OLU1" sourceRef="G0" targetRef="OLU1"/>
    <sequenceFlow id="G0-G2" sourceRef="G0" targetRef="G2"/>
