<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_f34a87e9-4cbd-4f6a-8188-7e0aecc18de2" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CPO1</outgoing>
    </startEvent>
    <task id="CPO1" name="Customer Places Order">
      <incoming>Default_init-CPO1</incoming>
      <outgoing>CPO1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CPO1-G0</incoming>
      <outgoing>G0-OLU1</outgoing>
      <outgoing>G0-G2</outgoing>
    </exclusiveGateway>
    <task id="OLU1" name="Order License Upgrade">
      <incoming>G0-OLU1</incoming>
      <outgoing>OLU1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>OLU1-G1</incoming>
      <outgoing>G1-CVG1</outgoing>
      <outgoing>G1-RCI1</outgoing>
    </exclusiveGateway>
    <task id="CVG1" name="Check Which Version of the Game the Customer Has">
      <incoming>G1-CVG1</incoming>
      <outgoing>CVG1-RIS1__1</outgoing>
    </task>
    <task id="RCI1" name="Register Customer Information">
      <incoming>G1-RCI1</incoming>
      <outgoing>RCI1-RIS1__2</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>G0-G2</incoming>
      <outgoing>G2-ONL1</outgoing>
      <outgoing>G2-XORCLOSE11</outgoing>
    </exclusiveGateway>
    <task id="ONL1" name="Order New License">
      <incoming>G2-ONL1</incoming>
      <outgoing>ONL1-XORCLOSE11</outgoing>
    </task>
    <task id="RIS1__1" name="Requested Item plus Invoice is Sent to Customer by Post">
      <incoming>CVG1-RIS1__1</incoming>
      <outgoing>RIS1__1-CIR1__1</outgoing>
    </task>
    <task id="RIS1__2" name="Requested Item plus Invoice is Sent to Customer by Post">
      <incoming>RCI1-RIS1__2</incoming>
      <outgoing>RIS1__2-CIR1__2</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE11" name="XORCLOSE11">
      <incoming>G2-XORCLOSE11</incoming>
      <incoming>ONL1-XORCLOSE11</incoming>
      <outgoing>XORCLOSE11-XORCLOSE16</outgoing>
    </exclusiveGateway>
    <task id="CIR1__1" name="Copy of Customer Invoice is Received">
      <incoming>RIS1__1-CIR1__1</incoming>
      <outgoing>CIR1__1-PIR1</outgoing>
    </task>
    <task id="CIR1__2" name="Copy of Customer Invoice is Received">
      <incoming>RIS1__2-CIR1__2</incoming>
      <outgoing>CIR1__2-XORCLOSE15</outgoing>
    </task>
    <task id="PIR1" name="Payment is Received">
      <incoming>CIR1__1-PIR1</incoming>
      <outgoing>PIR1-XORCLOSE15</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE15" name="XORCLOSE15">
      <incoming>CIR1__2-XORCLOSE15</incoming>
      <incoming>PIR1-XORCLOSE15</incoming>
      <outgoing>XORCLOSE15-XORCLOSE16</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
      <incoming>XORCLOSE11-XORCLOSE16</incoming>
      <incoming>XORCLOSE15-XORCLOSE16</incoming>
      <outgoing>XORCLOSE16-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE16-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-CPO1" sourceRef="Default_init" targetRef="CPO1"/>
    <sequenceFlow id="CPO1-G0" sourceRef="CPO1" targetRef="G0"/>
    <sequenceFlow id="G0-OLU1" sourceRef="G0" targetRef="OLU1"/>
    <sequenceFlow id="G0-G2" sourceRef="G0" targetRef="G2"/>
    <sequenceFlow id="OLU1-G1" sourceRef="OLU1" targetRef="G1"/>
    <sequenceFlow id="G1-CVG1" sourceRef="G1" targetRef="CVG1"/>
    <sequenceFlow id="G1-RCI1" sourceRef="G1" targetRef="RCI1"/>
    <sequenceFlow id="CVG1-RIS1__1" sourceRef="CVG1" targetRef="RIS1__1"/>
    <sequenceFlow id="RCI1-RIS1__2" sourceRef="RCI1" targetRef="RIS1__2"/>
    <sequenceFlow id="G2-ONL1" sourceRef="G2" targetRef="ONL1"/>
    <sequenceFlow id="G2-XORCLOSE11" sourceRef="G2" targetRef="XORCLOSE11"/>
    <sequenceFlow id="ONL1-XORCLOSE11" sourceRef="ONL1" targetRef="XORCLOSE11"/>
    <sequenceFlow id="RIS1__1-CIR1__1" sourceRef="RIS1__1" targetRef="CIR1__1"/>
    <sequenceFlow id="RIS1__2-CIR1__2" sourceRef="RIS1__2" targetRef="CIR1__2"/>
    <sequenceFlow id="XORCLOSE11-XORCLOSE16" sourceRef="XORCLOSE11" targetRef="XORCLOSE16"/>
    <sequenceFlow id="CIR1__1-PIR1" sourceRef="CIR1__1" targetRef="PIR1"/>
    <sequenceFlow id="CIR1__2-XORCLOSE15" sourceRef="CIR1__2" targetRef="XORCLOSE15"/>
    <sequenceFlow id="PIR1-XORCLOSE15" sourceRef="PIR1" targetRef="XORCLOSE15"/>
    <sequenceFlow id="XORCLOSE15-XORCLOSE16" sourceRef="XORCLOSE15" targetRef="XORCLOSE16"/>
    <sequenceFlow id="XORCLOSE16-END" sourceRef="XORCLOSE16" targetRef="END"/>
  </process>
