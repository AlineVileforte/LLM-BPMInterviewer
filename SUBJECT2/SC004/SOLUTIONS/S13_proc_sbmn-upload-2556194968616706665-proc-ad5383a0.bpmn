    <sequenceFlow id="G2-XORCLOSE13" sourceRef="G2" targetRef="XORCLOSE13"/>
    <sequenceFlow id="ONL1-XORCLOSE13" sourceRef="ONL1" targetRef="XORCLOSE13"/>
    <sequenceFlow id="Par9-RIS1__1" sourceRef="Par9" targetRef="RIS1__1"/>
    <sequenceFlow id="Par9-CIR1" sourceRef="Par9" targetRef="CIR1"/>
    <sequenceFlow id="RIS1__1-PARCLOSE15" sourceRef="RIS1__1" targetRef="PARCLOSE15"/>
    <sequenceFlow id="CIR1-PIR1" sourceRef="CIR1" targetRef="PIR1"/>
    <sequenceFlow id="RIS1__2-XORCLOSE16" sourceRef="RIS1__2" targetRef="XORCLOSE16"/>
    <sequenceFlow id="XORCLOSE13-XORCLOSE17" sourceRef="XORCLOSE13" targetRef="XORCLOSE17"/>
    <sequenceFlow id="PIR1-PARCLOSE15" sourceRef="PIR1" targetRef="PARCLOSE15"/>
    <sequenceFlow id="PARCLOSE15-XORCLOSE16" sourceRef="PARCLOSE15" targetRef="XORCLOSE16"/>
    <sequenceFlow id="XORCLOSE16-XORCLOSE17" sourceRef="XORCLOSE16" targetRef="XORCLOSE17"/>
    <sequenceFlow id="XORCLOSE17-END" sourceRef="XORCLOSE17" targetRef="END"/>
  </process>
