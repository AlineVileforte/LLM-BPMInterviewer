    <sequenceFlow id="Par10-RIS1__2" sourceRef="Par10" targetRef="RIS1__2"/>
    <sequenceFlow id="Par10-CIR1__1" sourceRef="Par10" targetRef="CIR1__1"/>
    <sequenceFlow id="RIS1__2-PARCLOSE15" sourceRef="RIS1__2" targetRef="PARCLOSE15"/>
    <sequenceFlow id="CIR1__1-PARCLOSE15" sourceRef="CIR1__1" targetRef="PARCLOSE15"/>
    <sequenceFlow id="XORCLOSE13-XORCLOSE18" sourceRef="XORCLOSE13" targetRef="XORCLOSE18"/>
    <sequenceFlow id="CIR1__2-XORCLOSE17" sourceRef="CIR1__2" targetRef="XORCLOSE17"/>
    <sequenceFlow id="PARCLOSE15-PIR1" sourceRef="PARCLOSE15" targetRef="PIR1"/>
    <sequenceFlow id="PIR1-XORCLOSE17" sourceRef="PIR1" targetRef="XORCLOSE17"/>
    <sequenceFlow id="XORCLOSE17-XORCLOSE18" sourceRef="XORCLOSE17" targetRef="XORCLOSE18"/>
    <sequenceFlow id="XORCLOSE18-END" sourceRef="XORCLOSE18" targetRef="END"/>
  </process>
