<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_c039090f-ca12-4e14-94e5-06116438db4e" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CPO1</outgoing>
    </startEvent>
    <task id="CPO1" name="Customer Places Order">
      <incoming>Default_init-CPO1</incoming>
      <outgoing>CPO1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CPO1-G0</incoming>
      <outgoing>G0-OLU1</outgoing>
      <outgoing>G0-G2</outgoing>
    </exclusiveGateway>
    <task id="OLU1" name="Order License Upgrade">
      <incoming>G0-OLU1</incoming>
      <outgoing>OLU1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>OLU1-G1</incoming>
      <outgoing>G1-CVG1</outgoing>
      <outgoing>G1-RCI1</outgoing>
    </exclusiveGateway>
    <task id="CVG1" name="Check Which Version of the Game the Customer Has">
      <incoming>G1-CVG1</incoming>
      <outgoing>CVG1-CIR1</outgoing>
    </task>
    <task id="RCI1" name="Register Customer Information">
      <incoming>G1-RCI1</incoming>
      <outgoing>RCI1-RIS1__1</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>G0-G2</incoming>
      <outgoing>G2-ONL1</outgoing>
      <outgoing>G2-XORCLOSE11</outgoing>
    </exclusiveGateway>
    <task id="ONL1" name="Order New License">
      <incoming>G2-ONL1</incoming>
      <outgoing>ONL1-XORCLOSE11</outgoing>
    </task>
    <task id="CIR1" name="Copy of Customer Invoice is Received">
      <incoming>CVG1-CIR1</incoming>
      <outgoing>CIR1-Par12</outgoing>
    </task>
    <task id="RIS1__1" name="Requested Item plus Invoice is Sent to Customer by Post">
      <incoming>RCI1-RIS1__1</incoming>
      <outgoing>RIS1__1-XORCLOSE16</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE11" name="XORCLOSE11">
      <incoming>G2-XORCLOSE11</incoming>
      <incoming>ONL1-XORCLOSE11</incoming>
      <outgoing>XORCLOSE11-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <parallelGateway id="Par12" name="PAR">
      <incoming>CIR1-Par12</incoming>
      <outgoing>Par12-RIS1__2</outgoing>
      <outgoing>Par12-PIR1</outgoing>
    </parallelGateway>
    <task id="RIS1__2" name="Requested Item plus Invoice is Sent to Customer by Post">
      <incoming>Par12-RIS1__2</incoming>
      <outgoing>RIS1__2-PARCLOSE15</outgoing>
    </task>
    <task id="PIR1" name="Payment is Received">
      <incoming>Par12-PIR1</incoming>
      <outgoing>PIR1-PARCLOSE15</outgoing>
    </task>
    <parallelGateway id="PARCLOSE15" name="PARCLOSE15">
      <incoming>RIS1__2-PARCLOSE15</incoming>
      <incoming>PIR1-PARCLOSE15</incoming>
      <outgoing>PARCLOSE15-XORCLOSE16</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
      <incoming>RIS1__1-XORCLOSE16</incoming>
      <incoming>PARCLOSE15-XORCLOSE16</incoming>
      <outgoing>XORCLOSE16-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE17" name="XORCLOSE17">
      <incoming>XORCLOSE11-XORCLOSE17</incoming>
      <incoming>XORCLOSE16-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE17-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-CPO1" sourceRef="Default_init" targetRef="CPO1"/>
    <sequenceFlow id="CPO1-G0" sourceRef="CPO1" targetRef="G0"/>
    <sequenceFlow id="G0-OLU1" sourceRef="G0" targetRef="OLU1"/>
    <sequenceFlow id="G0-G2" sourceRef="G0" targetRef="G2"/>
    <sequenceFlow id="OLU1-G1" sourceRef="OLU1" targetRef="G1"/>
    <sequenceFlow id="G1-CVG1" sourceRef="G1" targetRef="CVG1"/>
    <sequenceFlow id="G1-RCI1" sourceRef="G1" targetRef="RCI1"/>
    <sequenceFlow id="CVG1-CIR1" sourceRef="CVG1" targetRef="CIR1"/>
    <sequenceFlow id="RCI1-RIS1__1" sourceRef="RCI1" targetRef="RIS1__1"/>
    <sequenceFlow id="G2-ONL1" sourceRef="G2" targetRef="ONL1"/>
    <sequenceFlow id="G2-XORCLOSE11" sourceRef="G2" targetRef="XORCLOSE11"/>
    <sequenceFlow id="ONL1-XORCLOSE11" sourceRef="ONL1" targetRef="XORCLOSE11"/>
    <sequenceFlow id="CIR1-Par12" sourceRef="CIR1" targetRef="Par12"/>
    <sequenceFlow id="RIS1__1-XORCLOSE16" sourceRef="RIS1__1" targetRef="XORCLOSE16"/>
    <sequenceFlow id="XORCLOSE11-XORCLOSE17" sourceRef="XORCLOSE11" targetRef="XORCLOSE17"/>
    <sequenceFlow id="Par12-RIS1__2" sourceRef="Par12" targetRef="RIS1__2"/>
    <sequenceFlow id="Par12-PIR1" sourceRef="Par12" targetRef="PIR1"/>
    <sequenceFlow id="RIS1__2-PARCLOSE15" sourceRef="RIS1__2" targetRef="PARCLOSE15"/>
    <sequenceFlow id="PIR1-PARCLOSE15" sourceRef="PIR1" targetRef="PARCLOSE15"/>
    <sequenceFlow id="PARCLOSE15-XORCLOSE16" sourceRef="PARCLOSE15" targetRef="XORCLOSE16"/>
    <sequenceFlow id="XORCLOSE16-XORCLOSE17" sourceRef="XORCLOSE16" targetRef="XORCLOSE17"/>
    <sequenceFlow id="XORCLOSE17-END" sourceRef="XORCLOSE17" targetRef="END"/>
  </process>
