    <sequenceFlow id="G2-XORCLOSE13" sourceRef="G2" targetRef="XORCLOSE13"/>
    <sequenceFlow id="ONL1-XORCLOSE13" sourceRef="ONL1" targetRef="XORCLOSE13"/>
    <sequenceFlow id="RIS1__1-CIR1__2" sourceRef="RIS1__1" targetRef="CIR1__2"/>
    <sequenceFlow id="Par10-RIS1__2" sourceRef="Par10" targetRef="RIS1__2"/>
    <sequenceFlow id="Par10-CIR1__1" sourceRef="Par10" targetRef="CIR1__1"/>
    <sequenceFlow id="RIS1__2-PARCLOSE16" sourceRef="RIS1__2" targetRef="PARCLOSE16"/>
    <sequenceFlow id="CIR1__1-PIR1" sourceRef="CIR1__1" targetRef="PIR1"/>
    <sequenceFlow id="XORCLOSE13-XORCLOSE18" sourceRef="XORCLOSE13" targetRef="XORCLOSE18"/>
    <sequenceFlow id="CIR1__2-XORCLOSE17" sourceRef="CIR1__2" targetRef="XORCLOSE17"/>
    <sequenceFlow id="PIR1-PARCLOSE16" sourceRef="PIR1" targetRef="PARCLOSE16"/>
    <sequenceFlow id="PARCLOSE16-XORCLOSE17" sourceRef="PARCLOSE16" targetRef="XORCLOSE17"/>
    <sequenceFlow id="XORCLOSE17-XORCLOSE18" sourceRef="XORCLOSE17" targetRef="XORCLOSE18"/>
    <sequenceFlow id="XORCLOSE18-END" sourceRef="XORCLOSE18" targetRef="END"/>
  </process>
