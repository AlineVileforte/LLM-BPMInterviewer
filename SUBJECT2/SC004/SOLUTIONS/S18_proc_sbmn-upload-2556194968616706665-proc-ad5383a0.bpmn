<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_c16948ac-8bd8-48df-b78b-71d4cde0a784" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CPO1</outgoing>
    </startEvent>
    <task id="CPO1" name="Customer Places Order">
      <incoming>Default_init-CPO1</incoming>
      <outgoing>CPO1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CPO1-G0</incoming>
      <outgoing>G0-OLU1</outgoing>
      <outgoing>G0-G2</outgoing>
    </exclusiveGateway>
    <task id="OLU1" name="Order License Upgrade">
      <incoming>G0-OLU1</incoming>
      <outgoing>OLU1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>OLU1-G1</incoming>
      <outgoing>G1-CVG1</outgoing>
      <outgoing>G1-RCI1</outgoing>
    </exclusiveGateway>
    <task id="CVG1" name="Check Which Version of the Game the Customer Has">
      <incoming>G1-CVG1</incoming>
      <outgoing>CVG1-RIS1__1</outgoing>
    </task>
    <task id="RCI1" name="Register Customer Information">
      <incoming>G1-RCI1</incoming>
      <outgoing>RCI1-Par10</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>G0-G2</incoming>
      <outgoing>G2-ONL1</outgoing>
      <outgoing>G2-XORCLOSE13</outgoing>
    </exclusiveGateway>
    <task id="ONL1" name="Order New License">
      <incoming>G2-ONL1</incoming>
      <outgoing>ONL1-XORCLOSE13</outgoing>
    </task>
    <task id="RIS1__1" name="Requested Item plus Invoice is Sent to Customer by Post">
      <incoming>CVG1-RIS1__1</incoming>
      <outgoing>RIS1__1-CIR1__2</outgoing>
    </task>
    <parallelGateway id="Par10" name="PAR">
      <incoming>RCI1-Par10</incoming>
      <outgoing>Par10-RIS1__2</outgoing>
      <outgoing>Par10-CIR1__1</outgoing>
    </parallelGateway>
    <task id="RIS1__2" name="Requested Item plus Invoice is Sent to Customer by Post">
      <incoming>Par10-RIS1__2</incoming>
      <outgoing>RIS1__2-PARCLOSE16</outgoing>
    </task>
    <task id="CIR1__1" name="Copy of Customer Invoice is Received">
      <incoming>Par10-CIR1__1</incoming>
      <outgoing>CIR1__1-PIR1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE13" name="XORCLOSE13">
      <incoming>G2-XORCLOSE13</incoming>
      <incoming>ONL1-XORCLOSE13</incoming>
      <outgoing>XORCLOSE13-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="CIR1__2" name="Copy of Customer Invoice is Received">
      <incoming>RIS1__1-CIR1__2</incoming>
      <outgoing>CIR1__2-XORCLOSE17</outgoing>
    </task>
    <task id="PIR1" name="Payment is Received">
      <incoming>CIR1__1-PIR1</incoming>
      <outgoing>PIR1-PARCLOSE16</outgoing>
    </task>
    <parallelGateway id="PARCLOSE16" name="PARCLOSE16">
      <incoming>RIS1__2-PARCLOSE16</incoming>
      <incoming>PIR1-PARCLOSE16</incoming>
      <outgoing>PARCLOSE16-XORCLOSE17</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE17" name="XORCLOSE17">
      <incoming>CIR1__2-XORCLOSE17</incoming>
      <incoming>PARCLOSE16-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>XORCLOSE13-XORCLOSE18</incoming>
      <incoming>XORCLOSE17-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE18-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-CPO1" sourceRef="Default_init" targetRef="CPO1"/>
    <sequenceFlow id="CPO1-G0" sourceRef="CPO1" targetRef="G0"/>
    <sequenceFlow id="G0-OLU1" sourceRef="G0" targetRef="OLU1"/>
    <sequenceFlow id="G0-G2" sourceRef="G0" targetRef="G2"/>
    <sequenceFlow id="OLU1-G1" sourceRef="OLU1" targetRef="G1"/>
