    <sequenceFlow id="G1-CSV1" sourceRef="G1" targetRef="CSV1"/>
    <sequenceFlow id="G1-CI1" sourceRef="G1" targetRef="CI1"/>
    <sequenceFlow id="CSV1-XORCLOSE13" sourceRef="CSV1" targetRef="XORCLOSE13"/>
    <sequenceFlow id="CI1-XORCLOSE13" sourceRef="CI1" targetRef="XORCLOSE13"/>
    <sequenceFlow id="XORCLOSE13-SS1" sourceRef="XORCLOSE13" targetRef="SS1"/>
    <sequenceFlow id="XORCLOSE13-XOR_JMPBB_CI1_EP1" sourceRef="XORCLOSE13" targetRef="XOR_JMPBB_CI1_EP1"/>
    <sequenceFlow id="SS1-BCN1" sourceRef="SS1" targetRef="BCN1"/>
    <sequenceFlow id="BCN1-SC1" sourceRef="BCN1" targetRef="SC1"/>
    <sequenceFlow id="SC1-OS1" sourceRef="SC1" targetRef="OS1"/>
    <sequenceFlow id="OS1-EC1" sourceRef="OS1" targetRef="EC1"/>
    <sequenceFlow id="EC1-END" sourceRef="EC1" targetRef="END"/>
    <sequenceFlow id="XOR_JMPBB_CI1_EP1-EP1" sourceRef="XOR_JMPBB_CI1_EP1" targetRef="EP1"/>
  </process>
