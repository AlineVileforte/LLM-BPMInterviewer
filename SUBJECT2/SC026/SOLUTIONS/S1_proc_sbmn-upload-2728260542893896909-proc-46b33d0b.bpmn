<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_459debd5-7721-42c4-959f-d01fb2625b07" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-INSV1</outgoing>
    </startEvent>
    <task id="INSV1" name="Identify need for new supplier or vendor">
      <incoming>Default_init-INSV1</incoming>
      <outgoing>INSV1-IRFP1</outgoing>
    </task>
    <task id="IRFP1" name="Issue request for proposals (RFP)">
      <incoming>INSV1-IRFP1</incoming>
      <outgoing>IRFP1-RSP1</outgoing>
    </task>
    <task id="RSP1" name="Receive supplier proposals">
      <incoming>IRFP1-RSP1</incoming>
      <outgoing>RSP1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>RSP1-G0</incoming>
      <outgoing>G0-XORCLOSE7</outgoing>
      <outgoing>G0-XOR_JMPBB_CI1_EP1</outgoing>
    </exclusiveGateway>
    <task id="EP1" name="Evaluate proposal">
      <incoming>XOR_JMPBB_CI1_EP1-EP1</incoming>
      <outgoing>EP1-XORCLOSE7</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE7" name="XORCLOSE7">
      <incoming>G0-XORCLOSE7</incoming>
      <incoming>EP1-XORCLOSE7</incoming>
      <outgoing>XORCLOSE7-G1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G1" name="G1">
      <incoming>XORCLOSE7-G1</incoming>
      <outgoing>G1-CSV1</outgoing>
      <outgoing>G1-CI1</outgoing>
    </exclusiveGateway>
    <task id="CSV1" name="Conduct site visit">
      <incoming>G1-CSV1</incoming>
      <outgoing>CSV1-XORCLOSE11</outgoing>
    </task>
    <task id="CI1" name="Conduct interview">
      <incoming>G1-CI1</incoming>
      <outgoing>CI1-XORCLOSE11</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE11" name="XORCLOSE11">
      <incoming>CSV1-XORCLOSE11</incoming>
      <incoming>CI1-XORCLOSE11</incoming>
      <outgoing>XORCLOSE11-SS1</outgoing>
      <outgoing>XORCLOSE11-XOR_JMPBB_CI1_EP1</outgoing>
    </exclusiveGateway>
    <task id="SS1" name="Select supplier">
      <incoming>XORCLOSE11-SS1</incoming>
      <outgoing>SS1-BCN1</outgoing>
    </task>
    <task id="BCN1" name="Begin contract negotiations">
      <incoming>SS1-BCN1</incoming>
      <outgoing>BCN1-SC1</outgoing>
    </task>
    <task id="SC1" name="Sign contract">
      <incoming>BCN1-SC1</incoming>
      <outgoing>SC1-OS1</outgoing>
    </task>
    <task id="OS1" name="Onboard supplier">
      <incoming>SC1-OS1</incoming>
      <outgoing>OS1-EC1</outgoing>
    </task>
    <task id="EC1" name="Execute contract">
      <incoming>OS1-EC1</incoming>
      <outgoing>EC1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>EC1-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPBB_CI1_EP1" name="XOR_JMPBB_Evaluate proposal">
      <incoming>G0-XOR_JMPBB_CI1_EP1</incoming>
      <incoming>XORCLOSE11-XOR_JMPBB_CI1_EP1</incoming>
      <outgoing>XOR_JMPBB_CI1_EP1-EP1</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Default_init-INSV1" sourceRef="Default_init" targetRef="INSV1"/>
    <sequenceFlow id="INSV1-IRFP1" sourceRef="INSV1" targetRef="IRFP1"/>
    <sequenceFlow id="IRFP1-RSP1" sourceRef="IRFP1" targetRef="RSP1"/>
