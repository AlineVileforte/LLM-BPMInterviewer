<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_f18863c5-3bfd-4791-a954-f53dc51b3641" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CI1</outgoing>
    </startEvent>
    <task id="CI1" name="Check Inventory">
      <incoming>Default_init-CI1</incoming>
      <outgoing>CI1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CI1-G0</incoming>
      <outgoing>G0-IA1</outgoing>
      <outgoing>G0-G1</outgoing>
    </exclusiveGateway>
    <task id="IA1" name="Inventory Available">
      <incoming>G0-IA1</incoming>
      <outgoing>IA1-CPO1</outgoing>
    </task>
    <task id="CPO1" name="Confirm Purchase Order">
      <incoming>IA1-CPO1</incoming>
      <outgoing>CPO1-Par7</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>G0-G1</incoming>
      <outgoing>G1-INA1</outgoing>
      <outgoing>G1-XORCLOSE10</outgoing>
    </exclusiveGateway>
    <task id="INA1" name="Inventory Not Available">
      <incoming>G1-INA1</incoming>
      <outgoing>INA1-XORCLOSE10</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>CPO1-Par7</incoming>
      <outgoing>Par7-SP1</outgoing>
      <outgoing>Par7-SI1</outgoing>
    </parallelGateway>
    <task id="SP1" name="Ship Product">
      <incoming>Par7-SP1</incoming>
      <outgoing>SP1-PARCLOSE11</outgoing>
    </task>
    <task id="SI1" name="Send Invoice">
      <incoming>Par7-SI1</incoming>
      <outgoing>SI1-PARCLOSE11</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE10" name="XORCLOSE10">
      <incoming>G1-XORCLOSE10</incoming>
      <incoming>INA1-XORCLOSE10</incoming>
      <outgoing>XORCLOSE10-XORCLOSE12</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE11" name="PARCLOSE11">
      <incoming>SP1-PARCLOSE11</incoming>
      <incoming>SI1-PARCLOSE11</incoming>
      <outgoing>PARCLOSE11-XORCLOSE12</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE12" name="XORCLOSE12">
      <incoming>XORCLOSE10-XORCLOSE12</incoming>
      <incoming>PARCLOSE11-XORCLOSE12</incoming>
      <outgoing>XORCLOSE12-RPO1</outgoing>
    </exclusiveGateway>
    <task id="RPO1" name="Reject Purchase Order">
      <incoming>XORCLOSE12-RPO1</incoming>
      <outgoing>RPO1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>RPO1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-CI1" sourceRef="Default_init" targetRef="CI1"/>
    <sequenceFlow id="CI1-G0" sourceRef="CI1" targetRef="G0"/>
    <sequenceFlow id="G0-IA1" sourceRef="G0" targetRef="IA1"/>
    <sequenceFlow id="G0-G1" sourceRef="G0" targetRef="G1"/>
    <sequenceFlow id="IA1-CPO1" sourceRef="IA1" targetRef="CPO1"/>
    <sequenceFlow id="CPO1-Par7" sourceRef="CPO1" targetRef="Par7"/>
    <sequenceFlow id="G1-INA1" sourceRef="G1" targetRef="INA1"/>
    <sequenceFlow id="G1-XORCLOSE10" sourceRef="G1" targetRef="XORCLOSE10"/>
    <sequenceFlow id="INA1-XORCLOSE10" sourceRef="INA1" targetRef="XORCLOSE10"/>
    <sequenceFlow id="Par7-SP1" sourceRef="Par7" targetRef="SP1"/>
    <sequenceFlow id="Par7-SI1" sourceRef="Par7" targetRef="SI1"/>
    <sequenceFlow id="SP1-PARCLOSE11" sourceRef="SP1" targetRef="PARCLOSE11"/>
    <sequenceFlow id="SI1-PARCLOSE11" sourceRef="SI1" targetRef="PARCLOSE11"/>
    <sequenceFlow id="XORCLOSE10-XORCLOSE12" sourceRef="XORCLOSE10" targetRef="XORCLOSE12"/>
    <sequenceFlow id="PARCLOSE11-XORCLOSE12" sourceRef="PARCLOSE11" targetRef="XORCLOSE12"/>
    <sequenceFlow id="XORCLOSE12-RPO1" sourceRef="XORCLOSE12" targetRef="RPO1"/>
    <sequenceFlow id="RPO1-END" sourceRef="RPO1" targetRef="END"/>
  </process>
