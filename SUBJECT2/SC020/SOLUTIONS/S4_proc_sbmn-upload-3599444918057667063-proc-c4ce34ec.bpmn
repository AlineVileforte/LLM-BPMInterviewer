<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_92f5063d-7758-4e36-8e95-3d8d88d6d4d7" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CI1</outgoing>
    </startEvent>
    <task id="CI1" name="Check Inventory">
      <incoming>Default_init-CI1</incoming>
      <outgoing>CI1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CI1-G0</incoming>
      <outgoing>G0-IA1</outgoing>
      <outgoing>G0-G1</outgoing>
    </exclusiveGateway>
    <task id="IA1" name="Inventory Available">
      <incoming>G0-IA1</incoming>
      <outgoing>IA1-CPO1</outgoing>
    </task>
    <task id="CPO1" name="Confirm Purchase Order">
      <incoming>IA1-CPO1</incoming>
      <outgoing>CPO1-SI1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>G0-G1</incoming>
      <outgoing>G1-INA1</outgoing>
      <outgoing>G1-XORCLOSE8</outgoing>
    </exclusiveGateway>
    <task id="INA1" name="Inventory Not Available">
      <incoming>G1-INA1</incoming>
      <outgoing>INA1-XORCLOSE8</outgoing>
    </task>
    <task id="SI1" name="Send Invoice">
      <incoming>CPO1-SI1</incoming>
      <outgoing>SI1-SP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE8" name="XORCLOSE8">
      <incoming>G1-XORCLOSE8</incoming>
      <incoming>INA1-XORCLOSE8</incoming>
      <outgoing>XORCLOSE8-XORCLOSE10</outgoing>
    </exclusiveGateway>
    <task id="SP1" name="Ship Product">
      <incoming>SI1-SP1</incoming>
      <outgoing>SP1-XORCLOSE10</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE10" name="XORCLOSE10">
      <incoming>XORCLOSE8-XORCLOSE10</incoming>
      <incoming>SP1-XORCLOSE10</incoming>
      <outgoing>XORCLOSE10-RPO1</outgoing>
    </exclusiveGateway>
    <task id="RPO1" name="Reject Purchase Order">
      <incoming>XORCLOSE10-RPO1</incoming>
      <outgoing>RPO1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>RPO1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-CI1" sourceRef="Default_init" targetRef="CI1"/>
    <sequenceFlow id="CI1-G0" sourceRef="CI1" targetRef="G0"/>
    <sequenceFlow id="G0-IA1" sourceRef="G0" targetRef="IA1"/>
    <sequenceFlow id="G0-G1" sourceRef="G0" targetRef="G1"/>
    <sequenceFlow id="IA1-CPO1" sourceRef="IA1" targetRef="CPO1"/>
    <sequenceFlow id="CPO1-SI1" sourceRef="CPO1" targetRef="SI1"/>
    <sequenceFlow id="G1-INA1" sourceRef="G1" targetRef="INA1"/>
    <sequenceFlow id="G1-XORCLOSE8" sourceRef="G1" targetRef="XORCLOSE8"/>
    <sequenceFlow id="INA1-XORCLOSE8" sourceRef="INA1" targetRef="XORCLOSE8"/>
    <sequenceFlow id="SI1-SP1" sourceRef="SI1" targetRef="SP1"/>
    <sequenceFlow id="XORCLOSE8-XORCLOSE10" sourceRef="XORCLOSE8" targetRef="XORCLOSE10"/>
    <sequenceFlow id="SP1-XORCLOSE10" sourceRef="SP1" targetRef="XORCLOSE10"/>
    <sequenceFlow id="XORCLOSE10-RPO1" sourceRef="XORCLOSE10" targetRef="RPO1"/>
    <sequenceFlow id="RPO1-END" sourceRef="RPO1" targetRef="END"/>
  </process>
