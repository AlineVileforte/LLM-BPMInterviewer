<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_9204fc00-58c0-4e0e-aa93-c69804fc9b07" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-AE1</outgoing>
    </startEvent>
    <task id="AE1" name="ACCESS ESSE3">
      <incoming>Default_init-AE1</incoming>
      <outgoing>AE1-EL1</outgoing>
    </task>
    <task id="EL1" name="ENTER LOGIN">
      <incoming>AE1-EL1</incoming>
      <outgoing>EL1-EP1</outgoing>
    </task>
    <task id="EP1" name="ENTER PASSWORD">
      <incoming>EL1-EP1</incoming>
      <outgoing>EP1-PC1</outgoing>
    </task>
    <task id="PC1" name="PRESS CONFIRM">
      <incoming>EP1-PC1</incoming>
      <outgoing>PC1-CEI1</outgoing>
    </task>
    <task id="CEI1" name="CLICK THE EXAMS ITEM">
      <incoming>PC1-CEI1</incoming>
      <outgoing>CEI1-CESI1</outgoing>
    </task>
    <task id="CESI1" name="CLICK THE EXAM SESSIONS ITEM">
      <incoming>CEI1-CESI1</incoming>
      <outgoing>CESI1-XOR_JMPBB_EAE1_CC1</outgoing>
    </task>
    <task id="CC1" name="CHOOSE THE COURSE">
      <incoming>XOR_JMPBB_EAE1_CC1-CC1</incoming>
      <outgoing>CC1-PC3TR1</outgoing>
    </task>
    <task id="PC3TR1" name="PRESS CONFIRM 3 TIMES WITHOUT READING WHAT IS WRITTEN">
      <incoming>CC1-PC3TR1</incoming>
      <outgoing>PC3TR1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>PC3TR1-G0</incoming>
      <outgoing>G0-G1</outgoing>
      <outgoing>G0-PEC1</outgoing>
    </exclusiveGateway>
    <task id="PEC1" name="PRINT THE ENROLLMENT CONFIRMATION">
      <incoming>G0-PEC1</incoming>
      <outgoing>PEC1-HGO1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>G0-G1</incoming>
      <outgoing>G1-EE1</outgoing>
      <outgoing>G1-XORCLOSE14</outgoing>
    </exclusiveGateway>
    <task id="EE1" name="END ENROLLMENT">
      <incoming>G1-EE1</incoming>
      <outgoing>EE1-XORCLOSE14</outgoing>
    </task>
    <task id="HGO1" name="HOPE FOR A GOOD OUTCOME">
      <incoming>PEC1-HGO1</incoming>
      <outgoing>HGO1-G2</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>G1-XORCLOSE14</incoming>
      <incoming>EE1-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-XORCLOSE19</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G2" name="G2">
      <incoming>HGO1-G2</incoming>
      <outgoing>G2-EAE1</outgoing>
      <outgoing>G2-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="EAE1" name="ENROLL IN ANOTHER EXAM">
      <incoming>G2-EAE1</incoming>
      <outgoing>EAE1-XOR_JMPAA_EAE1_CC1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>G2-XORCLOSE18</incoming>
      <incoming>XOR_JMPAA_EAE1_CC1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-XORCLOSE19</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE19" name="XORCLOSE19">
      <incoming>XORCLOSE14-XORCLOSE19</incoming>
      <incoming>XORCLOSE18-XORCLOSE19</incoming>
      <outgoing>XORCLOSE19-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE19-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_EAE1_CC1" name="XOR_JMPAA_ENROLL IN ANOTHER EXAM">
      <incoming>EAE1-XOR_JMPAA_EAE1_CC1</incoming>
      <outgoing>XOR_JMPAA_EAE1_CC1-XORCLOSE18</outgoing>
      <outgoing>XOR_JMPAA_EAE1_CC1-XOR_JMPBB_EAE1_CC1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_EAE1_CC1" name="XOR_JMPBB_CHOOSE THE COURSE">
      <incoming>CESI1-XOR_JMPBB_EAE1_CC1</incoming>
      <incoming>XOR_JMPAA_EAE1_CC1-XOR_JMPBB_EAE1_CC1</incoming>
      <outgoing>XOR_JMPBB_EAE1_CC1-CC1</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Default_init-AE1" sourceRef="Default_init" targetRef="AE1"/>
