    <sequenceFlow id="CESI1-XOR_JMPBB_EAE1_CC1" sourceRef="CESI1" targetRef="XOR_JMPBB_EAE1_CC1"/>
    <sequenceFlow id="CC1-PC3TR1" sourceRef="CC1" targetRef="PC3TR1"/>
    <sequenceFlow id="PC3TR1-G0" sourceRef="PC3TR1" targetRef="G0"/>
    <sequenceFlow id="G0-EE1" sourceRef="G0" targetRef="EE1"/>
    <sequenceFlow id="G0-PEC1" sourceRef="G0" targetRef="PEC1"/>
    <sequenceFlow id="EE1-HGO1__1" sourceRef="EE1" targetRef="HGO1__1"/>
    <sequenceFlow id="PEC1-HGO1__2" sourceRef="PEC1" targetRef="HGO1__2"/>
    <sequenceFlow id="HGO1__1-EAE1" sourceRef="HGO1__1" targetRef="EAE1"/>
    <sequenceFlow id="HGO1__2-XORCLOSE18" sourceRef="HGO1__2" targetRef="XORCLOSE18"/>
    <sequenceFlow id="EAE1-XOR_JMPAA_EAE1_CC1" sourceRef="EAE1" targetRef="XOR_JMPAA_EAE1_CC1"/>
    <sequenceFlow id="XORCLOSE18-END" sourceRef="XORCLOSE18" targetRef="END"/>
    <sequenceFlow id="XOR_JMPAA_EAE1_CC1-XORCLOSE18" sourceRef="XOR_JMPAA_EAE1_CC1" targetRef="XORCLOSE18"/>
    <sequenceFlow id="XOR_JMPAA_EAE1_CC1-XOR_JMPBB_EAE1_CC1" sourceRef="XOR_JMPAA_EAE1_CC1" targetRef="XOR_JMPBB_EAE1_CC1"/>
    <sequenceFlow id="XOR_JMPBB_EAE1_CC1-CC1" sourceRef="XOR_JMPBB_EAE1_CC1" targetRef="CC1"/>
  </process>
