<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_7b9dc29e-39c9-489c-9039-fbaba5afa404" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-AE1</outgoing>
    </startEvent>
    <task id="AE1" name="ACCESS ESSE3">
      <incoming>Default_init-AE1</incoming>
      <outgoing>AE1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>AE1-Par1</incoming>
      <outgoing>Par1-EL1</outgoing>
      <outgoing>Par1-EP1</outgoing>
    </parallelGateway>
    <task id="EL1" name="ENTER LOGIN">
      <incoming>Par1-EL1</incoming>
      <outgoing>EL1-PARCLOSE6</outgoing>
    </task>
    <task id="EP1" name="ENTER PASSWORD">
      <incoming>Par1-EP1</incoming>
      <outgoing>EP1-PARCLOSE6</outgoing>
    </task>
    <parallelGateway id="PARCLOSE6" name="PARCLOSE6">
      <incoming>EL1-PARCLOSE6</incoming>
      <incoming>EP1-PARCLOSE6</incoming>
      <outgoing>PARCLOSE6-PC1</outgoing>
    </parallelGateway>
    <task id="PC1" name="PRESS CONFIRM">
      <incoming>PARCLOSE6-PC1</incoming>
      <outgoing>PC1-CEI1</outgoing>
    </task>
    <task id="CEI1" name="CLICK THE EXAMS ITEM">
      <incoming>PC1-CEI1</incoming>
      <outgoing>CEI1-CESI1</outgoing>
    </task>
    <task id="CESI1" name="CLICK THE EXAM SESSIONS ITEM">
      <incoming>CEI1-CESI1</incoming>
      <outgoing>CESI1-XOR_JMPBB_EAE1_CC1</outgoing>
    </task>
    <task id="CC1" name="CHOOSE THE COURSE">
      <incoming>XOR_JMPBB_EAE1_CC1-CC1</incoming>
      <outgoing>CC1-PC3TR1</outgoing>
    </task>
    <task id="PC3TR1" name="PRESS CONFIRM 3 TIMES WITHOUT READING WHAT IS WRITTEN">
      <incoming>CC1-PC3TR1</incoming>
      <outgoing>PC3TR1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>PC3TR1-G0</incoming>
      <outgoing>G0-EE1</outgoing>
      <outgoing>G0-PEC1</outgoing>
    </exclusiveGateway>
    <task id="EE1" name="END ENROLLMENT">
      <incoming>G0-EE1</incoming>
      <outgoing>EE1-HGO1__1</outgoing>
    </task>
    <task id="PEC1" name="PRINT THE ENROLLMENT CONFIRMATION">
      <incoming>G0-PEC1</incoming>
      <outgoing>PEC1-HGO1__2</outgoing>
    </task>
    <task id="HGO1__1" name="HOPE FOR A GOOD OUTCOME">
      <incoming>EE1-HGO1__1</incoming>
      <outgoing>HGO1__1-EAE1</outgoing>
    </task>
    <task id="HGO1__2" name="HOPE FOR A GOOD OUTCOME">
      <incoming>PEC1-HGO1__2</incoming>
      <outgoing>HGO1__2-XORCLOSE18</outgoing>
    </task>
    <task id="EAE1" name="ENROLL IN ANOTHER EXAM">
      <incoming>HGO1__1-EAE1</incoming>
      <outgoing>EAE1-XOR_JMPAA_EAE1_CC1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>HGO1__2-XORCLOSE18</incoming>
      <incoming>XOR_JMPAA_EAE1_CC1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE18-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_EAE1_CC1" name="XOR_JMPAA_ENROLL IN ANOTHER EXAM">
      <incoming>EAE1-XOR_JMPAA_EAE1_CC1</incoming>
      <outgoing>XOR_JMPAA_EAE1_CC1-XORCLOSE18</outgoing>
      <outgoing>XOR_JMPAA_EAE1_CC1-XOR_JMPBB_EAE1_CC1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_EAE1_CC1" name="XOR_JMPBB_CHOOSE THE COURSE">
      <incoming>CESI1-XOR_JMPBB_EAE1_CC1</incoming>
      <incoming>XOR_JMPAA_EAE1_CC1-XOR_JMPBB_EAE1_CC1</incoming>
      <outgoing>XOR_JMPBB_EAE1_CC1-CC1</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Default_init-AE1" sourceRef="Default_init" targetRef="AE1"/>
    <sequenceFlow id="AE1-Par1" sourceRef="AE1" targetRef="Par1"/>
    <sequenceFlow id="Par1-EL1" sourceRef="Par1" targetRef="EL1"/>
    <sequenceFlow id="Par1-EP1" sourceRef="Par1" targetRef="EP1"/>
