    <sequenceFlow id="CC1-PC3TR1" sourceRef="CC1" targetRef="PC3TR1"/>
    <sequenceFlow id="PC3TR1-G0" sourceRef="PC3TR1" targetRef="G0"/>
    <sequenceFlow id="G0-G1" sourceRef="G0" targetRef="G1"/>
