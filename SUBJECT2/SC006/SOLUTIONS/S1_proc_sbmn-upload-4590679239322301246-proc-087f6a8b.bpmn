    <sequenceFlow id="PEC1-HGO1" sourceRef="PEC1" targetRef="HGO1"/>
    <sequenceFlow id="G1-EE1" sourceRef="G1" targetRef="EE1"/>
    <sequenceFlow id="G1-XORCLOSE14" sourceRef="G1" targetRef="XORCLOSE14"/>
    <sequenceFlow id="EE1-XORCLOSE14" sourceRef="EE1" targetRef="XORCLOSE14"/>
    <sequenceFlow id="HGO1-G2" sourceRef="HGO1" targetRef="G2"/>
    <sequenceFlow id="XORCLOSE14-XORCLOSE19" sourceRef="XORCLOSE14" targetRef="XORCLOSE19"/>
    <sequenceFlow id="G2-EAE1" sourceRef="G2" targetRef="EAE1"/>
    <sequenceFlow id="G2-XORCLOSE18" sourceRef="G2" targetRef="XORCLOSE18"/>
    <sequenceFlow id="EAE1-XOR_JMPAA_EAE1_CC1" sourceRef="EAE1" targetRef="XOR_JMPAA_EAE1_CC1"/>
    <sequenceFlow id="XORCLOSE18-XORCLOSE19" sourceRef="XORCLOSE18" targetRef="XORCLOSE19"/>
    <sequenceFlow id="XORCLOSE19-END" sourceRef="XORCLOSE19" targetRef="END"/>
    <sequenceFlow id="XOR_JMPAA_EAE1_CC1-XORCLOSE18" sourceRef="XOR_JMPAA_EAE1_CC1" targetRef="XORCLOSE18"/>
    <sequenceFlow id="XOR_JMPAA_EAE1_CC1-XOR_JMPBB_EAE1_CC1" sourceRef="XOR_JMPAA_EAE1_CC1" targetRef="XOR_JMPBB_EAE1_CC1"/>
    <sequenceFlow id="XOR_JMPBB_EAE1_CC1-CC1" sourceRef="XOR_JMPBB_EAE1_CC1" targetRef="CC1"/>
  </process>
