<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_465c7ed7-15d3-4330-a8e3-508e162fd5c9" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-SISR1</outgoing>
    </startEvent>
    <task id="SISR1" name="Submit IT solution request">
      <incoming>Default_init-SISR1</incoming>
      <outgoing>SISR1-AC1</outgoing>
    </task>
    <task id="AC1" name="Assess compatibility">
      <incoming>SISR1-AC1</incoming>
      <outgoing>AC1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>AC1-G0</incoming>
      <outgoing>G0-PNT1</outgoing>
      <outgoing>G0-XORCLOSE5</outgoing>
    </exclusiveGateway>
    <task id="PNT1" name="Procure necessary tools or licenses">
      <incoming>G0-PNT1</incoming>
      <outgoing>PNT1-XORCLOSE5</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE5" name="XORCLOSE5">
      <incoming>G0-XORCLOSE5</incoming>
      <incoming>PNT1-XORCLOSE5</incoming>
      <outgoing>XORCLOSE5-IS1</outgoing>
    </exclusiveGateway>
    <task id="IS1" name="Install the solution">
      <incoming>XORCLOSE5-IS1</incoming>
      <outgoing>IS1-TS1</outgoing>
    </task>
    <task id="TS1" name="Test solution">
      <incoming>IS1-TS1</incoming>
      <outgoing>TS1-ECN1</outgoing>
    </task>
    <task id="ECN1" name="Evaluate cost and resource needs">
      <incoming>TS1-ECN1</incoming>
      <outgoing>ECN1-ROS1</outgoing>
    </task>
    <task id="ROS1" name="Roll out solution to requesting department">
      <incoming>ECN1-ROS1</incoming>
      <outgoing>ROS1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>ROS1-G1</incoming>
      <outgoing>G1-PT1</outgoing>
      <outgoing>G1-XOR_JMPBB_PSFT1_PSFT1</outgoing>
    </exclusiveGateway>
    <task id="PT1" name="Provide training">
      <incoming>G1-PT1</incoming>
      <outgoing>PT1-XORCLOSE13</outgoing>
    </task>
    <task id="PSFT1" name="Provide support for troubleshooting">
      <incoming>XOR_JMPBB_PSFT1_PSFT1-PSFT1</incoming>
      <outgoing>PSFT1-XOR_JMPAA_PSFT1_PSFT1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE13" name="XORCLOSE13">
      <incoming>PT1-XORCLOSE13</incoming>
      <incoming>XOR_JMPAA_PSFT1_PSFT1-XORCLOSE13</incoming>
      <outgoing>XORCLOSE13-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE13-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_PSFT1_PSFT1" name="XOR_JMPAA_Provide support for troubleshooting">
      <incoming>PSFT1-XOR_JMPAA_PSFT1_PSFT1</incoming>
      <outgoing>XOR_JMPAA_PSFT1_PSFT1-XORCLOSE13</outgoing>
      <outgoing>XOR_JMPAA_PSFT1_PSFT1-XOR_JMPBB_PSFT1_PSFT1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_PSFT1_PSFT1" name="XOR_JMPBB_Provide support for troubleshooting">
      <incoming>G1-XOR_JMPBB_PSFT1_PSFT1</incoming>
      <incoming>XOR_JMPAA_PSFT1_PSFT1-XOR_JMPBB_PSFT1_PSFT1</incoming>
      <outgoing>XOR_JMPBB_PSFT1_PSFT1-PSFT1</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Default_init-SISR1" sourceRef="Default_init" targetRef="SISR1"/>
    <sequenceFlow id="SISR1-AC1" sourceRef="SISR1" targetRef="AC1"/>
    <sequenceFlow id="AC1-G0" sourceRef="AC1" targetRef="G0"/>
    <sequenceFlow id="G0-PNT1" sourceRef="G0" targetRef="PNT1"/>
    <sequenceFlow id="G0-XORCLOSE5" sourceRef="G0" targetRef="XORCLOSE5"/>
    <sequenceFlow id="PNT1-XORCLOSE5" sourceRef="PNT1" targetRef="XORCLOSE5"/>
    <sequenceFlow id="XORCLOSE5-IS1" sourceRef="XORCLOSE5" targetRef="IS1"/>
    <sequenceFlow id="IS1-TS1" sourceRef="IS1" targetRef="TS1"/>
    <sequenceFlow id="TS1-ECN1" sourceRef="TS1" targetRef="ECN1"/>
    <sequenceFlow id="ECN1-ROS1" sourceRef="ECN1" targetRef="ROS1"/>
    <sequenceFlow id="ROS1-G1" sourceRef="ROS1" targetRef="G1"/>
    <sequenceFlow id="G1-PT1" sourceRef="G1" targetRef="PT1"/>
    <sequenceFlow id="G1-XOR_JMPBB_PSFT1_PSFT1" sourceRef="G1" targetRef="XOR_JMPBB_PSFT1_PSFT1"/>
    <sequenceFlow id="PT1-XORCLOSE13" sourceRef="PT1" targetRef="XORCLOSE13"/>
    <sequenceFlow id="PSFT1-XOR_JMPAA_PSFT1_PSFT1" sourceRef="PSFT1" targetRef="XOR_JMPAA_PSFT1_PSFT1"/>
    <sequenceFlow id="XORCLOSE13-END" sourceRef="XORCLOSE13" targetRef="END"/>
    <sequenceFlow id="XOR_JMPAA_PSFT1_PSFT1-XORCLOSE13" sourceRef="XOR_JMPAA_PSFT1_PSFT1" targetRef="XORCLOSE13"/>
    <sequenceFlow id="XOR_JMPAA_PSFT1_PSFT1-XOR_JMPBB_PSFT1_PSFT1" sourceRef="XOR_JMPAA_PSFT1_PSFT1" targetRef="XOR_JMPBB_PSFT1_PSFT1"/>
    <sequenceFlow id="XOR_JMPBB_PSFT1_PSFT1-PSFT1" sourceRef="XOR_JMPBB_PSFT1_PSFT1" targetRef="PSFT1"/>
  </process>
