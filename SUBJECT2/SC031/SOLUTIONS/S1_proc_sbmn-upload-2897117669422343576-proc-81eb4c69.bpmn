<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_6560ff37-dd28-4d68-a41c-82bd4961f510" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-SISR1</outgoing>
    </startEvent>
    <task id="SISR1" name="Submit IT solution request">
      <incoming>Default_init-SISR1</incoming>
      <outgoing>SISR1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>SISR1-Par1</incoming>
      <outgoing>Par1-AC1</outgoing>
      <outgoing>Par1-ECN1</outgoing>
    </parallelGateway>
    <task id="AC1" name="Assess compatibility">
      <incoming>Par1-AC1</incoming>
      <outgoing>AC1-G0</outgoing>
    </task>
    <task id="ECN1" name="Evaluate cost and resource needs">
      <incoming>Par1-ECN1</incoming>
      <outgoing>ECN1-PARCLOSE11</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>AC1-G0</incoming>
      <outgoing>G0-PNT1</outgoing>
      <outgoing>G0-XORCLOSE8</outgoing>
    </exclusiveGateway>
    <task id="PNT1" name="Procure necessary tools or licenses">
      <incoming>G0-PNT1</incoming>
      <outgoing>PNT1-XORCLOSE8</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE8" name="XORCLOSE8">
      <incoming>G0-XORCLOSE8</incoming>
      <incoming>PNT1-XORCLOSE8</incoming>
      <outgoing>XORCLOSE8-IS1</outgoing>
    </exclusiveGateway>
    <task id="IS1" name="Install the solution">
      <incoming>XORCLOSE8-IS1</incoming>
      <outgoing>IS1-TS1</outgoing>
    </task>
    <task id="TS1" name="Test solution">
      <incoming>IS1-TS1</incoming>
      <outgoing>TS1-PARCLOSE11</outgoing>
    </task>
    <parallelGateway id="PARCLOSE11" name="PARCLOSE11">
      <incoming>ECN1-PARCLOSE11</incoming>
      <incoming>TS1-PARCLOSE11</incoming>
      <outgoing>PARCLOSE11-ROS1</outgoing>
    </parallelGateway>
    <task id="ROS1" name="Roll out solution to requesting department">
      <incoming>PARCLOSE11-ROS1</incoming>
      <outgoing>ROS1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>ROS1-G1</incoming>
      <outgoing>G1-PT1</outgoing>
      <outgoing>G1-XOR_JMPBB_PSFT1_PSFT1</outgoing>
    </exclusiveGateway>
    <task id="PT1" name="Provide training">
      <incoming>G1-PT1</incoming>
      <outgoing>PT1-XORCLOSE16</outgoing>
    </task>
    <task id="PSFT1" name="Provide support for troubleshooting">
      <incoming>XOR_JMPBB_PSFT1_PSFT1-PSFT1</incoming>
      <outgoing>PSFT1-XOR_JMPAA_PSFT1_PSFT1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
      <incoming>PT1-XORCLOSE16</incoming>
      <incoming>XOR_JMPAA_PSFT1_PSFT1-XORCLOSE16</incoming>
      <outgoing>XORCLOSE16-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE16-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_PSFT1_PSFT1" name="XOR_JMPAA_Provide support for troubleshooting">
      <incoming>PSFT1-XOR_JMPAA_PSFT1_PSFT1</incoming>
      <outgoing>XOR_JMPAA_PSFT1_PSFT1-XORCLOSE16</outgoing>
      <outgoing>XOR_JMPAA_PSFT1_PSFT1-XOR_JMPBB_PSFT1_PSFT1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_PSFT1_PSFT1" name="XOR_JMPBB_Provide support for troubleshooting">
      <incoming>G1-XOR_JMPBB_PSFT1_PSFT1</incoming>
      <incoming>XOR_JMPAA_PSFT1_PSFT1-XOR_JMPBB_PSFT1_PSFT1</incoming>
      <outgoing>XOR_JMPBB_PSFT1_PSFT1-PSFT1</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Default_init-SISR1" sourceRef="Default_init" targetRef="SISR1"/>
    <sequenceFlow id="SISR1-Par1" sourceRef="SISR1" targetRef="Par1"/>
    <sequenceFlow id="Par1-AC1" sourceRef="Par1" targetRef="AC1"/>
    <sequenceFlow id="Par1-ECN1" sourceRef="Par1" targetRef="ECN1"/>
    <sequenceFlow id="AC1-G0" sourceRef="AC1" targetRef="G0"/>
    <sequenceFlow id="ECN1-PARCLOSE11" sourceRef="ECN1" targetRef="PARCLOSE11"/>
    <sequenceFlow id="G0-PNT1" sourceRef="G0" targetRef="PNT1"/>
    <sequenceFlow id="G0-XORCLOSE8" sourceRef="G0" targetRef="XORCLOSE8"/>
    <sequenceFlow id="PNT1-XORCLOSE8" sourceRef="PNT1" targetRef="XORCLOSE8"/>
    <sequenceFlow id="XORCLOSE8-IS1" sourceRef="XORCLOSE8" targetRef="IS1"/>
    <sequenceFlow id="IS1-TS1" sourceRef="IS1" targetRef="TS1"/>
    <sequenceFlow id="TS1-PARCLOSE11" sourceRef="TS1" targetRef="PARCLOSE11"/>
    <sequenceFlow id="PARCLOSE11-ROS1" sourceRef="PARCLOSE11" targetRef="ROS1"/>
    <sequenceFlow id="ROS1-G1" sourceRef="ROS1" targetRef="G1"/>
    <sequenceFlow id="G1-PT1" sourceRef="G1" targetRef="PT1"/>
    <sequenceFlow id="G1-XOR_JMPBB_PSFT1_PSFT1" sourceRef="G1" targetRef="XOR_JMPBB_PSFT1_PSFT1"/>
    <sequenceFlow id="PT1-XORCLOSE16" sourceRef="PT1" targetRef="XORCLOSE16"/>
    <sequenceFlow id="PSFT1-XOR_JMPAA_PSFT1_PSFT1" sourceRef="PSFT1" targetRef="XOR_JMPAA_PSFT1_PSFT1"/>
    <sequenceFlow id="XORCLOSE16-END" sourceRef="XORCLOSE16" targetRef="END"/>
    <sequenceFlow id="XOR_JMPAA_PSFT1_PSFT1-XORCLOSE16" sourceRef="XOR_JMPAA_PSFT1_PSFT1" targetRef="XORCLOSE16"/>
    <sequenceFlow id="XOR_JMPAA_PSFT1_PSFT1-XOR_JMPBB_PSFT1_PSFT1" sourceRef="XOR_JMPAA_PSFT1_PSFT1" targetRef="XOR_JMPBB_PSFT1_PSFT1"/>
    <sequenceFlow id="XOR_JMPBB_PSFT1_PSFT1-PSFT1" sourceRef="XOR_JMPBB_PSFT1_PSFT1" targetRef="PSFT1"/>
  </process>
