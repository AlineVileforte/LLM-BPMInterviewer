<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_f9751741-820e-4cf8-97dc-b9f4873de7d2" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-SISR1</outgoing>
    </startEvent>
    <task id="SISR1" name="Submit IT solution request">
      <incoming>Default_init-SISR1</incoming>
      <outgoing>SISR1-AC1</outgoing>
    </task>
    <task id="AC1" name="Assess compatibility">
      <incoming>SISR1-AC1</incoming>
      <outgoing>AC1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>AC1-Par2</incoming>
      <outgoing>Par2-ECN1</outgoing>
      <outgoing>Par2-G0</outgoing>
    </parallelGateway>
    <task id="ECN1" name="Evaluate cost and resource needs">
      <incoming>Par2-ECN1</incoming>
      <outgoing>ECN1-PARCLOSE10</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par2-G0</incoming>
      <outgoing>G0-PNT1</outgoing>
      <outgoing>G0-XORCLOSE7</outgoing>
    </exclusiveGateway>
    <task id="PNT1" name="Procure necessary tools or licenses">
      <incoming>G0-PNT1</incoming>
      <outgoing>PNT1-XORCLOSE7</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE7" name="XORCLOSE7">
      <incoming>G0-XORCLOSE7</incoming>
      <incoming>PNT1-XORCLOSE7</incoming>
      <outgoing>XORCLOSE7-IS1</outgoing>
    </exclusiveGateway>
    <task id="IS1" name="Install the solution">
      <incoming>XORCLOSE7-IS1</incoming>
      <outgoing>IS1-TS1</outgoing>
    </task>
    <task id="TS1" name="Test solution">
      <incoming>IS1-TS1</incoming>
      <outgoing>TS1-PARCLOSE10</outgoing>
    </task>
    <parallelGateway id="PARCLOSE10" name="PARCLOSE10">
      <incoming>ECN1-PARCLOSE10</incoming>
      <incoming>TS1-PARCLOSE10</incoming>
      <outgoing>PARCLOSE10-ROS1</outgoing>
    </parallelGateway>
    <task id="ROS1" name="Roll out solution to requesting department">
      <incoming>PARCLOSE10-ROS1</incoming>
      <outgoing>ROS1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>ROS1-G1</incoming>
      <outgoing>G1-PT1</outgoing>
      <outgoing>G1-XOR_JMPBB_PSFT1_PSFT1</outgoing>
    </exclusiveGateway>
    <task id="PT1" name="Provide training">
      <incoming>G1-PT1</incoming>
      <outgoing>PT1-XORCLOSE15</outgoing>
    </task>
    <task id="PSFT1" name="Provide support for troubleshooting">
      <incoming>XOR_JMPBB_PSFT1_PSFT1-PSFT1</incoming>
      <outgoing>PSFT1-XOR_JMPAA_PSFT1_PSFT1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE15" name="XORCLOSE15">
      <incoming>PT1-XORCLOSE15</incoming>
      <incoming>XOR_JMPAA_PSFT1_PSFT1-XORCLOSE15</incoming>
      <outgoing>XORCLOSE15-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE15-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_PSFT1_PSFT1" name="XOR_JMPAA_Provide support for troubleshooting">
      <incoming>PSFT1-XOR_JMPAA_PSFT1_PSFT1</incoming>
      <outgoing>XOR_JMPAA_PSFT1_PSFT1-XORCLOSE15</outgoing>
      <outgoing>XOR_JMPAA_PSFT1_PSFT1-XOR_JMPBB_PSFT1_PSFT1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_PSFT1_PSFT1" name="XOR_JMPBB_Provide support for troubleshooting">
      <incoming>G1-XOR_JMPBB_PSFT1_PSFT1</incoming>
      <incoming>XOR_JMPAA_PSFT1_PSFT1-XOR_JMPBB_PSFT1_PSFT1</incoming>
      <outgoing>XOR_JMPBB_PSFT1_PSFT1-PSFT1</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Default_init-SISR1" sourceRef="Default_init" targetRef="SISR1"/>
    <sequenceFlow id="SISR1-AC1" sourceRef="SISR1" targetRef="AC1"/>
    <sequenceFlow id="AC1-Par2" sourceRef="AC1" targetRef="Par2"/>
    <sequenceFlow id="Par2-ECN1" sourceRef="Par2" targetRef="ECN1"/>
    <sequenceFlow id="Par2-G0" sourceRef="Par2" targetRef="G0"/>
    <sequenceFlow id="ECN1-PARCLOSE10" sourceRef="ECN1" targetRef="PARCLOSE10"/>
