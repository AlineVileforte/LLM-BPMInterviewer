    <sequenceFlow id="XORCLOSE8-IS1" sourceRef="XORCLOSE8" targetRef="IS1"/>
    <sequenceFlow id="IS1-PARCLOSE10" sourceRef="IS1" targetRef="PARCLOSE10"/>
    <sequenceFlow id="PARCLOSE10-TS1" sourceRef="PARCLOSE10" targetRef="TS1"/>
    <sequenceFlow id="TS1-ROS1" sourceRef="TS1" targetRef="ROS1"/>
    <sequenceFlow id="ROS1-G1" sourceRef="ROS1" targetRef="G1"/>
    <sequenceFlow id="G1-PT1" sourceRef="G1" targetRef="PT1"/>
    <sequenceFlow id="G1-XOR_JMPBB_PSFT1_PSFT1" sourceRef="G1" targetRef="XOR_JMPBB_PSFT1_PSFT1"/>
    <sequenceFlow id="PT1-XORCLOSE16" sourceRef="PT1" targetRef="XORCLOSE16"/>
    <sequenceFlow id="PSFT1-XOR_JMPAA_PSFT1_PSFT1" sourceRef="PSFT1" targetRef="XOR_JMPAA_PSFT1_PSFT1"/>
    <sequenceFlow id="XORCLOSE16-END" sourceRef="XORCLOSE16" targetRef="END"/>
    <sequenceFlow id="XOR_JMPAA_PSFT1_PSFT1-XORCLOSE16" sourceRef="XOR_JMPAA_PSFT1_PSFT1" targetRef="XORCLOSE16"/>
    <sequenceFlow id="XOR_JMPAA_PSFT1_PSFT1-XOR_JMPBB_PSFT1_PSFT1" sourceRef="XOR_JMPAA_PSFT1_PSFT1" targetRef="XOR_JMPBB_PSFT1_PSFT1"/>
    <sequenceFlow id="XOR_JMPBB_PSFT1_PSFT1-PSFT1" sourceRef="XOR_JMPBB_PSFT1_PSFT1" targetRef="PSFT1"/>
  </process>
