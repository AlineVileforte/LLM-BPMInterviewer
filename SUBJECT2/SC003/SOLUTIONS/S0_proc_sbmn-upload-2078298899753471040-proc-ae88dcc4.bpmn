    <sequenceFlow id="G1-RNPN1" sourceRef="G1" targetRef="RNPN1"/>
    <sequenceFlow id="RPC1-XORCLOSE10" sourceRef="RPC1" targetRef="XORCLOSE10"/>
    <sequenceFlow id="RNPN1-XORCLOSE10" sourceRef="RNPN1" targetRef="XORCLOSE10"/>
    <sequenceFlow id="G2-DNRP1" sourceRef="G2" targetRef="DNRP1"/>
    <sequenceFlow id="G2-XORCLOSE11" sourceRef="G2" targetRef="XORCLOSE11"/>
    <sequenceFlow id="DNRP1-XORCLOSE11" sourceRef="DNRP1" targetRef="XORCLOSE11"/>
    <sequenceFlow id="XORCLOSE10-XORCLOSE12" sourceRef="XORCLOSE10" targetRef="XORCLOSE12"/>
    <sequenceFlow id="XORCLOSE11-XORCLOSE12" sourceRef="XORCLOSE11" targetRef="XORCLOSE12"/>
    <sequenceFlow id="XORCLOSE12-END" sourceRef="XORCLOSE12" targetRef="END"/>
  </process>
