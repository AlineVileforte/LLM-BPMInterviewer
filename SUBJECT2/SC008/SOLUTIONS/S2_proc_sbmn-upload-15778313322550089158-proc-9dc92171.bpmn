      <incoming>Par7-CSP1</incoming>
      <outgoing>CSP1-PARCLOSE20</outgoing>
    </task>
    <task id="CSS1" name="Choose a shipping speed">
      <incoming>Par7-CSS1</incoming>
      <outgoing>CSS1-G5</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE10" name="XORCLOSE10">
      <incoming>CESA1-XORCLOSE10</incoming>
      <incoming>EESA1-XORCLOSE10</incoming>
      <outgoing>XORCLOSE10-XORCLOSE41</outgoing>
    </exclusiveGateway>
