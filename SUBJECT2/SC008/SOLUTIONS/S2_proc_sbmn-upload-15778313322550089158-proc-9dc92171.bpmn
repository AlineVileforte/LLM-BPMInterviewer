  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-PB1</outgoing>
    </startEvent>
    <task id="PB1" name="Pay the book/s fee">
      <incoming>Default_init-PB1</incoming>
      <outgoing>PB1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>PB1-G1</incoming>
      <outgoing>G1-ENSA1</outgoing>
      <outgoing>G1-G2</outgoing>
    </exclusiveGateway>
    <task id="ENSA1" name="Enter new shipping address">
      <incoming>G1-ENSA1</incoming>
      <outgoing>ENSA1-XOR_JMPBB_RYO1_CSD1</outgoing>
    </task>
    <task id="CSD1" name="Choose shipping detail">
      <incoming>XOR_JMPBB_RYO1_CSD1-CSD1</incoming>
      <outgoing>CSD1-Par7</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>G1-G2</incoming>
      <outgoing>G2-CESA1</outgoing>
      <outgoing>G2-EESA1</outgoing>
    </exclusiveGateway>
    <task id="CESA1" name="Choose existing shipping address">
      <incoming>G2-CESA1</incoming>
      <outgoing>CESA1-XORCLOSE10</outgoing>
    </task>
