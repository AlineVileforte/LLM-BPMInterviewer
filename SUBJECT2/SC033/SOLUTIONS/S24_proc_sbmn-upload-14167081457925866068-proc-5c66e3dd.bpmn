  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-INT1</outgoing>
      <outgoing>Par0-Par3</outgoing>
    </parallelGateway>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par0-INT1</incoming>
      <outgoing>INT1-PA1</outgoing>
    </task>
    <task id="PA1" name="Patient Arrival">
      <incoming>INT1-PA1</incoming>
      <outgoing>PA1-Par6</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>Par0-Par3</incoming>
      <outgoing>Par3-PAS1</outgoing>
      <outgoing>Par3-HIA1</outgoing>
    </parallelGateway>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>Par3-PAS1</incoming>
      <outgoing>PAS1-G0</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par3-HIA1</incoming>
      <outgoing>HIA1-PARCLOSE18</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>PA1-Par6</incoming>
      <outgoing>Par6-AR1</outgoing>
      <outgoing>Par6-MCA1</outgoing>
    </parallelGateway>
    <task id="AR1" name="Administrative Registration">
      <incoming>Par6-AR1</incoming>
      <outgoing>AR1-RE1</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par6-MCA1</incoming>
      <outgoing>MCA1-AIM1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>PAS1-G0</incoming>
      <outgoing>G0-PHP1</outgoing>
      <outgoing>G0-XORCLOSE15</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G0-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE15</outgoing>
    </task>
    <task id="RE1" name="Request Exams">
      <incoming>AR1-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>MCA1-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE15" name="XORCLOSE15">
      <incoming>G0-XORCLOSE15</incoming>
      <incoming>PHP1-XORCLOSE15</incoming>
      <outgoing>XORCLOSE15-PARCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE22</outgoing>
    </task>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>HIA1-PARCLOSE18</incoming>
      <incoming>XORCLOSE15-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-PARCLOSE27</outgoing>
    </parallelGateway>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-CS1</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>RD1-CS1</incoming>
      <outgoing>CS1-RAE1</outgoing>
    </task>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>CS1-RAE1</incoming>
      <outgoing>RAE1-PARCLOSE22</outgoing>
    </task>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>TIP1-PARCLOSE22</incoming>
      <incoming>RAE1-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-Par23</outgoing>
    </parallelGateway>
    <parallelGateway id="Par23" name="PAR">
      <incoming>PARCLOSE22-Par23</incoming>
      <outgoing>Par23-DFI1</outgoing>
      <outgoing>Par23-PDP1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>Par23-DFI1</incoming>
      <outgoing>DFI1-PARCLOSE26</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>Par23-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE26</outgoing>
    </task>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>DFI1-PARCLOSE26</incoming>
      <incoming>PDP1-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-PARCLOSE27</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>PARCLOSE18-PARCLOSE27</incoming>
      <incoming>PARCLOSE26-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE27-END</incoming>
    </endEvent>
