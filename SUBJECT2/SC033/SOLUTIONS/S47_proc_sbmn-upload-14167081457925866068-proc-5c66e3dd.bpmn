  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-INT1</outgoing>
      <outgoing>Par0-Par5</outgoing>
    </parallelGateway>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par0-INT1</incoming>
      <outgoing>INT1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>INT1-Par2</incoming>
      <outgoing>Par2-PA1</outgoing>
      <outgoing>Par2-MCA1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par2-PA1</incoming>
      <outgoing>PA1-AR1</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par2-MCA1</incoming>
      <outgoing>MCA1-PARCLOSE20</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>Par0-Par5</incoming>
      <outgoing>Par5-PAS1</outgoing>
      <outgoing>Par5-HIA1</outgoing>
    </parallelGateway>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>Par5-PAS1</incoming>
      <outgoing>PAS1-AIM1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par5-HIA1</incoming>
      <outgoing>HIA1-PARCLOSE21</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>PA1-AR1</incoming>
      <outgoing>AR1-RE1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>PAS1-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <task id="RE1" name="Request Exams">
      <incoming>AR1-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-G4</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <exclusiveGateway id="G4" name="G4">
      <incoming>TIP1-G4</incoming>
      <outgoing>G4-PHP1</outgoing>
      <outgoing>G4-XORCLOSE19</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G4-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE19</outgoing>
    </task>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-PARCLOSE20</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE19" name="XORCLOSE19">
      <incoming>G4-XORCLOSE19</incoming>
      <incoming>PHP1-XORCLOSE19</incoming>
      <outgoing>XORCLOSE19-PARCLOSE21</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE20" name="PARCLOSE20">
      <incoming>MCA1-PARCLOSE20</incoming>
      <incoming>RD1-PARCLOSE20</incoming>
      <outgoing>PARCLOSE20-DFI1</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>HIA1-PARCLOSE21</incoming>
      <incoming>XORCLOSE19-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-Par23</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>PARCLOSE20-DFI1</incoming>
      <outgoing>DFI1-PARCLOSE30</outgoing>
    </task>
    <parallelGateway id="Par23" name="PAR">
      <incoming>PARCLOSE21-Par23</incoming>
      <outgoing>Par23-PDP1</outgoing>
      <outgoing>Par23-G6</outgoing>
    </parallelGateway>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>Par23-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE29</outgoing>
    </task>
    <exclusiveGateway id="G6" name="G6">
      <incoming>Par23-G6</incoming>
      <outgoing>G6-RAE1</outgoing>
      <outgoing>G6-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G6-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE28</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>G6-CS1</incoming>
      <outgoing>CS1-XORCLOSE28</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE28" name="XORCLOSE28">
      <incoming>RAE1-XORCLOSE28</incoming>
      <incoming>CS1-XORCLOSE28</incoming>
      <outgoing>XORCLOSE28-PARCLOSE29</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>PDP1-PARCLOSE29</incoming>
      <incoming>XORCLOSE28-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-PARCLOSE30</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE30" name="PARCLOSE30">
      <incoming>DFI1-PARCLOSE30</incoming>
      <incoming>PARCLOSE29-PARCLOSE30</incoming>
      <outgoing>PARCLOSE30-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE30-END</incoming>
    </endEvent>
