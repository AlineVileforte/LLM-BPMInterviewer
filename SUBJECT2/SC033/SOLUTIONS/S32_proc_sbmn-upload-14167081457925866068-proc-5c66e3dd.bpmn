    <parallelGateway id="Par23" name="PAR">
      <incoming>PARCLOSE21-Par23</incoming>
      <outgoing>Par23-DFI1</outgoing>
      <outgoing>Par23-G2</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>Par23-DFI1</incoming>
      <outgoing>DFI1-PARCLOSE34</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
