  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-INT1</outgoing>
      <outgoing>Par0-MCA1</outgoing>
    </parallelGateway>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par0-INT1</incoming>
      <outgoing>INT1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>INT1-Par2</incoming>
      <outgoing>Par2-PAS1</outgoing>
      <outgoing>Par2-AIM1</outgoing>
    </parallelGateway>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>Par2-PAS1</incoming>
      <outgoing>PAS1-Par5</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par0-MCA1</incoming>
      <outgoing>MCA1-Par12</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>PAS1-Par5</incoming>
      <outgoing>Par5-RE1</outgoing>
      <outgoing>Par5-G0</outgoing>
    </parallelGateway>
    <task id="RE1" name="Request Exams">
      <incoming>Par5-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
