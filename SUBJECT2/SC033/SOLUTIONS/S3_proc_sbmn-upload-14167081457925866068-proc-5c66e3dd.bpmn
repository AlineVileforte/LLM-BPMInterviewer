  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-PA1</outgoing>
      <outgoing>Par0-INT1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par0-PA1</incoming>
      <outgoing>PA1-MCA1</outgoing>
    </task>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par0-INT1</incoming>
      <outgoing>INT1-Par4</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>PA1-MCA1</incoming>
      <outgoing>MCA1-AR1</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>INT1-Par4</incoming>
      <outgoing>Par4-PAS1</outgoing>
      <outgoing>Par4-HIA1</outgoing>
    </parallelGateway>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>Par4-PAS1</incoming>
      <outgoing>PAS1-Par8</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par4-HIA1</incoming>
      <outgoing>HIA1-PARCLOSE22</outgoing>
    </task>
    <parallelGateway id="Par8" name="PAR">
      <incoming>PAS1-Par8</incoming>
      <outgoing>Par8-RE1</outgoing>
      <outgoing>Par8-AIM1</outgoing>
    </parallelGateway>
    <task id="RE1" name="Request Exams">
      <incoming>Par8-RE1</incoming>
      <outgoing>RE1-Par13</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par8-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>MCA1-AR1</incoming>
      <outgoing>AR1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="Par13" name="PAR">
      <incoming>RE1-Par13</incoming>
      <outgoing>Par13-PHP1</outgoing>
      <outgoing>Par13-PE1</outgoing>
    </parallelGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>Par13-PHP1</incoming>
      <outgoing>PHP1-PARCLOSE19</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>Par13-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE20</outgoing>
    </task>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-CS1</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>RD1-CS1</incoming>
      <outgoing>CS1-PARCLOSE19</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>PHP1-PARCLOSE19</incoming>
      <incoming>CS1-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-PARCLOSE20</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE20" name="PARCLOSE20">
      <incoming>TIP1-PARCLOSE20</incoming>
      <incoming>PARCLOSE19-PARCLOSE20</incoming>
      <outgoing>PARCLOSE20-RAE1</outgoing>
    </parallelGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>PARCLOSE20-RAE1</incoming>
      <outgoing>RAE1-PARCLOSE22</outgoing>
    </task>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>HIA1-PARCLOSE22</incoming>
      <incoming>RAE1-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-DFI1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>PARCLOSE22-DFI1</incoming>
      <outgoing>DFI1-PDP1</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>DFI1-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>AR1-PARCLOSE25</incoming>
      <incoming>PDP1-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE25-END</incoming>
    </endEvent>
