<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_9a2fe826-b7ea-404c-b761-f85196d68964" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-INT1</outgoing>
      <outgoing>Par0-HIA1</outgoing>
    </parallelGateway>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par0-INT1</incoming>
      <outgoing>INT1-PA1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par0-HIA1</incoming>
      <outgoing>HIA1-AR1</outgoing>
    </task>
    <task id="PA1" name="Patient Arrival">
      <incoming>INT1-PA1</incoming>
      <outgoing>PA1-MCA1</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>PA1-MCA1</incoming>
      <outgoing>MCA1-PAS1</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>HIA1-AR1</incoming>
      <outgoing>AR1-PARCLOSE21</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>MCA1-PAS1</incoming>
      <outgoing>PAS1-Par10</outgoing>
    </task>
    <parallelGateway id="Par10" name="PAR">
      <incoming>PAS1-Par10</incoming>
      <outgoing>Par10-PHP1</outgoing>
      <outgoing>Par10-AIM1</outgoing>
    </parallelGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>Par10-PHP1</incoming>
      <outgoing>PHP1-RE1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par10-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <task id="RE1" name="Request Exams">
      <incoming>PHP1-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE17</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-PARCLOSE17</outgoing>
    </task>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>TIP1-PARCLOSE17</incoming>
      <incoming>RD1-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-CS1</outgoing>
    </parallelGateway>
    <task id="CS1" name="Consult Specialist">
      <incoming>PARCLOSE17-CS1</incoming>
      <outgoing>CS1-RAE1</outgoing>
    </task>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>CS1-RAE1</incoming>
      <outgoing>RAE1-PARCLOSE21</outgoing>
    </task>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>AR1-PARCLOSE21</incoming>
      <incoming>RAE1-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-Par22</outgoing>
    </parallelGateway>
    <parallelGateway id="Par22" name="PAR">
      <incoming>PARCLOSE21-Par22</incoming>
      <outgoing>Par22-DFI1</outgoing>
      <outgoing>Par22-PDP1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>Par22-DFI1</incoming>
      <outgoing>DFI1-PARCLOSE25</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>Par22-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>DFI1-PARCLOSE25</incoming>
      <incoming>PDP1-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE25-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
