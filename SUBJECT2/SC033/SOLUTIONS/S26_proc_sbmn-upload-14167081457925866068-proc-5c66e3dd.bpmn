    <sequenceFlow id="RAE1-PARCLOSE21" sourceRef="RAE1" targetRef="PARCLOSE21"/>
    <sequenceFlow id="PARCLOSE21-Par22" sourceRef="PARCLOSE21" targetRef="Par22"/>
    <sequenceFlow id="Par22-DFI1" sourceRef="Par22" targetRef="DFI1"/>
    <sequenceFlow id="Par22-PDP1" sourceRef="Par22" targetRef="PDP1"/>
    <sequenceFlow id="DFI1-PARCLOSE25" sourceRef="DFI1" targetRef="PARCLOSE25"/>
    <sequenceFlow id="PDP1-PARCLOSE25" sourceRef="PDP1" targetRef="PARCLOSE25"/>
    <sequenceFlow id="PARCLOSE25-END" sourceRef="PARCLOSE25" targetRef="END"/>
  </process>
