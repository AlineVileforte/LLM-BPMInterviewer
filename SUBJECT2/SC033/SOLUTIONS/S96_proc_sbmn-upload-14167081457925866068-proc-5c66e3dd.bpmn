  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-PA1</outgoing>
      <outgoing>Par0-INT1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par0-PA1</incoming>
      <outgoing>PA1-HIA1</outgoing>
    </task>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par0-INT1</incoming>
      <outgoing>INT1-Par5</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>PA1-HIA1</incoming>
      <outgoing>HIA1-AR1</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>INT1-Par5</incoming>
      <outgoing>Par5-PAS1</outgoing>
      <outgoing>Par5-MCA1</outgoing>
    </parallelGateway>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>Par5-PAS1</incoming>
      <outgoing>PAS1-Par12</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par5-MCA1</incoming>
      <outgoing>MCA1-PARCLOSE25</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>HIA1-AR1</incoming>
      <outgoing>AR1-PARCLOSE31</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>PAS1-Par12</incoming>
      <outgoing>Par12-RE1</outgoing>
      <outgoing>Par12-AIM1</outgoing>
    </parallelGateway>
    <task id="RE1" name="Request Exams">
      <incoming>Par12-RE1</incoming>
      <outgoing>RE1-Par17</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par12-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <parallelGateway id="Par17" name="PAR">
      <incoming>RE1-Par17</incoming>
      <outgoing>Par17-PHP1</outgoing>
      <outgoing>Par17-PE1</outgoing>
    </parallelGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>Par17-PHP1</incoming>
      <outgoing>PHP1-PARCLOSE21</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>Par17-PE1</incoming>
      <outgoing>PE1-PARCLOSE21</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>PHP1-PARCLOSE21</incoming>
      <incoming>PE1-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-RD1</outgoing>
    </parallelGateway>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PARCLOSE21-RD1</incoming>
      <outgoing>RD1-CS1</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>RD1-CS1</incoming>
      <outgoing>CS1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>TIP1-PARCLOSE24</incoming>
