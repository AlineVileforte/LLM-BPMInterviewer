    <parallelGateway id="Par26" name="PAR">
      <incoming>PARCLOSE25-Par26</incoming>
      <outgoing>Par26-DFI1</outgoing>
      <outgoing>Par26-PDP1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>Par26-DFI1</incoming>
      <outgoing>DFI1-RAE1</outgoing>
    </task>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>DFI1-RAE1</incoming>
      <outgoing>RAE1-PARCLOSE30</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>Par26-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE30</outgoing>
    </task>
    <parallelGateway id="PARCLOSE30" name="PARCLOSE30">
      <incoming>RAE1-PARCLOSE30</incoming>
      <incoming>PDP1-PARCLOSE30</incoming>
      <outgoing>PARCLOSE30-PARCLOSE31</outgoing>
