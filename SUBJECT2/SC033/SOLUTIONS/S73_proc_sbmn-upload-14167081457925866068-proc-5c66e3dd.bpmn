  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-INT1</outgoing>
      <outgoing>Par0-HIA1</outgoing>
    </parallelGateway>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par0-INT1</incoming>
      <outgoing>INT1-Par3</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par0-HIA1</incoming>
      <outgoing>HIA1-AR1</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>INT1-Par3</incoming>
      <outgoing>Par3-PA1</outgoing>
      <outgoing>Par3-MCA1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par3-PA1</incoming>
      <outgoing>PA1-PAS1</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par3-MCA1</incoming>
      <outgoing>MCA1-PARCLOSE21</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>PA1-PAS1</incoming>
      <outgoing>PAS1-AIM1</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>HIA1-AR1</incoming>
      <outgoing>AR1-PARCLOSE22</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>PAS1-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-Par15</outgoing>
    </task>
    <parallelGateway id="Par15" name="PAR">
      <incoming>TIP1-Par15</incoming>
      <outgoing>Par15-PHP1</outgoing>
      <outgoing>Par15-RE1</outgoing>
    </parallelGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>Par15-PHP1</incoming>
      <outgoing>PHP1-PARCLOSE19</outgoing>
    </task>
    <task id="RE1" name="Request Exams">
      <incoming>Par15-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-PARCLOSE19</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>PHP1-PARCLOSE19</incoming>
      <incoming>PE1-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-PARCLOSE21</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>MCA1-PARCLOSE21</incoming>
      <incoming>PARCLOSE19-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-PARCLOSE22</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>AR1-PARCLOSE22</incoming>
      <incoming>PARCLOSE21-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-RD1</outgoing>
    </parallelGateway>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PARCLOSE22-RD1</incoming>
      <outgoing>RD1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>RD1-G0</incoming>
      <outgoing>G0-RAE1</outgoing>
      <outgoing>G0-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G0-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE27</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>G0-CS1</incoming>
      <outgoing>CS1-XORCLOSE27</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE27" name="XORCLOSE27">
      <incoming>RAE1-XORCLOSE27</incoming>
      <incoming>CS1-XORCLOSE27</incoming>
      <outgoing>XORCLOSE27-Par28</outgoing>
    </exclusiveGateway>
    <parallelGateway id="Par28" name="PAR">
      <incoming>XORCLOSE27-Par28</incoming>
      <outgoing>Par28-DFI1</outgoing>
      <outgoing>Par28-PDP1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>Par28-DFI1</incoming>
      <outgoing>DFI1-PARCLOSE31</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>Par28-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE31</outgoing>
    </task>
    <parallelGateway id="PARCLOSE31" name="PARCLOSE31">
      <incoming>DFI1-PARCLOSE31</incoming>
      <incoming>PDP1-PARCLOSE31</incoming>
      <outgoing>PARCLOSE31-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE31-END</incoming>
    </endEvent>
