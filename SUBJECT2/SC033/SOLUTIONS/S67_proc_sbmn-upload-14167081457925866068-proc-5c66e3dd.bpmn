  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-MCA1</outgoing>
    </startEvent>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Default_init-MCA1</incoming>
      <outgoing>MCA1-PA1</outgoing>
    </task>
    <task id="PA1" name="Patient Arrival">
      <incoming>MCA1-PA1</incoming>
      <outgoing>PA1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>PA1-Par2</incoming>
      <outgoing>Par2-AR1</outgoing>
      <outgoing>Par2-HIA1</outgoing>
    </parallelGateway>
    <task id="AR1" name="Administrative Registration">
      <incoming>Par2-AR1</incoming>
      <outgoing>AR1-INT1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par2-HIA1</incoming>
      <outgoing>HIA1-PARCLOSE23</outgoing>
    </task>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>AR1-INT1</incoming>
      <outgoing>INT1-PAS1</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>INT1-PAS1</incoming>
      <outgoing>PAS1-Par7</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>PAS1-Par7</incoming>
      <outgoing>Par7-RE1</outgoing>
      <outgoing>Par7-AIM1</outgoing>
    </parallelGateway>
    <task id="RE1" name="Request Exams">
      <incoming>Par7-RE1</incoming>
      <outgoing>RE1-Par10</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par7-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <parallelGateway id="Par10" name="PAR">
      <incoming>RE1-Par10</incoming>
      <outgoing>Par10-PE1</outgoing>
      <outgoing>Par10-G1</outgoing>
    </parallelGateway>
    <task id="PE1" name="Process Exams">
      <incoming>Par10-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par10-G1</incoming>
      <outgoing>G1-PHP1</outgoing>
      <outgoing>G1-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G1-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE17</outgoing>
    </task>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-CS1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE17" name="XORCLOSE17">
      <incoming>G1-XORCLOSE17</incoming>
      <incoming>PHP1-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-PARCLOSE21</outgoing>
    </exclusiveGateway>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE22</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>RD1-CS1</incoming>
      <outgoing>CS1-RAE1</outgoing>
    </task>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>CS1-RAE1</incoming>
      <outgoing>RAE1-PARCLOSE21</outgoing>
    </task>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>XORCLOSE17-PARCLOSE21</incoming>
      <incoming>RAE1-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-PARCLOSE22</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>TIP1-PARCLOSE22</incoming>
      <incoming>PARCLOSE21-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-PARCLOSE23</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>HIA1-PARCLOSE23</incoming>
      <incoming>PARCLOSE22-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-Par24</outgoing>
    </parallelGateway>
    <parallelGateway id="Par24" name="PAR">
      <incoming>PARCLOSE23-Par24</incoming>
      <outgoing>Par24-DFI1</outgoing>
      <outgoing>Par24-PDP1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>Par24-DFI1</incoming>
      <outgoing>DFI1-PARCLOSE27</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>Par24-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE27</outgoing>
    </task>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>DFI1-PARCLOSE27</incoming>
      <incoming>PDP1-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE27-END</incoming>
    </endEvent>
