  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-PA1</outgoing>
      <outgoing>Par0-HIA1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par0-PA1</incoming>
      <outgoing>PA1-INT1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par0-HIA1</incoming>
      <outgoing>HIA1-MCA1</outgoing>
    </task>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>PA1-INT1</incoming>
      <outgoing>INT1-Par6</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>HIA1-MCA1</incoming>
      <outgoing>MCA1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>INT1-Par6</incoming>
      <outgoing>Par6-AR1</outgoing>
      <outgoing>Par6-PAS1</outgoing>
    </parallelGateway>
    <task id="AR1" name="Administrative Registration">
      <incoming>Par6-AR1</incoming>
      <outgoing>AR1-PARCLOSE22</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>Par6-PAS1</incoming>
      <outgoing>PAS1-Par12</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>PAS1-Par12</incoming>
      <outgoing>Par12-RE1</outgoing>
      <outgoing>Par12-AIM1</outgoing>
    </parallelGateway>
    <task id="RE1" name="Request Exams">
      <incoming>Par12-RE1</incoming>
      <outgoing>RE1-Par16</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par12-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <parallelGateway id="Par16" name="PAR">
      <incoming>RE1-Par16</incoming>
      <outgoing>Par16-PHP1</outgoing>
      <outgoing>Par16-PE1</outgoing>
    </parallelGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>Par16-PHP1</incoming>
      <outgoing>PHP1-PARCLOSE20</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>Par16-PE1</incoming>
      <outgoing>PE1-PARCLOSE20</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE21</outgoing>
    </task>
    <parallelGateway id="PARCLOSE20" name="PARCLOSE20">
      <incoming>PHP1-PARCLOSE20</incoming>
      <incoming>PE1-PARCLOSE20</incoming>
      <outgoing>PARCLOSE20-PARCLOSE21</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>TIP1-PARCLOSE21</incoming>
      <incoming>PARCLOSE20-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-PARCLOSE22</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>AR1-PARCLOSE22</incoming>
      <incoming>PARCLOSE21-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-RD1</outgoing>
    </parallelGateway>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PARCLOSE22-RD1</incoming>
      <outgoing>RD1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>MCA1-PARCLOSE25</incoming>
      <incoming>RD1-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-DFI1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>PARCLOSE25-DFI1</incoming>
      <outgoing>DFI1-Par27</outgoing>
    </task>
    <parallelGateway id="Par27" name="PAR">
      <incoming>DFI1-Par27</incoming>
      <outgoing>Par27-PDP1</outgoing>
      <outgoing>Par27-G3</outgoing>
    </parallelGateway>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>Par27-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE33</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>Par27-G3</incoming>
      <outgoing>G3-RAE1</outgoing>
      <outgoing>G3-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G3-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE32</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>G3-CS1</incoming>
      <outgoing>CS1-XORCLOSE32</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE32" name="XORCLOSE32">
      <incoming>RAE1-XORCLOSE32</incoming>
      <incoming>CS1-XORCLOSE32</incoming>
      <outgoing>XORCLOSE32-PARCLOSE33</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE33" name="PARCLOSE33">
      <incoming>PDP1-PARCLOSE33</incoming>
      <incoming>XORCLOSE32-PARCLOSE33</incoming>
      <outgoing>PARCLOSE33-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE33-END</incoming>
    </endEvent>
