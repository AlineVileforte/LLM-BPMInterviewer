    <sequenceFlow id="PE1-RD1" sourceRef="PE1" targetRef="RD1"/>
    <sequenceFlow id="TIP1-PARCLOSE20" sourceRef="TIP1" targetRef="PARCLOSE20"/>
    <sequenceFlow id="RD1-PARCLOSE20" sourceRef="RD1" targetRef="PARCLOSE20"/>
    <sequenceFlow id="PARCLOSE20-PDP1" sourceRef="PARCLOSE20" targetRef="PDP1"/>
    <sequenceFlow id="PDP1-DFI1" sourceRef="PDP1" targetRef="DFI1"/>
    <sequenceFlow id="DFI1-PARCLOSE23" sourceRef="DFI1" targetRef="PARCLOSE23"/>
    <sequenceFlow id="PARCLOSE23-G4" sourceRef="PARCLOSE23" targetRef="G4"/>
    <sequenceFlow id="G4-RAE1" sourceRef="G4" targetRef="RAE1"/>
    <sequenceFlow id="G4-CS1" sourceRef="G4" targetRef="CS1"/>
    <sequenceFlow id="RAE1-XORCLOSE27" sourceRef="RAE1" targetRef="XORCLOSE27"/>
    <sequenceFlow id="CS1-XORCLOSE27" sourceRef="CS1" targetRef="XORCLOSE27"/>
    <sequenceFlow id="XORCLOSE27-END" sourceRef="XORCLOSE27" targetRef="END"/>
  </process>
