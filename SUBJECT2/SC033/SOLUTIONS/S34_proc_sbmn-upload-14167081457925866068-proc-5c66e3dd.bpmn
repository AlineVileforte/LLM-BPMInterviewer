<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_611361ff-90a4-4a7b-aa77-42a8f81c4358" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-INT1</outgoing>
    </startEvent>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Default_init-INT1</incoming>
      <outgoing>INT1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>INT1-Par1</incoming>
      <outgoing>Par1-PA1</outgoing>
      <outgoing>Par1-MCA1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par1-PA1</incoming>
      <outgoing>PA1-HIA1</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par1-MCA1</incoming>
      <outgoing>MCA1-PAS1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>PA1-HIA1</incoming>
      <outgoing>HIA1-AR1</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>MCA1-PAS1</incoming>
      <outgoing>PAS1-AIM1</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>HIA1-AR1</incoming>
      <outgoing>AR1-G1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>PAS1-AIM1</incoming>
      <outgoing>AIM1-Par12</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>AR1-G1</incoming>
      <outgoing>G1-PHP1</outgoing>
      <outgoing>G1-XORCLOSE15</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G1-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE15</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>AIM1-Par12</incoming>
      <outgoing>Par12-RE1</outgoing>
      <outgoing>Par12-TIP1</outgoing>
    </parallelGateway>
    <task id="RE1" name="Request Exams">
      <incoming>Par12-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>Par12-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE18</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE15" name="XORCLOSE15">
      <incoming>G1-XORCLOSE15</incoming>
      <incoming>PHP1-XORCLOSE15</incoming>
      <outgoing>XORCLOSE15-PARCLOSE29</outgoing>
    </exclusiveGateway>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-PARCLOSE18</outgoing>
    </task>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>TIP1-PARCLOSE18</incoming>
      <incoming>PE1-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-RD1</outgoing>
    </parallelGateway>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PARCLOSE18-RD1</incoming>
      <outgoing>RD1-Par20</outgoing>
    </task>
    <parallelGateway id="Par20" name="PAR">
      <incoming>RD1-Par20</incoming>
      <outgoing>Par20-DFI1</outgoing>
      <outgoing>Par20-PDP1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>Par20-DFI1</incoming>
      <outgoing>DFI1-G3</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>Par20-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE27</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>DFI1-G3</incoming>
      <outgoing>G3-RAE1</outgoing>
      <outgoing>G3-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G3-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE26</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>G3-CS1</incoming>
      <outgoing>CS1-XORCLOSE26</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE26" name="XORCLOSE26">
      <incoming>RAE1-XORCLOSE26</incoming>
      <incoming>CS1-XORCLOSE26</incoming>
      <outgoing>XORCLOSE26-PARCLOSE27</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>PDP1-PARCLOSE27</incoming>
      <incoming>XORCLOSE26-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-PARCLOSE29</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>XORCLOSE15-PARCLOSE29</incoming>
      <incoming>PARCLOSE27-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE29-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-INT1" sourceRef="Default_init" targetRef="INT1"/>
