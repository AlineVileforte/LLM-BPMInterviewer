    <sequenceFlow id="Par20-PDP1" sourceRef="Par20" targetRef="PDP1"/>
    <sequenceFlow id="DFI1-G3" sourceRef="DFI1" targetRef="G3"/>
    <sequenceFlow id="PDP1-PARCLOSE27" sourceRef="PDP1" targetRef="PARCLOSE27"/>
    <sequenceFlow id="G3-RAE1" sourceRef="G3" targetRef="RAE1"/>
    <sequenceFlow id="G3-CS1" sourceRef="G3" targetRef="CS1"/>
    <sequenceFlow id="RAE1-XORCLOSE26" sourceRef="RAE1" targetRef="XORCLOSE26"/>
    <sequenceFlow id="CS1-XORCLOSE26" sourceRef="CS1" targetRef="XORCLOSE26"/>
    <sequenceFlow id="XORCLOSE26-PARCLOSE27" sourceRef="XORCLOSE26" targetRef="PARCLOSE27"/>
    <sequenceFlow id="PARCLOSE27-PARCLOSE29" sourceRef="PARCLOSE27" targetRef="PARCLOSE29"/>
    <sequenceFlow id="PARCLOSE29-END" sourceRef="PARCLOSE29" targetRef="END"/>
  </process>
