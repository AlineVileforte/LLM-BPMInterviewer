<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_0670f4e8-8950-4b72-8b04-ccb95fd0db4f" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-MCA1</outgoing>
    </startEvent>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Default_init-MCA1</incoming>
      <outgoing>MCA1-HIA1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>MCA1-HIA1</incoming>
      <outgoing>HIA1-PA1</outgoing>
    </task>
    <task id="PA1" name="Patient Arrival">
      <incoming>HIA1-PA1</incoming>
      <outgoing>PA1-INT1</outgoing>
    </task>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>PA1-INT1</incoming>
      <outgoing>INT1-PAS1</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>INT1-PAS1</incoming>
      <outgoing>PAS1-Par5</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>PAS1-Par5</incoming>
      <outgoing>Par5-AR1</outgoing>
      <outgoing>Par5-G0</outgoing>
    </parallelGateway>
    <task id="AR1" name="Administrative Registration">
      <incoming>Par5-AR1</incoming>
      <outgoing>AR1-RE1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par5-G0</incoming>
      <outgoing>G0-PHP1</outgoing>
      <outgoing>G0-XORCLOSE11</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G0-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE11</outgoing>
    </task>
    <task id="RE1" name="Request Exams">
      <incoming>AR1-RE1</incoming>
      <outgoing>RE1-AIM1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE11" name="XORCLOSE11">
      <incoming>G0-XORCLOSE11</incoming>
      <incoming>PHP1-XORCLOSE11</incoming>
      <outgoing>XORCLOSE11-PE1</outgoing>
    </exclusiveGateway>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>RE1-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>XORCLOSE11-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE23</outgoing>
    </task>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>RD1-G1</incoming>
      <outgoing>G1-RAE1</outgoing>
      <outgoing>G1-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G1-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE20</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>G1-CS1</incoming>
      <outgoing>CS1-XORCLOSE20</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>RAE1-XORCLOSE20</incoming>
      <incoming>CS1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-DFI1</outgoing>
    </exclusiveGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>XORCLOSE20-DFI1</incoming>
      <outgoing>DFI1-PDP1</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>DFI1-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>TIP1-PARCLOSE23</incoming>
      <incoming>PDP1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE23-END</incoming>
    </endEvent>
