    <sequenceFlow id="RAE1-XORCLOSE20" sourceRef="RAE1" targetRef="XORCLOSE20"/>
    <sequenceFlow id="CS1-XORCLOSE20" sourceRef="CS1" targetRef="XORCLOSE20"/>
    <sequenceFlow id="XORCLOSE20-DFI1" sourceRef="XORCLOSE20" targetRef="DFI1"/>
    <sequenceFlow id="DFI1-PDP1" sourceRef="DFI1" targetRef="PDP1"/>
    <sequenceFlow id="PDP1-PARCLOSE23" sourceRef="PDP1" targetRef="PARCLOSE23"/>
    <sequenceFlow id="PARCLOSE23-END" sourceRef="PARCLOSE23" targetRef="END"/>
  </process>
