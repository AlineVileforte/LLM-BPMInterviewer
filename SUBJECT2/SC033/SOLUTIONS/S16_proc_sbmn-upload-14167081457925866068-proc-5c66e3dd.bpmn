      <incoming>PA1-Par7</incoming>
      <outgoing>Par7-PAS1</outgoing>
      <outgoing>Par7-AIM1</outgoing>
    </parallelGateway>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>Par7-PAS1</incoming>
      <outgoing>PAS1-Par12</outgoing>
