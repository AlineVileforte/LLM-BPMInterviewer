<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_5f9b4639-c832-4ed6-9069-ae319fb97174" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-HIA1</outgoing>
    </startEvent>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Default_init-HIA1</incoming>
      <outgoing>HIA1-MCA1</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>HIA1-MCA1</incoming>
      <outgoing>MCA1-PA1</outgoing>
    </task>
    <task id="PA1" name="Patient Arrival">
      <incoming>MCA1-PA1</incoming>
      <outgoing>PA1-INT1</outgoing>
    </task>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>PA1-INT1</incoming>
      <outgoing>INT1-Par4</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>INT1-Par4</incoming>
      <outgoing>Par4-AR1</outgoing>
      <outgoing>Par4-PAS1</outgoing>
    </parallelGateway>
    <task id="AR1" name="Administrative Registration">
      <incoming>Par4-AR1</incoming>
      <outgoing>AR1-PARCLOSE18</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>Par4-PAS1</incoming>
      <outgoing>PAS1-RE1</outgoing>
    </task>
    <task id="RE1" name="Request Exams">
      <incoming>PAS1-RE1</incoming>
      <outgoing>RE1-PHP1</outgoing>
    </task>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>RE1-PHP1</incoming>
      <outgoing>PHP1-AIM1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>PHP1-AIM1</incoming>
      <outgoing>AIM1-Par14</outgoing>
    </task>
    <parallelGateway id="Par14" name="PAR">
      <incoming>AIM1-Par14</incoming>
      <outgoing>Par14-PE1</outgoing>
      <outgoing>Par14-TIP1</outgoing>
    </parallelGateway>
    <task id="PE1" name="Process Exams">
      <incoming>Par14-PE1</incoming>
      <outgoing>PE1-PARCLOSE17</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>Par14-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE17</outgoing>
    </task>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>PE1-PARCLOSE17</incoming>
      <incoming>TIP1-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-PARCLOSE18</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>AR1-PARCLOSE18</incoming>
      <incoming>PARCLOSE17-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-RD1</outgoing>
    </parallelGateway>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PARCLOSE18-RD1</incoming>
      <outgoing>RD1-PDP1</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>RD1-PDP1</incoming>
      <outgoing>PDP1-Par21</outgoing>
    </task>
    <parallelGateway id="Par21" name="PAR">
      <incoming>PDP1-Par21</incoming>
      <outgoing>Par21-DFI1</outgoing>
      <outgoing>Par21-G2</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>Par21-DFI1</incoming>
      <outgoing>DFI1-PARCLOSE27</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par21-G2</incoming>
      <outgoing>G2-RAE1</outgoing>
      <outgoing>G2-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G2-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE26</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>G2-CS1</incoming>
      <outgoing>CS1-XORCLOSE26</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE26" name="XORCLOSE26">
      <incoming>RAE1-XORCLOSE26</incoming>
      <incoming>CS1-XORCLOSE26</incoming>
      <outgoing>XORCLOSE26-PARCLOSE27</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>DFI1-PARCLOSE27</incoming>
      <incoming>XORCLOSE26-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE27-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-HIA1" sourceRef="Default_init" targetRef="HIA1"/>
