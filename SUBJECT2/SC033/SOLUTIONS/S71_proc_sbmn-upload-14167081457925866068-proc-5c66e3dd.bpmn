    <sequenceFlow id="Par21-G2" sourceRef="Par21" targetRef="G2"/>
    <sequenceFlow id="DFI1-PARCLOSE27" sourceRef="DFI1" targetRef="PARCLOSE27"/>
    <sequenceFlow id="G2-RAE1" sourceRef="G2" targetRef="RAE1"/>
    <sequenceFlow id="G2-CS1" sourceRef="G2" targetRef="CS1"/>
    <sequenceFlow id="RAE1-XORCLOSE26" sourceRef="RAE1" targetRef="XORCLOSE26"/>
    <sequenceFlow id="CS1-XORCLOSE26" sourceRef="CS1" targetRef="XORCLOSE26"/>
    <sequenceFlow id="XORCLOSE26-PARCLOSE27" sourceRef="XORCLOSE26" targetRef="PARCLOSE27"/>
    <sequenceFlow id="PARCLOSE27-END" sourceRef="PARCLOSE27" targetRef="END"/>
  </process>
