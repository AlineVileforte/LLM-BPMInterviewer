  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-INT1</outgoing>
      <outgoing>Par0-HIA1</outgoing>
    </parallelGateway>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par0-INT1</incoming>
      <outgoing>INT1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>INT1-Par2</incoming>
      <outgoing>Par2-PAS1</outgoing>
      <outgoing>Par2-Par8</outgoing>
    </parallelGateway>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>Par2-PAS1</incoming>
      <outgoing>PAS1-Par5</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par0-HIA1</incoming>
      <outgoing>HIA1-G2</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>PAS1-Par5</incoming>
      <outgoing>Par5-PA1</outgoing>
      <outgoing>Par5-AIM1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par5-PA1</incoming>
      <outgoing>PA1-AR1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par5-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <parallelGateway id="Par8" name="PAR">
      <incoming>Par2-Par8</incoming>
      <outgoing>Par8-MCA1</outgoing>
      <outgoing>Par8-RE1</outgoing>
    </parallelGateway>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par8-MCA1</incoming>
      <outgoing>MCA1-PARCLOSE20</outgoing>
    </task>
    <task id="RE1" name="Request Exams">
      <incoming>Par8-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>HIA1-G2</incoming>
      <outgoing>G2-PHP1</outgoing>
      <outgoing>G2-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G2-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE18</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>PA1-AR1</incoming>
      <outgoing>AR1-PARCLOSE19</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE19</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-PARCLOSE20</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>G2-XORCLOSE18</incoming>
