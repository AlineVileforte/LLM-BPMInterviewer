      <incoming>PE1-PARCLOSE20</incoming>
      <outgoing>PARCLOSE20-PARCLOSE22</outgoing>
    </parallelGateway>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>XORCLOSE18-RD1</incoming>
      <outgoing>RD1-Par23</outgoing>
    </task>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>PARCLOSE19-PARCLOSE22</incoming>
      <incoming>PARCLOSE20-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-PDP1</outgoing>
    </parallelGateway>
    <parallelGateway id="Par23" name="PAR">
      <incoming>RD1-Par23</incoming>
      <outgoing>Par23-DFI1</outgoing>
      <outgoing>Par23-G3</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>Par23-DFI1</incoming>
      <outgoing>DFI1-PARCLOSE30</outgoing>
