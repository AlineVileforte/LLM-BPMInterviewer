<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_e23401fa-f4c4-4186-981a-0ca827c2a236" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-INT1</outgoing>
      <outgoing>Par0-PA1</outgoing>
    </parallelGateway>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par0-INT1</incoming>
      <outgoing>INT1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>INT1-Par2</incoming>
      <outgoing>Par2-PAS1</outgoing>
      <outgoing>Par2-MCA1</outgoing>
    </parallelGateway>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>Par2-PAS1</incoming>
      <outgoing>PAS1-G0</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par2-MCA1</incoming>
      <outgoing>MCA1-HIA1</outgoing>
    </task>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par0-PA1</incoming>
      <outgoing>PA1-Par10</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>PAS1-G0</incoming>
      <outgoing>G0-PHP1</outgoing>
      <outgoing>G0-XORCLOSE13</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G0-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE13</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>MCA1-HIA1</incoming>
      <outgoing>HIA1-AR1</outgoing>
    </task>
    <parallelGateway id="Par10" name="PAR">
      <incoming>PA1-Par10</incoming>
      <outgoing>Par10-RE1</outgoing>
      <outgoing>Par10-AIM1</outgoing>
    </parallelGateway>
    <task id="RE1" name="Request Exams">
      <incoming>Par10-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par10-AIM1</incoming>
      <outgoing>AIM1-PARCLOSE22</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE13" name="XORCLOSE13">
      <incoming>G0-XORCLOSE13</incoming>
      <incoming>PHP1-XORCLOSE13</incoming>
      <outgoing>XORCLOSE13-TIP1</outgoing>
    </exclusiveGateway>
    <task id="AR1" name="Administrative Registration">
      <incoming>HIA1-AR1</incoming>
      <outgoing>AR1-PARCLOSE19</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>XORCLOSE13-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE19</outgoing>
    </task>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-CS1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>AR1-PARCLOSE19</incoming>
      <incoming>TIP1-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-PDP1</outgoing>
    </parallelGateway>
    <task id="CS1" name="Consult Specialist">
      <incoming>RD1-CS1</incoming>
      <outgoing>CS1-PARCLOSE22</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>PARCLOSE19-PDP1</incoming>
      <outgoing>PDP1-RAE1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>AIM1-PARCLOSE22</incoming>
      <incoming>CS1-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-DFI1</outgoing>
    </parallelGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>PDP1-RAE1</incoming>
      <outgoing>RAE1-PARCLOSE25</outgoing>
    </task>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>PARCLOSE22-DFI1</incoming>
      <outgoing>DFI1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>RAE1-PARCLOSE25</incoming>
      <incoming>DFI1-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE25-END</incoming>
    </endEvent>
