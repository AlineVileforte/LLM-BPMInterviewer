    <sequenceFlow id="DFI1-PARCLOSE25" sourceRef="DFI1" targetRef="PARCLOSE25"/>
    <sequenceFlow id="PARCLOSE25-END" sourceRef="PARCLOSE25" targetRef="END"/>
  </process>
