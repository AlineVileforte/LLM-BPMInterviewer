  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-PA1</outgoing>
    </startEvent>
    <task id="PA1" name="Patient Arrival">
      <incoming>Default_init-PA1</incoming>
      <outgoing>PA1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>PA1-Par1</incoming>
      <outgoing>Par1-INT1</outgoing>
      <outgoing>Par1-MCA1</outgoing>
    </parallelGateway>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par1-INT1</incoming>
      <outgoing>INT1-Par4</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par1-MCA1</incoming>
      <outgoing>MCA1-AR1</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>INT1-Par4</incoming>
      <outgoing>Par4-PAS1</outgoing>
      <outgoing>Par4-HIA1</outgoing>
    </parallelGateway>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>Par4-PAS1</incoming>
      <outgoing>PAS1-RE1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par4-HIA1</incoming>
      <outgoing>HIA1-PARCLOSE12</outgoing>
    </task>
    <task id="RE1" name="Request Exams">
      <incoming>PAS1-RE1</incoming>
      <outgoing>RE1-AIM1</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>MCA1-AR1</incoming>
      <outgoing>AR1-PARCLOSE23</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>RE1-AIM1</incoming>
      <outgoing>AIM1-PARCLOSE12</outgoing>
    </task>
    <parallelGateway id="PARCLOSE12" name="PARCLOSE12">
      <incoming>HIA1-PARCLOSE12</incoming>
      <incoming>AIM1-PARCLOSE12</incoming>
      <outgoing>PARCLOSE12-Par13</outgoing>
    </parallelGateway>
    <parallelGateway id="Par13" name="PAR">
      <incoming>PARCLOSE12-Par13</incoming>
      <outgoing>Par13-PHP1</outgoing>
      <outgoing>Par13-PE1</outgoing>
    </parallelGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>Par13-PHP1</incoming>
      <outgoing>PHP1-TIP1</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>Par13-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>PHP1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE22</outgoing>
    </task>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>RD1-G1</incoming>
      <outgoing>G1-RAE1</outgoing>
      <outgoing>G1-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G1-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE21</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>G1-CS1</incoming>
      <outgoing>CS1-XORCLOSE21</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE21" name="XORCLOSE21">
      <incoming>RAE1-XORCLOSE21</incoming>
      <incoming>CS1-XORCLOSE21</incoming>
      <outgoing>XORCLOSE21-PARCLOSE22</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>TIP1-PARCLOSE22</incoming>
      <incoming>XORCLOSE21-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-PARCLOSE23</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>AR1-PARCLOSE23</incoming>
      <incoming>PARCLOSE22-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-Par24</outgoing>
    </parallelGateway>
    <parallelGateway id="Par24" name="PAR">
      <incoming>PARCLOSE23-Par24</incoming>
      <outgoing>Par24-DFI1</outgoing>
      <outgoing>Par24-PDP1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>Par24-DFI1</incoming>
      <outgoing>DFI1-PARCLOSE27</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>Par24-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE27</outgoing>
    </task>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>DFI1-PARCLOSE27</incoming>
      <incoming>PDP1-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE27-END</incoming>
    </endEvent>
