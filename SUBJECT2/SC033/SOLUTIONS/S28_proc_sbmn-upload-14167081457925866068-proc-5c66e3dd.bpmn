<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_d8555b1e-d542-4b50-934a-32dbeb71062f" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-INT1</outgoing>
      <outgoing>Par0-HIA1</outgoing>
    </parallelGateway>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par0-INT1</incoming>
      <outgoing>INT1-MCA1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par0-HIA1</incoming>
      <outgoing>HIA1-PARCLOSE17</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>INT1-MCA1</incoming>
      <outgoing>MCA1-PA1</outgoing>
    </task>
    <task id="PA1" name="Patient Arrival">
      <incoming>MCA1-PA1</incoming>
      <outgoing>PA1-AR1</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>PA1-AR1</incoming>
      <outgoing>AR1-PAS1</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>AR1-PAS1</incoming>
      <outgoing>PAS1-PHP1</outgoing>
    </task>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>PAS1-PHP1</incoming>
      <outgoing>PHP1-AIM1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>PHP1-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-RE1</outgoing>
    </task>
    <task id="RE1" name="Request Exams">
      <incoming>TIP1-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-PARCLOSE17</outgoing>
    </task>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>HIA1-PARCLOSE17</incoming>
      <incoming>RD1-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-Par18</outgoing>
    </parallelGateway>
    <parallelGateway id="Par18" name="PAR">
      <incoming>PARCLOSE17-Par18</incoming>
      <outgoing>Par18-DFI1</outgoing>
      <outgoing>Par18-PDP1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>Par18-DFI1</incoming>
      <outgoing>DFI1-G1</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>Par18-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE25</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>DFI1-G1</incoming>
      <outgoing>G1-RAE1</outgoing>
      <outgoing>G1-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G1-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE24</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>G1-CS1</incoming>
      <outgoing>CS1-XORCLOSE24</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE24" name="XORCLOSE24">
      <incoming>RAE1-XORCLOSE24</incoming>
      <incoming>CS1-XORCLOSE24</incoming>
      <outgoing>XORCLOSE24-PARCLOSE25</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>PDP1-PARCLOSE25</incoming>
      <incoming>XORCLOSE24-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE25-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
    <sequenceFlow id="Par0-INT1" sourceRef="Par0" targetRef="INT1"/>
