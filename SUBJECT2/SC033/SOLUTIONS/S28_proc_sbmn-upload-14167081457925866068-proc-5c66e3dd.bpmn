    <sequenceFlow id="RD1-PARCLOSE17" sourceRef="RD1" targetRef="PARCLOSE17"/>
    <sequenceFlow id="PARCLOSE17-Par18" sourceRef="PARCLOSE17" targetRef="Par18"/>
    <sequenceFlow id="Par18-DFI1" sourceRef="Par18" targetRef="DFI1"/>
    <sequenceFlow id="Par18-PDP1" sourceRef="Par18" targetRef="PDP1"/>
    <sequenceFlow id="DFI1-G1" sourceRef="DFI1" targetRef="G1"/>
    <sequenceFlow id="PDP1-PARCLOSE25" sourceRef="PDP1" targetRef="PARCLOSE25"/>
    <sequenceFlow id="G1-RAE1" sourceRef="G1" targetRef="RAE1"/>
    <sequenceFlow id="G1-CS1" sourceRef="G1" targetRef="CS1"/>
    <sequenceFlow id="RAE1-XORCLOSE24" sourceRef="RAE1" targetRef="XORCLOSE24"/>
    <sequenceFlow id="CS1-XORCLOSE24" sourceRef="CS1" targetRef="XORCLOSE24"/>
    <sequenceFlow id="XORCLOSE24-PARCLOSE25" sourceRef="XORCLOSE24" targetRef="PARCLOSE25"/>
    <sequenceFlow id="PARCLOSE25-END" sourceRef="PARCLOSE25" targetRef="END"/>
  </process>
