  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-INT1</outgoing>
      <outgoing>Par0-MCA1</outgoing>
    </parallelGateway>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par0-INT1</incoming>
      <outgoing>INT1-Par3</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par0-MCA1</incoming>
      <outgoing>MCA1-PARCLOSE20</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>INT1-Par3</incoming>
      <outgoing>Par3-PA1</outgoing>
      <outgoing>Par3-HIA1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par3-PA1</incoming>
      <outgoing>PA1-AR1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par3-HIA1</incoming>
      <outgoing>HIA1-PAS1</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>PA1-AR1</incoming>
      <outgoing>AR1-PARCLOSE19</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>HIA1-PAS1</incoming>
      <outgoing>PAS1-Par10</outgoing>
    </task>
    <parallelGateway id="Par10" name="PAR">
      <incoming>PAS1-Par10</incoming>
      <outgoing>Par10-PHP1</outgoing>
      <outgoing>Par10-AIM1</outgoing>
    </parallelGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>Par10-PHP1</incoming>
      <outgoing>PHP1-RE1</outgoing>
    </task>
    <task id="RE1" name="Request Exams">
      <incoming>PHP1-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par10-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE18</outgoing>
    </task>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-CS1</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>RD1-CS1</incoming>
      <outgoing>CS1-PARCLOSE18</outgoing>
    </task>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>TIP1-PARCLOSE18</incoming>
      <incoming>CS1-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-PARCLOSE19</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>AR1-PARCLOSE19</incoming>
      <incoming>PARCLOSE18-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-PARCLOSE20</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE20" name="PARCLOSE20">
      <incoming>MCA1-PARCLOSE20</incoming>
      <incoming>PARCLOSE19-PARCLOSE20</incoming>
      <outgoing>PARCLOSE20-DFI1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>PARCLOSE20-DFI1</incoming>
      <outgoing>DFI1-Par23</outgoing>
    </task>
    <parallelGateway id="Par23" name="PAR">
      <incoming>DFI1-Par23</incoming>
      <outgoing>Par23-RAE1</outgoing>
      <outgoing>Par23-PDP1</outgoing>
    </parallelGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>Par23-RAE1</incoming>
      <outgoing>RAE1-PARCLOSE26</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>Par23-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE26</outgoing>
    </task>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>RAE1-PARCLOSE26</incoming>
      <incoming>PDP1-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE26-END</incoming>
    </endEvent>
