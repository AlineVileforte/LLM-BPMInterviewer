  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-INT1</outgoing>
      <outgoing>Par0-HIA1</outgoing>
    </parallelGateway>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par0-INT1</incoming>
      <outgoing>INT1-Par3</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par0-HIA1</incoming>
      <outgoing>HIA1-MCA1</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>INT1-Par3</incoming>
      <outgoing>Par3-PA1</outgoing>
      <outgoing>Par3-PAS1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par3-PA1</incoming>
      <outgoing>PA1-AR1</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>Par3-PAS1</incoming>
      <outgoing>PAS1-AIM1</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>HIA1-MCA1</incoming>
      <outgoing>MCA1-PARCLOSE20</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>PA1-AR1</incoming>
      <outgoing>AR1-PARCLOSE19</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>PAS1-AIM1</incoming>
      <outgoing>AIM1-Par13</outgoing>
    </task>
    <parallelGateway id="Par13" name="PAR">
      <incoming>AIM1-Par13</incoming>
      <outgoing>Par13-RE1</outgoing>
      <outgoing>Par13-TIP1</outgoing>
    </parallelGateway>
    <task id="RE1" name="Request Exams">
      <incoming>Par13-RE1</incoming>
      <outgoing>RE1-PHP1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>Par13-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE18</outgoing>
    </task>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>RE1-PHP1</incoming>
      <outgoing>PHP1-PE1</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>PHP1-PE1</incoming>
      <outgoing>PE1-PARCLOSE18</outgoing>
    </task>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>TIP1-PARCLOSE18</incoming>
      <incoming>PE1-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-PARCLOSE19</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>AR1-PARCLOSE19</incoming>
      <incoming>PARCLOSE18-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-PARCLOSE20</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE20" name="PARCLOSE20">
      <incoming>MCA1-PARCLOSE20</incoming>
      <incoming>PARCLOSE19-PARCLOSE20</incoming>
      <outgoing>PARCLOSE20-RD1</outgoing>
    </parallelGateway>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PARCLOSE20-RD1</incoming>
      <outgoing>RD1-Par22</outgoing>
    </task>
    <parallelGateway id="Par22" name="PAR">
      <incoming>RD1-Par22</incoming>
      <outgoing>Par22-PDP1</outgoing>
      <outgoing>Par22-G2</outgoing>
    </parallelGateway>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>Par22-PDP1</incoming>
      <outgoing>PDP1-DFI1</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par22-G2</incoming>
      <outgoing>G2-RAE1</outgoing>
      <outgoing>G2-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G2-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE28</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>G2-CS1</incoming>
      <outgoing>CS1-XORCLOSE28</outgoing>
    </task>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>PDP1-DFI1</incoming>
      <outgoing>DFI1-PARCLOSE29</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE28" name="XORCLOSE28">
      <incoming>RAE1-XORCLOSE28</incoming>
      <incoming>CS1-XORCLOSE28</incoming>
      <outgoing>XORCLOSE28-PARCLOSE29</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>DFI1-PARCLOSE29</incoming>
      <incoming>XORCLOSE28-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE29-END</incoming>
    </endEvent>
