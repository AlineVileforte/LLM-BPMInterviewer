  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-PA1</outgoing>
      <outgoing>Par0-HIA1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par0-PA1</incoming>
      <outgoing>PA1-MCA1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par0-HIA1</incoming>
      <outgoing>HIA1-INT1</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>PA1-MCA1</incoming>
      <outgoing>MCA1-AR1</outgoing>
    </task>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>HIA1-INT1</incoming>
      <outgoing>INT1-PAS1</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>MCA1-AR1</incoming>
      <outgoing>AR1-AIM1</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>INT1-PAS1</incoming>
      <outgoing>PAS1-Par9</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>PAS1-Par9</incoming>
      <outgoing>Par9-RE1</outgoing>
      <outgoing>Par9-G0</outgoing>
    </parallelGateway>
    <task id="RE1" name="Request Exams">
      <incoming>Par9-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par9-G0</incoming>
      <outgoing>G0-PHP1</outgoing>
      <outgoing>G0-XORCLOSE16</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G0-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE16</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>AR1-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
      <incoming>G0-XORCLOSE16</incoming>
      <incoming>PHP1-XORCLOSE16</incoming>
      <outgoing>XORCLOSE16-PARCLOSE28</outgoing>
    </exclusiveGateway>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE29</outgoing>
    </task>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-Par19</outgoing>
    </task>
    <parallelGateway id="Par19" name="PAR">
      <incoming>RD1-Par19</incoming>
      <outgoing>Par19-PDP1</outgoing>
      <outgoing>Par19-DFI1</outgoing>
    </parallelGateway>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>Par19-PDP1</incoming>
      <outgoing>PDP1-G2</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>PDP1-G2</incoming>
      <outgoing>G2-RAE1</outgoing>
      <outgoing>G2-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G2-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE26</outgoing>
    </task>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>Par19-DFI1</incoming>
      <outgoing>DFI1-PARCLOSE27</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>G2-CS1</incoming>
      <outgoing>CS1-XORCLOSE26</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE26" name="XORCLOSE26">
      <incoming>RAE1-XORCLOSE26</incoming>
      <incoming>CS1-XORCLOSE26</incoming>
      <outgoing>XORCLOSE26-PARCLOSE27</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>DFI1-PARCLOSE27</incoming>
      <incoming>XORCLOSE26-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-PARCLOSE28</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>XORCLOSE16-PARCLOSE28</incoming>
      <incoming>PARCLOSE27-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-PARCLOSE29</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>TIP1-PARCLOSE29</incoming>
      <incoming>PARCLOSE28-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE29-END</incoming>
    </endEvent>
