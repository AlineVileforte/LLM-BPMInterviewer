  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-INT1</outgoing>
    </startEvent>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Default_init-INT1</incoming>
      <outgoing>INT1-MCA1</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>INT1-MCA1</incoming>
      <outgoing>MCA1-HIA1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>MCA1-HIA1</incoming>
      <outgoing>HIA1-PA1</outgoing>
    </task>
    <task id="PA1" name="Patient Arrival">
      <incoming>HIA1-PA1</incoming>
      <outgoing>PA1-Par4</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>PA1-Par4</incoming>
      <outgoing>Par4-AR1</outgoing>
      <outgoing>Par4-PAS1</outgoing>
    </parallelGateway>
    <task id="AR1" name="Administrative Registration">
      <incoming>Par4-AR1</incoming>
      <outgoing>AR1-PARCLOSE18</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>Par4-PAS1</incoming>
      <outgoing>PAS1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>PAS1-G0</incoming>
      <outgoing>G0-PHP1</outgoing>
      <outgoing>G0-XORCLOSE14</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G0-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE14</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>G0-XORCLOSE14</incoming>
      <incoming>PHP1-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-AIM1</outgoing>
    </exclusiveGateway>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>XORCLOSE14-AIM1</incoming>
      <outgoing>AIM1-RE1</outgoing>
    </task>
    <task id="RE1" name="Request Exams">
      <incoming>AIM1-RE1</incoming>
      <outgoing>RE1-TIP1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>RE1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE18</outgoing>
    </task>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>AR1-PARCLOSE18</incoming>
      <incoming>TIP1-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-PE1</outgoing>
    </parallelGateway>
    <task id="PE1" name="Process Exams">
      <incoming>PARCLOSE18-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-PDP1</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>RD1-PDP1</incoming>
      <outgoing>PDP1-Par22</outgoing>
    </task>
    <parallelGateway id="Par22" name="PAR">
      <incoming>PDP1-Par22</incoming>
      <outgoing>Par22-DFI1</outgoing>
      <outgoing>Par22-G2</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>Par22-DFI1</incoming>
      <outgoing>DFI1-PARCLOSE28</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par22-G2</incoming>
      <outgoing>G2-RAE1</outgoing>
      <outgoing>G2-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G2-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE27</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>G2-CS1</incoming>
      <outgoing>CS1-XORCLOSE27</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE27" name="XORCLOSE27">
      <incoming>RAE1-XORCLOSE27</incoming>
      <incoming>CS1-XORCLOSE27</incoming>
      <outgoing>XORCLOSE27-PARCLOSE28</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>DFI1-PARCLOSE28</incoming>
      <incoming>XORCLOSE27-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE28-END</incoming>
    </endEvent>
