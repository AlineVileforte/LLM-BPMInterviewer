    <sequenceFlow id="Par22-G2" sourceRef="Par22" targetRef="G2"/>
    <sequenceFlow id="DFI1-PARCLOSE28" sourceRef="DFI1" targetRef="PARCLOSE28"/>
    <sequenceFlow id="G2-RAE1" sourceRef="G2" targetRef="RAE1"/>
