  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-PA1</outgoing>
      <outgoing>Par0-MCA1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par0-PA1</incoming>
      <outgoing>PA1-Par3</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par0-MCA1</incoming>
      <outgoing>MCA1-HIA1</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>PA1-Par3</incoming>
      <outgoing>Par3-AR1</outgoing>
      <outgoing>Par3-INT1</outgoing>
    </parallelGateway>
    <task id="AR1" name="Administrative Registration">
      <incoming>Par3-AR1</incoming>
      <outgoing>AR1-PARCLOSE19</outgoing>
    </task>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par3-INT1</incoming>
      <outgoing>INT1-PAS1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>MCA1-HIA1</incoming>
      <outgoing>HIA1-PARCLOSE20</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>INT1-PAS1</incoming>
      <outgoing>PAS1-Par12</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>PAS1-Par12</incoming>
      <outgoing>Par12-PHP1</outgoing>
      <outgoing>Par12-RE1</outgoing>
    </parallelGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>Par12-PHP1</incoming>
      <outgoing>PHP1-AIM1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>PHP1-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <task id="RE1" name="Request Exams">
      <incoming>Par12-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE18</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-PARCLOSE18</outgoing>
    </task>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>TIP1-PARCLOSE18</incoming>
      <incoming>PE1-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-PARCLOSE19</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>AR1-PARCLOSE19</incoming>
      <incoming>PARCLOSE18-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-PARCLOSE20</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE20" name="PARCLOSE20">
      <incoming>HIA1-PARCLOSE20</incoming>
      <incoming>PARCLOSE19-PARCLOSE20</incoming>
      <outgoing>PARCLOSE20-RD1</outgoing>
    </parallelGateway>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PARCLOSE20-RD1</incoming>
      <outgoing>RD1-DFI1</outgoing>
    </task>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>RD1-DFI1</incoming>
      <outgoing>DFI1-Par24</outgoing>
    </task>
    <parallelGateway id="Par24" name="PAR">
      <incoming>DFI1-Par24</incoming>
      <outgoing>Par24-PDP1</outgoing>
      <outgoing>Par24-G1</outgoing>
    </parallelGateway>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>Par24-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE30</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par24-G1</incoming>
      <outgoing>G1-RAE1</outgoing>
      <outgoing>G1-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G1-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE29</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>G1-CS1</incoming>
      <outgoing>CS1-XORCLOSE29</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE29" name="XORCLOSE29">
      <incoming>RAE1-XORCLOSE29</incoming>
      <incoming>CS1-XORCLOSE29</incoming>
      <outgoing>XORCLOSE29-PARCLOSE30</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE30" name="PARCLOSE30">
      <incoming>PDP1-PARCLOSE30</incoming>
      <incoming>XORCLOSE29-PARCLOSE30</incoming>
      <outgoing>PARCLOSE30-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE30-END</incoming>
    </endEvent>
