  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-PA1</outgoing>
      <outgoing>Par0-HIA1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par0-PA1</incoming>
      <outgoing>PA1-AR1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par0-HIA1</incoming>
      <outgoing>HIA1-Par5</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>PA1-AR1</incoming>
      <outgoing>AR1-PARCLOSE32</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>HIA1-Par5</incoming>
      <outgoing>Par5-INT1</outgoing>
      <outgoing>Par5-MCA1</outgoing>
    </parallelGateway>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par5-INT1</incoming>
      <outgoing>INT1-PAS1</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par5-MCA1</incoming>
      <outgoing>MCA1-PARCLOSE22</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>INT1-PAS1</incoming>
      <outgoing>PAS1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>PAS1-G0</incoming>
      <outgoing>G0-PHP1</outgoing>
      <outgoing>G0-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G0-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE17</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE17" name="XORCLOSE17">
      <incoming>G0-XORCLOSE17</incoming>
      <incoming>PHP1-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-RE1</outgoing>
    </exclusiveGateway>
    <task id="RE1" name="Request Exams">
      <incoming>XORCLOSE17-RE1</incoming>
      <outgoing>RE1-AIM1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>RE1-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PE1</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>TIP1-PE1</incoming>
      <outgoing>PE1-PARCLOSE22</outgoing>
    </task>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>MCA1-PARCLOSE22</incoming>
      <incoming>PE1-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-RD1</outgoing>
    </parallelGateway>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PARCLOSE22-RD1</incoming>
      <outgoing>RD1-Par24</outgoing>
    </task>
    <parallelGateway id="Par24" name="PAR">
      <incoming>RD1-Par24</incoming>
      <outgoing>Par24-DFI1</outgoing>
      <outgoing>Par24-G1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>Par24-DFI1</incoming>
      <outgoing>DFI1-PDP1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par24-G1</incoming>
      <outgoing>G1-RAE1</outgoing>
      <outgoing>G1-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G1-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE30</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>G1-CS1</incoming>
      <outgoing>CS1-XORCLOSE30</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>DFI1-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE31</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE30" name="XORCLOSE30">
      <incoming>RAE1-XORCLOSE30</incoming>
      <incoming>CS1-XORCLOSE30</incoming>
      <outgoing>XORCLOSE30-PARCLOSE31</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE31" name="PARCLOSE31">
      <incoming>PDP1-PARCLOSE31</incoming>
      <incoming>XORCLOSE30-PARCLOSE31</incoming>
      <outgoing>PARCLOSE31-PARCLOSE32</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE32" name="PARCLOSE32">
      <incoming>AR1-PARCLOSE32</incoming>
      <incoming>PARCLOSE31-PARCLOSE32</incoming>
      <outgoing>PARCLOSE32-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE32-END</incoming>
    </endEvent>
