  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-MCA1</outgoing>
      <outgoing>Par0-HIA1</outgoing>
    </parallelGateway>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par0-MCA1</incoming>
      <outgoing>MCA1-PA1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par0-HIA1</incoming>
      <outgoing>HIA1-INT1</outgoing>
    </task>
    <task id="PA1" name="Patient Arrival">
      <incoming>MCA1-PA1</incoming>
      <outgoing>PA1-AR1</outgoing>
    </task>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>HIA1-INT1</incoming>
      <outgoing>INT1-PAS1</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>PA1-AR1</incoming>
      <outgoing>AR1-PARCLOSE24</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>INT1-PAS1</incoming>
      <outgoing>PAS1-Par7</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>PAS1-Par7</incoming>
      <outgoing>Par7-Par11</outgoing>
      <outgoing>Par7-G0</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par7-G0</incoming>
      <outgoing>G0-PHP1</outgoing>
      <outgoing>G0-XORCLOSE14</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G0-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE14</outgoing>
    </task>
    <parallelGateway id="Par11" name="PAR">
      <incoming>Par7-Par11</incoming>
      <outgoing>Par11-RE1</outgoing>
      <outgoing>Par11-AIM1</outgoing>
    </parallelGateway>
    <task id="RE1" name="Request Exams">
      <incoming>Par11-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par11-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>G0-XORCLOSE14</incoming>
      <incoming>PHP1-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-PARCLOSE23</outgoing>
    </exclusiveGateway>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE22</outgoing>
    </task>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-CS1</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>RD1-CS1</incoming>
      <outgoing>CS1-PARCLOSE22</outgoing>
    </task>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>TIP1-PARCLOSE22</incoming>
      <incoming>CS1-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-PARCLOSE23</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>XORCLOSE14-PARCLOSE23</incoming>
      <incoming>PARCLOSE22-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-PARCLOSE24</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>AR1-PARCLOSE24</incoming>
      <incoming>PARCLOSE23-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-Par25</outgoing>
    </parallelGateway>
    <parallelGateway id="Par25" name="PAR">
      <incoming>PARCLOSE24-Par25</incoming>
      <outgoing>Par25-RAE1</outgoing>
      <outgoing>Par25-DFI1</outgoing>
    </parallelGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>Par25-RAE1</incoming>
      <outgoing>RAE1-PDP1</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>RAE1-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE29</outgoing>
    </task>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>Par25-DFI1</incoming>
      <outgoing>DFI1-PARCLOSE29</outgoing>
    </task>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>PDP1-PARCLOSE29</incoming>
      <incoming>DFI1-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE29-END</incoming>
    </endEvent>
