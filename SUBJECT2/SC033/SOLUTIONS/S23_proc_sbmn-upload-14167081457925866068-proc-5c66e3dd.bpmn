  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-INT1</outgoing>
      <outgoing>Par0-HIA1</outgoing>
    </parallelGateway>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par0-INT1</incoming>
      <outgoing>INT1-MCA1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par0-HIA1</incoming>
      <outgoing>HIA1-PARCLOSE27</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>INT1-MCA1</incoming>
      <outgoing>MCA1-Par8</outgoing>
    </task>
    <parallelGateway id="Par8" name="PAR">
      <incoming>MCA1-Par8</incoming>
      <outgoing>Par8-PA1</outgoing>
      <outgoing>Par8-PAS1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par8-PA1</incoming>
      <outgoing>PA1-AR1</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>Par8-PAS1</incoming>
      <outgoing>PAS1-Par13</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>PA1-AR1</incoming>
      <outgoing>AR1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="Par13" name="PAR">
      <incoming>PAS1-Par13</incoming>
      <outgoing>Par13-RE1</outgoing>
      <outgoing>Par13-AIM1</outgoing>
    </parallelGateway>
    <task id="RE1" name="Request Exams">
      <incoming>Par13-RE1</incoming>
      <outgoing>RE1-Par16</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par13-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <parallelGateway id="Par16" name="PAR">
      <incoming>RE1-Par16</incoming>
      <outgoing>Par16-PHP1</outgoing>
      <outgoing>Par16-PE1</outgoing>
    </parallelGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>Par16-PHP1</incoming>
      <outgoing>PHP1-PARCLOSE20</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>Par16-PE1</incoming>
      <outgoing>PE1-PARCLOSE20</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE21</outgoing>
    </task>
    <parallelGateway id="PARCLOSE20" name="PARCLOSE20">
      <incoming>PHP1-PARCLOSE20</incoming>
      <incoming>PE1-PARCLOSE20</incoming>
      <outgoing>PARCLOSE20-PARCLOSE21</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>TIP1-PARCLOSE21</incoming>
      <incoming>PARCLOSE20-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-RD1</outgoing>
    </parallelGateway>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PARCLOSE21-RD1</incoming>
      <outgoing>RD1-CS1</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>RD1-CS1</incoming>
      <outgoing>CS1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>AR1-PARCLOSE24</incoming>
      <incoming>CS1-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-RAE1</outgoing>
    </parallelGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>PARCLOSE24-RAE1</incoming>
      <outgoing>RAE1-PARCLOSE27</outgoing>
    </task>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>HIA1-PARCLOSE27</incoming>
      <incoming>RAE1-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-DFI1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>PARCLOSE27-DFI1</incoming>
      <outgoing>DFI1-PDP1</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>DFI1-PDP1</incoming>
      <outgoing>PDP1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PDP1-END</incoming>
    </endEvent>
