<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_a8436244-9044-4853-ae90-75fd06620e6a" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-PA1</outgoing>
    </startEvent>
    <task id="PA1" name="Patient Arrival">
      <incoming>Default_init-PA1</incoming>
      <outgoing>PA1-AR1</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>PA1-AR1</incoming>
      <outgoing>AR1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>AR1-Par2</incoming>
      <outgoing>Par2-HIA1</outgoing>
      <outgoing>Par2-MCA1</outgoing>
    </parallelGateway>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par2-HIA1</incoming>
      <outgoing>HIA1-INT1</outgoing>
    </task>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>HIA1-INT1</incoming>
      <outgoing>INT1-PAS1</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par2-MCA1</incoming>
      <outgoing>MCA1-PARCLOSE26</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>INT1-PAS1</incoming>
      <outgoing>PAS1-Par7</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>PAS1-Par7</incoming>
      <outgoing>Par7-RE1</outgoing>
      <outgoing>Par7-G0</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par7-G0</incoming>
      <outgoing>G0-PHP1</outgoing>
      <outgoing>G0-XORCLOSE12</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G0-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE12</outgoing>
    </task>
    <task id="RE1" name="Request Exams">
      <incoming>Par7-RE1</incoming>
      <outgoing>RE1-Par13</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE12" name="XORCLOSE12">
      <incoming>G0-XORCLOSE12</incoming>
      <incoming>PHP1-XORCLOSE12</incoming>
      <outgoing>XORCLOSE12-PARCLOSE25</outgoing>
    </exclusiveGateway>
    <parallelGateway id="Par13" name="PAR">
      <incoming>RE1-Par13</incoming>
      <outgoing>Par13-PE1</outgoing>
      <outgoing>Par13-AIM1</outgoing>
    </parallelGateway>
    <task id="PE1" name="Process Exams">
      <incoming>Par13-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par13-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-G1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE23</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>RD1-G1</incoming>
      <outgoing>G1-RAE1</outgoing>
      <outgoing>G1-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G1-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE22</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>G1-CS1</incoming>
      <outgoing>CS1-XORCLOSE22</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE22" name="XORCLOSE22">
      <incoming>RAE1-XORCLOSE22</incoming>
      <incoming>CS1-XORCLOSE22</incoming>
      <outgoing>XORCLOSE22-PARCLOSE23</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>TIP1-PARCLOSE23</incoming>
      <incoming>XORCLOSE22-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-PDP1</outgoing>
    </parallelGateway>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>PARCLOSE23-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>XORCLOSE12-PARCLOSE25</incoming>
      <incoming>PDP1-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-PARCLOSE26</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>MCA1-PARCLOSE26</incoming>
      <incoming>PARCLOSE25-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-DFI1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>PARCLOSE26-DFI1</incoming>
      <outgoing>DFI1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>DFI1-END</incoming>
    </endEvent>
