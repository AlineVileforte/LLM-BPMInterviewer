    <sequenceFlow id="PE1-RD1" sourceRef="PE1" targetRef="RD1"/>
    <sequenceFlow id="RD1-CS1" sourceRef="RD1" targetRef="CS1"/>
    <sequenceFlow id="CS1-PARCLOSE20" sourceRef="CS1" targetRef="PARCLOSE20"/>
    <sequenceFlow id="PARCLOSE20-RAE1" sourceRef="PARCLOSE20" targetRef="RAE1"/>
    <sequenceFlow id="RAE1-PARCLOSE22" sourceRef="RAE1" targetRef="PARCLOSE22"/>
    <sequenceFlow id="PARCLOSE22-PARCLOSE23" sourceRef="PARCLOSE22" targetRef="PARCLOSE23"/>
    <sequenceFlow id="PARCLOSE23-PDP1" sourceRef="PARCLOSE23" targetRef="PDP1"/>
    <sequenceFlow id="PDP1-DFI1" sourceRef="PDP1" targetRef="DFI1"/>
    <sequenceFlow id="DFI1-END" sourceRef="DFI1" targetRef="END"/>
  </process>
