  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-HIA1</outgoing>
    </startEvent>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Default_init-HIA1</incoming>
      <outgoing>HIA1-INT1</outgoing>
    </task>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>HIA1-INT1</incoming>
      <outgoing>INT1-PA1</outgoing>
    </task>
    <task id="PA1" name="Patient Arrival">
      <incoming>INT1-PA1</incoming>
      <outgoing>PA1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>PA1-Par3</incoming>
      <outgoing>Par3-PAS1</outgoing>
      <outgoing>Par3-RE1</outgoing>
    </parallelGateway>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>Par3-PAS1</incoming>
      <outgoing>PAS1-Par5</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>PAS1-Par5</incoming>
      <outgoing>Par5-MCA1</outgoing>
      <outgoing>Par5-G0</outgoing>
    </parallelGateway>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par5-MCA1</incoming>
      <outgoing>MCA1-Par12</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par5-G0</incoming>
      <outgoing>G0-PHP1</outgoing>
      <outgoing>G0-XORCLOSE15</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G0-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE15</outgoing>
    </task>
    <task id="RE1" name="Request Exams">
      <incoming>Par3-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>MCA1-Par12</incoming>
      <outgoing>Par12-AR1</outgoing>
      <outgoing>Par12-AIM1</outgoing>
    </parallelGateway>
    <task id="AR1" name="Administrative Registration">
      <incoming>Par12-AR1</incoming>
      <outgoing>AR1-PARCLOSE19</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par12-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE15" name="XORCLOSE15">
      <incoming>G0-XORCLOSE15</incoming>
      <incoming>PHP1-XORCLOSE15</incoming>
      <outgoing>XORCLOSE15-PARCLOSE23</outgoing>
    </exclusiveGateway>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE19</outgoing>
    </task>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-Par20</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>AR1-PARCLOSE19</incoming>
      <incoming>TIP1-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-PARCLOSE23</outgoing>
    </parallelGateway>
    <parallelGateway id="Par20" name="PAR">
      <incoming>RD1-Par20</incoming>
      <outgoing>Par20-DFI1</outgoing>
      <outgoing>Par20-G1</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par20-G1</incoming>
      <outgoing>G1-RAE1</outgoing>
      <outgoing>G1-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G1-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE30</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>XORCLOSE15-PARCLOSE23</incoming>
      <incoming>PARCLOSE19-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-PDP1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>Par20-DFI1</incoming>
      <outgoing>DFI1-PARCLOSE31</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>G1-CS1</incoming>
      <outgoing>CS1-XORCLOSE30</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>PARCLOSE23-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE33</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE30" name="XORCLOSE30">
      <incoming>RAE1-XORCLOSE30</incoming>
      <incoming>CS1-XORCLOSE30</incoming>
      <outgoing>XORCLOSE30-PARCLOSE31</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE31" name="PARCLOSE31">
      <incoming>DFI1-PARCLOSE31</incoming>
      <incoming>XORCLOSE30-PARCLOSE31</incoming>
      <outgoing>PARCLOSE31-PARCLOSE33</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE33" name="PARCLOSE33">
      <incoming>PDP1-PARCLOSE33</incoming>
      <incoming>PARCLOSE31-PARCLOSE33</incoming>
      <outgoing>PARCLOSE33-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE33-END</incoming>
    </endEvent>
