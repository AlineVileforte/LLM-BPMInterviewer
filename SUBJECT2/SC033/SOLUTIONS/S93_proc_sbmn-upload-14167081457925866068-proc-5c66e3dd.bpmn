<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_65793098-f18c-4f4f-b35a-5fb70c6d19ff" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-HIA1</outgoing>
    </startEvent>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Default_init-HIA1</incoming>
      <outgoing>HIA1-INT1</outgoing>
    </task>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>HIA1-INT1</incoming>
      <outgoing>INT1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>INT1-Par2</incoming>
      <outgoing>Par2-PAS1</outgoing>
      <outgoing>Par2-Par8</outgoing>
    </parallelGateway>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>Par2-PAS1</incoming>
      <outgoing>PAS1-Par4</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>PAS1-Par4</incoming>
      <outgoing>Par4-PA1</outgoing>
      <outgoing>Par4-G0</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par4-G0</incoming>
      <outgoing>G0-PHP1</outgoing>
      <outgoing>G0-XORCLOSE12</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G0-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE12</outgoing>
    </task>
    <parallelGateway id="Par8" name="PAR">
      <incoming>Par2-Par8</incoming>
      <outgoing>Par8-MCA1</outgoing>
      <outgoing>Par8-AIM1</outgoing>
    </parallelGateway>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par8-MCA1</incoming>
      <outgoing>MCA1-RE1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par8-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par4-PA1</incoming>
      <outgoing>PA1-AR1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE12" name="XORCLOSE12">
      <incoming>G0-XORCLOSE12</incoming>
      <incoming>PHP1-XORCLOSE12</incoming>
      <outgoing>XORCLOSE12-PARCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="RE1" name="Request Exams">
      <incoming>MCA1-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE19</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>PA1-AR1</incoming>
      <outgoing>AR1-PARCLOSE17</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>XORCLOSE12-PARCLOSE17</incoming>
      <incoming>AR1-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-PARCLOSE27</outgoing>
    </parallelGateway>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-PARCLOSE19</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>TIP1-PARCLOSE19</incoming>
      <incoming>RD1-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-DFI1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>PARCLOSE19-DFI1</incoming>
      <outgoing>DFI1-G3</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>DFI1-G3</incoming>
      <outgoing>G3-RAE1</outgoing>
      <outgoing>G3-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G3-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE25</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>G3-CS1</incoming>
      <outgoing>CS1-XORCLOSE25</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE25" name="XORCLOSE25">
      <incoming>RAE1-XORCLOSE25</incoming>
      <incoming>CS1-XORCLOSE25</incoming>
      <outgoing>XORCLOSE25-PDP1</outgoing>
    </exclusiveGateway>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>XORCLOSE25-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE27</outgoing>
    </task>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>PARCLOSE17-PARCLOSE27</incoming>
      <incoming>PDP1-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE27-END</incoming>
    </endEvent>
