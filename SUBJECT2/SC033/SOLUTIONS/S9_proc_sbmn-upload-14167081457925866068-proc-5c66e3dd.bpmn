  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-PA1</outgoing>
      <outgoing>Par0-INT1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par0-PA1</incoming>
      <outgoing>PA1-AR1</outgoing>
    </task>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par0-INT1</incoming>
      <outgoing>INT1-HIA1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>INT1-HIA1</incoming>
      <outgoing>HIA1-Par9</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>PA1-AR1</incoming>
      <outgoing>AR1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>HIA1-Par9</incoming>
      <outgoing>Par9-PAS1</outgoing>
      <outgoing>Par9-MCA1</outgoing>
    </parallelGateway>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>Par9-PAS1</incoming>
      <outgoing>PAS1-Par13</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par9-MCA1</incoming>
      <outgoing>MCA1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="Par13" name="PAR">
      <incoming>PAS1-Par13</incoming>
      <outgoing>Par13-PHP1</outgoing>
      <outgoing>Par13-AIM1</outgoing>
    </parallelGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>Par13-PHP1</incoming>
      <outgoing>PHP1-RE1</outgoing>
    </task>
    <task id="RE1" name="Request Exams">
      <incoming>PHP1-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par13-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE21</outgoing>
    </task>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-CS1</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>RD1-CS1</incoming>
      <outgoing>CS1-PARCLOSE21</outgoing>
    </task>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>TIP1-PARCLOSE21</incoming>
      <incoming>CS1-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-RAE1</outgoing>
    </parallelGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>PARCLOSE21-RAE1</incoming>
      <outgoing>RAE1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>MCA1-PARCLOSE23</incoming>
      <incoming>RAE1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-PARCLOSE25</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>AR1-PARCLOSE25</incoming>
      <incoming>PARCLOSE23-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-DFI1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>PARCLOSE25-DFI1</incoming>
      <outgoing>DFI1-PDP1</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>DFI1-PDP1</incoming>
      <outgoing>PDP1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PDP1-END</incoming>
    </endEvent>
