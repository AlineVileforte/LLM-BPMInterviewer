  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-INT1</outgoing>
      <outgoing>Par0-HIA1</outgoing>
    </parallelGateway>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par0-INT1</incoming>
      <outgoing>INT1-Par3</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par0-HIA1</incoming>
      <outgoing>HIA1-PA1</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>INT1-Par3</incoming>
      <outgoing>Par3-PAS1</outgoing>
      <outgoing>Par3-MCA1</outgoing>
    </parallelGateway>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>Par3-PAS1</incoming>
      <outgoing>PAS1-G0</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par3-MCA1</incoming>
      <outgoing>MCA1-PARCLOSE21</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>PAS1-G0</incoming>
      <outgoing>G0-PHP1</outgoing>
      <outgoing>G0-XORCLOSE12</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G0-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE12</outgoing>
    </task>
    <task id="PA1" name="Patient Arrival">
      <incoming>HIA1-PA1</incoming>
      <outgoing>PA1-AR1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE12" name="XORCLOSE12">
      <incoming>G0-XORCLOSE12</incoming>
      <incoming>PHP1-XORCLOSE12</incoming>
      <outgoing>XORCLOSE12-RE1</outgoing>
    </exclusiveGateway>
    <task id="AR1" name="Administrative Registration">
      <incoming>PA1-AR1</incoming>
      <outgoing>AR1-PARCLOSE26</outgoing>
    </task>
    <task id="RE1" name="Request Exams">
      <incoming>XORCLOSE12-RE1</incoming>
      <outgoing>RE1-AIM1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>RE1-AIM1</incoming>
      <outgoing>AIM1-Par16</outgoing>
    </task>
    <parallelGateway id="Par16" name="PAR">
      <incoming>AIM1-Par16</incoming>
      <outgoing>Par16-PE1</outgoing>
      <outgoing>Par16-TIP1</outgoing>
    </parallelGateway>
    <task id="PE1" name="Process Exams">
      <incoming>Par16-PE1</incoming>
      <outgoing>PE1-PARCLOSE19</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>Par16-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE19</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>PE1-PARCLOSE19</incoming>
      <incoming>TIP1-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-RD1</outgoing>
    </parallelGateway>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PARCLOSE19-RD1</incoming>
      <outgoing>RD1-PARCLOSE21</outgoing>
    </task>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>MCA1-PARCLOSE21</incoming>
      <incoming>RD1-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-G1</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G1" name="G1">
      <incoming>PARCLOSE21-G1</incoming>
      <outgoing>G1-RAE1</outgoing>
      <outgoing>G1-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G1-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE25</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>G1-CS1</incoming>
      <outgoing>CS1-XORCLOSE25</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE25" name="XORCLOSE25">
      <incoming>RAE1-XORCLOSE25</incoming>
      <incoming>CS1-XORCLOSE25</incoming>
      <outgoing>XORCLOSE25-PARCLOSE26</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>AR1-PARCLOSE26</incoming>
      <incoming>XORCLOSE25-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-DFI1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>PARCLOSE26-DFI1</incoming>
      <outgoing>DFI1-PDP1</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>DFI1-PDP1</incoming>
      <outgoing>PDP1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PDP1-END</incoming>
    </endEvent>
