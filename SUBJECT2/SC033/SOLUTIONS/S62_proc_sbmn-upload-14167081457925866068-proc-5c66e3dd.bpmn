  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-INT1</outgoing>
      <outgoing>Par0-HIA1</outgoing>
    </parallelGateway>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par0-INT1</incoming>
      <outgoing>INT1-Par3</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par0-HIA1</incoming>
      <outgoing>HIA1-PARCLOSE28</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>INT1-Par3</incoming>
      <outgoing>Par3-PA1</outgoing>
      <outgoing>Par3-PAS1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par3-PA1</incoming>
      <outgoing>PA1-AR1</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>Par3-PAS1</incoming>
      <outgoing>PAS1-Par9</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>PA1-AR1</incoming>
      <outgoing>AR1-PARCLOSE27</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>PAS1-Par9</incoming>
      <outgoing>Par9-MCA1</outgoing>
      <outgoing>Par9-RE1</outgoing>
    </parallelGateway>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par9-MCA1</incoming>
      <outgoing>MCA1-G1</outgoing>
    </task>
    <task id="RE1" name="Request Exams">
      <incoming>Par9-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>MCA1-G1</incoming>
      <outgoing>G1-PHP1</outgoing>
      <outgoing>G1-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G1-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE18</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-AIM1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>G1-XORCLOSE18</incoming>
      <incoming>PHP1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-PARCLOSE24</outgoing>
    </exclusiveGateway>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>PE1-AIM1</incoming>
      <outgoing>AIM1-Par20</outgoing>
    </task>
    <parallelGateway id="Par20" name="PAR">
      <incoming>AIM1-Par20</incoming>
      <outgoing>Par20-RD1</outgoing>
      <outgoing>Par20-TIP1</outgoing>
    </parallelGateway>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>Par20-RD1</incoming>
      <outgoing>RD1-PARCLOSE23</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>Par20-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>RD1-PARCLOSE23</incoming>
      <incoming>TIP1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-PARCLOSE24</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>XORCLOSE18-PARCLOSE24</incoming>
      <incoming>PARCLOSE23-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-CS1</outgoing>
    </parallelGateway>
    <task id="CS1" name="Consult Specialist">
      <incoming>PARCLOSE24-CS1</incoming>
      <outgoing>CS1-RAE1</outgoing>
    </task>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>CS1-RAE1</incoming>
      <outgoing>RAE1-PARCLOSE27</outgoing>
    </task>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>AR1-PARCLOSE27</incoming>
      <incoming>RAE1-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-PARCLOSE28</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>HIA1-PARCLOSE28</incoming>
      <incoming>PARCLOSE27-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-PDP1</outgoing>
    </parallelGateway>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>PARCLOSE28-PDP1</incoming>
      <outgoing>PDP1-DFI1</outgoing>
    </task>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>PDP1-DFI1</incoming>
      <outgoing>DFI1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>DFI1-END</incoming>
    </endEvent>
