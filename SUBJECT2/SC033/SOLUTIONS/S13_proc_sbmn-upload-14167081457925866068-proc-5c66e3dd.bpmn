  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-MCA1</outgoing>
    </startEvent>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Default_init-MCA1</incoming>
      <outgoing>MCA1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>MCA1-Par1</incoming>
      <outgoing>Par1-PA1</outgoing>
      <outgoing>Par1-INT1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par1-PA1</incoming>
      <outgoing>PA1-Par4</outgoing>
    </task>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par1-INT1</incoming>
      <outgoing>INT1-PAS1</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>PA1-Par4</incoming>
      <outgoing>Par4-HIA1</outgoing>
      <outgoing>Par4-AR1</outgoing>
    </parallelGateway>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par4-HIA1</incoming>
      <outgoing>HIA1-PARCLOSE15</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>INT1-PAS1</incoming>
      <outgoing>PAS1-Par10</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>Par4-AR1</incoming>
      <outgoing>AR1-PARCLOSE15</outgoing>
    </task>
    <parallelGateway id="Par10" name="PAR">
      <incoming>PAS1-Par10</incoming>
      <outgoing>Par10-AIM1</outgoing>
      <outgoing>Par10-G0</outgoing>
    </parallelGateway>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par10-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par10-G0</incoming>
      <outgoing>G0-PHP1</outgoing>
      <outgoing>G0-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G0-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE17</outgoing>
    </task>
    <parallelGateway id="PARCLOSE15" name="PARCLOSE15">
      <incoming>HIA1-PARCLOSE15</incoming>
      <incoming>AR1-PARCLOSE15</incoming>
      <outgoing>PARCLOSE15-PARCLOSE22</outgoing>
    </parallelGateway>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-RE1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE17" name="XORCLOSE17">
      <incoming>G0-XORCLOSE17</incoming>
      <incoming>PHP1-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-PARCLOSE19</outgoing>
    </exclusiveGateway>
    <task id="RE1" name="Request Exams">
      <incoming>TIP1-RE1</incoming>
      <outgoing>RE1-PARCLOSE19</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>XORCLOSE17-PARCLOSE19</incoming>
      <incoming>RE1-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-PE1</outgoing>
    </parallelGateway>
    <task id="PE1" name="Process Exams">
      <incoming>PARCLOSE19-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-PARCLOSE22</outgoing>
    </task>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>PARCLOSE15-PARCLOSE22</incoming>
      <incoming>RD1-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-Par23</outgoing>
    </parallelGateway>
    <parallelGateway id="Par23" name="PAR">
      <incoming>PARCLOSE22-Par23</incoming>
      <outgoing>Par23-Par27</outgoing>
      <outgoing>Par23-G1</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par23-G1</incoming>
      <outgoing>G1-RAE1</outgoing>
      <outgoing>G1-CS1</outgoing>
