    <sequenceFlow id="TIP1-PARCLOSE19" sourceRef="TIP1" targetRef="PARCLOSE19"/>
    <sequenceFlow id="PARCLOSE19-G0" sourceRef="PARCLOSE19" targetRef="G0"/>
    <sequenceFlow id="G0-RAE1" sourceRef="G0" targetRef="RAE1"/>
    <sequenceFlow id="G0-CS1" sourceRef="G0" targetRef="CS1"/>
    <sequenceFlow id="RAE1-XORCLOSE24" sourceRef="RAE1" targetRef="XORCLOSE24"/>
    <sequenceFlow id="CS1-XORCLOSE24" sourceRef="CS1" targetRef="XORCLOSE24"/>
    <sequenceFlow id="XORCLOSE24-PARCLOSE25" sourceRef="XORCLOSE24" targetRef="PARCLOSE25"/>
    <sequenceFlow id="PARCLOSE25-DFI1" sourceRef="PARCLOSE25" targetRef="DFI1"/>
    <sequenceFlow id="DFI1-PDP1" sourceRef="DFI1" targetRef="PDP1"/>
    <sequenceFlow id="PDP1-END" sourceRef="PDP1" targetRef="END"/>
  </process>
