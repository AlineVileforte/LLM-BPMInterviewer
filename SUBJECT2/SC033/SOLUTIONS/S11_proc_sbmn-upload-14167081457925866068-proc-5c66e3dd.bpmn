  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-INT1</outgoing>
    </startEvent>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Default_init-INT1</incoming>
      <outgoing>INT1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>INT1-Par1</incoming>
      <outgoing>Par1-PAS1</outgoing>
      <outgoing>Par1-HIA1</outgoing>
    </parallelGateway>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>Par1-PAS1</incoming>
      <outgoing>PAS1-MCA1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par1-HIA1</incoming>
      <outgoing>HIA1-PA1</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>PAS1-MCA1</incoming>
      <outgoing>MCA1-Par8</outgoing>
    </task>
    <task id="PA1" name="Patient Arrival">
      <incoming>HIA1-PA1</incoming>
      <outgoing>PA1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="Par8" name="PAR">
      <incoming>MCA1-Par8</incoming>
      <outgoing>Par8-AIM1</outgoing>
      <outgoing>Par8-G1</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par8-G1</incoming>
      <outgoing>G1-PHP1</outgoing>
      <outgoing>G1-XORCLOSE14</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G1-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE14</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par8-AIM1</incoming>
      <outgoing>AIM1-AR1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>G1-XORCLOSE14</incoming>
      <incoming>PHP1-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-Par17</outgoing>
    </exclusiveGateway>
    <task id="AR1" name="Administrative Registration">
      <incoming>AIM1-AR1</incoming>
      <outgoing>AR1-PARCLOSE22</outgoing>
    </task>
    <parallelGateway id="Par17" name="PAR">
      <incoming>XORCLOSE14-Par17</incoming>
      <outgoing>Par17-RE1</outgoing>
      <outgoing>Par17-TIP1</outgoing>
    </parallelGateway>
    <task id="RE1" name="Request Exams">
      <incoming>Par17-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>Par17-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE21</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-PARCLOSE21</outgoing>
    </task>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>TIP1-PARCLOSE21</incoming>
      <incoming>PE1-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-PARCLOSE22</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>AR1-PARCLOSE22</incoming>
      <incoming>PARCLOSE21-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-PARCLOSE23</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>PA1-PARCLOSE23</incoming>
      <incoming>PARCLOSE22-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-RD1</outgoing>
    </parallelGateway>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PARCLOSE23-RD1</incoming>
      <outgoing>RD1-Par25</outgoing>
    </task>
    <parallelGateway id="Par25" name="PAR">
      <incoming>RD1-Par25</incoming>
      <outgoing>Par25-PDP1</outgoing>
      <outgoing>Par25-G2</outgoing>
    </parallelGateway>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>Par25-PDP1</incoming>
      <outgoing>PDP1-DFI1</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par25-G2</incoming>
      <outgoing>G2-RAE1</outgoing>
      <outgoing>G2-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G2-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE31</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>G2-CS1</incoming>
      <outgoing>CS1-XORCLOSE31</outgoing>
    </task>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>PDP1-DFI1</incoming>
      <outgoing>DFI1-PARCLOSE32</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE31" name="XORCLOSE31">
      <incoming>RAE1-XORCLOSE31</incoming>
      <incoming>CS1-XORCLOSE31</incoming>
      <outgoing>XORCLOSE31-PARCLOSE32</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE32" name="PARCLOSE32">
      <incoming>DFI1-PARCLOSE32</incoming>
      <incoming>XORCLOSE31-PARCLOSE32</incoming>
      <outgoing>PARCLOSE32-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE32-END</incoming>
    </endEvent>
