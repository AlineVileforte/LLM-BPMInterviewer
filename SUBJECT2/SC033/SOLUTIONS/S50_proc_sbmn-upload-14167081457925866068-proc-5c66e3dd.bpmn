    <sequenceFlow id="CS1-PARCLOSE24" sourceRef="CS1" targetRef="PARCLOSE24"/>
    <sequenceFlow id="PARCLOSE24-PARCLOSE25" sourceRef="PARCLOSE24" targetRef="PARCLOSE25"/>
    <sequenceFlow id="PARCLOSE25-RAE1" sourceRef="PARCLOSE25" targetRef="RAE1"/>
    <sequenceFlow id="RAE1-DFI1" sourceRef="RAE1" targetRef="DFI1"/>
    <sequenceFlow id="DFI1-PDP1" sourceRef="DFI1" targetRef="PDP1"/>
    <sequenceFlow id="PDP1-END" sourceRef="PDP1" targetRef="END"/>
  </process>
