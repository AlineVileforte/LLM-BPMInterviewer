    <sequenceFlow id="G1-XORCLOSE20" sourceRef="G1" targetRef="XORCLOSE20"/>
    <sequenceFlow id="PHP1-XORCLOSE20" sourceRef="PHP1" targetRef="XORCLOSE20"/>
    <sequenceFlow id="TIP1-PARCLOSE24" sourceRef="TIP1" targetRef="PARCLOSE24"/>
    <sequenceFlow id="PE1-RD1" sourceRef="PE1" targetRef="RD1"/>
    <sequenceFlow id="XORCLOSE20-PARCLOSE22" sourceRef="XORCLOSE20" targetRef="PARCLOSE22"/>
    <sequenceFlow id="RD1-PARCLOSE22" sourceRef="RD1" targetRef="PARCLOSE22"/>
