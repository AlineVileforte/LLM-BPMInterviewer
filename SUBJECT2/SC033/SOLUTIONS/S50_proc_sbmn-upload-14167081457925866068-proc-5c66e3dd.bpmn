<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_947b4e1e-52d1-4d9f-9dc8-c1a07501e921" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-INT1</outgoing>
    </startEvent>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Default_init-INT1</incoming>
      <outgoing>INT1-PA1</outgoing>
    </task>
    <task id="PA1" name="Patient Arrival">
      <incoming>INT1-PA1</incoming>
      <outgoing>PA1-AR1</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>PA1-AR1</incoming>
      <outgoing>AR1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>AR1-Par3</incoming>
      <outgoing>Par3-PAS1</outgoing>
      <outgoing>Par3-HIA1</outgoing>
    </parallelGateway>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>Par3-PAS1</incoming>
      <outgoing>PAS1-Par6</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par3-HIA1</incoming>
      <outgoing>HIA1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>PAS1-Par6</incoming>
      <outgoing>Par6-RE1</outgoing>
      <outgoing>Par6-AIM1</outgoing>
    </parallelGateway>
    <task id="RE1" name="Request Exams">
      <incoming>Par6-RE1</incoming>
      <outgoing>RE1-Par12</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par6-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>RE1-Par12</incoming>
      <outgoing>Par12-MCA1</outgoing>
      <outgoing>Par12-G1</outgoing>
    </parallelGateway>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par12-MCA1</incoming>
      <outgoing>MCA1-PE1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par12-G1</incoming>
      <outgoing>G1-PHP1</outgoing>
      <outgoing>G1-XORCLOSE20</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G1-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE20</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE24</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>MCA1-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>G1-XORCLOSE20</incoming>
      <incoming>PHP1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-PARCLOSE22</outgoing>
    </exclusiveGateway>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-PARCLOSE22</outgoing>
    </task>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>XORCLOSE20-PARCLOSE22</incoming>
      <incoming>RD1-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-CS1</outgoing>
    </parallelGateway>
    <task id="CS1" name="Consult Specialist">
      <incoming>PARCLOSE22-CS1</incoming>
      <outgoing>CS1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>TIP1-PARCLOSE24</incoming>
      <incoming>CS1-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-PARCLOSE25</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>HIA1-PARCLOSE25</incoming>
      <incoming>PARCLOSE24-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-RAE1</outgoing>
    </parallelGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>PARCLOSE25-RAE1</incoming>
      <outgoing>RAE1-DFI1</outgoing>
    </task>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>RAE1-DFI1</incoming>
      <outgoing>DFI1-PDP1</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>DFI1-PDP1</incoming>
      <outgoing>PDP1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PDP1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-INT1" sourceRef="Default_init" targetRef="INT1"/>
