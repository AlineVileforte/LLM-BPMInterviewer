  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-INT1</outgoing>
      <outgoing>Par0-MCA1</outgoing>
    </parallelGateway>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par0-INT1</incoming>
      <outgoing>INT1-HIA1</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par0-MCA1</incoming>
      <outgoing>MCA1-Par5</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>INT1-HIA1</incoming>
      <outgoing>HIA1-PAS1</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>MCA1-Par5</incoming>
      <outgoing>Par5-PA1</outgoing>
      <outgoing>Par5-AR1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par5-PA1</incoming>
      <outgoing>PA1-PARCLOSE17</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>HIA1-PAS1</incoming>
      <outgoing>PAS1-AIM1</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>Par5-AR1</incoming>
      <outgoing>AR1-PARCLOSE17</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>PAS1-AIM1</incoming>
      <outgoing>AIM1-Par14</outgoing>
    </task>
    <parallelGateway id="Par14" name="PAR">
      <incoming>AIM1-Par14</incoming>
      <outgoing>Par14-RE1</outgoing>
      <outgoing>Par14-TIP1</outgoing>
    </parallelGateway>
    <task id="RE1" name="Request Exams">
      <incoming>Par14-RE1</incoming>
      <outgoing>RE1-Par18</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>Par14-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>PA1-PARCLOSE17</incoming>
      <incoming>AR1-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-PARCLOSE27</outgoing>
    </parallelGateway>
    <parallelGateway id="Par18" name="PAR">
      <incoming>RE1-Par18</incoming>
      <outgoing>Par18-PHP1</outgoing>
      <outgoing>Par18-PE1</outgoing>
    </parallelGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>Par18-PHP1</incoming>
      <outgoing>PHP1-PARCLOSE24</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>Par18-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-CS1</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>RD1-CS1</incoming>
      <outgoing>CS1-RAE1</outgoing>
    </task>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>CS1-RAE1</incoming>
      <outgoing>RAE1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
