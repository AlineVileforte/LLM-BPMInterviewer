  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-PA1</outgoing>
      <outgoing>Par0-MCA1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par0-PA1</incoming>
      <outgoing>PA1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>PA1-Par2</incoming>
      <outgoing>Par2-INT1</outgoing>
      <outgoing>Par2-HIA1</outgoing>
    </parallelGateway>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par2-INT1</incoming>
      <outgoing>INT1-AR1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par2-HIA1</incoming>
      <outgoing>HIA1-PARCLOSE9</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par0-MCA1</incoming>
      <outgoing>MCA1-PAS1</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>INT1-AR1</incoming>
      <outgoing>AR1-PARCLOSE9</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>MCA1-PAS1</incoming>
      <outgoing>PAS1-AIM1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE9" name="PARCLOSE9">
      <incoming>HIA1-PARCLOSE9</incoming>
      <incoming>AR1-PARCLOSE9</incoming>
      <outgoing>PARCLOSE9-PHP1</outgoing>
    </parallelGateway>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>PAS1-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>PARCLOSE9-PHP1</incoming>
      <outgoing>PHP1-RE1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE14</outgoing>
    </task>
    <task id="RE1" name="Request Exams">
      <incoming>PHP1-RE1</incoming>
      <outgoing>RE1-PARCLOSE14</outgoing>
    </task>
    <parallelGateway id="PARCLOSE14" name="PARCLOSE14">
      <incoming>TIP1-PARCLOSE14</incoming>
      <incoming>RE1-PARCLOSE14</incoming>
      <outgoing>PARCLOSE14-PE1</outgoing>
    </parallelGateway>
    <task id="PE1" name="Process Exams">
      <incoming>PARCLOSE14-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-Par17</outgoing>
    </task>
    <parallelGateway id="Par17" name="PAR">
      <incoming>RD1-Par17</incoming>
      <outgoing>Par17-PDP1</outgoing>
      <outgoing>Par17-G0</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par17-G0</incoming>
      <outgoing>G0-RAE1</outgoing>
      <outgoing>G0-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G0-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE24</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>Par17-PDP1</incoming>
      <outgoing>PDP1-DFI1</outgoing>
    </task>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>PDP1-DFI1</incoming>
      <outgoing>DFI1-PARCLOSE25</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>G0-CS1</incoming>
      <outgoing>CS1-XORCLOSE24</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE24" name="XORCLOSE24">
      <incoming>RAE1-XORCLOSE24</incoming>
      <incoming>CS1-XORCLOSE24</incoming>
      <outgoing>XORCLOSE24-PARCLOSE25</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>DFI1-PARCLOSE25</incoming>
      <incoming>XORCLOSE24-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE25-END</incoming>
    </endEvent>
