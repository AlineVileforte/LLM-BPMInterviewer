<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_54883505-c342-4174-8777-fca500d461a4" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-MCA1</outgoing>
    </startEvent>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Default_init-MCA1</incoming>
      <outgoing>MCA1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>MCA1-Par1</incoming>
      <outgoing>Par1-HIA1</outgoing>
      <outgoing>Par1-PA1</outgoing>
    </parallelGateway>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par1-HIA1</incoming>
      <outgoing>HIA1-INT1</outgoing>
    </task>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>HIA1-INT1</incoming>
      <outgoing>INT1-PAS1</outgoing>
    </task>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par1-PA1</incoming>
      <outgoing>PA1-AR1</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>INT1-PAS1</incoming>
      <outgoing>PAS1-Par7</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>PA1-AR1</incoming>
      <outgoing>AR1-RE1</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>PAS1-Par7</incoming>
      <outgoing>Par7-AIM1</outgoing>
      <outgoing>Par7-G0</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par7-G0</incoming>
      <outgoing>G0-PHP1</outgoing>
      <outgoing>G0-XORCLOSE13</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G0-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE13</outgoing>
    </task>
    <task id="RE1" name="Request Exams">
      <incoming>AR1-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par7-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE13" name="XORCLOSE13">
      <incoming>G0-XORCLOSE13</incoming>
      <incoming>PHP1-XORCLOSE13</incoming>
      <outgoing>XORCLOSE13-PARCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE17</outgoing>
    </task>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-Par18</outgoing>
    </task>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>XORCLOSE13-PARCLOSE17</incoming>
      <incoming>TIP1-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-G2</outgoing>
    </parallelGateway>
    <parallelGateway id="Par18" name="PAR">
      <incoming>RD1-Par18</incoming>
      <outgoing>Par18-DFI1</outgoing>
      <outgoing>Par18-PDP1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>Par18-DFI1</incoming>
      <outgoing>DFI1-PARCLOSE23</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>Par18-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE23</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>PARCLOSE17-G2</incoming>
      <outgoing>G2-RAE1</outgoing>
      <outgoing>G2-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G2-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE26</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>DFI1-PARCLOSE23</incoming>
      <incoming>PDP1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-PARCLOSE27</outgoing>
    </parallelGateway>
    <task id="CS1" name="Consult Specialist">
      <incoming>G2-CS1</incoming>
      <outgoing>CS1-XORCLOSE26</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE26" name="XORCLOSE26">
      <incoming>RAE1-XORCLOSE26</incoming>
      <incoming>CS1-XORCLOSE26</incoming>
      <outgoing>XORCLOSE26-PARCLOSE27</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>PARCLOSE23-PARCLOSE27</incoming>
      <incoming>XORCLOSE26-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE27-END</incoming>
    </endEvent>
