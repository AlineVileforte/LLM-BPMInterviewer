  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-MCA1</outgoing>
      <outgoing>Par0-HIA1</outgoing>
    </parallelGateway>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par0-MCA1</incoming>
      <outgoing>MCA1-INT1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par0-HIA1</incoming>
      <outgoing>HIA1-PA1</outgoing>
    </task>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>MCA1-INT1</incoming>
      <outgoing>INT1-PAS1</outgoing>
    </task>
    <task id="PA1" name="Patient Arrival">
      <incoming>HIA1-PA1</incoming>
      <outgoing>PA1-AR1</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>INT1-PAS1</incoming>
      <outgoing>PAS1-AIM1</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>PA1-AR1</incoming>
      <outgoing>AR1-RE1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>PAS1-AIM1</incoming>
      <outgoing>AIM1-G2</outgoing>
    </task>
    <task id="RE1" name="Request Exams">
      <incoming>AR1-RE1</incoming>
      <outgoing>RE1-Par12</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>AIM1-G2</incoming>
      <outgoing>G2-PHP1</outgoing>
      <outgoing>G2-XORCLOSE15</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G2-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE15</outgoing>
    </task>
    <parallelGateway id="Par12" name="PAR">
      <incoming>RE1-Par12</incoming>
      <outgoing>Par12-PE1</outgoing>
      <outgoing>Par12-TIP1</outgoing>
    </parallelGateway>
    <task id="PE1" name="Process Exams">
      <incoming>Par12-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>Par12-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE23</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE15" name="XORCLOSE15">
      <incoming>G2-XORCLOSE15</incoming>
      <incoming>PHP1-XORCLOSE15</incoming>
      <outgoing>XORCLOSE15-PARCLOSE24</outgoing>
    </exclusiveGateway>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-G3</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>RD1-G3</incoming>
      <outgoing>G3-RAE1</outgoing>
      <outgoing>G3-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G3-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE22</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>G3-CS1</incoming>
      <outgoing>CS1-XORCLOSE22</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE22" name="XORCLOSE22">
      <incoming>RAE1-XORCLOSE22</incoming>
      <incoming>CS1-XORCLOSE22</incoming>
      <outgoing>XORCLOSE22-PARCLOSE23</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>TIP1-PARCLOSE23</incoming>
      <incoming>XORCLOSE22-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-PARCLOSE24</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>XORCLOSE15-PARCLOSE24</incoming>
      <incoming>PARCLOSE23-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-Par25</outgoing>
    </parallelGateway>
    <parallelGateway id="Par25" name="PAR">
      <incoming>PARCLOSE24-Par25</incoming>
      <outgoing>Par25-DFI1</outgoing>
      <outgoing>Par25-PDP1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>Par25-DFI1</incoming>
      <outgoing>DFI1-PARCLOSE28</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>Par25-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE28</outgoing>
    </task>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>DFI1-PARCLOSE28</incoming>
      <incoming>PDP1-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE28-END</incoming>
    </endEvent>
