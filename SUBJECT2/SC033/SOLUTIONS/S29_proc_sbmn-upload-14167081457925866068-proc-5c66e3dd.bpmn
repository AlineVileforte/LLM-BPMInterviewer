    <sequenceFlow id="PARCLOSE28-PARCLOSE29" sourceRef="PARCLOSE28" targetRef="PARCLOSE29"/>
    <sequenceFlow id="PARCLOSE29-END" sourceRef="PARCLOSE29" targetRef="END"/>
  </process>
