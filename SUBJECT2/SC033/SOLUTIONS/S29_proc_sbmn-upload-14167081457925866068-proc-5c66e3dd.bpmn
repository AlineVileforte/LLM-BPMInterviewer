<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_db9cfc91-0c58-4648-af55-dc7e0a37da5e" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-MCA1</outgoing>
    </startEvent>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Default_init-MCA1</incoming>
      <outgoing>MCA1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>MCA1-Par1</incoming>
      <outgoing>Par1-PA1</outgoing>
      <outgoing>Par1-INT1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par1-PA1</incoming>
      <outgoing>PA1-HIA1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>PA1-HIA1</incoming>
      <outgoing>HIA1-AR1</outgoing>
    </task>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par1-INT1</incoming>
      <outgoing>INT1-PAS1</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>HIA1-AR1</incoming>
      <outgoing>AR1-AIM1</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>INT1-PAS1</incoming>
      <outgoing>PAS1-Par9</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>PAS1-Par9</incoming>
      <outgoing>Par9-RE1</outgoing>
      <outgoing>Par9-G0</outgoing>
    </parallelGateway>
    <task id="RE1" name="Request Exams">
      <incoming>Par9-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par9-G0</incoming>
      <outgoing>G0-PHP1</outgoing>
      <outgoing>G0-XORCLOSE16</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G0-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE16</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>AR1-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-PARCLOSE18</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
      <incoming>G0-XORCLOSE16</incoming>
      <incoming>PHP1-XORCLOSE16</incoming>
      <outgoing>XORCLOSE16-PARCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-RD1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>PE1-PARCLOSE18</incoming>
      <incoming>XORCLOSE16-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-PARCLOSE29</outgoing>
    </parallelGateway>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>TIP1-RD1</incoming>
      <outgoing>RD1-Par20</outgoing>
    </task>
    <parallelGateway id="Par20" name="PAR">
      <incoming>RD1-Par20</incoming>
      <outgoing>Par20-DFI1</outgoing>
      <outgoing>Par20-G1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>Par20-DFI1</incoming>
      <outgoing>DFI1-PDP1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par20-G1</incoming>
      <outgoing>G1-RAE1</outgoing>
      <outgoing>G1-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G1-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE27</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>DFI1-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE28</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>G1-CS1</incoming>
      <outgoing>CS1-XORCLOSE27</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE27" name="XORCLOSE27">
      <incoming>RAE1-XORCLOSE27</incoming>
      <incoming>CS1-XORCLOSE27</incoming>
      <outgoing>XORCLOSE27-PARCLOSE28</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>PDP1-PARCLOSE28</incoming>
      <incoming>XORCLOSE27-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-PARCLOSE29</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>PARCLOSE18-PARCLOSE29</incoming>
      <incoming>PARCLOSE28-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE29-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-MCA1" sourceRef="Default_init" targetRef="MCA1"/>
