  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-PA1</outgoing>
      <outgoing>Par0-INT1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par0-PA1</incoming>
      <outgoing>PA1-MCA1</outgoing>
    </task>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par0-INT1</incoming>
      <outgoing>INT1-HIA1</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>PA1-MCA1</incoming>
      <outgoing>MCA1-AR1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>INT1-HIA1</incoming>
      <outgoing>HIA1-PAS1</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>MCA1-AR1</incoming>
      <outgoing>AR1-PARCLOSE29</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>HIA1-PAS1</incoming>
      <outgoing>PAS1-PHP1</outgoing>
    </task>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>PAS1-PHP1</incoming>
      <outgoing>PHP1-Par15</outgoing>
    </task>
    <parallelGateway id="Par15" name="PAR">
      <incoming>PHP1-Par15</incoming>
      <outgoing>Par15-RE1</outgoing>
      <outgoing>Par15-AIM1</outgoing>
    </parallelGateway>
    <task id="RE1" name="Request Exams">
      <incoming>Par15-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par15-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE21</outgoing>
    </task>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-PARCLOSE21</outgoing>
    </task>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>TIP1-PARCLOSE21</incoming>
      <incoming>RD1-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-CS1</outgoing>
    </parallelGateway>
    <task id="CS1" name="Consult Specialist">
      <incoming>PARCLOSE21-CS1</incoming>
      <outgoing>CS1-Par23</outgoing>
    </task>
    <parallelGateway id="Par23" name="PAR">
      <incoming>CS1-Par23</incoming>
      <outgoing>Par23-DFI1</outgoing>
      <outgoing>Par23-PDP1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>Par23-DFI1</incoming>
      <outgoing>DFI1-RAE1</outgoing>
    </task>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>DFI1-RAE1</incoming>
      <outgoing>RAE1-PARCLOSE27</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>Par23-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE27</outgoing>
    </task>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>RAE1-PARCLOSE27</incoming>
      <incoming>PDP1-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-PARCLOSE29</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>AR1-PARCLOSE29</incoming>
      <incoming>PARCLOSE27-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE29-END</incoming>
    </endEvent>
