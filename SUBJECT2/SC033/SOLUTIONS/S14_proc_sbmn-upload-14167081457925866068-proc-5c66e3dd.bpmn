<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_0e9d8f84-094c-4b59-8150-5515cf975f67" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-MCA1</outgoing>
    </startEvent>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Default_init-MCA1</incoming>
      <outgoing>MCA1-PA1</outgoing>
    </task>
    <task id="PA1" name="Patient Arrival">
      <incoming>MCA1-PA1</incoming>
      <outgoing>PA1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>PA1-Par2</incoming>
      <outgoing>Par2-AR1</outgoing>
      <outgoing>Par2-HIA1</outgoing>
    </parallelGateway>
    <task id="AR1" name="Administrative Registration">
      <incoming>Par2-AR1</incoming>
      <outgoing>AR1-INT1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par2-HIA1</incoming>
      <outgoing>HIA1-PARCLOSE7</outgoing>
    </task>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>AR1-INT1</incoming>
      <outgoing>INT1-PAS1</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>INT1-PAS1</incoming>
      <outgoing>PAS1-PARCLOSE7</outgoing>
    </task>
    <parallelGateway id="PARCLOSE7" name="PARCLOSE7">
      <incoming>HIA1-PARCLOSE7</incoming>
      <incoming>PAS1-PARCLOSE7</incoming>
      <outgoing>PARCLOSE7-Par8</outgoing>
    </parallelGateway>
    <parallelGateway id="Par8" name="PAR">
      <incoming>PARCLOSE7-Par8</incoming>
      <outgoing>Par8-RE1</outgoing>
      <outgoing>Par8-AIM1</outgoing>
    </parallelGateway>
    <task id="RE1" name="Request Exams">
      <incoming>Par8-RE1</incoming>
      <outgoing>RE1-Par11</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par8-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <parallelGateway id="Par11" name="PAR">
      <incoming>RE1-Par11</incoming>
      <outgoing>Par11-PE1</outgoing>
      <outgoing>Par11-G2</outgoing>
    </parallelGateway>
    <task id="PE1" name="Process Exams">
      <incoming>Par11-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>Par11-G2</incoming>
      <outgoing>G2-PHP1</outgoing>
      <outgoing>G2-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G2-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE18</outgoing>
    </task>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-CS1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>G2-XORCLOSE18</incoming>
      <incoming>PHP1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-PARCLOSE21</outgoing>
    </exclusiveGateway>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE22</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>RD1-CS1</incoming>
      <outgoing>CS1-PARCLOSE21</outgoing>
    </task>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>XORCLOSE18-PARCLOSE21</incoming>
      <incoming>CS1-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-PARCLOSE22</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>TIP1-PARCLOSE22</incoming>
      <incoming>PARCLOSE21-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-RAE1</outgoing>
    </parallelGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>PARCLOSE22-RAE1</incoming>
      <outgoing>RAE1-PDP1</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>RAE1-PDP1</incoming>
      <outgoing>PDP1-DFI1</outgoing>
    </task>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>PDP1-DFI1</incoming>
      <outgoing>DFI1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>DFI1-END</incoming>
    </endEvent>
