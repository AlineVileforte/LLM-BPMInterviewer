    <sequenceFlow id="TIP1-PARCLOSE22" sourceRef="TIP1" targetRef="PARCLOSE22"/>
    <sequenceFlow id="CS1-PARCLOSE21" sourceRef="CS1" targetRef="PARCLOSE21"/>
