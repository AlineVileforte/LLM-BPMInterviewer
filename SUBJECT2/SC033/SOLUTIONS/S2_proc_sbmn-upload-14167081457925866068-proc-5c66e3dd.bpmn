<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_7ed62a37-8734-45ec-a3cf-b460d2d1952c" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-INT1</outgoing>
      <outgoing>Par0-HIA1</outgoing>
    </parallelGateway>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par0-INT1</incoming>
      <outgoing>INT1-PAS1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par0-HIA1</incoming>
      <outgoing>HIA1-Par4</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>INT1-PAS1</incoming>
      <outgoing>PAS1-Par7</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>HIA1-Par4</incoming>
      <outgoing>Par4-MCA1</outgoing>
      <outgoing>Par4-PA1</outgoing>
    </parallelGateway>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par4-MCA1</incoming>
      <outgoing>MCA1-PARCLOSE18</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>PAS1-Par7</incoming>
      <outgoing>Par7-AIM1</outgoing>
      <outgoing>Par7-G0</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par7-G0</incoming>
      <outgoing>G0-PHP1</outgoing>
      <outgoing>G0-XORCLOSE14</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G0-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE14</outgoing>
    </task>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par4-PA1</incoming>
      <outgoing>PA1-AR1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par7-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>G0-XORCLOSE14</incoming>
      <incoming>PHP1-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-RE1</outgoing>
    </exclusiveGateway>
    <task id="AR1" name="Administrative Registration">
      <incoming>PA1-AR1</incoming>
      <outgoing>AR1-PARCLOSE18</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE23</outgoing>
    </task>
    <task id="RE1" name="Request Exams">
      <incoming>XORCLOSE14-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>MCA1-PARCLOSE18</incoming>
      <incoming>AR1-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-PARCLOSE24</outgoing>
    </parallelGateway>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-CS1</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>RD1-CS1</incoming>
      <outgoing>CS1-RAE1</outgoing>
    </task>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>CS1-RAE1</incoming>
      <outgoing>RAE1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>TIP1-PARCLOSE23</incoming>
      <incoming>RAE1-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-PARCLOSE24</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>PARCLOSE18-PARCLOSE24</incoming>
      <incoming>PARCLOSE23-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-PDP1</outgoing>
    </parallelGateway>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>PARCLOSE24-PDP1</incoming>
      <outgoing>PDP1-DFI1</outgoing>
    </task>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>PDP1-DFI1</incoming>
      <outgoing>DFI1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>DFI1-END</incoming>
    </endEvent>
