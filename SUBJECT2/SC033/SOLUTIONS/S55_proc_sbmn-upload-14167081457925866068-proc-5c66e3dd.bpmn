  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-INT1</outgoing>
      <outgoing>Par0-MCA1</outgoing>
    </parallelGateway>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par0-INT1</incoming>
      <outgoing>INT1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>INT1-Par2</incoming>
      <outgoing>Par2-PA1</outgoing>
      <outgoing>Par2-HIA1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par2-PA1</incoming>
      <outgoing>PA1-Par6</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par2-HIA1</incoming>
      <outgoing>HIA1-PARCLOSE27</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par0-MCA1</incoming>
      <outgoing>MCA1-PARCLOSE29</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>PA1-Par6</incoming>
      <outgoing>Par6-AR1</outgoing>
      <outgoing>Par6-PAS1</outgoing>
    </parallelGateway>
    <task id="AR1" name="Administrative Registration">
      <incoming>Par6-AR1</incoming>
      <outgoing>AR1-PARCLOSE26</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>Par6-PAS1</incoming>
      <outgoing>PAS1-Par10</outgoing>
    </task>
    <parallelGateway id="Par10" name="PAR">
      <incoming>PAS1-Par10</incoming>
      <outgoing>Par10-AIM1</outgoing>
      <outgoing>Par10-TIP1</outgoing>
    </parallelGateway>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par10-AIM1</incoming>
      <outgoing>AIM1-Par13</outgoing>
    </task>
    <parallelGateway id="Par13" name="PAR">
      <incoming>AIM1-Par13</incoming>
      <outgoing>Par13-RE1</outgoing>
      <outgoing>Par13-G1</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par13-G1</incoming>
      <outgoing>G1-PHP1</outgoing>
      <outgoing>G1-XORCLOSE19</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G1-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE19</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>Par10-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE25</outgoing>
    </task>
    <task id="RE1" name="Request Exams">
      <incoming>Par13-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE19" name="XORCLOSE19">
      <incoming>G1-XORCLOSE19</incoming>
      <incoming>PHP1-XORCLOSE19</incoming>
      <outgoing>XORCLOSE19-PARCLOSE24</outgoing>
    </exclusiveGateway>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-CS1</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>RD1-CS1</incoming>
      <outgoing>CS1-RAE1</outgoing>
    </task>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>CS1-RAE1</incoming>
      <outgoing>RAE1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>XORCLOSE19-PARCLOSE24</incoming>
      <incoming>RAE1-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-PARCLOSE25</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>TIP1-PARCLOSE25</incoming>
      <incoming>PARCLOSE24-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-PARCLOSE26</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>AR1-PARCLOSE26</incoming>
      <incoming>PARCLOSE25-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-PARCLOSE27</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>HIA1-PARCLOSE27</incoming>
      <incoming>PARCLOSE26-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-DFI1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>PARCLOSE27-DFI1</incoming>
      <outgoing>DFI1-PARCLOSE29</outgoing>
    </task>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>MCA1-PARCLOSE29</incoming>
      <incoming>DFI1-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-PDP1</outgoing>
    </parallelGateway>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>PARCLOSE29-PDP1</incoming>
      <outgoing>PDP1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PDP1-END</incoming>
    </endEvent>
