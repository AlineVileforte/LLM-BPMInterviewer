<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_ce979fca-3b1c-459e-b66c-fdfc08817907" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-MCA1</outgoing>
    </startEvent>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Default_init-MCA1</incoming>
      <outgoing>MCA1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>MCA1-Par1</incoming>
      <outgoing>Par1-INT1</outgoing>
      <outgoing>Par1-HIA1</outgoing>
    </parallelGateway>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par1-INT1</incoming>
      <outgoing>INT1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>INT1-Par3</incoming>
      <outgoing>Par3-PAS1</outgoing>
      <outgoing>Par3-Par9</outgoing>
    </parallelGateway>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>Par3-PAS1</incoming>
      <outgoing>PAS1-G0</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par1-HIA1</incoming>
      <outgoing>HIA1-RE1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>PAS1-G0</incoming>
      <outgoing>G0-PHP1</outgoing>
      <outgoing>G0-XORCLOSE13</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G0-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE13</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>Par3-Par9</incoming>
      <outgoing>Par9-PA1</outgoing>
      <outgoing>Par9-AIM1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par9-PA1</incoming>
      <outgoing>PA1-AR1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par9-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <task id="RE1" name="Request Exams">
      <incoming>HIA1-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE13" name="XORCLOSE13">
      <incoming>G0-XORCLOSE13</incoming>
      <incoming>PHP1-XORCLOSE13</incoming>
      <outgoing>XORCLOSE13-PARCLOSE19</outgoing>
    </exclusiveGateway>
    <task id="AR1" name="Administrative Registration">
      <incoming>PA1-AR1</incoming>
      <outgoing>AR1-PARCLOSE17</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE17</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>AR1-PARCLOSE17</incoming>
      <incoming>TIP1-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-PARCLOSE19</outgoing>
    </parallelGateway>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-PDP1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>XORCLOSE13-PARCLOSE19</incoming>
      <incoming>PARCLOSE17-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-DFI1</outgoing>
    </parallelGateway>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>RD1-PDP1</incoming>
      <outgoing>PDP1-G3</outgoing>
    </task>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>PARCLOSE19-DFI1</incoming>
      <outgoing>DFI1-PARCLOSE29</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>PDP1-G3</incoming>
      <outgoing>G3-RAE1</outgoing>
      <outgoing>G3-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G3-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE27</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>G3-CS1</incoming>
      <outgoing>CS1-XORCLOSE27</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE27" name="XORCLOSE27">
      <incoming>RAE1-XORCLOSE27</incoming>
      <incoming>CS1-XORCLOSE27</incoming>
      <outgoing>XORCLOSE27-PARCLOSE29</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>DFI1-PARCLOSE29</incoming>
      <incoming>XORCLOSE27-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE29-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-MCA1" sourceRef="Default_init" targetRef="MCA1"/>
