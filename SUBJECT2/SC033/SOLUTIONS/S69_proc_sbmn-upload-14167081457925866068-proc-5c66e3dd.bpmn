    <sequenceFlow id="DFI1-PARCLOSE29" sourceRef="DFI1" targetRef="PARCLOSE29"/>
    <sequenceFlow id="G3-RAE1" sourceRef="G3" targetRef="RAE1"/>
    <sequenceFlow id="G3-CS1" sourceRef="G3" targetRef="CS1"/>
    <sequenceFlow id="RAE1-XORCLOSE27" sourceRef="RAE1" targetRef="XORCLOSE27"/>
    <sequenceFlow id="CS1-XORCLOSE27" sourceRef="CS1" targetRef="XORCLOSE27"/>
    <sequenceFlow id="XORCLOSE27-PARCLOSE29" sourceRef="XORCLOSE27" targetRef="PARCLOSE29"/>
    <sequenceFlow id="PARCLOSE29-END" sourceRef="PARCLOSE29" targetRef="END"/>
  </process>
