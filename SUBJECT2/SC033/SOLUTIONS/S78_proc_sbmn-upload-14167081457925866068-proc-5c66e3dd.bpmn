  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-PA1</outgoing>
    </startEvent>
    <task id="PA1" name="Patient Arrival">
      <incoming>Default_init-PA1</incoming>
      <outgoing>PA1-INT1</outgoing>
    </task>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>PA1-INT1</incoming>
      <outgoing>INT1-HIA1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>INT1-HIA1</incoming>
      <outgoing>HIA1-MCA1</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>HIA1-MCA1</incoming>
      <outgoing>MCA1-AR1</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>MCA1-AR1</incoming>
      <outgoing>AR1-PAS1</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>AR1-PAS1</incoming>
      <outgoing>PAS1-Par6</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>PAS1-Par6</incoming>
      <outgoing>Par6-RE1</outgoing>
      <outgoing>Par6-G0</outgoing>
    </parallelGateway>
    <task id="RE1" name="Request Exams">
      <incoming>Par6-RE1</incoming>
      <outgoing>RE1-Par11</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par6-G0</incoming>
      <outgoing>G0-PHP1</outgoing>
      <outgoing>G0-XORCLOSE14</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G0-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE14</outgoing>
    </task>
    <parallelGateway id="Par11" name="PAR">
      <incoming>RE1-Par11</incoming>
      <outgoing>Par11-PE1</outgoing>
      <outgoing>Par11-AIM1</outgoing>
    </parallelGateway>
    <task id="PE1" name="Process Exams">
      <incoming>Par11-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par11-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>G0-XORCLOSE14</incoming>
      <incoming>PHP1-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-PARCLOSE28</outgoing>
    </exclusiveGateway>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-G1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE25</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>RD1-G1</incoming>
      <outgoing>G1-RAE1</outgoing>
      <outgoing>G1-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G1-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE24</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>G1-CS1</incoming>
      <outgoing>CS1-XORCLOSE24</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE24" name="XORCLOSE24">
      <incoming>RAE1-XORCLOSE24</incoming>
      <incoming>CS1-XORCLOSE24</incoming>
      <outgoing>XORCLOSE24-PARCLOSE25</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>TIP1-PARCLOSE25</incoming>
      <incoming>XORCLOSE24-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-DFI1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>PARCLOSE25-DFI1</incoming>
      <outgoing>DFI1-PDP1</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>DFI1-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE28</outgoing>
    </task>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>XORCLOSE14-PARCLOSE28</incoming>
      <incoming>PDP1-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE28-END</incoming>
    </endEvent>
