<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_63977260-e586-4a54-a8b6-657e43cd47d2" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-PA1</outgoing>
    </startEvent>
    <task id="PA1" name="Patient Arrival">
      <incoming>Default_init-PA1</incoming>
      <outgoing>PA1-MCA1</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>PA1-MCA1</incoming>
      <outgoing>MCA1-AR1</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>MCA1-AR1</incoming>
      <outgoing>AR1-INT1</outgoing>
    </task>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>AR1-INT1</incoming>
      <outgoing>INT1-PAS1</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>INT1-PAS1</incoming>
      <outgoing>PAS1-Par5</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>PAS1-Par5</incoming>
      <outgoing>Par5-AIM1</outgoing>
      <outgoing>Par5-G0</outgoing>
    </parallelGateway>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par5-AIM1</incoming>
      <outgoing>AIM1-RE1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par5-G0</incoming>
      <outgoing>G0-PHP1</outgoing>
      <outgoing>G0-XORCLOSE11</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G0-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE11</outgoing>
    </task>
    <task id="RE1" name="Request Exams">
      <incoming>AIM1-RE1</incoming>
      <outgoing>RE1-Par12</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE11" name="XORCLOSE11">
      <incoming>G0-XORCLOSE11</incoming>
      <incoming>PHP1-XORCLOSE11</incoming>
      <outgoing>XORCLOSE11-PARCLOSE25</outgoing>
    </exclusiveGateway>
    <parallelGateway id="Par12" name="PAR">
      <incoming>RE1-Par12</incoming>
      <outgoing>Par12-HIA1</outgoing>
      <outgoing>Par12-PE1</outgoing>
    </parallelGateway>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par12-HIA1</incoming>
      <outgoing>HIA1-PARCLOSE19</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>Par12-PE1</incoming>
      <outgoing>PE1-TIP1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>PE1-TIP1</incoming>
      <outgoing>TIP1-RD1</outgoing>
    </task>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>TIP1-RD1</incoming>
      <outgoing>RD1-CS1</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>RD1-CS1</incoming>
      <outgoing>CS1-PARCLOSE19</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>HIA1-PARCLOSE19</incoming>
      <incoming>CS1-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-Par20</outgoing>
    </parallelGateway>
    <parallelGateway id="Par20" name="PAR">
      <incoming>PARCLOSE19-Par20</incoming>
      <outgoing>Par20-DFI1</outgoing>
      <outgoing>Par20-PDP1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>Par20-DFI1</incoming>
      <outgoing>DFI1-RAE1</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>Par20-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE24</outgoing>
    </task>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>DFI1-RAE1</incoming>
      <outgoing>RAE1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>PDP1-PARCLOSE24</incoming>
      <incoming>RAE1-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-PARCLOSE25</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>XORCLOSE11-PARCLOSE25</incoming>
      <incoming>PARCLOSE24-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE25-END</incoming>
    </endEvent>
