    <sequenceFlow id="Par20-PDP1" sourceRef="Par20" targetRef="PDP1"/>
    <sequenceFlow id="DFI1-RAE1" sourceRef="DFI1" targetRef="RAE1"/>
    <sequenceFlow id="PDP1-PARCLOSE24" sourceRef="PDP1" targetRef="PARCLOSE24"/>
    <sequenceFlow id="RAE1-PARCLOSE24" sourceRef="RAE1" targetRef="PARCLOSE24"/>
    <sequenceFlow id="PARCLOSE24-PARCLOSE25" sourceRef="PARCLOSE24" targetRef="PARCLOSE25"/>
    <sequenceFlow id="PARCLOSE25-END" sourceRef="PARCLOSE25" targetRef="END"/>
  </process>
