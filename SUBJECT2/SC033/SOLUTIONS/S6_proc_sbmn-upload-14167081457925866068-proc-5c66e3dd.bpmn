  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-PA1</outgoing>
      <outgoing>Par0-HIA1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par0-PA1</incoming>
      <outgoing>PA1-AR1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par0-HIA1</incoming>
      <outgoing>HIA1-MCA1</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>PA1-AR1</incoming>
      <outgoing>AR1-INT1</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>HIA1-MCA1</incoming>
      <outgoing>MCA1-PARCLOSE27</outgoing>
    </task>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>AR1-INT1</incoming>
      <outgoing>INT1-PAS1</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>INT1-PAS1</incoming>
      <outgoing>PAS1-AIM1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>PAS1-AIM1</incoming>
      <outgoing>AIM1-Par9</outgoing>
    </task>
    <parallelGateway id="Par9" name="PAR">
      <incoming>AIM1-Par9</incoming>
      <outgoing>Par9-TIP1</outgoing>
      <outgoing>Par9-G1</outgoing>
    </parallelGateway>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>Par9-TIP1</incoming>
      <outgoing>TIP1-RE1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par9-G1</incoming>
      <outgoing>G1-PHP1</outgoing>
      <outgoing>G1-XORCLOSE15</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G1-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE15</outgoing>
    </task>
    <task id="RE1" name="Request Exams">
      <incoming>TIP1-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE15" name="XORCLOSE15">
      <incoming>G1-XORCLOSE15</incoming>
      <incoming>PHP1-XORCLOSE15</incoming>
      <outgoing>XORCLOSE15-PARCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-PARCLOSE18</outgoing>
    </task>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>XORCLOSE15-PARCLOSE18</incoming>
      <incoming>RD1-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-G3</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G3" name="G3">
      <incoming>PARCLOSE18-G3</incoming>
      <outgoing>G3-RAE1</outgoing>
      <outgoing>G3-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G3-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE25</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>G3-CS1</incoming>
      <outgoing>CS1-XORCLOSE25</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE25" name="XORCLOSE25">
      <incoming>RAE1-XORCLOSE25</incoming>
      <incoming>CS1-XORCLOSE25</incoming>
      <outgoing>XORCLOSE25-PARCLOSE27</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>MCA1-PARCLOSE27</incoming>
      <incoming>XORCLOSE25-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-Par28</outgoing>
    </parallelGateway>
    <parallelGateway id="Par28" name="PAR">
      <incoming>PARCLOSE27-Par28</incoming>
      <outgoing>Par28-DFI1</outgoing>
      <outgoing>Par28-PDP1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>Par28-DFI1</incoming>
      <outgoing>DFI1-PARCLOSE31</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>Par28-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE31</outgoing>
    </task>
    <parallelGateway id="PARCLOSE31" name="PARCLOSE31">
      <incoming>DFI1-PARCLOSE31</incoming>
      <incoming>PDP1-PARCLOSE31</incoming>
      <outgoing>PARCLOSE31-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE31-END</incoming>
    </endEvent>
