      <incoming>PE1-PARCLOSE20</incoming>
      <outgoing>PARCLOSE20-RD1</outgoing>
    </parallelGateway>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PARCLOSE20-RD1</incoming>
      <outgoing>RD1-PARCLOSE22</outgoing>
    </task>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>TIP1-PARCLOSE22</incoming>
