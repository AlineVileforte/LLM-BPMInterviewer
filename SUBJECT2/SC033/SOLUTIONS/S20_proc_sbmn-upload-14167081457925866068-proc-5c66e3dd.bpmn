  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-PA1</outgoing>
    </startEvent>
    <task id="PA1" name="Patient Arrival">
      <incoming>Default_init-PA1</incoming>
      <outgoing>PA1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>PA1-Par1</incoming>
      <outgoing>Par1-MCA1</outgoing>
      <outgoing>Par1-HIA1</outgoing>
    </parallelGateway>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par1-MCA1</incoming>
      <outgoing>MCA1-INT1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par1-HIA1</incoming>
      <outgoing>HIA1-AR1</outgoing>
    </task>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>MCA1-INT1</incoming>
      <outgoing>INT1-PAS1</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>HIA1-AR1</incoming>
      <outgoing>AR1-PARCLOSE25</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>INT1-PAS1</incoming>
      <outgoing>PAS1-Par7</outgoing>
    </task>
    <parallelGateway id="Par7" name="PAR">
      <incoming>PAS1-Par7</incoming>
      <outgoing>Par7-Par11</outgoing>
      <outgoing>Par7-G0</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par7-G0</incoming>
      <outgoing>G0-PHP1</outgoing>
      <outgoing>G0-XORCLOSE14</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G0-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE14</outgoing>
    </task>
    <parallelGateway id="Par11" name="PAR">
      <incoming>Par7-Par11</incoming>
      <outgoing>Par11-RE1</outgoing>
      <outgoing>Par11-AIM1</outgoing>
    </parallelGateway>
    <task id="RE1" name="Request Exams">
      <incoming>Par11-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par11-AIM1</incoming>
      <outgoing>AIM1-PARCLOSE19</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>G0-XORCLOSE14</incoming>
      <incoming>PHP1-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-TIP1</outgoing>
    </exclusiveGateway>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>XORCLOSE14-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE20</outgoing>
    </task>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-PARCLOSE19</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>AIM1-PARCLOSE19</incoming>
      <incoming>RD1-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-PARCLOSE20</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE20" name="PARCLOSE20">
      <incoming>TIP1-PARCLOSE20</incoming>
      <incoming>PARCLOSE19-PARCLOSE20</incoming>
      <outgoing>PARCLOSE20-G2</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G2" name="G2">
      <incoming>PARCLOSE20-G2</incoming>
      <outgoing>G2-RAE1</outgoing>
      <outgoing>G2-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G2-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE24</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>G2-CS1</incoming>
      <outgoing>CS1-XORCLOSE24</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE24" name="XORCLOSE24">
      <incoming>RAE1-XORCLOSE24</incoming>
      <incoming>CS1-XORCLOSE24</incoming>
      <outgoing>XORCLOSE24-PARCLOSE25</outgoing>
