  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-PA1</outgoing>
      <outgoing>Par0-MCA1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par0-PA1</incoming>
      <outgoing>PA1-Par3</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par0-MCA1</incoming>
      <outgoing>MCA1-HIA1</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>PA1-Par3</incoming>
      <outgoing>Par3-INT1</outgoing>
      <outgoing>Par3-PAS1</outgoing>
    </parallelGateway>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par3-INT1</incoming>
      <outgoing>INT1-AR1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>MCA1-HIA1</incoming>
      <outgoing>HIA1-PARCLOSE19</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>INT1-AR1</incoming>
      <outgoing>AR1-PARCLOSE18</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>Par3-PAS1</incoming>
      <outgoing>PAS1-Par8</outgoing>
    </task>
    <parallelGateway id="Par8" name="PAR">
      <incoming>PAS1-Par8</incoming>
      <outgoing>Par8-AIM1</outgoing>
      <outgoing>Par8-G0</outgoing>
    </parallelGateway>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par8-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par8-G0</incoming>
      <outgoing>G0-PHP1</outgoing>
      <outgoing>G0-XORCLOSE14</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G0-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE14</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-RE1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>G0-XORCLOSE14</incoming>
      <incoming>PHP1-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-PARCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="RE1" name="Request Exams">
      <incoming>TIP1-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-PARCLOSE17</outgoing>
    </task>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>XORCLOSE14-PARCLOSE17</incoming>
      <incoming>PE1-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-PARCLOSE18</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>AR1-PARCLOSE18</incoming>
      <incoming>PARCLOSE17-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-PARCLOSE19</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>HIA1-PARCLOSE19</incoming>
      <incoming>PARCLOSE18-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-RD1</outgoing>
    </parallelGateway>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PARCLOSE19-RD1</incoming>
      <outgoing>RD1-Par21</outgoing>
    </task>
    <parallelGateway id="Par21" name="PAR">
      <incoming>RD1-Par21</incoming>
      <outgoing>Par21-DFI1</outgoing>
      <outgoing>Par21-G1</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par21-G1</incoming>
      <outgoing>G1-RAE1</outgoing>
      <outgoing>G1-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G1-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE28</outgoing>
    </task>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>Par21-DFI1</incoming>
      <outgoing>DFI1-PDP1</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>G1-CS1</incoming>
      <outgoing>CS1-XORCLOSE28</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>DFI1-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE29</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE28" name="XORCLOSE28">
      <incoming>RAE1-XORCLOSE28</incoming>
      <incoming>CS1-XORCLOSE28</incoming>
      <outgoing>XORCLOSE28-PARCLOSE29</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>PDP1-PARCLOSE29</incoming>
      <incoming>XORCLOSE28-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE29-END</incoming>
    </endEvent>
