  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-INT1</outgoing>
    </startEvent>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Default_init-INT1</incoming>
      <outgoing>INT1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>INT1-Par1</incoming>
      <outgoing>Par1-HIA1</outgoing>
      <outgoing>Par1-Par4</outgoing>
    </parallelGateway>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par1-HIA1</incoming>
      <outgoing>HIA1-MCA1</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>HIA1-MCA1</incoming>
      <outgoing>MCA1-PARCLOSE32</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>Par1-Par4</incoming>
      <outgoing>Par4-PA1</outgoing>
      <outgoing>Par4-PAS1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par4-PA1</incoming>
      <outgoing>PA1-AR1</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>Par4-PAS1</incoming>
      <outgoing>PAS1-Par10</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>PA1-AR1</incoming>
      <outgoing>AR1-PARCLOSE31</outgoing>
    </task>
    <parallelGateway id="Par10" name="PAR">
      <incoming>PAS1-Par10</incoming>
      <outgoing>Par10-RE1</outgoing>
      <outgoing>Par10-G0</outgoing>
    </parallelGateway>
    <task id="RE1" name="Request Exams">
      <incoming>Par10-RE1</incoming>
      <outgoing>RE1-Par17</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par10-G0</incoming>
      <outgoing>G0-PHP1</outgoing>
      <outgoing>G0-XORCLOSE20</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G0-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE20</outgoing>
    </task>
    <parallelGateway id="Par17" name="PAR">
      <incoming>RE1-Par17</incoming>
      <outgoing>Par17-PE1</outgoing>
      <outgoing>Par17-AIM1</outgoing>
    </parallelGateway>
    <task id="PE1" name="Process Exams">
      <incoming>Par17-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par17-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE20" name="XORCLOSE20">
      <incoming>G0-XORCLOSE20</incoming>
      <incoming>PHP1-XORCLOSE20</incoming>
      <outgoing>XORCLOSE20-PARCLOSE25</outgoing>
    </exclusiveGateway>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-CS1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE24</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>RD1-CS1</incoming>
      <outgoing>CS1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>TIP1-PARCLOSE24</incoming>
      <incoming>CS1-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-PARCLOSE25</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>XORCLOSE20-PARCLOSE25</incoming>
      <incoming>PARCLOSE24-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-DFI1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>PARCLOSE25-DFI1</incoming>
      <outgoing>DFI1-Par27</outgoing>
    </task>
    <parallelGateway id="Par27" name="PAR">
      <incoming>DFI1-Par27</incoming>
      <outgoing>Par27-RAE1</outgoing>
      <outgoing>Par27-PDP1</outgoing>
    </parallelGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>Par27-RAE1</incoming>
      <outgoing>RAE1-PARCLOSE30</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>Par27-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE30</outgoing>
    </task>
    <parallelGateway id="PARCLOSE30" name="PARCLOSE30">
      <incoming>RAE1-PARCLOSE30</incoming>
      <incoming>PDP1-PARCLOSE30</incoming>
      <outgoing>PARCLOSE30-PARCLOSE31</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE31" name="PARCLOSE31">
      <incoming>AR1-PARCLOSE31</incoming>
      <incoming>PARCLOSE30-PARCLOSE31</incoming>
      <outgoing>PARCLOSE31-PARCLOSE32</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE32" name="PARCLOSE32">
      <incoming>MCA1-PARCLOSE32</incoming>
      <incoming>PARCLOSE31-PARCLOSE32</incoming>
      <outgoing>PARCLOSE32-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE32-END</incoming>
    </endEvent>
