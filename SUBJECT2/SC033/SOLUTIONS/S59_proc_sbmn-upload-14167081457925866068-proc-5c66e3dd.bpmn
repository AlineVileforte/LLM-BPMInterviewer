      <outgoing>PDP1-PARCLOSE29</outgoing>
    </task>
    <exclusiveGateway id="G4" name="G4">
      <incoming>PARCLOSE22-G4</incoming>
      <outgoing>G4-RAE1</outgoing>
      <outgoing>G4-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G4-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE30</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>G4-CS1</incoming>
      <outgoing>CS1-XORCLOSE30</outgoing>
    </task>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>DFI1-PARCLOSE29</incoming>
      <incoming>PDP1-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-PARCLOSE31</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE30" name="XORCLOSE30">
      <incoming>RAE1-XORCLOSE30</incoming>
      <incoming>CS1-XORCLOSE30</incoming>
      <outgoing>XORCLOSE30-PARCLOSE31</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE31" name="PARCLOSE31">
      <incoming>PARCLOSE29-PARCLOSE31</incoming>
      <incoming>XORCLOSE30-PARCLOSE31</incoming>
      <outgoing>PARCLOSE31-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE31-END</incoming>
    </endEvent>
