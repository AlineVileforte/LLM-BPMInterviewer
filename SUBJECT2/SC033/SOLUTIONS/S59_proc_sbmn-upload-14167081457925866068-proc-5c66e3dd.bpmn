  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-INT1</outgoing>
    </startEvent>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Default_init-INT1</incoming>
      <outgoing>INT1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>INT1-Par1</incoming>
      <outgoing>Par1-PAS1</outgoing>
      <outgoing>Par1-Par5</outgoing>
    </parallelGateway>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>Par1-PAS1</incoming>
      <outgoing>PAS1-Par3</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>PAS1-Par3</incoming>
      <outgoing>Par3-MCA1</outgoing>
      <outgoing>Par3-Par11</outgoing>
    </parallelGateway>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par3-MCA1</incoming>
      <outgoing>MCA1-G2</outgoing>
    </task>
    <parallelGateway id="Par5" name="PAR">
      <incoming>Par1-Par5</incoming>
      <outgoing>Par5-PA1</outgoing>
      <outgoing>Par5-HIA1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par5-PA1</incoming>
      <outgoing>PA1-AR1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par5-HIA1</incoming>
      <outgoing>HIA1-PARCLOSE18</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>MCA1-G2</incoming>
      <outgoing>G2-PHP1</outgoing>
      <outgoing>G2-XORCLOSE15</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G2-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE15</outgoing>
    </task>
    <parallelGateway id="Par11" name="PAR">
      <incoming>Par3-Par11</incoming>
      <outgoing>Par11-RE1</outgoing>
      <outgoing>Par11-AIM1</outgoing>
    </parallelGateway>
    <task id="RE1" name="Request Exams">
      <incoming>Par11-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par11-AIM1</incoming>
      <outgoing>AIM1-PARCLOSE20</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>PA1-AR1</incoming>
      <outgoing>AR1-PARCLOSE18</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE15" name="XORCLOSE15">
      <incoming>G2-XORCLOSE15</incoming>
      <incoming>PHP1-XORCLOSE15</incoming>
      <outgoing>XORCLOSE15-TIP1</outgoing>
    </exclusiveGateway>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-PARCLOSE20</outgoing>
    </task>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>HIA1-PARCLOSE18</incoming>
      <incoming>AR1-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-RD1</outgoing>
    </parallelGateway>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>XORCLOSE15-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE22</outgoing>
    </task>
    <parallelGateway id="PARCLOSE20" name="PARCLOSE20">
      <incoming>AIM1-PARCLOSE20</incoming>
      <incoming>PE1-PARCLOSE20</incoming>
      <outgoing>PARCLOSE20-PARCLOSE22</outgoing>
    </parallelGateway>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PARCLOSE18-RD1</incoming>
      <outgoing>RD1-Par23</outgoing>
    </task>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>TIP1-PARCLOSE22</incoming>
      <incoming>PARCLOSE20-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-G4</outgoing>
    </parallelGateway>
    <parallelGateway id="Par23" name="PAR">
      <incoming>RD1-Par23</incoming>
      <outgoing>Par23-DFI1</outgoing>
      <outgoing>Par23-PDP1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>Par23-DFI1</incoming>
      <outgoing>DFI1-PARCLOSE29</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
