  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-HIA1</outgoing>
    </startEvent>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Default_init-HIA1</incoming>
      <outgoing>HIA1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>HIA1-Par1</incoming>
      <outgoing>Par1-PA1</outgoing>
      <outgoing>Par1-MCA1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par1-PA1</incoming>
      <outgoing>PA1-Par4</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par1-MCA1</incoming>
      <outgoing>MCA1-PARCLOSE23</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>PA1-Par4</incoming>
      <outgoing>Par4-AR1</outgoing>
      <outgoing>Par4-INT1</outgoing>
    </parallelGateway>
    <task id="AR1" name="Administrative Registration">
      <incoming>Par4-AR1</incoming>
      <outgoing>AR1-PARCLOSE18</outgoing>
    </task>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par4-INT1</incoming>
      <outgoing>INT1-PAS1</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>INT1-PAS1</incoming>
      <outgoing>PAS1-Par10</outgoing>
    </task>
    <parallelGateway id="Par10" name="PAR">
      <incoming>PAS1-Par10</incoming>
      <outgoing>Par10-RE1</outgoing>
      <outgoing>Par10-AIM1</outgoing>
    </parallelGateway>
    <task id="RE1" name="Request Exams">
      <incoming>Par10-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par10-AIM1</incoming>
      <outgoing>AIM1-PHP1</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>AIM1-PHP1</incoming>
      <outgoing>PHP1-TIP1</outgoing>
    </task>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-PARCLOSE17</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>PHP1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE17</outgoing>
    </task>
    <parallelGateway id="PARCLOSE17" name="PARCLOSE17">
      <incoming>RD1-PARCLOSE17</incoming>
      <incoming>TIP1-PARCLOSE17</incoming>
      <outgoing>PARCLOSE17-PARCLOSE18</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE18" name="PARCLOSE18">
      <incoming>AR1-PARCLOSE18</incoming>
      <incoming>PARCLOSE17-PARCLOSE18</incoming>
      <outgoing>PARCLOSE18-G1</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G1" name="G1">
      <incoming>PARCLOSE18-G1</incoming>
      <outgoing>G1-RAE1</outgoing>
      <outgoing>G1-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G1-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE22</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>G1-CS1</incoming>
      <outgoing>CS1-XORCLOSE22</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE22" name="XORCLOSE22">
      <incoming>RAE1-XORCLOSE22</incoming>
      <incoming>CS1-XORCLOSE22</incoming>
      <outgoing>XORCLOSE22-PARCLOSE23</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE23" name="PARCLOSE23">
      <incoming>MCA1-PARCLOSE23</incoming>
      <incoming>XORCLOSE22-PARCLOSE23</incoming>
      <outgoing>PARCLOSE23-Par24</outgoing>
    </parallelGateway>
    <parallelGateway id="Par24" name="PAR">
      <incoming>PARCLOSE23-Par24</incoming>
      <outgoing>Par24-DFI1</outgoing>
      <outgoing>Par24-PDP1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>Par24-DFI1</incoming>
      <outgoing>DFI1-PARCLOSE27</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>Par24-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE27</outgoing>
    </task>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>DFI1-PARCLOSE27</incoming>
      <incoming>PDP1-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE27-END</incoming>
    </endEvent>
