  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-PA1</outgoing>
      <outgoing>Par0-HIA1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par0-PA1</incoming>
      <outgoing>PA1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>PA1-Par2</incoming>
      <outgoing>Par2-INT1</outgoing>
      <outgoing>Par2-MCA1</outgoing>
    </parallelGateway>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par2-INT1</incoming>
      <outgoing>INT1-Par6</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par2-MCA1</incoming>
      <outgoing>MCA1-PARCLOSE27</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par0-HIA1</incoming>
      <outgoing>HIA1-PARCLOSE29</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>INT1-Par6</incoming>
      <outgoing>Par6-AR1</outgoing>
      <outgoing>Par6-PAS1</outgoing>
    </parallelGateway>
    <task id="AR1" name="Administrative Registration">
      <incoming>Par6-AR1</incoming>
      <outgoing>AR1-PARCLOSE26</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>Par6-PAS1</incoming>
      <outgoing>PAS1-Par11</outgoing>
    </task>
    <parallelGateway id="Par11" name="PAR">
      <incoming>PAS1-Par11</incoming>
      <outgoing>Par11-RE1</outgoing>
      <outgoing>Par11-G0</outgoing>
    </parallelGateway>
    <task id="RE1" name="Request Exams">
      <incoming>Par11-RE1</incoming>
      <outgoing>RE1-Par16</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par11-G0</incoming>
      <outgoing>G0-PHP1</outgoing>
      <outgoing>G0-XORCLOSE19</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G0-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE19</outgoing>
    </task>
    <parallelGateway id="Par16" name="PAR">
      <incoming>RE1-Par16</incoming>
      <outgoing>Par16-PE1</outgoing>
      <outgoing>Par16-AIM1</outgoing>
    </parallelGateway>
    <task id="PE1" name="Process Exams">
      <incoming>Par16-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par16-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE19" name="XORCLOSE19">
      <incoming>G0-XORCLOSE19</incoming>
      <incoming>PHP1-XORCLOSE19</incoming>
      <outgoing>XORCLOSE19-PARCLOSE25</outgoing>
    </exclusiveGateway>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-PARCLOSE22</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE22</outgoing>
    </task>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>RD1-PARCLOSE22</incoming>
      <incoming>TIP1-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-CS1</outgoing>
    </parallelGateway>
    <task id="CS1" name="Consult Specialist">
      <incoming>PARCLOSE22-CS1</incoming>
      <outgoing>CS1-RAE1</outgoing>
    </task>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>CS1-RAE1</incoming>
      <outgoing>RAE1-PARCLOSE25</outgoing>
    </task>
    <parallelGateway id="PARCLOSE25" name="PARCLOSE25">
      <incoming>XORCLOSE19-PARCLOSE25</incoming>
      <incoming>RAE1-PARCLOSE25</incoming>
      <outgoing>PARCLOSE25-PARCLOSE26</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>AR1-PARCLOSE26</incoming>
      <incoming>PARCLOSE25-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-PARCLOSE27</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>MCA1-PARCLOSE27</incoming>
      <incoming>PARCLOSE26-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-PDP1</outgoing>
    </parallelGateway>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>PARCLOSE27-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE29</outgoing>
    </task>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>HIA1-PARCLOSE29</incoming>
      <incoming>PDP1-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-DFI1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>PARCLOSE29-DFI1</incoming>
      <outgoing>DFI1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>DFI1-END</incoming>
    </endEvent>
