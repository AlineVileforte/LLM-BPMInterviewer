    <exclusiveGateway id="G0" name="G0">
      <incoming>Par10-G0</incoming>
      <outgoing>G0-PHP1</outgoing>
      <outgoing>G0-XORCLOSE20</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G0-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE20</outgoing>
    </task>
    <parallelGateway id="Par14" name="PAR">
      <incoming>HIA1-Par14</incoming>
      <outgoing>Par14-AR1</outgoing>
      <outgoing>Par14-RE1</outgoing>
