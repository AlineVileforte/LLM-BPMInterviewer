    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>AR1-PARCLOSE21</incoming>
      <incoming>RE1-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-PARCLOSE38</outgoing>
    </parallelGateway>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE36</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>XORCLOSE20-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-DFI1</outgoing>
    </task>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>RD1-DFI1</incoming>
      <outgoing>DFI1-Par28</outgoing>
    </task>
    <parallelGateway id="Par28" name="PAR">
      <incoming>DFI1-Par28</incoming>
      <outgoing>Par28-PDP1</outgoing>
      <outgoing>Par28-G2</outgoing>
    </parallelGateway>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>Par28-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE34</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
