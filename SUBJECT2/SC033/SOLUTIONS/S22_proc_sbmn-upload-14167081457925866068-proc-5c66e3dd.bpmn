<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_78255847-dfe9-45ab-b616-8e9bdb1eb8d8" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-PA1</outgoing>
      <outgoing>Par0-AR1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par0-PA1</incoming>
      <outgoing>PA1-MCA1</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>PA1-MCA1</incoming>
      <outgoing>MCA1-Par4</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>Par0-AR1</incoming>
      <outgoing>AR1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>MCA1-Par4</incoming>
      <outgoing>Par4-INT1</outgoing>
      <outgoing>Par4-HIA1</outgoing>
    </parallelGateway>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par4-INT1</incoming>
      <outgoing>INT1-PAS1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par4-HIA1</incoming>
      <outgoing>HIA1-PARCLOSE22</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>INT1-PAS1</incoming>
      <outgoing>PAS1-AIM1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>PAS1-AIM1</incoming>
      <outgoing>AIM1-Par11</outgoing>
    </task>
    <parallelGateway id="Par11" name="PAR">
      <incoming>AIM1-Par11</incoming>
      <outgoing>Par11-RE1</outgoing>
      <outgoing>Par11-G1</outgoing>
    </parallelGateway>
    <task id="RE1" name="Request Exams">
      <incoming>Par11-RE1</incoming>
      <outgoing>RE1-TIP1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par11-G1</incoming>
      <outgoing>G1-PHP1</outgoing>
      <outgoing>G1-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G1-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE17</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>RE1-TIP1</incoming>
      <outgoing>TIP1-PE1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE17" name="XORCLOSE17">
      <incoming>G1-XORCLOSE17</incoming>
      <incoming>PHP1-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-PARCLOSE19</outgoing>
    </exclusiveGateway>
    <task id="PE1" name="Process Exams">
      <incoming>TIP1-PE1</incoming>
      <outgoing>PE1-PARCLOSE19</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>XORCLOSE17-PARCLOSE19</incoming>
      <incoming>PE1-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-RD1</outgoing>
    </parallelGateway>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PARCLOSE19-RD1</incoming>
      <outgoing>RD1-CS1</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>RD1-CS1</incoming>
      <outgoing>CS1-PARCLOSE22</outgoing>
    </task>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>HIA1-PARCLOSE22</incoming>
      <incoming>CS1-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-RAE1</outgoing>
    </parallelGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>PARCLOSE22-RAE1</incoming>
      <outgoing>RAE1-PARCLOSE24</outgoing>
    </task>
    <parallelGateway id="PARCLOSE24" name="PARCLOSE24">
      <incoming>AR1-PARCLOSE24</incoming>
      <incoming>RAE1-PARCLOSE24</incoming>
      <outgoing>PARCLOSE24-PDP1</outgoing>
    </parallelGateway>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>PARCLOSE24-PDP1</incoming>
      <outgoing>PDP1-DFI1</outgoing>
    </task>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>PDP1-DFI1</incoming>
      <outgoing>DFI1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>DFI1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-Par0" sourceRef="Default_init" targetRef="Par0"/>
