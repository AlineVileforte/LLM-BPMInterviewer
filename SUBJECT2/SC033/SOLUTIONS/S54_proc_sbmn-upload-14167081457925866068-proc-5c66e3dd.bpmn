<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_9f771ef7-3eb5-4944-8b27-34fd96098eaa" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-MCA1</outgoing>
    </startEvent>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Default_init-MCA1</incoming>
      <outgoing>MCA1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>MCA1-Par1</incoming>
      <outgoing>Par1-PA1</outgoing>
      <outgoing>Par1-INT1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par1-PA1</incoming>
      <outgoing>PA1-HIA1</outgoing>
    </task>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par1-INT1</incoming>
      <outgoing>INT1-PAS1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>PA1-HIA1</incoming>
      <outgoing>HIA1-AR1</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>INT1-PAS1</incoming>
      <outgoing>PAS1-Par11</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>HIA1-AR1</incoming>
      <outgoing>AR1-PARCLOSE28</outgoing>
    </task>
    <parallelGateway id="Par11" name="PAR">
      <incoming>PAS1-Par11</incoming>
      <outgoing>Par11-RE1</outgoing>
      <outgoing>Par11-G0</outgoing>
    </parallelGateway>
    <task id="RE1" name="Request Exams">
      <incoming>Par11-RE1</incoming>
      <outgoing>RE1-Par18</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par11-G0</incoming>
      <outgoing>G0-PHP1</outgoing>
      <outgoing>G0-XORCLOSE21</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G0-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE21</outgoing>
    </task>
    <parallelGateway id="Par18" name="PAR">
      <incoming>RE1-Par18</incoming>
      <outgoing>Par18-PE1</outgoing>
      <outgoing>Par18-AIM1</outgoing>
    </parallelGateway>
    <task id="PE1" name="Process Exams">
      <incoming>Par18-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par18-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE21" name="XORCLOSE21">
      <incoming>G0-XORCLOSE21</incoming>
      <incoming>PHP1-XORCLOSE21</incoming>
      <outgoing>XORCLOSE21-PARCLOSE27</outgoing>
    </exclusiveGateway>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-CS1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE26</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>RD1-CS1</incoming>
      <outgoing>CS1-RAE1</outgoing>
    </task>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>CS1-RAE1</incoming>
      <outgoing>RAE1-PARCLOSE26</outgoing>
    </task>
    <parallelGateway id="PARCLOSE26" name="PARCLOSE26">
      <incoming>TIP1-PARCLOSE26</incoming>
      <incoming>RAE1-PARCLOSE26</incoming>
      <outgoing>PARCLOSE26-PARCLOSE27</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>XORCLOSE21-PARCLOSE27</incoming>
      <incoming>PARCLOSE26-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-PARCLOSE28</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>AR1-PARCLOSE28</incoming>
      <incoming>PARCLOSE27-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-DFI1</outgoing>
    </parallelGateway>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>PARCLOSE28-DFI1</incoming>
      <outgoing>DFI1-PDP1</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>DFI1-PDP1</incoming>
      <outgoing>PDP1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>PDP1-END</incoming>
    </endEvent>
