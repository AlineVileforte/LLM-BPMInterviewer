  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-MCA1</outgoing>
      <outgoing>Par0-INT1</outgoing>
    </parallelGateway>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par0-MCA1</incoming>
      <outgoing>MCA1-Par2</outgoing>
    </task>
    <parallelGateway id="Par2" name="PAR">
      <incoming>MCA1-Par2</incoming>
      <outgoing>Par2-PA1</outgoing>
      <outgoing>Par2-HIA1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par2-PA1</incoming>
      <outgoing>PA1-AR1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par2-HIA1</incoming>
      <outgoing>HIA1-PARCLOSE8</outgoing>
    </task>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par0-INT1</incoming>
      <outgoing>INT1-PAS1</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>PA1-AR1</incoming>
      <outgoing>AR1-PARCLOSE8</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>INT1-PAS1</incoming>
      <outgoing>PAS1-RE1</outgoing>
    </task>
    <parallelGateway id="PARCLOSE8" name="PARCLOSE8">
      <incoming>HIA1-PARCLOSE8</incoming>
      <incoming>AR1-PARCLOSE8</incoming>
      <outgoing>PARCLOSE8-G1</outgoing>
    </parallelGateway>
    <task id="RE1" name="Request Exams">
      <incoming>PAS1-RE1</incoming>
      <outgoing>RE1-Par13</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>PARCLOSE8-G1</incoming>
      <outgoing>G1-PHP1</outgoing>
      <outgoing>G1-XORCLOSE16</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G1-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE16</outgoing>
    </task>
    <parallelGateway id="Par13" name="PAR">
      <incoming>RE1-Par13</incoming>
      <outgoing>Par13-PE1</outgoing>
      <outgoing>Par13-AIM1</outgoing>
    </parallelGateway>
    <task id="PE1" name="Process Exams">
      <incoming>Par13-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par13-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE16" name="XORCLOSE16">
      <incoming>G1-XORCLOSE16</incoming>
      <incoming>PHP1-XORCLOSE16</incoming>
      <outgoing>XORCLOSE16-PARCLOSE34</outgoing>
    </exclusiveGateway>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-G2</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE29</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>RD1-G2</incoming>
      <outgoing>G2-RAE1</outgoing>
      <outgoing>G2-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G2-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE28</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>G2-CS1</incoming>
      <outgoing>CS1-XORCLOSE28</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE28" name="XORCLOSE28">
      <incoming>RAE1-XORCLOSE28</incoming>
      <incoming>CS1-XORCLOSE28</incoming>
      <outgoing>XORCLOSE28-PARCLOSE29</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>TIP1-PARCLOSE29</incoming>
      <incoming>XORCLOSE28-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-Par30</outgoing>
    </parallelGateway>
    <parallelGateway id="Par30" name="PAR">
      <incoming>PARCLOSE29-Par30</incoming>
      <outgoing>Par30-DFI1</outgoing>
      <outgoing>Par30-PDP1</outgoing>
