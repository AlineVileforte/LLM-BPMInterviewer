    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>Par30-DFI1</incoming>
      <outgoing>DFI1-PARCLOSE33</outgoing>
    </task>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>Par30-PDP1</incoming>
      <outgoing>PDP1-PARCLOSE33</outgoing>
    </task>
    <parallelGateway id="PARCLOSE33" name="PARCLOSE33">
      <incoming>DFI1-PARCLOSE33</incoming>
      <incoming>PDP1-PARCLOSE33</incoming>
      <outgoing>PARCLOSE33-PARCLOSE34</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE34" name="PARCLOSE34">
      <incoming>XORCLOSE16-PARCLOSE34</incoming>
      <incoming>PARCLOSE33-PARCLOSE34</incoming>
      <outgoing>PARCLOSE34-END</outgoing>
    </parallelGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>PARCLOSE34-END</incoming>
    </endEvent>
