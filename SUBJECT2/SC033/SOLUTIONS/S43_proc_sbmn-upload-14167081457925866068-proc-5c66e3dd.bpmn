  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-PA1</outgoing>
      <outgoing>Par0-MCA1</outgoing>
    </parallelGateway>
    <task id="PA1" name="Patient Arrival">
      <incoming>Par0-PA1</incoming>
      <outgoing>PA1-Par3</outgoing>
    </task>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Par0-MCA1</incoming>
      <outgoing>MCA1-HIA1</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>PA1-Par3</incoming>
      <outgoing>Par3-INT1</outgoing>
      <outgoing>Par3-AR1</outgoing>
    </parallelGateway>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par3-INT1</incoming>
      <outgoing>INT1-PAS1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>MCA1-HIA1</incoming>
      <outgoing>HIA1-PARCLOSE29</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>INT1-PAS1</incoming>
      <outgoing>PAS1-RE1</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>Par3-AR1</incoming>
      <outgoing>AR1-Par10</outgoing>
    </task>
    <task id="RE1" name="Request Exams">
      <incoming>PAS1-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <parallelGateway id="Par10" name="PAR">
      <incoming>AR1-Par10</incoming>
      <outgoing>Par10-AIM1</outgoing>
      <outgoing>Par10-G1</outgoing>
    </parallelGateway>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par10-AIM1</incoming>
      <outgoing>AIM1-TIP1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par10-G1</incoming>
      <outgoing>G1-PHP1</outgoing>
      <outgoing>G1-XORCLOSE17</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G1-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE17</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE19</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE17" name="XORCLOSE17">
      <incoming>G1-XORCLOSE17</incoming>
      <incoming>PHP1-XORCLOSE17</incoming>
      <outgoing>XORCLOSE17-PARCLOSE19</outgoing>
    </exclusiveGateway>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-G2</outgoing>
    </task>
    <parallelGateway id="PARCLOSE19" name="PARCLOSE19">
      <incoming>TIP1-PARCLOSE19</incoming>
      <incoming>XORCLOSE17-PARCLOSE19</incoming>
      <outgoing>PARCLOSE19-PARCLOSE28</outgoing>
    </parallelGateway>
    <exclusiveGateway id="G2" name="G2">
      <incoming>RD1-G2</incoming>
      <outgoing>G2-RAE1</outgoing>
      <outgoing>G2-CS1</outgoing>
    </exclusiveGateway>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>G2-RAE1</incoming>
      <outgoing>RAE1-XORCLOSE26</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>G2-CS1</incoming>
      <outgoing>CS1-XORCLOSE26</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE26" name="XORCLOSE26">
      <incoming>RAE1-XORCLOSE26</incoming>
      <incoming>CS1-XORCLOSE26</incoming>
      <outgoing>XORCLOSE26-PARCLOSE28</outgoing>
    </exclusiveGateway>
    <parallelGateway id="PARCLOSE28" name="PARCLOSE28">
      <incoming>PARCLOSE19-PARCLOSE28</incoming>
      <incoming>XORCLOSE26-PARCLOSE28</incoming>
      <outgoing>PARCLOSE28-PARCLOSE29</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>HIA1-PARCLOSE29</incoming>
      <incoming>PARCLOSE28-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-PDP1</outgoing>
    </parallelGateway>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>PARCLOSE29-PDP1</incoming>
      <outgoing>PDP1-DFI1</outgoing>
    </task>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>PDP1-DFI1</incoming>
      <outgoing>DFI1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>DFI1-END</incoming>
    </endEvent>
