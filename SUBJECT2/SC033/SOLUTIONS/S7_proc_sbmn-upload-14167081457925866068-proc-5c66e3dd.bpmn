<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_13413043-5c1a-4d39-907e-08ee5773628e" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-MCA1</outgoing>
    </startEvent>
    <task id="MCA1" name="Monitor Costs and Approvals">
      <incoming>Default_init-MCA1</incoming>
      <outgoing>MCA1-PA1</outgoing>
    </task>
    <task id="PA1" name="Patient Arrival">
      <incoming>MCA1-PA1</incoming>
      <outgoing>PA1-AR1</outgoing>
    </task>
    <task id="AR1" name="Administrative Registration">
      <incoming>PA1-AR1</incoming>
      <outgoing>AR1-Par4</outgoing>
    </task>
    <parallelGateway id="Par4" name="PAR">
      <incoming>AR1-Par4</incoming>
      <outgoing>Par4-INT1</outgoing>
      <outgoing>Par4-HIA1</outgoing>
    </parallelGateway>
    <task id="INT1" name="Initial Nursing Triage">
      <incoming>Par4-INT1</incoming>
      <outgoing>INT1-PAS1</outgoing>
    </task>
    <task id="HIA1" name="Handle Insurance Authorization">
      <incoming>Par4-HIA1</incoming>
      <outgoing>HIA1-PARCLOSE22</outgoing>
    </task>
    <task id="PAS1" name="Physician Analyze Symptoms">
      <incoming>INT1-PAS1</incoming>
      <outgoing>PAS1-Par11</outgoing>
    </task>
    <parallelGateway id="Par11" name="PAR">
      <incoming>PAS1-Par11</incoming>
      <outgoing>Par11-AIM1</outgoing>
      <outgoing>Par11-RE1</outgoing>
    </parallelGateway>
    <task id="AIM1" name="Administer Initial Medication">
      <incoming>Par11-AIM1</incoming>
      <outgoing>AIM1-PHP1</outgoing>
    </task>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>AIM1-PHP1</incoming>
      <outgoing>PHP1-TIP1</outgoing>
    </task>
    <task id="RE1" name="Request Exams">
      <incoming>Par11-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>PHP1-TIP1</incoming>
      <outgoing>TIP1-PARCLOSE21</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-RD1</outgoing>
    </task>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PE1-RD1</incoming>
      <outgoing>RD1-CS1</outgoing>
    </task>
    <task id="CS1" name="Consult Specialist">
      <incoming>RD1-CS1</incoming>
      <outgoing>CS1-RAE1</outgoing>
    </task>
    <task id="RAE1" name="Request Additional Exams">
      <incoming>CS1-RAE1</incoming>
      <outgoing>RAE1-PARCLOSE21</outgoing>
    </task>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>TIP1-PARCLOSE21</incoming>
      <incoming>RAE1-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-PARCLOSE22</outgoing>
    </parallelGateway>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>HIA1-PARCLOSE22</incoming>
      <incoming>PARCLOSE21-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-PDP1</outgoing>
    </parallelGateway>
    <task id="PDP1" name="Prepare Discharge Procedures">
      <incoming>PARCLOSE22-PDP1</incoming>
      <outgoing>PDP1-DFI1</outgoing>
    </task>
    <task id="DFI1" name="Deliver Final Instructions">
      <incoming>PDP1-DFI1</incoming>
      <outgoing>DFI1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>DFI1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-MCA1" sourceRef="Default_init" targetRef="MCA1"/>
