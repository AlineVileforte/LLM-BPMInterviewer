    <sequenceFlow id="RD1-CS1" sourceRef="RD1" targetRef="CS1"/>
    <sequenceFlow id="CS1-RAE1" sourceRef="CS1" targetRef="RAE1"/>
    <sequenceFlow id="RAE1-PARCLOSE21" sourceRef="RAE1" targetRef="PARCLOSE21"/>
    <sequenceFlow id="PARCLOSE21-PARCLOSE22" sourceRef="PARCLOSE21" targetRef="PARCLOSE22"/>
    <sequenceFlow id="PARCLOSE22-PDP1" sourceRef="PARCLOSE22" targetRef="PDP1"/>
    <sequenceFlow id="PDP1-DFI1" sourceRef="PDP1" targetRef="DFI1"/>
    <sequenceFlow id="DFI1-END" sourceRef="DFI1" targetRef="END"/>
  </process>
