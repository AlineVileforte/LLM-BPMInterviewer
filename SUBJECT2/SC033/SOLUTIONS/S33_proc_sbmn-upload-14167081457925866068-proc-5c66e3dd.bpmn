    <exclusiveGateway id="G0" name="G0">
      <incoming>Par11-G0</incoming>
      <outgoing>G0-PHP1</outgoing>
      <outgoing>G0-XORCLOSE18</outgoing>
    </exclusiveGateway>
    <task id="PHP1" name="Prepare Hospitalization Procedures">
      <incoming>G0-PHP1</incoming>
      <outgoing>PHP1-XORCLOSE18</outgoing>
    </task>
    <task id="TIP1" name="Treatment in Progress">
      <incoming>AIM1-TIP1</incoming>
      <outgoing>TIP1-RE1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE18" name="XORCLOSE18">
      <incoming>G0-XORCLOSE18</incoming>
      <incoming>PHP1-XORCLOSE18</incoming>
      <outgoing>XORCLOSE18-PARCLOSE21</outgoing>
    </exclusiveGateway>
    <task id="RE1" name="Request Exams">
      <incoming>TIP1-RE1</incoming>
      <outgoing>RE1-PE1</outgoing>
    </task>
    <task id="PE1" name="Process Exams">
      <incoming>RE1-PE1</incoming>
      <outgoing>PE1-PARCLOSE21</outgoing>
    </task>
    <parallelGateway id="PARCLOSE21" name="PARCLOSE21">
      <incoming>XORCLOSE18-PARCLOSE21</incoming>
      <incoming>PE1-PARCLOSE21</incoming>
      <outgoing>PARCLOSE21-RD1</outgoing>
    </parallelGateway>
    <task id="RD1" name="Revise Diagnosis">
      <incoming>PARCLOSE21-RD1</incoming>
      <outgoing>RD1-Par23</outgoing>
    </task>
    <parallelGateway id="Par23" name="PAR">
      <incoming>RD1-Par23</incoming>
      <outgoing>Par23-CS1</outgoing>
      <outgoing>Par23-DFI1</outgoing>
