<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_837f2a23-25b0-4047-b72b-95b9c8790405" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-RCI1</outgoing>
    </startEvent>
    <task id="RCI1" name="Receive customer inquiry">
      <incoming>Default_init-RCI1</incoming>
      <outgoing>RCI1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>RCI1-Par1</incoming>
      <outgoing>Par1-CCI1</outgoing>
      <outgoing>Par1-ACCQ1</outgoing>
    </parallelGateway>
    <task id="CCI1" name="Collect customer information">
      <incoming>Par1-CCI1</incoming>
      <outgoing>CCI1-PARCLOSE9</outgoing>
    </task>
    <task id="ACCQ1" name="Address customer concerns or questions">
      <incoming>Par1-ACCQ1</incoming>
      <outgoing>ACCQ1-PARCLOSE9</outgoing>
    </task>
    <parallelGateway id="PARCLOSE9" name="PARCLOSE9">
      <incoming>CCI1-PARCLOSE9</incoming>
      <incoming>ACCQ1-PARCLOSE9</incoming>
      <outgoing>PARCLOSE9-GCSP1</outgoing>
    </parallelGateway>
    <task id="GCSP1" name="Guide customer in selecting product/service">
      <incoming>PARCLOSE9-GCSP1</incoming>
      <outgoing>GCSP1-PQ1</outgoing>
    </task>
    <task id="PQ1" name="Provide quote">
      <incoming>GCSP1-PQ1</incoming>
      <outgoing>PQ1-PO1</outgoing>
    </task>
    <task id="PO1" name="Place order">
      <incoming>PQ1-PO1</incoming>
      <outgoing>PO1-ROIS1</outgoing>
    </task>
    <task id="ROIS1" name="Record order in system">
      <incoming>PO1-ROIS1</incoming>
      <outgoing>ROIS1-SOCC1</outgoing>
    </task>
    <task id="SOCC1" name="Send order confirmation to customer">
      <incoming>ROIS1-SOCC1</incoming>
      <outgoing>SOCC1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>SOCC1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-RCI1" sourceRef="Default_init" targetRef="RCI1"/>
    <sequenceFlow id="RCI1-Par1" sourceRef="RCI1" targetRef="Par1"/>
    <sequenceFlow id="Par1-CCI1" sourceRef="Par1" targetRef="CCI1"/>
    <sequenceFlow id="Par1-ACCQ1" sourceRef="Par1" targetRef="ACCQ1"/>
    <sequenceFlow id="CCI1-PARCLOSE9" sourceRef="CCI1" targetRef="PARCLOSE9"/>
    <sequenceFlow id="ACCQ1-PARCLOSE9" sourceRef="ACCQ1" targetRef="PARCLOSE9"/>
    <sequenceFlow id="PARCLOSE9-GCSP1" sourceRef="PARCLOSE9" targetRef="GCSP1"/>
    <sequenceFlow id="GCSP1-PQ1" sourceRef="GCSP1" targetRef="PQ1"/>
    <sequenceFlow id="PQ1-PO1" sourceRef="PQ1" targetRef="PO1"/>
    <sequenceFlow id="PO1-ROIS1" sourceRef="PO1" targetRef="ROIS1"/>
    <sequenceFlow id="ROIS1-SOCC1" sourceRef="ROIS1" targetRef="SOCC1"/>
    <sequenceFlow id="SOCC1-END" sourceRef="SOCC1" targetRef="END"/>
  </process>
