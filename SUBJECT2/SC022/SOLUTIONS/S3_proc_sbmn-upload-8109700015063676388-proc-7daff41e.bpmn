<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_9cf016ea-1d02-432f-a2d2-a987cfb6c471" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-RCI1</outgoing>
    </startEvent>
    <task id="RCI1" name="Receive customer inquiry">
      <incoming>Default_init-RCI1</incoming>
      <outgoing>RCI1-ACCQ1</outgoing>
    </task>
    <task id="ACCQ1" name="Address customer concerns or questions">
      <incoming>RCI1-ACCQ1</incoming>
      <outgoing>ACCQ1-CCI1</outgoing>
    </task>
    <task id="CCI1" name="Collect customer information">
      <incoming>ACCQ1-CCI1</incoming>
      <outgoing>CCI1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CCI1-G0</incoming>
      <outgoing>G0-GCSP1</outgoing>
      <outgoing>G0-XORCLOSE9</outgoing>
    </exclusiveGateway>
    <task id="GCSP1" name="Guide customer in selecting product/service">
      <incoming>G0-GCSP1</incoming>
      <outgoing>GCSP1-XORCLOSE9</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE9" name="XORCLOSE9">
      <incoming>G0-XORCLOSE9</incoming>
      <incoming>GCSP1-XORCLOSE9</incoming>
      <outgoing>XORCLOSE9-PQ1</outgoing>
    </exclusiveGateway>
    <task id="PQ1" name="Provide quote">
      <incoming>XORCLOSE9-PQ1</incoming>
      <outgoing>PQ1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>PQ1-G1</incoming>
      <outgoing>G1-PO1</outgoing>
      <outgoing>G1-XORCLOSE14</outgoing>
    </exclusiveGateway>
    <task id="PO1" name="Place order">
      <incoming>G1-PO1</incoming>
      <outgoing>PO1-XORCLOSE14</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE14" name="XORCLOSE14">
      <incoming>G1-XORCLOSE14</incoming>
      <incoming>PO1-XORCLOSE14</incoming>
      <outgoing>XORCLOSE14-ROIS1</outgoing>
    </exclusiveGateway>
    <task id="ROIS1" name="Record order in system">
      <incoming>XORCLOSE14-ROIS1</incoming>
      <outgoing>ROIS1-SOCC1</outgoing>
    </task>
    <task id="SOCC1" name="Send order confirmation to customer">
      <incoming>ROIS1-SOCC1</incoming>
      <outgoing>SOCC1-END</outgoing>
    </task>
    <endEvent id="END" name="END_EVENT">
      <incoming>SOCC1-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-RCI1" sourceRef="Default_init" targetRef="RCI1"/>
    <sequenceFlow id="RCI1-ACCQ1" sourceRef="RCI1" targetRef="ACCQ1"/>
    <sequenceFlow id="ACCQ1-CCI1" sourceRef="ACCQ1" targetRef="CCI1"/>
    <sequenceFlow id="CCI1-G0" sourceRef="CCI1" targetRef="G0"/>
    <sequenceFlow id="G0-GCSP1" sourceRef="G0" targetRef="GCSP1"/>
    <sequenceFlow id="G0-XORCLOSE9" sourceRef="G0" targetRef="XORCLOSE9"/>
    <sequenceFlow id="GCSP1-XORCLOSE9" sourceRef="GCSP1" targetRef="XORCLOSE9"/>
    <sequenceFlow id="XORCLOSE9-PQ1" sourceRef="XORCLOSE9" targetRef="PQ1"/>
    <sequenceFlow id="PQ1-G1" sourceRef="PQ1" targetRef="G1"/>
    <sequenceFlow id="G1-PO1" sourceRef="G1" targetRef="PO1"/>
    <sequenceFlow id="G1-XORCLOSE14" sourceRef="G1" targetRef="XORCLOSE14"/>
    <sequenceFlow id="PO1-XORCLOSE14" sourceRef="PO1" targetRef="XORCLOSE14"/>
    <sequenceFlow id="XORCLOSE14-ROIS1" sourceRef="XORCLOSE14" targetRef="ROIS1"/>
    <sequenceFlow id="ROIS1-SOCC1" sourceRef="ROIS1" targetRef="SOCC1"/>
    <sequenceFlow id="SOCC1-END" sourceRef="SOCC1" targetRef="END"/>
  </process>
