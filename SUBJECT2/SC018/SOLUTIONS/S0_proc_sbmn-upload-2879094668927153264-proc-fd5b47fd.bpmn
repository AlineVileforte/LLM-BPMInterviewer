<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_a77b1d8e-7131-43cd-be7f-faebcd0ffbb2" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-CCIS1</outgoing>
    </startEvent>
    <task id="CCIS1" name="Customer connects to the information system">
      <incoming>Default_init-CCIS1</incoming>
      <outgoing>CCIS1-CTSP1</outgoing>
    </task>
    <task id="CTSP1" name="Choose the type of search to perform">
      <incoming>CCIS1-CTSP1</incoming>
      <outgoing>CTSP1-G0</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>CTSP1-G0</incoming>
      <outgoing>G0-STR1</outgoing>
      <outgoing>G0-G1</outgoing>
    </exclusiveGateway>
    <task id="STR1" name="Select theater room">
      <incoming>G0-STR1</incoming>
      <outgoing>STR1-SMT1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>G0-G1</incoming>
      <outgoing>G1-SM1</outgoing>
      <outgoing>G1-ST1</outgoing>
    </exclusiveGateway>
    <task id="SMT1" name="Select movie and time">
      <incoming>STR1-SMT1</incoming>
      <outgoing>SMT1-XORCLOSE11</outgoing>
    </task>
    <task id="SM1" name="Select movie">
      <incoming>G1-SM1</incoming>
      <outgoing>SM1-STRT1</outgoing>
    </task>
    <task id="ST1" name="Select time">
      <incoming>G1-ST1</incoming>
      <outgoing>ST1-SMTR1</outgoing>
    </task>
    <task id="STRT1" name="Select theater room and time">
      <incoming>SM1-STRT1</incoming>
      <outgoing>STRT1-XORCLOSE10</outgoing>
    </task>
    <task id="SMTR1" name="Select movie and theater room">
      <incoming>ST1-SMTR1</incoming>
      <outgoing>SMTR1-XORCLOSE10</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE10" name="XORCLOSE10">
      <incoming>STRT1-XORCLOSE10</incoming>
      <incoming>SMTR1-XORCLOSE10</incoming>
      <outgoing>XORCLOSE10-XORCLOSE11</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE11" name="XORCLOSE11">
      <incoming>SMT1-XORCLOSE11</incoming>
      <incoming>XORCLOSE10-XORCLOSE11</incoming>
      <outgoing>XORCLOSE11-SS1</outgoing>
    </exclusiveGateway>
    <task id="SS1" name="Selection summary">
      <incoming>XORCLOSE11-SS1</incoming>
      <outgoing>SS1-ICAR1</outgoing>
    </task>
    <task id="ICAR1" name="Is the customer already registered?">
      <incoming>SS1-ICAR1</incoming>
      <outgoing>ICAR1-G2</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>ICAR1-G2</incoming>
      <outgoing>G2-LI1</outgoing>
      <outgoing>G2-G3</outgoing>
    </exclusiveGateway>
    <task id="LI1" name="Log in">
      <incoming>G2-LI1</incoming>
      <outgoing>LI1-R1</outgoing>
    </task>
    <task id="R1" name="Reservation">
      <incoming>LI1-R1</incoming>
      <outgoing>R1-PD1</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>G2-G3</incoming>
      <outgoing>G3-CAA1</outgoing>
      <outgoing>G3-XORCLOSE21</outgoing>
    </exclusiveGateway>
    <task id="CAA1" name="Create an account">
      <incoming>G3-CAA1</incoming>
      <outgoing>CAA1-XORCLOSE21</outgoing>
    </task>
    <task id="PD1" name="Payment decision">
      <incoming>R1-PD1</incoming>
      <outgoing>PD1-CRSE1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE21" name="XORCLOSE21">
      <incoming>G3-XORCLOSE21</incoming>
      <incoming>CAA1-XORCLOSE21</incoming>
      <outgoing>XORCLOSE21-XORCLOSE24</outgoing>
    </exclusiveGateway>
    <task id="CRSE1" name="Confirm reservation by sending an email">
      <incoming>PD1-CRSE1</incoming>
      <outgoing>CRSE1-MSS1</outgoing>
    </task>
    <task id="MSS1" name="Manage satisfaction survey">
      <incoming>CRSE1-MSS1</incoming>
      <outgoing>MSS1-XORCLOSE24</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE24" name="XORCLOSE24">
      <incoming>XORCLOSE21-XORCLOSE24</incoming>
      <incoming>MSS1-XORCLOSE24</incoming>
      <outgoing>XORCLOSE24-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE24-END</incoming>
    </endEvent>
    <sequenceFlow id="Default_init-CCIS1" sourceRef="Default_init" targetRef="CCIS1"/>
    <sequenceFlow id="CCIS1-CTSP1" sourceRef="CCIS1" targetRef="CTSP1"/>
    <sequenceFlow id="CTSP1-G0" sourceRef="CTSP1" targetRef="G0"/>
    <sequenceFlow id="G0-STR1" sourceRef="G0" targetRef="STR1"/>
    <sequenceFlow id="G0-G1" sourceRef="G0" targetRef="G1"/>
    <sequenceFlow id="STR1-SMT1" sourceRef="STR1" targetRef="SMT1"/>
    <sequenceFlow id="G1-SM1" sourceRef="G1" targetRef="SM1"/>
    <sequenceFlow id="G1-ST1" sourceRef="G1" targetRef="ST1"/>
    <sequenceFlow id="SMT1-XORCLOSE11" sourceRef="SMT1" targetRef="XORCLOSE11"/>
    <sequenceFlow id="SM1-STRT1" sourceRef="SM1" targetRef="STRT1"/>
    <sequenceFlow id="ST1-SMTR1" sourceRef="ST1" targetRef="SMTR1"/>
    <sequenceFlow id="STRT1-XORCLOSE10" sourceRef="STRT1" targetRef="XORCLOSE10"/>
    <sequenceFlow id="SMTR1-XORCLOSE10" sourceRef="SMTR1" targetRef="XORCLOSE10"/>
    <sequenceFlow id="XORCLOSE10-XORCLOSE11" sourceRef="XORCLOSE10" targetRef="XORCLOSE11"/>
    <sequenceFlow id="XORCLOSE11-SS1" sourceRef="XORCLOSE11" targetRef="SS1"/>
    <sequenceFlow id="SS1-ICAR1" sourceRef="SS1" targetRef="ICAR1"/>
    <sequenceFlow id="ICAR1-G2" sourceRef="ICAR1" targetRef="G2"/>
    <sequenceFlow id="G2-LI1" sourceRef="G2" targetRef="LI1"/>
    <sequenceFlow id="G2-G3" sourceRef="G2" targetRef="G3"/>
    <sequenceFlow id="LI1-R1" sourceRef="LI1" targetRef="R1"/>
    <sequenceFlow id="R1-PD1" sourceRef="R1" targetRef="PD1"/>
    <sequenceFlow id="G3-CAA1" sourceRef="G3" targetRef="CAA1"/>
    <sequenceFlow id="G3-XORCLOSE21" sourceRef="G3" targetRef="XORCLOSE21"/>
    <sequenceFlow id="CAA1-XORCLOSE21" sourceRef="CAA1" targetRef="XORCLOSE21"/>
    <sequenceFlow id="PD1-CRSE1" sourceRef="PD1" targetRef="CRSE1"/>
    <sequenceFlow id="XORCLOSE21-XORCLOSE24" sourceRef="XORCLOSE21" targetRef="XORCLOSE24"/>
    <sequenceFlow id="CRSE1-MSS1" sourceRef="CRSE1" targetRef="MSS1"/>
    <sequenceFlow id="MSS1-XORCLOSE24" sourceRef="MSS1" targetRef="XORCLOSE24"/>
    <sequenceFlow id="XORCLOSE24-END" sourceRef="XORCLOSE24" targetRef="END"/>
  </process>
