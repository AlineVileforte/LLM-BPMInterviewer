<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_d68f029e-6994-4035-bccb-40efc9fa0527" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-INH1</outgoing>
    </startEvent>
    <task id="INH1" name="Identify need for new hire">
      <incoming>Default_init-INH1</incoming>
      <outgoing>INH1-Par1</outgoing>
    </task>
    <parallelGateway id="Par1" name="PAR">
      <incoming>INH1-Par1</incoming>
      <outgoing>Par1-CJD1</outgoing>
      <outgoing>Par1-G1</outgoing>
    </parallelGateway>
    <task id="CJD1" name="Create job description">
      <incoming>Par1-CJD1</incoming>
      <outgoing>CJD1-PJD1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>Par1-G1</incoming>
      <incoming>XORCLOSE7-G1</incoming>
      <outgoing>G1-CIPI2</outgoing>
      <outgoing>G1-CVI1</outgoing>
    </exclusiveGateway>
    <task id="CIPI2" name="Conduct an in-person interview">
      <incoming>G1-CIPI2</incoming>
      <outgoing>CIPI2-XORCLOSE7</outgoing>
    </task>
    <task id="CVI1" name="Conduct a virtual interview">
      <incoming>G1-CVI1</incoming>
      <outgoing>CVI1-XORCLOSE7</outgoing>
    </task>
    <task id="PJD1" name="Post job description">
      <incoming>CJD1-PJD1</incoming>
      <outgoing>PJD1-CR1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE7" name="XORCLOSE7">
      <incoming>CIPI2-XORCLOSE7</incoming>
      <incoming>CVI1-XORCLOSE7</incoming>
      <outgoing>XORCLOSE7-PARCLOSE10</outgoing>
      <outgoing>XORCLOSE7-G1</outgoing>
    </exclusiveGateway>
    <task id="CR1" name="Collect resumes">
      <incoming>PJD1-CR1</incoming>
      <outgoing>CR1-SR1</outgoing>
    </task>
    <task id="SR1" name="Screen resumes">
      <incoming>CR1-SR1</incoming>
      <outgoing>SR1-PARCLOSE10</outgoing>
    </task>
    <parallelGateway id="PARCLOSE10" name="PARCLOSE10">
      <incoming>XORCLOSE7-PARCLOSE10</incoming>
      <incoming>SR1-PARCLOSE10</incoming>
      <outgoing>PARCLOSE10-CIPI1</outgoing>
    </parallelGateway>
    <task id="CIPI1" name="Conduct initial phone interviews">
      <incoming>PARCLOSE10-CIPI1</incoming>
      <outgoing>CIPI1-ICI1</outgoing>
    </task>
    <task id="ICI1" name="Invite candidates for interviews">
      <incoming>CIPI1-ICI1</incoming>
      <outgoing>ICI1-G2</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>ICI1-G2</incoming>
      <outgoing>G2-CC1</outgoing>
      <outgoing>G2-XORCLOSE29</outgoing>
    </exclusiveGateway>
    <task id="CC1" name="Choose candidate">
      <incoming>G2-CC1</incoming>
      <outgoing>CC1-EO1</outgoing>
    </task>
    <task id="EO1" name="Extend offer">
      <incoming>CC1-EO1</incoming>
      <outgoing>EO1-G3</outgoing>
    </task>
    <exclusiveGateway id="G3" name="G3">
      <incoming>EO1-G3</incoming>
      <outgoing>G3-XORCLOSE28</outgoing>
      <outgoing>G3-XOR_JMPBB_NS1_NS1</outgoing>
    </exclusiveGateway>
    <task id="NS1" name="Negotiate salary">
      <incoming>XOR_JMPBB_NS1_NS1-NS1</incoming>
      <outgoing>NS1-XOR_JMPAA_NS1_NS1</outgoing>
    </task>
    <task id="BOP1" name="Begin onboarding process">
      <incoming>XOR_JMPAA_NS1_NS1-BOP1</incoming>
      <outgoing>BOP1-Par23</outgoing>
    </task>
    <parallelGateway id="Par23" name="PAR">
      <incoming>BOP1-Par23</incoming>
      <outgoing>Par23-CO1</outgoing>
      <outgoing>Par23-CT1</outgoing>
    </parallelGateway>
    <task id="CO1" name="Complete orientation">
      <incoming>Par23-CO1</incoming>
      <outgoing>CO1-CP1</outgoing>
    </task>
    <task id="CT1" name="Complete training">
      <incoming>Par23-CT1</incoming>
      <outgoing>CT1-PARCLOSE27</outgoing>
    </task>
    <task id="CP1" name="Complete paperwork">
      <incoming>CO1-CP1</incoming>
      <outgoing>CP1-PARCLOSE27</outgoing>
    </task>
    <parallelGateway id="PARCLOSE27" name="PARCLOSE27">
      <incoming>CT1-PARCLOSE27</incoming>
      <incoming>CP1-PARCLOSE27</incoming>
      <outgoing>PARCLOSE27-XORCLOSE28</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE28" name="XORCLOSE28">
      <incoming>G3-XORCLOSE28</incoming>
      <incoming>PARCLOSE27-XORCLOSE28</incoming>
      <outgoing>XORCLOSE28-XORCLOSE29</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE29" name="XORCLOSE29">
      <incoming>G2-XORCLOSE29</incoming>
      <incoming>XORCLOSE28-XORCLOSE29</incoming>
      <outgoing>XORCLOSE29-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE29-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_NS1_NS1" name="XOR_JMPAA_Negotiate salary">
      <incoming>NS1-XOR_JMPAA_NS1_NS1</incoming>
      <outgoing>XOR_JMPAA_NS1_NS1-BOP1</outgoing>
      <outgoing>XOR_JMPAA_NS1_NS1-XOR_JMPBB_NS1_NS1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_NS1_NS1" name="XOR_JMPBB_Negotiate salary">
      <incoming>G3-XOR_JMPBB_NS1_NS1</incoming>
      <incoming>XOR_JMPAA_NS1_NS1-XOR_JMPBB_NS1_NS1</incoming>
      <outgoing>XOR_JMPBB_NS1_NS1-NS1</outgoing>
    </exclusiveGateway>
    <sequenceFlow id="Default_init-INH1" sourceRef="Default_init" targetRef="INH1"/>
    <sequenceFlow id="INH1-Par1" sourceRef="INH1" targetRef="Par1"/>
    <sequenceFlow id="Par1-CJD1" sourceRef="Par1" targetRef="CJD1"/>
    <sequenceFlow id="Par1-G1" sourceRef="Par1" targetRef="G1"/>
