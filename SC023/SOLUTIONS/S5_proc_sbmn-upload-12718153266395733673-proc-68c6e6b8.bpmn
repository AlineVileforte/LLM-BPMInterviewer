<definitions xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="definitions_dc93f6aa-ff6f-47fa-adfc-08c6b8a53bef" targetNamespace="http://camunda.org/examples" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL">
  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-INH1</outgoing>
      <outgoing>Par0-G0</outgoing>
    </parallelGateway>
    <task id="INH1" name="Identify need for new hire">
      <incoming>Par0-INH1</incoming>
      <outgoing>INH1-CJD1</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>Par0-G0</incoming>
      <incoming>XORCLOSE6-G0</incoming>
      <outgoing>G0-CIPI2</outgoing>
      <outgoing>G0-CVI1</outgoing>
    </exclusiveGateway>
    <task id="CIPI2" name="Conduct an in-person interview">
      <incoming>G0-CIPI2</incoming>
      <outgoing>CIPI2-XORCLOSE6</outgoing>
    </task>
    <task id="CVI1" name="Conduct a virtual interview">
      <incoming>G0-CVI1</incoming>
      <outgoing>CVI1-XORCLOSE6</outgoing>
    </task>
    <task id="CJD1" name="Create job description">
      <incoming>INH1-CJD1</incoming>
      <outgoing>CJD1-PJD1</outgoing>
    </task>
    <exclusiveGateway id="XORCLOSE6" name="XORCLOSE6">
      <incoming>CIPI2-XORCLOSE6</incoming>
      <incoming>CVI1-XORCLOSE6</incoming>
      <outgoing>XORCLOSE6-PARCLOSE8</outgoing>
      <outgoing>XORCLOSE6-G0</outgoing>
    </exclusiveGateway>
    <task id="PJD1" name="Post job description">
      <incoming>CJD1-PJD1</incoming>
      <outgoing>PJD1-PARCLOSE8</outgoing>
    </task>
    <parallelGateway id="PARCLOSE8" name="PARCLOSE8">
      <incoming>XORCLOSE6-PARCLOSE8</incoming>
      <incoming>PJD1-PARCLOSE8</incoming>
      <outgoing>PARCLOSE8-CR1</outgoing>
    </parallelGateway>
    <task id="CR1" name="Collect resumes">
      <incoming>PARCLOSE8-CR1</incoming>
      <outgoing>CR1-SR1</outgoing>
    </task>
    <task id="SR1" name="Screen resumes">
      <incoming>CR1-SR1</incoming>
      <outgoing>SR1-CIPI1</outgoing>
    </task>
    <task id="CIPI1" name="Conduct initial phone interviews">
      <incoming>SR1-CIPI1</incoming>
      <outgoing>CIPI1-ICI1</outgoing>
    </task>
    <task id="ICI1" name="Invite candidates for interviews">
      <incoming>CIPI1-ICI1</incoming>
      <outgoing>ICI1-G1</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>ICI1-G1</incoming>
      <outgoing>G1-CC1</outgoing>
      <outgoing>G1-XORCLOSE31</outgoing>
    </exclusiveGateway>
    <task id="CC1" name="Choose candidate">
      <incoming>G1-CC1</incoming>
      <outgoing>CC1-EO1</outgoing>
    </task>
    <task id="EO1" name="Extend offer">
      <incoming>CC1-EO1</incoming>
      <outgoing>EO1-G2</outgoing>
    </task>
    <exclusiveGateway id="G2" name="G2">
      <incoming>EO1-G2</incoming>
      <outgoing>G2-XOR_JMPBB_NS1_NS1</outgoing>
      <outgoing>G2-XORCLOSE30</outgoing>
    </exclusiveGateway>
    <task id="NS1" name="Negotiate salary">
      <incoming>XOR_JMPBB_NS1_NS1-NS1</incoming>
      <outgoing>NS1-XOR_JMPAA_NS1_NS1</outgoing>
    </task>
    <task id="BOP1" name="Begin onboarding process">
      <incoming>XOR_JMPAA_NS1_NS1-BOP1</incoming>
      <outgoing>BOP1-Par25</outgoing>
    </task>
    <parallelGateway id="Par25" name="PAR">
      <incoming>BOP1-Par25</incoming>
      <outgoing>Par25-CO1</outgoing>
      <outgoing>Par25-CP1</outgoing>
    </parallelGateway>
    <task id="CO1" name="Complete orientation">
      <incoming>Par25-CO1</incoming>
      <outgoing>CO1-CT1</outgoing>
    </task>
    <task id="CT1" name="Complete training">
      <incoming>CO1-CT1</incoming>
      <outgoing>CT1-PARCLOSE29</outgoing>
    </task>
    <task id="CP1" name="Complete paperwork">
      <incoming>Par25-CP1</incoming>
      <outgoing>CP1-PARCLOSE29</outgoing>
    </task>
    <parallelGateway id="PARCLOSE29" name="PARCLOSE29">
      <incoming>CT1-PARCLOSE29</incoming>
      <incoming>CP1-PARCLOSE29</incoming>
      <outgoing>PARCLOSE29-XORCLOSE30</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE30" name="XORCLOSE30">
      <incoming>G2-XORCLOSE30</incoming>
      <incoming>PARCLOSE29-XORCLOSE30</incoming>
      <outgoing>XORCLOSE30-XORCLOSE31</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XORCLOSE31" name="XORCLOSE31">
      <incoming>G1-XORCLOSE31</incoming>
      <incoming>XORCLOSE30-XORCLOSE31</incoming>
      <outgoing>XORCLOSE31-END</outgoing>
    </exclusiveGateway>
    <endEvent id="END" name="END_EVENT">
      <incoming>XORCLOSE31-END</incoming>
    </endEvent>
    <exclusiveGateway id="XOR_JMPAA_NS1_NS1" name="XOR_JMPAA_Negotiate salary">
      <incoming>NS1-XOR_JMPAA_NS1_NS1</incoming>
      <outgoing>XOR_JMPAA_NS1_NS1-BOP1</outgoing>
      <outgoing>XOR_JMPAA_NS1_NS1-XOR_JMPBB_NS1_NS1</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="XOR_JMPBB_NS1_NS1" name="XOR_JMPBB_Negotiate salary">
      <incoming>G2-XOR_JMPBB_NS1_NS1</incoming>
      <incoming>XOR_JMPAA_NS1_NS1-XOR_JMPBB_NS1_NS1</incoming>
      <outgoing>XOR_JMPBB_NS1_NS1-NS1</outgoing>
    </exclusiveGateway>
