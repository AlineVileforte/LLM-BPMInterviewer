    <sequenceFlow id="NS1-XOR_JMPAA_NS1_NS1" sourceRef="NS1" targetRef="XOR_JMPAA_NS1_NS1"/>
    <sequenceFlow id="BOP1-Par25" sourceRef="BOP1" targetRef="Par25"/>
    <sequenceFlow id="Par25-CO1" sourceRef="Par25" targetRef="CO1"/>
    <sequenceFlow id="Par25-CP1" sourceRef="Par25" targetRef="CP1"/>
