    <task id="PIP1" name="Prepare Interface Prototypes">
      <incoming>Par14-PIP1</incoming>
      <outgoing>PIP1-PARCLOSE22</outgoing>
    </task>
    <task id="MDEI1" name="Model Database Entities and Indexes">
      <incoming>Par14-MDEI1</incoming>
      <outgoing>MDEI1-PARCLOSE22</outgoing>
    </task>
    <exclusiveGateway id="G0" name="G0">
      <incoming>PVA1-G0</incoming>
      <outgoing>G0-CTV1</outgoing>
      <outgoing>G0-XORCLOSE23</outgoing>
    </exclusiveGateway>
    <task id="CTV1" name="Correct and Test Vulnerabilities">
      <incoming>G0-CTV1</incoming>
      <outgoing>CTV1-XORCLOSE23</outgoing>
    </task>
    <exclusiveGateway id="G1" name="G1">
      <incoming>CEI1-G1</incoming>
      <outgoing>G1-CAI1</outgoing>
      <outgoing>G1-XORCLOSE31</outgoing>
    </exclusiveGateway>
    <task id="CAI1" name="Configure API Infrastructure">
      <incoming>G1-CAI1</incoming>
      <outgoing>CAI1-XORCLOSE31</outgoing>
    </task>
    <parallelGateway id="PARCLOSE22" name="PARCLOSE22">
      <incoming>PIP1-PARCLOSE22</incoming>
      <incoming>MDEI1-PARCLOSE22</incoming>
      <outgoing>PARCLOSE22-PARCLOSE30</outgoing>
    </parallelGateway>
    <exclusiveGateway id="XORCLOSE23" name="XORCLOSE23">
      <incoming>G0-XORCLOSE23</incoming>
      <incoming>CTV1-XORCLOSE23</incoming>
      <outgoing>XORCLOSE23-DSE1</outgoing>
    </exclusiveGateway>
    <task id="DSE1" name="Deploy to Staging Environment">
      <incoming>XORCLOSE23-DSE1</incoming>
      <outgoing>DSE1-PARCLOSE30</outgoing>
