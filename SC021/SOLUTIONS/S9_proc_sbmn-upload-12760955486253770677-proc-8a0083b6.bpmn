  <process id="process">
    <startEvent id="Default_init" name="Default_init">
      <outgoing>Default_init-Par0</outgoing>
    </startEvent>
    <parallelGateway id="Par0" name="PAR">
      <incoming>Default_init-Par0</incoming>
      <outgoing>Par0-A1</outgoing>
      <outgoing>Par0-A3</outgoing>
    </parallelGateway>
    <task id="A1" name="Produce Technical Documentation">
      <incoming>Par0-A1</incoming>
      <outgoing>A1-Par3</outgoing>
    </task>
    <task id="A3" name="Prepare Test Cases">
      <incoming>Par0-A3</incoming>
      <outgoing>A3-Par6</outgoing>
    </task>
    <parallelGateway id="Par3" name="PAR">
      <incoming>A1-Par3</incoming>
      <outgoing>Par3-PPV1</outgoing>
      <outgoing>Par3-A2</outgoing>
    </parallelGateway>
    <task id="PPV1" name="Perform Partial Validations">
      <incoming>Par3-PPV1</incoming>
      <outgoing>PPV1-DF1</outgoing>
    </task>
    <task id="A2" name="Execute Automated Tests">
      <incoming>Par3-A2</incoming>
      <outgoing>A2-PVA1</outgoing>
    </task>
    <parallelGateway id="Par6" name="PAR">
      <incoming>A3-Par6</incoming>
      <outgoing>Par6-APP1</outgoing>
      <outgoing>Par6-IIS1</outgoing>
    </parallelGateway>
    <task id="APP1" name="Approve Platform Project">
      <incoming>Par6-APP1</incoming>
      <outgoing>APP1-CEI1</outgoing>
    </task>
    <task id="IIS1" name="Implement Initial Screens">
      <incoming>Par6-IIS1</incoming>
      <outgoing>IIS1-IM1</outgoing>
    </task>
    <task id="DF1" name="Detail Functionalities">
      <incoming>PPV1-DF1</incoming>
      <outgoing>DF1-Par14</outgoing>
    </task>
    <task id="PVA1" name="Perform Vulnerability Assessments">
      <incoming>A2-PVA1</incoming>
      <outgoing>PVA1-G0</outgoing>
    </task>
    <task id="CEI1" name="Configure External Integrations">
      <incoming>APP1-CEI1</incoming>
      <outgoing>CEI1-G1</outgoing>
    </task>
    <task id="IM1" name="Integrate Modules">
      <incoming>IIS1-IM1</incoming>
      <outgoing>IM1-PARCLOSE33</outgoing>
    </task>
    <parallelGateway id="Par14" name="PAR">
      <incoming>DF1-Par14</incoming>
      <outgoing>Par14-PIP1</outgoing>
      <outgoing>Par14-MDEI1</outgoing>
